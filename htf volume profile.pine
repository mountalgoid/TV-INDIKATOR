//@version=6
indicator("HTF Volume Profile - Premium Edition", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500, max_bars_back=2000)

// =============================================================================
// 1. INPUTS & CONFIGURATION - THEME SYSTEM
// =============================================================================
var string GlobalGroup = "Visual Themes & Global Settings"
color_theme = input.string(defval = 'DEX Deep', title = 'Select Color Theme', options = ['Spartan Edge Theme', 'MountAlgo Themes', 'MountAlgo Neon', 'MountAlgo Frost', 'MountAlgo Cyber', 'Standard Spartan Edge Theme', 'Dark ICT Theme', 'Garuda Gold', 'MountAlgo Super Premium Theme', 'MountAlgo Orange White Theme', 'DEX Deep', 'Deep Sea', 'Gear Protocol'], group=GlobalGroup)

// Core Colors
color dark   = #000000
color white  = #c4d3ff
color green  = #179c74
color purple = #5134ff
color gray   = #62647a
color red    = #f23645
color yellow = #f3ba2f
color orange = #ff9800
color blue   = #1848cc
color brown  = #8b4513
color Transparent_Color = color.new(white, 100)

color col_bull = switch color_theme
    'Spartan Edge Theme' => red
    'MountAlgo Themes' => purple
    'MountAlgo Neon' => #5134ff
    'MountAlgo Frost' => #5134ff
    'MountAlgo Cyber' => #1848cc
    'Standard Spartan Edge Theme' => green
    'Dark ICT Theme' => green
    'Garuda Gold' => yellow
    'MountAlgo Super Premium Theme' => purple
    'MountAlgo Orange White Theme' => orange
    'DEX Deep' => #a1ff3b
    'Deep Sea' => blue
    'Gear Protocol' => white
    => blue

color col_bear = switch color_theme
    'Spartan Edge Theme' => gray
    'MountAlgo Themes' => green
    'MountAlgo Neon' => #ff009a
    'MountAlgo Frost' => #00e5ff
    'MountAlgo Cyber' => #ff009a
    'Standard Spartan Edge Theme' => red
    'Dark ICT Theme' => gray
    'Garuda Gold' => gray
    'MountAlgo Super Premium Theme' => yellow
    'MountAlgo Orange White Theme' => gray
    'DEX Deep' => #ff009a
    'Deep Sea' => gray
    'Gear Protocol' => gray
    => white

color col_poc = switch color_theme
    'Spartan Edge Theme' => white
    'MountAlgo Themes' => white
    'MountAlgo Neon' => white
    'MountAlgo Frost' => white
    'MountAlgo Cyber' => white
    'Standard Spartan Edge Theme' => white
    'Dark ICT Theme' => white
    'Garuda Gold' => white
    'MountAlgo Super Premium Theme' => white
    'MountAlgo Orange White Theme' => white
    'DEX Deep' => white
    'Deep Sea' => white
    => white

color box_col_bull = color.new(col_bull, 80)
color box_col_bear = color.new(col_bear, 80)
color transparent_col = color.new(dark, 100)

mitigated_color            = brown
mitigated_box_color        = color.new(brown, 80)

// Volume Profile Settings
var string g_vp = "Volume Profile Settings"
vp_mode = input.string("Recent Bars", "Profile Mode", options=["Recent Bars", "Fixed Range"], group=g_vp)
vp_period = input.int(200, "Lookback Period (Recent Bars)", minval=10, maxval=1000, group=g_vp)
vp_resolution = input.int(50, "Profile Resolution (Rows)", minval=10, maxval=200, group=g_vp)
vp_val_percent = input.int(70, "Value Area Volume %", minval=10, maxval=100, group=g_vp)
vp_type = input.string("Delta", "Profile View Type", options=["Normal", "Delta"], group=g_vp)

// Fixed Range Dates
vp_startTime = input.time(timestamp("2025-01-01T00:00:00"), "Fixed Range Start Time", group=g_vp)
vp_endTime = input.time(timestamp("2030-01-01T23:59:59"), "Fixed Range End Time", group=g_vp)

// HVN / LVN Config
show_lvn       = input.bool(true, "Show LVN (Low Volume Nodes)", group=g_vp)
lvn_threshold  = input.float(0.15, "LVN Threshold (%)", minval=0.01, maxval=0.5, step=0.01, group=g_vp)
color_lvn      = input.color(color.new(#62647a, 90), "LVN Color", group=g_vp)

show_hvn       = input.bool(true, "Show HVN (High Volume Nodes)", group=g_vp)
hvn_threshold  = input.float(0.70, "HVN Threshold (%)", minval=0.01, maxval=1.0, step=0.01, group=g_vp)
color_hvn      = input.color(color.new(#ff9800, 90), "HVN Color", group=g_vp)

// Display Settings
show_vp_histogram = input.bool(true, "Show VP Histogram", group="Display Settings")
show_vp_labels = input.bool(true, "Show POC/VAH/VAL Labels", group="Display Settings")
show_logo = input.bool(true, "Show Logo", group="Logo Settings")

// =============================================================================
// 2. HELPER FUNCTIONS
// =============================================================================
format_vol(float v) =>
    float abs_v = math.abs(v)
    string res = ""
    if abs_v >= 1000000000
        res := str.tostring(v / 1000000000, "#.##") + "B"
    else if abs_v >= 1000000
        res := str.tostring(v / 1000000, "#.##") + "M"
    else if abs_v >= 1000
        res := str.tostring(v / 1000, "#.#") + "K"
    else
        res := str.tostring(v, "0.##")
    res

get_tick_volume() => math.max(volume, 0)

f_gradientColor(color baseColor, float val, float maxVal) =>
    float ratio = maxVal > 0 ? math.abs(val) / maxVal : 0.0
    int transparency = math.round(95 - (ratio * 75))
    color.new(baseColor, transparency)

// 3-part wick/body anatomical partitioning heuristic (safe OHLC parameters)
calc_vol_partition(float vol, float o, float h, float l, float c) =>
    float range_size = h - l
    float b_vol = 0.0
    float s_vol = 0.0

    if range_size > 0
        float body_high = math.max(o, c)
        float body_low  = math.min(o, c)
        float body_size = body_high - body_low
        float upper_wick = h - body_high
        float lower_wick = body_low - l

        float w_body = body_size / range_size
        float w_upper = upper_wick / range_size
        float w_lower = lower_wick / range_size

        float b_center = (o + c) / 2
        float body_pos = (b_center - l) / range_size
        float br_b = c > o ? math.min(0.9, 0.6 + body_pos * 0.3) : (c < o ? math.max(0.1, 0.4 - (1-body_pos) * 0.3) : 0.5)

        b_vol := vol * (w_body * br_b + w_lower * 0.9 + w_upper * 0.1)
        s_vol := vol * (w_body * (1 - br_b) + w_upper * 0.9 + w_lower * 0.1)
    else
        b_vol := vol * 0.5
        s_vol := vol * 0.5
    [b_vol, s_vol]

// Directional Volume Profiling for LTF (Strict candle direction)
get_ltf_v() =>
    float b_vol = close >= open ? volume : 0.0
    float s_vol = close < open ? volume : 0.0
    [open, high, low, close, volume, b_vol, s_vol]

// =============================================================================
// 3. PRECISION ACCURACY ENGINE (request.security_lower_tf)
// =============================================================================
[ltf_o, ltf_h, ltf_l, ltf_c, ltf_v, ltf_b, ltf_s] = request.security_lower_tf(syminfo.tickerid, "1", get_ltf_v())

float ltf_buy_sum  = 0.0
float ltf_sell_sum = 0.0
float ltf_v_total  = 0.0

if not na(ltf_v)
    int ltf_count = array.size(ltf_v)
    if ltf_count > 0
        for i = 0 to ltf_count - 1
            ltf_buy_sum  += array.get(ltf_b, i)
            ltf_sell_sum += array.get(ltf_s, i)
            ltf_v_total  += array.get(ltf_v, i)

// Responsive Volume Engine: Sync LTF with actual HTF volume using fallback
float missing_v = math.max(0, get_tick_volume() - ltf_v_total)
[miss_b, miss_s] = calc_vol_partition(missing_v, open, high, low, close)

float current_buy_vol = ltf_buy_sum + miss_b
float current_sell_vol = ltf_sell_sum + miss_s

// =============================================================================
// 4. DATA AGGREGATION & STORAGE
// =============================================================================
var array<float> volume_at_price = array.new_float(vp_resolution, 0.0)
var array<float> buy_at_price = array.new_float(vp_resolution, 0.0)
var array<float> sell_at_price = array.new_float(vp_resolution, 0.0)

// Store historical values to recalculate precisely on barstate.islast
var float[] hist_open  = array.new_float(0)
var float[] hist_high  = array.new_float(0)
var float[] hist_low   = array.new_float(0)
var float[] hist_close = array.new_float(0)
var float[] hist_vol   = array.new_float(0)
var int[]   hist_time  = array.new_int(0)

if barstate.isconfirmed
    array.push(hist_open, open)
    array.push(hist_high, high)
    array.push(hist_low, low)
    array.push(hist_close, close)
    array.push(hist_vol, volume)
    array.push(hist_time, time)
    if array.size(hist_close) > 2000
        array.shift(hist_open)
        array.shift(hist_high)
        array.shift(hist_low)
        array.shift(hist_close)
        array.shift(hist_vol)
        array.shift(hist_time)

// Recalculate everything only on barstate.islast to prevent timeout and maintain high fidelity
float vp_high = na
float vp_low = na

// Calculate global indicator series outside condition blocks
bars_since_start = ta.barssince(time >= vp_startTime)

// Distribution Heuristic
distribute_vol_to_bins(int _rows, float _lowest_p, float _inv_row_h, float _o, float _h, float _l, float _c, float _v_total, float _b_total, float _s_total, array<float> _bucket_total, array<float> _bucket_buy, array<float> _bucket_sell) =>
    float b_high = math.max(_o, _c)
    float b_low  = math.min(_o, _c)
    float _range_val = _h - _l
    int max_idx = _rows - 1

    if max_idx >= 0
        if _range_val <= 0
            int idx = math.min(max_idx, math.max(0, math.floor((_c - _lowest_p) * _inv_row_h)))
            array.set(_bucket_total, idx, array.get(_bucket_total, idx) + _v_total)
            array.set(_bucket_buy, idx, array.get(_bucket_buy, idx) + _b_total)
            array.set(_bucket_sell, idx, array.get(_bucket_sell, idx) + _s_total)
        else
            float inv_range = 1.0 / _range_val
            float w_l = (b_low - _l) * inv_range
            float w_b = (b_high - b_low) * inv_range
            float w_u = (_h - b_high) * inv_range

            float v_l = _v_total * w_l
            float v_b = _v_total * w_b
            float v_u = _v_total * w_u

            float b_center = (_o + _c) * 0.5
            float body_pos = (b_center - _l) * inv_range
            float br_b = _c > _o ? math.min(0.9, 0.6 + body_pos * 0.3) : (_c < _o ? math.max(0.1, 0.4 - (1-body_pos) * 0.3) : 0.5)

            if v_l > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((_l - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_l / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.90
                    float v_j_sell = v_j * 0.10
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_b > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_b / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * br_b
                    float v_j_sell = v_j * (1.0 - br_b)
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_u > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((_h - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_u / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.10
                    float v_j_sell = v_j * 0.90
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)

// =============================================================================
// 5. DRAWING & RENDERING ENGINE
// =============================================================================
var box[] vp_boxes = array.new_box()
var line[] vp_lines = array.new_line()
var label[] vp_labels = array.new_label()

if barstate.islast
    // Cleanup drawings
    if array.size(vp_boxes) > 0
        for i = 0 to array.size(vp_boxes) - 1
            box.delete(array.get(vp_boxes, i))
        array.clear(vp_boxes)
    if array.size(vp_lines) > 0
        for i = 0 to array.size(vp_lines) - 1
            line.delete(array.get(vp_lines, i))
        array.clear(vp_lines)
    if array.size(vp_labels) > 0
        for i = 0 to array.size(vp_labels) - 1
            label.delete(array.get(vp_labels, i))
        array.clear(vp_labels)

    // Reset bins
    array.fill(volume_at_price, 0.0)
    array.fill(buy_at_price, 0.0)
    array.fill(sell_at_price, 0.0)

    // Collect historical and real-time data within window constraints
    int data_size = array.size(hist_close)
    if data_size > 0
        if vp_mode == "Recent Bars"
            int start_hist_idx = math.max(0, data_size - (vp_period - 1))
            // Find absolute low/high bounds of historical bars
            vp_high := array.get(hist_high, start_hist_idx)
            vp_low  := array.get(hist_low, start_hist_idx)
            for k = start_hist_idx to data_size - 1
                vp_high := math.max(vp_high, array.get(hist_high, k))
                vp_low  := math.min(vp_low, array.get(hist_low, k))
            
            // Also include current real-time bar in range calculation
            vp_high := math.max(vp_high, high)
            vp_low  := math.min(vp_low, low)
            
            float p_range = vp_high - vp_low
            float p_step = p_range > 0 ? p_range / vp_resolution : 0
            if p_range > 0
                float inv_p_step = 1.0 / p_step
                // Distribute historical window bars
                for k = start_hist_idx to data_size - 1
                    float o_v = array.get(hist_open, k)
                    float h_v = array.get(hist_high, k)
                    float l_v = array.get(hist_low, k)
                    float c_v = array.get(hist_close, k)
                    float v_v = array.get(hist_vol, k)
                    [b_h, s_h] = calc_vol_partition(v_v, o_v, h_v, l_v, c_v)
                    distribute_vol_to_bins(vp_resolution, vp_low, inv_p_step, o_v, h_v, l_v, c_v, v_v, b_h, s_h, volume_at_price, buy_at_price, sell_at_price)
                // Distribute current bar
                distribute_vol_to_bins(vp_resolution, vp_low, inv_p_step, open, high, low, close, volume, current_buy_vol, current_sell_vol, volume_at_price, buy_at_price, sell_at_price)
        
        else // Fixed Range Recalculation
            float actual_endTime = math.min(vp_endTime, time)
            // Calculate absolute high and low first over the fixed range
            bool has_valid_bars = false
            for k = 0 to data_size - 1
                int t_val = array.get(hist_time, k)
                if t_val >= vp_startTime and t_val <= actual_endTime
                    if not has_valid_bars
                        vp_high := array.get(hist_high, k)
                        vp_low  := array.get(hist_low, k)
                        has_valid_bars := true
                    else
                        vp_high := math.max(vp_high, array.get(hist_high, k))
                        vp_low  := math.min(vp_low, array.get(hist_low, k))
            
            if time >= vp_startTime and time <= actual_endTime
                if not has_valid_bars
                    vp_high := high
                    vp_low  := low
                    has_valid_bars := true
                else
                    vp_high := math.max(vp_high, high)
                    vp_low  := math.min(vp_low, low)

            float p_range = vp_high - vp_low
            float p_step = p_range > 0 ? p_range / vp_resolution : 0
            if p_range > 0 and has_valid_bars
                float inv_p_step = 1.0 / p_step
                // Safely distribute fixed range bars
                for k = 0 to data_size - 1
                    int t_val = array.get(hist_time, k)
                    if t_val >= vp_startTime and t_val <= actual_endTime
                        float o_v = array.get(hist_open, k)
                        float h_v = array.get(hist_high, k)
                        float l_v = array.get(hist_low, k)
                        float c_v = array.get(hist_close, k)
                        float v_v = array.get(hist_vol, k)
                        [b_h, s_h] = calc_vol_partition(v_v, o_v, h_v, l_v, c_v)
                        distribute_vol_to_bins(vp_resolution, vp_low, inv_p_step, o_v, h_v, l_v, c_v, v_v, b_h, s_h, volume_at_price, buy_at_price, sell_at_price)
                if time >= vp_startTime and time <= actual_endTime
                    distribute_vol_to_bins(vp_resolution, vp_low, inv_p_step, open, high, low, close, volume, current_buy_vol, current_sell_vol, volume_at_price, buy_at_price, sell_at_price)

    float total_profile_volume = array.sum(volume_at_price)
    float max_profile_vol = 0.0
    int poc_index = 0

    if total_profile_volume > 0
        max_profile_vol := array.max(volume_at_price)
        poc_index := array.indexof(volume_at_price, max_profile_vol)

    // Calculate Value Area (VAH / VAL) - Standard 70% rule
    int va_high_idx = poc_index
    int va_low_idx = poc_index
    float target_va_vol = total_profile_volume * (vp_val_percent / 100.0)
    float current_va_vol = max_profile_vol

    while current_va_vol < target_va_vol
        float up_vol = (va_high_idx < vp_resolution - 1) ? array.get(volume_at_price, va_high_idx + 1) : 0.0
        float down_vol = (va_low_idx > 0) ? array.get(volume_at_price, va_low_idx - 1) : 0.0

        if up_vol == 0.0 and down_vol == 0.0
            break

        if up_vol >= down_vol
            current_va_vol += up_vol
            va_high_idx += 1
        else
            current_va_vol += down_vol
            va_low_idx -= 1

    float p_range = vp_high - vp_low
    float p_step = p_range > 0 ? p_range / vp_resolution : 0

    float poc_price = vp_low + (poc_index + 0.5) * p_step
    float vah_price = vp_low + (va_high_idx + 1) * p_step
    float val_price = vp_low + va_low_idx * p_step

    if show_vp_histogram and p_range > 0
        int profile_start_x = bar_index + 22
        int max_profile_width = 58
        int start_bar_for_drawing = vp_mode == "Recent Bars" ? bar_index - vp_period + 1 : bar_index - bars_since_start

        // Base frame box
        box bvp = box.new(start_bar_for_drawing, vp_high, bar_index + 20, vp_low,
             border_color=mitigated_color, border_style=line.style_dashed, border_width=2,
             bgcolor=Transparent_Color, extend=extend.none)
        array.push(vp_boxes, bvp)

        for i = 0 to vp_resolution - 1
            float level_price = vp_low + i * p_step
            float next_level_price = level_price + p_step
            float level_vol = array.get(volume_at_price, i)
            float level_buy = array.get(buy_at_price, i)
            float level_sell = array.get(sell_at_price, i)
            float level_delta = level_buy - level_sell

            if level_vol > 0
                // Color mapping: Delta view or Normal view
                color base_color = vp_type == "Delta" ? (level_delta >= 0 ? col_bull : col_bear) : col_poc
                color gradient_color = f_gradientColor(base_color, level_vol, max_profile_vol)
                int box_width = math.round(level_vol / max_profile_vol * max_profile_width)

                if i < va_low_idx or i > va_high_idx
                    gradient_color := color.new(gradient_color, 65) // Glass-effect fade out non-VA

                box bv1 = box.new(profile_start_x, next_level_price, profile_start_x + box_width, level_price, bgcolor=gradient_color, border_color=na)
                array.push(vp_boxes, bv1)

        // Draw POC / VAH / VAL Lines & Labels
        if not na(poc_price)
            // POC
            line lpoc = line.new(start_bar_for_drawing, poc_price, bar_index + 25, poc_price, color=color.new(col_poc, 0), style=line.style_solid, width=2)
            array.push(vp_lines, lpoc)
            if show_vp_labels
                string poc_lbl = "POC: " + str.tostring(poc_price, format.mintick) + " (" + format_vol(max_profile_vol) + ")"
                label lb_poc = label.new(bar_index + 25, poc_price, poc_lbl, color=col_poc, textcolor=dark, style=label.style_label_left, size=size.tiny)
                array.push(vp_labels, lb_poc)

            // VAH
            line lvah = line.new(start_bar_for_drawing, vah_price, bar_index + 25, vah_price, color=color.new(col_bull, 20), style=line.style_dashed, width=1)
            array.push(vp_lines, lvah)
            if show_vp_labels
                float vah_vol = va_high_idx < vp_resolution ? array.get(volume_at_price, va_high_idx) : 0.0
                string vah_lbl = "VAH: " + str.tostring(vah_price, format.mintick) + " (" + format_vol(vah_vol) + ")"
                label lb_vah = label.new(bar_index + 25, vah_price, vah_lbl, color=col_bull, textcolor=dark, style=label.style_label_left, size=size.tiny)
                array.push(vp_labels, lb_vah)

            // VAL
            line lval = line.new(start_bar_for_drawing, val_price, bar_index + 25, val_price, color=color.new(col_bear, 20), style=line.style_dashed, width=1)
            array.push(vp_lines, lval)
            if show_vp_labels
                float val_vol = va_low_idx >= 0 ? array.get(volume_at_price, va_low_idx) : 0.0
                string val_lbl = "VAL: " + str.tostring(val_price, format.mintick) + " (" + format_vol(val_vol) + ")"
                label lb_val = label.new(bar_index + 25, val_price, val_lbl, color=col_bear, textcolor=dark, style=label.style_label_left, size=size.tiny)
                array.push(vp_labels, lb_val)

        // HVN & LVN Detection
        if show_lvn or show_hvn
            float avg_profile_vol = array.avg(volume_at_price)
            float threshold_lvn = max_profile_vol * lvn_threshold
            float threshold_hvn = max_profile_vol * hvn_threshold

            for i = 1 to vp_resolution - 2
                float v_prev = array.get(volume_at_price, i - 1)
                float v_curr = array.get(volume_at_price, i)
                float v_next = array.get(volume_at_price, i + 1)
                float level_price_bottom = vp_low + i * p_step
                float level_price_top = level_price_bottom + p_step

                // HVN detection (excluding POC) - Solid border area box with strict "HVN" text
                if show_hvn and v_curr > v_prev and v_curr > v_next and v_curr >= threshold_hvn and i != poc_index
                    box bhvn = box.new(bar_index, level_price_top, bar_index + 25, level_price_bottom,
                         border_color=color.new(col_bull, 20), border_style=line.style_solid, border_width=1,
                         bgcolor=color.new(col_bull, 90), text="HVN", text_color=white, text_size=size.tiny, text_halign=text.align_center, text_valign=text.align_center)
                    array.push(vp_boxes, bhvn)

                // LVN detection - Dashed border area box with strict "LVN" text
                if show_lvn and v_curr < v_prev and v_curr < v_next and v_curr < threshold_lvn
                    box blvn = box.new(bar_index, level_price_top, bar_index + 25, level_price_bottom,
                         border_color=color.new(col_bear, 20), border_style=line.style_dashed, border_width=1,
                         bgcolor=color.new(col_bear, 90), text="LVN", text_color=white, text_size=size.tiny, text_halign=text.align_center, text_valign=text.align_center)
                    array.push(vp_boxes, blvn)

// =============================================================================
// 6. PREMIUM BREATHING LOGO SYSTEM (PORTED FROM BOOKMAP.PINE)
// =============================================================================
color bull_c1 = col_bull
color bull_c2 = col_bear
color bear_c1 = col_bull
color bear_c2 = col_bear

bool  trend_check = ta.ema(close, 2) > ta.ema(open, 2)
color c_start     = trend_check ? bull_c1 : bear_c1
color c_end       = trend_check ? bull_c2 : bear_c2

float time_cycle = timenow / 1000
float breathe    = (math.sin(time_cycle * 3) + 1) / 2

int LG_Line_Widthb = 1
int periodb        = 200

float logo_base_raw = ta.lowest(low, periodb)
float logo_range    = ta.highest(high, periodb) - logo_base_raw
var float h_unit    = na

float target_h = math.max(ta.atr(periodb) * 1.5, logo_range * 0.22)
h_unit := na(h_unit) ? target_h : h_unit * 0.98 + target_h * 0.02

float logo_base = logo_base_raw - h_unit * 0.2

float point1b  = logo_base + h_unit * 0.71
float point2b  = logo_base + h_unit * 0.43
float point3b  = logo_base + h_unit * 0.61
float point4b  = logo_base + h_unit * 0.32
float point5b  = logo_base + h_unit * 1.00 // Peak
float point6b  = logo_base + h_unit * 0.71
float point7b  = logo_base + h_unit * 0.18 // Base Top
float point8b  = logo_base + h_unit * 0.21
float point9b  = logo_base + h_unit * 0.71
float point1b0 = logo_base + h_unit * 0.86

var line Line1b  = na
var line Line2b  = na
var line Line3b  = na
var line Line4b  = na
var line Line5b  = na
var line Line6b  = na
var line Line7b  = na
var line Line8b  = na
var line Line9b  = na
var line Line1b0 = na
var line Line1b1 = na
var line Line1b2 = na
var line Line1b3 = na
var line Line1b4 = na
var line Line1b5 = na
var line Line1b6 = na
var line Line1b7 = na
var line Line1b8 = na
var label[] brand_labels = array.new<label>()

if not na(Line1b)
    line.delete(Line1b)
    line.delete(Line2b)
    line.delete(Line3b)
    line.delete(Line4b)
    line.delete(Line5b)
    line.delete(Line6b)
    line.delete(Line7b)
    line.delete(Line8b)
    line.delete(Line9b)
    line.delete(Line1b0)
    line.delete(Line1b1)
    line.delete(Line1b2)
    line.delete(Line1b3)
    line.delete(Line1b4)
    line.delete(Line1b5)
    line.delete(Line1b6)
    line.delete(Line1b7)
    line.delete(Line1b8)
    while array.size(brand_labels) > 0
        label.delete(array.pop(brand_labels))

get_adv_color(step) =>
    float ratio = step / 18.0
    float dynamic_ratio = ratio + (breathe * 0.15)
    if dynamic_ratio > 1
        dynamic_ratio := 1
    color.from_gradient(dynamic_ratio, 0, 1, c_start, c_end)

get_fade_alpha(float x_rel) =>
    float dist = math.abs(x_rel - 32)
    float ratio = dist / 32.0
    math.round(80 * (1 - ratio))

// Shift logo layout further right to prevent visual overlap with volume profile boxes
int l_off = 90

if show_logo and barstate.islast
    color c_head_sync = get_adv_color(1)

    Line1b := line.new(x1 = bar_index + l_off + 4, y1 = point7b, x2 = bar_index + l_off + 11, y2 = point1b, color = col_poc, width = LG_Line_Widthb)
    Line2b := line.new(x1 = bar_index + l_off + 8, y1 = point7b, x2 = bar_index + l_off + 11, y2 = point2b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b, Line2b, color = color.new(c_head_sync, get_fade_alpha(7.5)))

    Line3b := line.new(x1 = bar_index + l_off + 11, y1 = point1b, x2 = bar_index + l_off + 13, y2 = point3b, color = col_poc, width = LG_Line_Widthb)
    Line4b := line.new(x1 = bar_index + l_off + 11, y1 = point2b, x2 = bar_index + l_off + 13, y2 = point4b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line3b, Line4b, color = color.new(get_adv_color(3), get_fade_alpha(12.0)))

    Line5b := line.new(x1 = bar_index + l_off + 13, y1 = point3b, x2 = bar_index + l_off + 19, y2 = point5b, color = col_poc, width = LG_Line_Widthb)
    Line6b := line.new(x1 = bar_index + l_off + 13, y1 = point4b, x2 = bar_index + l_off + 19, y2 = point6b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line5b, Line6b, color = color.new(get_adv_color(5), get_fade_alpha(16.0)))

    Line7b := line.new(x1 = bar_index + l_off + 19, y1 = point5b, x2 = bar_index + l_off + 24, y2 = point3b, color = col_poc, width = LG_Line_Widthb)
    Line8b := line.new(x1 = bar_index + l_off + 19, y1 = point6b, x2 = bar_index + l_off + 24, y2 = point4b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line7b, Line8b, color = color.new(get_adv_color(7), get_fade_alpha(21.5)))

    Line9b := line.new(x1 = bar_index + l_off + 24, y1 = point3b, x2 = bar_index + l_off + 26, y2 = point1b, color = col_poc, width = LG_Line_Widthb)
    Line1b0 := line.new(x1 = bar_index + l_off + 24, y1 = point4b, x2 = bar_index + l_off + 26, y2 = point2b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line9b, Line1b0, color = color.new(get_adv_color(9), get_fade_alpha(25.0)))

    Line1b1 := line.new(x1 = bar_index + l_off + 26, y1 = point1b, x2 = bar_index + l_off + 36, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b2 := line.new(x1 = bar_index + l_off + 26, y1 = point2b, x2 = bar_index + l_off + 32, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b1, Line1b2, color = color.new(get_adv_color(11), get_fade_alpha(31.0)))

    Line1b3 := line.new(x1 = bar_index + l_off + 2, y1 = point7b, x2 = bar_index + l_off + 26, y2 = point7b, color = col_poc, width = LG_Line_Widthb)
    Line1b4 := line.new(x1 = bar_index + l_off + 0, y1 = logo_base, x2 = bar_index + l_off + 24, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b3, Line1b4, color = color.new(c_head_sync, get_fade_alpha(13.0)))

    Line1b5 := line.new(x1 = bar_index + l_off + 2, y1 = point7b, x2 = bar_index + l_off + 0, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b6 := line.new(x1 = bar_index + l_off + 26, y1 = point7b, x2 = bar_index + l_off + 24, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b7 := line.new(x1 = bar_index + l_off + 32, y1 = logo_base, x2 = bar_index + l_off + 36, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)

    label l = label.new(bar_index + l_off + 54, point2b, "MountAlgo", style=label.style_none, textcolor=col_poc, size=size.huge, textalign=text.align_right)
    array.push(brand_labels, l)

    label glow1 = label.new(bar_index + l_off + 13, point1b0, "●", style=label.style_none, textcolor=color.new(get_adv_color(2), get_fade_alpha(13.0)), size=size.huge)
    label glow2 = label.new(bar_index + l_off + 13, point1b0, "〇", style=label.style_none, textcolor=col_poc, size=size.huge)
    array.push(brand_labels, glow1)
    array.push(brand_labels, glow2)
