//@version=6
indicator("TDV Candles V1.0 𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜ο", shorttitle="TDV Candles", overlay=false)

// -----------------------------------------------------------------------------
// 1. INPUTS & CONFIGURATION (Theme system synced with footprints.pine)
// -----------------------------------------------------------------------------
string GlobalGroup = "Visual Themes & Global"
string color_theme = input.string(defval = 'DEX Deep', title = 'Select Color Theme', options = ['Spartan Edge Theme', 'MountAlgo Themes', 'MountAlgo Neon', 'MountAlgo Frost', 'MountAlgo Cyber', 'Standard Spartan Edge Theme', 'Dark ICT Theme', 'Garuda Gold', 'MountAlgo Super Premium Theme', 'MountAlgo Orange White Theme', 'DEX Deep', 'Deep Sea', 'Gear Protocol'], group=GlobalGroup)

// Core Colors
color dark   = #000000
color white  = #c4d3ff
color green  = #179c74
color purple = #5134ff
color gray   = #62647a
color red    = #f23645
color yellow = #f3ba2f
color orange = #ff9800
color blue   = #1848cc
color brown  = #8b4513

color col_bull = switch color_theme
    'Spartan Edge Theme' => red
    'MountAlgo Themes' => purple
    'MountAlgo Neon' => #5134ff
    'MountAlgo Frost' => #5134ff
    'MountAlgo Cyber' => #1848cc
    'Standard Spartan Edge Theme' => green
    'Dark ICT Theme' => green
    'Garuda Gold' => yellow
    'MountAlgo Super Premium Theme' => purple
    'MountAlgo Orange White Theme' => orange
    'DEX Deep' => #a1ff3b
    'Deep Sea' => blue
    'Gear Protocol' => white
    => blue
color col_bear = switch color_theme
    'Spartan Edge Theme' => gray
    'MountAlgo Themes' => green
    'MountAlgo Neon' => #ff009a
    'MountAlgo Frost' => #00e5ff
    'MountAlgo Cyber' => #ff009a
    'Standard Spartan Edge Theme' => red
    'Dark ICT Theme' => gray
    'Garuda Gold' => gray
    'MountAlgo Super Premium Theme' => yellow
    'MountAlgo Orange White Theme' => gray
    'DEX Deep' => #ff009a
    'Deep Sea' => gray
    'Gear Protocol' => gray
    => white

// -----------------------------------------------------------------------------
// 2. LOWER TIMEFRAME (LTF) SECURITY REQUEST
// -----------------------------------------------------------------------------
[ltf_o_series, ltf_h_series, ltf_l_series, ltf_c_series, ltf_v_series] = request.security_lower_tf(syminfo.tickerid, "1", [open, high, low, close, volume])

// Cumulative variable to allow continuous up-and-down (CVD-style) candles
var float cum_val = 0.0

float open_val = cum_val
float close_val = open_val
float high_val = open_val
float low_val = open_val

// Safe check for lower timeframe array existence
bool has_ltf = false
if not na(ltf_v_series)
    if array.size(ltf_v_series) > 0
        has_ltf := true

if has_ltf
    float current_running = 0.0
    float max_running = 0.0
    float min_running = 0.0
    int ltf_sz = array.size(ltf_v_series)
    for j = 0 to ltf_sz - 1
        float l_o = array.get(ltf_o_series, j)
        float l_c = array.get(ltf_c_series, j)
        float l_v = array.get(ltf_v_series, j)

        float delta = l_c >= l_o ? l_v : -l_v
        current_running := current_running + delta
        max_running := math.max(max_running, current_running)
        min_running := math.min(min_running, current_running)

    close_val := open_val + current_running
    high_val := open_val + max_running
    low_val := open_val + min_running
else
    // High-fidelity fallback heuristic partitioning
    float body_high = math.max(open, close)
    float body_low = math.min(open, close)
    float body_size = body_high - body_low
    float upper_wick = high - body_high
    float lower_wick = body_low - low

    float total_weight = body_size * 1.5 + upper_wick * 1.0 + lower_wick * 1.0
    float b_vol = 0.0
    float s_vol = 0.0
    if total_weight > 0
        float up_vol = volume * (upper_wick * 1.0 / total_weight)
        float bo_vol = volume * (body_size * 1.5 / total_weight)
        float dn_vol = volume * (lower_wick * 1.0 / total_weight)

        float b_up = up_vol * 0.1
        float s_up = up_vol * 0.9

        float b_dn = dn_vol * 0.9
        float s_dn = dn_vol * 0.1

        float b_bo = 0.0
        float s_bo = 0.0
        if close >= open
            b_bo := bo_vol * 0.8
            s_bo := bo_vol * 0.2
        else
            b_bo := bo_vol * 0.2
            s_bo := bo_vol * 0.8

        b_vol := b_up + b_dn + b_bo
        s_vol := s_up + s_dn + s_bo
    else
        b_vol := close >= open ? volume : 0.0
        s_vol := close < open ? volume : 0.0

    float total_delta = b_vol - s_vol
    close_val := open_val + total_delta
    high_val := math.max(open_val, close_val)
    low_val := math.min(open_val, close_val)

// Update cumulative state for the next bar
cum_val := close_val

// Render TDV continuous trend candle
color candle_col = close_val >= open_val ? col_bull : col_bear
plotcandle(open_val, high_val, low_val, close_val, "TDV Candles", color=candle_col, wickcolor=candle_col, bordercolor=candle_col)
