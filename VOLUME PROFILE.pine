Line1b  := line.new(x1=bar_index + 28, y1=point7b, x2=bar_index + 35, y2=point1b, color=col_logo, width=LG_Line_Widthb)
Line2b  := line.new(x1=bar_index + 32, y1=point7b, x2=bar_index + 35, y2=point2b, color=col_logo, width=LG_Line_Widthb)
Line3b  := line.new(x1=bar_index + 35, y1=point1b, x2=bar_index + 37, y2=point3b, color=col_logo, width=LG_Line_Widthb)
