// ====================================================================================================================================================================================
// | Advanced Order Flow & Volume Profile v6.0 (Value Area Edition)                                                                                           |
// | Crafted by Gemini AI (Hedge Fund Analyst Mode)                                                                                                           |
// ====================================================================================================================================================================================
// | CHANGELOG V6.0:                                                                                                                                          |
// | 1. [LOGIC] Added True Value Area (VA) Calculation algorithm (Standard 70% volume rule).                                                                  |
// | 2. [FEATURE] Added VAH (Value Area High) and VAL (Value Area Low) Lines.                                                                                 |
// | 3. [UI] Added Labels for POC, VAH, and VAL with Price Tags.                                                                                              |
// | 4. [STABILITY] Maintained array-based drawing management to prevent duplication.                                                                         |
// ====================================================================================================================================================================================
//@version=6
indicator(title            = "Advanced Order Flow & Volume Profile v6.0"
  , shorttitle             = "AOF-VP v6.0"
  , overlay                = true
  , max_bars_back          = 500
  , max_lines_count        = 500
  , max_boxes_count        = 500
  , max_labels_count       = 500)

// -----------------------------------------------------------------------------
// 1. INPUTS & CONFIGURATION - THEME SYSTEM
// -----------------------------------------------------------------------------
var string GlobalGroup = "Visual Themes & Global Settings"
color_theme = input.string(defval = 'DEX Deep', title = 'Select Color Theme', options = ['Spartan Edge Theme', 'MountAlgo Themes', 'MountAlgo Neon', 'MountAlgo Frost', 'MountAlgo Cyber', 'Standard Spartan Edge Theme', 'Dark ICT Theme', 'Garuda Gold', 'MountAlgo Super Premium Theme', 'MountAlgo Orange White Theme', 'DEX Deep', 'Deep Sea', 'Gear Protocol'], group=GlobalGroup)

// Core Colors
color dark   = #000000
color white  = #c4d3ff
color green  = #179c74
color purple = #5134ff
color gray   = #62647a
color red    = #f23645
color yellow = #f3ba2f
color orange = #ff9800
color blue   = #1848cc
color brown  = #8b4513
color Transparent_Color = color.new(white, 100)

color col_bull = switch color_theme
    'Spartan Edge Theme' => red
    'MountAlgo Themes' => purple
    'MountAlgo Neon' => #5134ff
    'MountAlgo Frost' => #5134ff
    'MountAlgo Cyber' => #1848cc
    'Standard Spartan Edge Theme' => green
    'Dark ICT Theme' => green
    'Garuda Gold' => yellow
    'MountAlgo Super Premium Theme' => purple
    'MountAlgo Orange White Theme' => orange
    'DEX Deep' => #a1ff3b
    'Deep Sea' => blue
    'Gear Protocol' => white
    => blue

color col_bear = switch color_theme
    'Spartan Edge Theme' => gray
    'MountAlgo Themes' => green
    'MountAlgo Neon' => #ff009a
    'MountAlgo Frost' => #00e5ff
    'MountAlgo Cyber' => #ff009a
    'Standard Spartan Edge Theme' => red
    'Dark ICT Theme' => gray
    'Garuda Gold' => gray
    'MountAlgo Super Premium Theme' => yellow
    'MountAlgo Orange White Theme' => gray
    'DEX Deep' => #ff009a
    'Deep Sea' => gray
    'Gear Protocol' => gray
    => white

color col_poc = switch color_theme
    'Spartan Edge Theme' => white
    'MountAlgo Themes' => white
    'MountAlgo Neon' => white
    'MountAlgo Frost' => white
    'MountAlgo Cyber' => white
    'Standard Spartan Edge Theme' => white
    'Dark ICT Theme' => white
    'Garuda Gold' => white
    'MountAlgo Super Premium Theme' => white
    'MountAlgo Orange White Theme' => white
    'DEX Deep' => white
    'Deep Sea' => white
    => white

color box_col_bull = color.new(col_bull, 80)
color box_col_bear = color.new(col_bear, 80)
color transparent_col = color.new(dark, 100)

mitigated_color            = brown    
mitigated_box_color        = color.new(brown, 80)

// ______________________________________________________________________________________________________________________________________________________
//| INPUTS                                                                                                                                                |
//|_______________________________________________________________________________________________________________________________________________________|

var string g_vp = "Volume Profile Settings"
vp_mode = input.string("Recent Bars", "Profile Mode", options=["Recent Bars", "Fixed Range"], group=g_vp)
vp_period = input.int(100, "Lookback Period (Recent Bars)", minval=10, maxval=500, group=g_vp)
vp_resolution = input.int(50, "Profile Resolution (Rows)", minval=10, maxval=200, group=g_vp)
vp_val_percent = input.int(70, "Value Area Volume %", minval=10, maxval=100, group=g_vp, tooltip="Percentage of total volume to include in the Value Area (Standard is 70%).")

// 5. Perbaiki fixed volume profile tanggal dan menit menggunakan tanggal modern ter-update (2025 ke 2030)
vp_startTime = input.time(timestamp("2025-01-01T00:00:00"), "Fixed Range Start Time", group=g_vp)
vp_endTime = input.time(timestamp("2030-01-01T23:59:59"), "Fixed Range End Time", group=g_vp)

vp_hvn_threshold = input.float(1.5, "HVN Volume Multiplier", minval=1.0, step=0.25, group=g_vp)
vp_lvn_threshold = input.float(0.1, "LVN Volume Threshold (%)", minval=0.01, maxval=0.5, step=0.01, group=g_vp)
vp_imbalance_threshold = input.float(3.0, "Delta Imbalance Ratio", minval=1.5, step=0.5, group=g_vp)

var string g_delta = "Delta Calculation Settings"
delta_tf = input.timeframe("1", "Delta Calculation Timeframe", group=g_delta)

var string g_ti = "Technical Indicator Settings"
ma_fast_len = input.int(50, "Fast MA Length", group=g_ti)
ma_slow_len = input.int(200, "Slow MA Length", group=g_ti)
rsi_len = input.int(14, "RSI Length", group=g_ti)
rsi_bull_level = input.float(55, "RSI Bullish Level", group=g_ti)
rsi_bear_level = input.float(45, "RSI Bearish Level", group=g_ti)

var string g_display = "Display Settings"
show_vp_histogram = input.bool(true, "Show VP Histogram", group=g_display)
show_vp_labels = input.bool(true, "Show POC/VAH/VAL Labels", group=g_display)
show_lvn_hvn = input.bool(true, "Show HVN and LVN Levels", group=g_display)
show_analysis_table = input.bool(true, "Show Trading Analysis Table", group=g_display)
show_volume_ladder = input.bool(true, "Show Volume Ladder Table", group=g_display)

// ______________________________________________________________________________________________________________________________________________________
//| COLORS & UTILS                                                                                                                                        |
//|_______________________________________________________________________________________________________________________________________________________|

color POSITIVE_COLOR = col_bull
color NEGATIVE_COLOR = col_bear
color NEUTRAL_COLOR = mitigated_color
color HEADER_COLOR = dark
color TEXT_COLOR = white
color POC_COLOR_BG = col_poc
color POC_COLOR_LINE = color.new(col_poc, 0)
color VAH_COLOR_LINE = color.new(col_bull, 20)
color VAL_COLOR_LINE = color.new(col_bear, 20)

f_gradientColor(base_color, current_value, max_value) =>
    float ratio = max_value > 0 ? math.abs(current_value) / max_value : 0
    int transparency = math.round(85 - (ratio * 45))
    color.new(base_color, transparency)

f_formatNumber(number, add_sign = false) =>
    string sign = ""
    if add_sign
        sign := number >= 0 ? "+" : ""
    string res = na
    float abs_number = math.abs(number)
    if abs_number >= 1000000000
        res := sign + str.tostring(abs_number / 1000000000, "#.##") + "B"
    else if abs_number >= 1000000
        res := sign + str.tostring(abs_number / 1000000, "#.##") + "M"
    else if abs_number >= 1000
        res := sign + str.tostring(abs_number / 1000, "#.##") + "K"
    else
        res := sign + str.tostring(abs_number, "#")
    res

get_tick_volume() => math.max(volume, 0)

// Heuristic Volume Partitioning
calc_vol_partition(float vol) =>
    float range_size = high - low
    float b_vol = 0.0
    float s_vol = 0.0

    if range_size > 0
        float b_high = math.max(open, close)
        float b_low  = math.min(open, close)
        float body_size = b_high - b_low
        float upper_wick = high - b_high
        float lower_wick = b_low - low

        float w_body = body_size / range_size
        float w_upper = upper_wick / range_size
        float w_lower = lower_wick / range_size

        float b_center = (open + close) / 2
        float body_pos = (b_center - low) / range_size
        float br_b = close > open ? math.min(0.9, 0.6 + body_pos * 0.3) : (close < open ? math.max(0.1, 0.4 - (1-body_pos) * 0.3) : 0.5)

        b_vol := vol * (w_body * br_b + w_lower * 0.9 + w_upper * 0.1)
        s_vol := vol * (w_body * (1 - br_b) + w_upper * 0.9 + w_lower * 0.1)
    else
        b_vol := vol * 0.5
        s_vol := vol * 0.5
    [b_vol, s_vol]

[buy_vol_heuristic, sell_vol_heuristic] = calc_vol_partition(get_tick_volume())

// ______________________________________________________________________________________________________________________________________________________
//| CORE DATA & INDICATOR CALCULATION                                                                                                                     |
//|_______________________________________________________________________________________________________________________________________________________|

get_ltf_v() =>
    [b, s] = calc_vol_partition(volume)
    [open, high, low, close, volume, b, s]

// 4. Tingkatkan akurasi volume profile secara real-time dan paling akurat menggunakan request.security_lower_tf
[ltf_o, ltf_h, ltf_l, ltf_c, ltf_v, ltf_b, ltf_s] = request.security_lower_tf(syminfo.tickerid, "1", get_ltf_v())

float ltf_buy_sum  = 0.0
float ltf_sell_sum = 0.0
int ltf_count = array.size(ltf_v)
float ltf_v_total = 0.0

if ltf_count > 0
    for i = 0 to ltf_count - 1
        ltf_buy_sum  += array.get(ltf_b, i)
        ltf_sell_sum += array.get(ltf_s, i)
        ltf_v_total  += array.get(ltf_v, i)

// Responsive Volume Engine: Sync LTF with actual HTF volume
float missing_v = math.max(0, get_tick_volume() - ltf_v_total)
[miss_b, miss_s] = calc_vol_partition(missing_v)

float current_buy_vol = ltf_buy_sum + miss_b
float current_sell_vol = ltf_sell_sum + miss_s
float current_delta = current_buy_vol - current_sell_vol
float cum_delta = ta.cum(current_delta)

float rsi = ta.rsi(close, rsi_len)
float ma50 = ta.sma(close, ma_fast_len)
float ma200 = ta.sma(close, ma_slow_len)
float vwap_val = ta.vwap(close)
bool is_uptrend = ma50 > ma200 and close > ma50
bool is_downtrend = ma50 < ma200 and close < ma50

// ______________________________________________________________________________________________________________________________________________________
//| VOLUME PROFILE ENGINE (DATA AGGREGATION)                                                                                                            |
//|_______________________________________________________________________________________________________________________________________________________|

var array<float> volume_at_price = array.new_float(vp_resolution, 0.0)
var array<float> delta_at_price = array.new_float(vp_resolution, 0.0)
var array<float> buy_at_price = array.new_float(vp_resolution, 0.0)
var array<float> sell_at_price = array.new_float(vp_resolution, 0.0)
var float vp_high = na
var float vp_low = na

// Reset & Calculate Range
if vp_mode == "Recent Bars"
    vp_high := ta.highest(high, vp_period)
    vp_low := ta.lowest(low, vp_period)
    array.fill(volume_at_price, 0.0)
    array.fill(delta_at_price, 0.0)
    array.fill(buy_at_price, 0.0)
    array.fill(sell_at_price, 0.0)
else // Fixed Range
    var float fixed_high = na
    var float fixed_low = na

    // Perbaikan: Selalu hitung dari awal vp_startTime hingga real-time bar terakhir
    // Jika vp_endTime lebih kecil dari time sekarang, biarkan meluas hingga time sekarang
    float actual_endTime = math.max(vp_endTime, time)

    if time >= vp_startTime and (na(fixed_high) or time[1] < vp_startTime)
        fixed_high := high
        fixed_low := low
        array.fill(volume_at_price, 0.0)
        array.fill(delta_at_price, 0.0)
        array.fill(buy_at_price, 0.0)
        array.fill(sell_at_price, 0.0)
    if time >= vp_startTime and time <= actual_endTime
        if high > fixed_high
            fixed_high := high
        if low < fixed_low
            fixed_low := low
    vp_high := fixed_high
    vp_low := fixed_low

float price_range = vp_high - vp_low
float price_step = price_range > 0 ? price_range / vp_resolution : 0

// Distribution Heuristic for Profile
distribute_vol(int _rows, float _lowest_p, float _inv_row_h, float _o, float _h, float _l, float _c, float _v_total, array<float> _bucket_total, array<float> _bucket_buy, array<float> _bucket_sell) =>
    float b_high = math.max(_o, _c)
    float b_low  = math.min(_o, _c)
    float _range_val = _h - _l
    int max_idx = _rows - 1

    if max_idx >= 0
        if _range_val <= 0
            int idx = math.min(max_idx, math.max(0, math.floor((_c - _lowest_p) * _inv_row_h)))
            array.set(_bucket_total, idx, array.get(_bucket_total, idx) + _v_total)
            float v_half = _v_total * 0.5
            array.set(_bucket_buy, idx, array.get(_bucket_buy, idx) + v_half)
            array.set(_bucket_sell, idx, array.get(_bucket_sell, idx) + v_half)
        else
            float inv_range = 1.0 / _range_val
            float w_l = (b_low - _l) * inv_range
            float w_b = (b_high - b_low) * inv_range
            float w_u = (_h - b_high) * inv_range

            float v_l = _v_total * w_l
            float v_b = _v_total * w_b
            float v_u = _v_total * w_u

            float b_center = (_o + _c) * 0.5
            float body_pos = (b_center - _l) * inv_range

            float br_b = _c > _o ? math.min(0.9, 0.6 + body_pos * 0.3) : (_c < _o ? math.max(0.1, 0.4 - (1-body_pos) * 0.3) : 0.5)

            if v_l > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((_l - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_l / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.90
                    float v_j_sell = v_j * 0.10
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_b > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_b / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * br_b
                    float v_j_sell = v_j * (1.0 - br_b)
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_u > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((_h - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_u / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.10
                    float v_j_sell = v_j * 0.90
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)

// Populate Arrays
if price_range > 0
    float inv_price_step = 1.0 / price_step
    if vp_mode == "Recent Bars"
        for i = 0 to vp_period - 1
            float o_val = open[i]
            float h_val = high[i]
            float l_val = low[i]
            float c_val = close[i]
            float v_val = volume[i]
            distribute_vol(vp_resolution, vp_low, inv_price_step, o_val, h_val, l_val, c_val, v_val, volume_at_price, buy_at_price, sell_at_price)

    else // Fixed Range
        float actual_endTime = math.max(vp_endTime, time)
        if time >= vp_startTime and time <= actual_endTime
            distribute_vol(vp_resolution, vp_low, inv_price_step, open, high, low, close, volume, volume_at_price, buy_at_price, sell_at_price)

    // Calculate delta_at_price from populated buy_at_price and sell_at_price
    for k = 0 to vp_resolution - 1
        array.set(delta_at_price, k, array.get(buy_at_price, k) - array.get(sell_at_price, k))

// ______________________________________________________________________________________________________________________________________________________
//| VISUALIZATIONS & ALERTS                                                                                                                               |
//|_______________________________________________________________________________________________________________________________________________________|

// Arrays for object management (Prevent Duplication)
var array<box>  vp_boxes = array.new<box>()
var array<line> vp_lines = array.new<line>()
var array<label> vp_labels = array.new<label>()

if barstate.islast
    // 1. CLEANUP
    if array.size(vp_boxes) > 0
        for i = 0 to array.size(vp_boxes) - 1
            box.delete(array.get(vp_boxes, i))
        array.clear(vp_boxes)
    if array.size(vp_lines) > 0
        for i = 0 to array.size(vp_lines) - 1
            line.delete(array.get(vp_lines, i))
        array.clear(vp_lines)
    if array.size(vp_labels) > 0
        for i = 0 to array.size(vp_labels) - 1
            label.delete(array.get(vp_labels, i))
        array.clear(vp_labels)

    // 2. CALCULATE POC & STATS
    float total_profile_volume = array.sum(volume_at_price)
    float max_profile_vol = 0.0
    int poc_index = 0
    float max_abs_delta = 0.0
    
    if total_profile_volume > 0
        max_profile_vol := array.max(volume_at_price)
        poc_index := array.indexof(volume_at_price, max_profile_vol)
        for i = 0 to vp_resolution - 1
            max_abs_delta := math.max(max_abs_delta, math.abs(array.get(delta_at_price, i)))

    // 3. CALCULATE VALUE AREA (VAH / VAL) - Standard 70% Logic
    int va_high_idx = poc_index
    int va_low_idx = poc_index
    float target_va_vol = total_profile_volume * (vp_val_percent / 100.0)
    float current_va_vol = max_profile_vol // Start with POC volume
    
    // Expansion Algorithm
    // Expand up and down from POC until 70% volume is reached
    while current_va_vol < target_va_vol
        float up_vol = (va_high_idx < vp_resolution - 1) ? array.get(volume_at_price, va_high_idx + 1) : 0.0
        float down_vol = (va_low_idx > 0) ? array.get(volume_at_price, va_low_idx - 1) : 0.0
        
        // Break if we hit edges
        if up_vol == 0.0 and down_vol == 0.0
            break
            
        if up_vol >= down_vol
            current_va_vol += up_vol
            va_high_idx += 1
        else
            current_va_vol += down_vol
            va_low_idx -= 1
            
    // Convert Indices to Prices
    float poc_price = vp_low + (poc_index + 0.5) * price_step
    float vah_price = vp_low + (va_high_idx + 1) * price_step // Top of the box
    float val_price = vp_low + va_low_idx * price_step // Bottom of the box

    // 4. DRAW TABLES
    var table analysis_tbl = table.new(position.bottom_center, 3, 9, bgcolor=mitigated_box_color, border_width=0,frame_width = 1,frame_color = mitigated_color, border_color=Transparent_Color)
    if show_analysis_table
        table.clear(analysis_tbl, 0, 0)
        table.cell(analysis_tbl, 0, 0, "AOF Analysis v6.0", bgcolor=HEADER_COLOR, text_color=TEXT_COLOR, text_size=size.small)
        table.cell(analysis_tbl, 1, 0, "Bullish", bgcolor=HEADER_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        table.cell(analysis_tbl, 2, 0, "Bearish", bgcolor=HEADER_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        table.cell(analysis_tbl, 0, 1, "Delta", text_color=TEXT_COLOR, text_size=size.tiny)
        table.cell(analysis_tbl, 1, 1, "Bar Delta: " + str.tostring(current_delta, "#"), bgcolor=current_delta > 0 ? POSITIVE_COLOR : NEUTRAL_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        table.cell(analysis_tbl, 2, 1, "Cum Delta: " + f_formatNumber(cum_delta, true), bgcolor=cum_delta < 0 ? NEGATIVE_COLOR : NEUTRAL_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        table.cell(analysis_tbl, 0, 2, "Momentum", text_color=TEXT_COLOR, text_size=size.tiny)
        table.cell(analysis_tbl, 1, 2, "RSI: " + str.tostring(rsi, "#.0"), bgcolor=rsi > rsi_bull_level ? POSITIVE_COLOR : NEUTRAL_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        table.cell(analysis_tbl, 2, 2, "RSI: " + str.tostring(rsi, "#.0"), bgcolor=rsi < rsi_bear_level ? NEGATIVE_COLOR : NEUTRAL_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        table.cell(analysis_tbl, 0, 3, "Trend", text_color=TEXT_COLOR, text_size=size.tiny)
        table.cell(analysis_tbl, 1, 3, is_uptrend ? "Strong Up" : "Neutral", bgcolor=is_uptrend ? POSITIVE_COLOR : NEUTRAL_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        table.cell(analysis_tbl, 2, 3, is_downtrend ? "Strong Down" : "Neutral", bgcolor=is_downtrend ? NEGATIVE_COLOR : NEUTRAL_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        table.cell(analysis_tbl, 0, 4, "Key Levels", text_color=TEXT_COLOR, text_size=size.tiny)
        table.cell(analysis_tbl, 1, 4, "Price > VWAP", bgcolor=close > vwap_val ? POSITIVE_COLOR : NEUTRAL_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        table.cell(analysis_tbl, 2, 4, "Price < POC", bgcolor=not na(poc_price) and close < poc_price ? NEGATIVE_COLOR : NEUTRAL_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        bool longSignal = current_delta > 0 and rsi > rsi_bull_level and close > vwap_val and is_uptrend
        bool shortSignal = current_delta < 0 and rsi < rsi_bear_level and close < vwap_val and is_downtrend
        table.cell(analysis_tbl, 0, 6, "Entry Signal", text_color=TEXT_COLOR, text_size=size.small)
        table.cell(analysis_tbl, 1, 6, longSignal ? "✓ Long" : "✗", bgcolor=longSignal ? color.new(POSITIVE_COLOR, 0) : NEUTRAL_COLOR, text_size=size.small, text_color=TEXT_COLOR)
        table.cell(analysis_tbl, 2, 6, shortSignal ? "✓ Short" : "✗", bgcolor=shortSignal ? color.new(NEGATIVE_COLOR, 0) : NEUTRAL_COLOR, text_size=size.small, text_color=TEXT_COLOR)

    var table ladder_tbl = table.new(position.top_right, 4, vp_resolution + 1, bgcolor=dark, border_width=1, border_color=Transparent_Color,frame_color = mitigated_color,frame_width = 1)
    if show_volume_ladder and total_profile_volume > 0
        table.clear(ladder_tbl, 0, 0)
        table.cell(ladder_tbl, 0, 0, "Sell | Buy", bgcolor=HEADER_COLOR, text_color=TEXT_COLOR, text_size=size.tiny)
        table.cell(ladder_tbl, 1, 0, "Total Vol", bgcolor=HEADER_COLOR, text_color=TEXT_COLOR, text_size=size.tiny)
        table.cell(ladder_tbl, 2, 0, "Delta", bgcolor=HEADER_COLOR, text_color=TEXT_COLOR, text_size=size.tiny)
        table.cell(ladder_tbl, 3, 0, "Price", bgcolor=HEADER_COLOR, text_color=TEXT_COLOR, text_size=size.tiny)
        float avg_profile_vol = array.avg(volume_at_price)
        for i = 0 to vp_resolution - 1
            int row = vp_resolution - i
            float level_price = vp_low + i * price_step
            float level_vol = array.get(volume_at_price, i)
            float level_delta = array.get(delta_at_price, i)
            float level_buy_vol = (level_vol + level_delta) / 2
            float level_sell_vol = level_vol - level_buy_vol
            color row_bgcolor = color.new(mitigated_color,80)
            if i == poc_index
                row_bgcolor := color.new(POC_COLOR_BG,40)
            else if level_vol > avg_profile_vol * vp_hvn_threshold
                row_bgcolor := color.new(NEUTRAL_COLOR, 30)
            else if i >= va_low_idx and i <= va_high_idx
                row_bgcolor := color.new(mitigated_color, 65) // Slightly lighter for Value Area
                
            string sell_buy_str = f_formatNumber(level_sell_vol) + " | " + f_formatNumber(level_buy_vol)
            table.cell(ladder_tbl, 0, row, sell_buy_str, bgcolor=row_bgcolor, text_color=TEXT_COLOR, text_size=size.tiny)
            table.cell(ladder_tbl, 1, row, f_formatNumber(level_vol), bgcolor=row_bgcolor, text_color=TEXT_COLOR, text_size=size.tiny)
            color base_delta_color = level_delta >= 0 ? POSITIVE_COLOR : NEGATIVE_COLOR
            color delta_bgcolor = f_gradientColor(base_delta_color, level_delta, max_abs_delta)
            if (level_buy_vol > level_sell_vol * vp_imbalance_threshold and level_sell_vol > 0) or (level_sell_vol > level_buy_vol * vp_imbalance_threshold and level_buy_vol > 0)
                delta_bgcolor := color.new(base_delta_color, 0)
            table.cell(ladder_tbl, 2, row, f_formatNumber(level_delta, true), bgcolor=delta_bgcolor, text_color=TEXT_COLOR, text_size=size.tiny)
            table.cell(ladder_tbl, 3, row, str.tostring(level_price, format.mintick), bgcolor=row_bgcolor, text_color=TEXT_COLOR, text_size=size.tiny)

    // 5. DRAW HISTOGRAM & LINES
    if show_vp_histogram and price_range > 0
        float avg_profile_vol = array.avg(volume_at_price)
        int profile_start_x = bar_index + 62
        int max_profile_width = 58
        int start_bar_for_drawing = vp_mode == "Recent Bars" ? bar_index - vp_period + 1 : bar_index - ta.barssince(time >= vp_startTime)
        
        // Frame Box
        box bvp = box.new(start_bar_for_drawing, vp_high, bar_index + 60, vp_low,
             border_color=mitigated_color, border_style=line.style_dashed, border_width=2,
             bgcolor=Transparent_Color, extend=extend.none)
        array.push(vp_boxes, bvp)

        for i = 0 to vp_resolution - 1
            float level_price = vp_low + i * price_step
            float next_level_price = level_price + price_step
            float level_vol = array.get(volume_at_price, i)
            float level_delta = array.get(delta_at_price, i)
            if level_vol > 0
                color base_color = level_delta >= 0 ? POSITIVE_COLOR : NEGATIVE_COLOR
                color gradient_color = f_gradientColor(base_color, level_vol, max_profile_vol)
                int box_width = math.round(level_vol / max_profile_vol * max_profile_width)
                
                // Color different for VA vs Non-VA
                if i < va_low_idx or i > va_high_idx
                    gradient_color := color.new(gradient_color, 60) // Fade out non-VA

                // Histogram Bar
                box bv1 = box.new(profile_start_x, next_level_price, profile_start_x + box_width, level_price, bgcolor=gradient_color, border_color=gradient_color)
                array.push(vp_boxes, bv1)

        // 6. DRAW POC / VAH / VAL LINES & LABELS
        if not na(poc_price)
            // POC
            line lpoc = line.new(start_bar_for_drawing, poc_price, bar_index + 65, poc_price, color=POC_COLOR_LINE, style=line.style_solid, width=2)
            array.push(vp_lines, lpoc)
            if show_vp_labels
                label lb_poc = label.new(bar_index + 65, poc_price, "POC\n" + str.tostring(poc_price, format.mintick), color=color.new(col_poc, 100), textcolor=col_poc, style=label.style_label_left, size=size.tiny)
                array.push(vp_labels, lb_poc)

            // VAH
            line lvah = line.new(start_bar_for_drawing, vah_price, bar_index + 65, vah_price, color=VAH_COLOR_LINE, style=line.style_dashed, width=1)
            array.push(vp_lines, lvah)
            if show_vp_labels
                label lb_vah = label.new(bar_index + 65, vah_price, "VAH\n" + str.tostring(vah_price, format.mintick), color=color.new(col_bull, 100), textcolor=col_bull, style=label.style_label_left, size=size.tiny)
                array.push(vp_labels, lb_vah)
            
            // VAL
            line lval = line.new(start_bar_for_drawing, val_price, bar_index + 65, val_price, color=VAL_COLOR_LINE, style=line.style_dashed, width=1)
            array.push(vp_lines, lval)
            if show_vp_labels
                label lb_val = label.new(bar_index + 65, val_price, "VAL\n" + str.tostring(val_price, format.mintick), color=color.new(col_bear, 100), textcolor=col_bear, style=label.style_label_left, size=size.tiny)
                array.push(vp_labels, lb_val)

        // 7. HVN AND LVN RE-INTEGRATED AS RE-PROCESSED LINES (NOT SUPPLY/DEMAND BLOCKS)
        if show_lvn_hvn and total_profile_volume > 0 and price_range > 0
            float avg_profile_vol = array.avg(volume_at_price)
            float threshold_lvn = max_profile_vol * vp_lvn_threshold

            for i = 1 to vp_resolution - 2
                float v_prev = array.get(volume_at_price, i - 1)
                float v_curr = array.get(volume_at_price, i)
                float v_next = array.get(volume_at_price, i + 1)
                float level_price = vp_low + (i + 0.5) * price_step

                // HVN detection (Local Maxima above threshold multiplier of average volume)
                if v_curr > v_prev and v_curr > v_next and v_curr > avg_profile_vol * vp_hvn_threshold
                    line lhvn = line.new(start_bar_for_drawing, level_price, bar_index + 65, level_price, color=color.new(col_bull, 40), style=line.style_solid, width=1)
                    array.push(vp_lines, lhvn)
                    if show_vp_labels
                        label lb_hvn = label.new(bar_index + 65, level_price, "HVN: " + str.tostring(level_price, format.mintick), color=color.new(col_bull, 100), textcolor=col_bull, style=label.style_label_left, size=size.tiny)
                        array.push(vp_labels, lb_hvn)

                // LVN detection (Local Minima below threshold volume)
                if v_curr < v_prev and v_curr < v_next and v_curr < threshold_lvn
                    line llvn = line.new(start_bar_for_drawing, level_price, bar_index + 65, level_price, color=color.new(col_bear, 40), style=line.style_dashed, width=1)
                    array.push(vp_lines, llvn)
                    if show_vp_labels
                        label lb_lvn = label.new(bar_index + 65, level_price, "LVN: " + str.tostring(level_price, format.mintick), color=color.new(col_bear, 100), textcolor=col_bear, style=label.style_label_left, size=size.tiny)
                        array.push(vp_labels, lb_lvn)

// ===== Plotting Basic Alerts on Every Bar =====
bool strong_buy_pressure = current_delta > 0 and current_sell_vol > 0 and (current_buy_vol / current_sell_vol) > 2
bool strong_sell_pressure = current_delta < 0 and current_buy_vol > 0 and (current_sell_vol / current_buy_vol) > 2
plotshape(strong_buy_pressure, title="Strong Buying Pressure", location=location.belowbar, color=POSITIVE_COLOR, style=shape.triangleup, size=size.tiny)
plotshape(strong_sell_pressure, title="Strong Selling Pressure", location=location.abovebar, color=NEGATIVE_COLOR, style=shape.triangledown, size=size.tiny)

//════════════════════════════════════
// LOGO (UNTOUCHED AND PROFESSIONAL)
//════════════════════════════════════
LG_Line_Widthb = 2
periodb = 70
col_logo        = close > open ? col_bull: close < open ? col_bear : mitigated_color
lowest1b = ta.lowest(low, periodb)
lowest2b = ta.lowest(low, periodb - 1)
lowest3b = ta.lowest(low, periodb - 2)
lowest4b = ta.lowest(low, periodb - 3) 
point1b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.99
point2b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.994
point3b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.9915
point4b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.9955
point5b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.986
point6b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.99
point7b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.9975
point8b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.997
point9b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.99
point1b0 = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.988
