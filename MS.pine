var array<bool> up_fvg_mit_ifvgHtf = array.new_bool(0)

//═══════════════════════════════════════════════════════════════════════════════
// GET INFORMATION A CANDLE
//═══════════════════════════════════════════════════════════════════════════════
//===> HTF (Tambahkan 'volume' di request)
[htf_O,htf_O1,htf_O2,htf_O3, htf_H,htf_H1,htf_H2,htf_H3, htf_L,htf_L1,htf_L2,htf_L3, htf_C,htf_C1,htf_C2,htf_C3, htf_Vol_value, htf_HH_value, htf_LW_value, htf_last_bear_H, htf_last_bear_L, htf_last_bull_H, htf_last_bull_L] = request.security(syminfo.tickerid, htf_str, [open,open[1],open[2],open[3], high,high[1],high[2],high[3], low,low[1],low[2],low[3], close,close[1],close[2],close[3], volume, ta.highest(high,5), ta.lowest(low,5), ta.valuewhen(close < open, high, 0), ta.valuewhen(close < open, low, 0), ta.valuewhen(close > open, high, 0), ta.valuewhen(close > open, low, 0)], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
//===> LTF (Tambahkan 'volume' di request)
[ltf_O,ltf_O1,ltf_O2,ltf_O3, ltf_H,ltf_H1,ltf_H2,ltf_H3, ltf_L,ltf_L1,ltf_L2,ltf_L3, ltf_C,ltf_C1,ltf_C2,ltf_C3, ltf_Vol_value, ltf_HH_value, ltf_LW_value, ltf_last_bear_H, ltf_last_bear_L, ltf_last_bull_H, ltf_last_bull_L] = request.security(syminfo.tickerid, ltf_in, [open,open[1],open[2],open[3], high,high[1],high[2],high[3], low,low[1],low[2],low[3], close,close[1],close[2],close[3], volume, ta.highest(high,5), ta.lowest(low,5), ta.valuewhen(close < open, high, 0), ta.valuewhen(close < open, low, 0), ta.valuewhen(close > open, high, 0), ta.valuewhen(close > open, low, 0)], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
//═══════════════════════════════════════════════════════════════════════════════
// CONDITIONS (FIXED)
//═══════════════════════════════════════════════════════════════════════════════
// FUNCTION: Format Text Info (Volatility, Volume, Delta)
get_info_text(vol, high_val, low_val, is_bull) =>
    float range_val = high_val - low_val
    string vol_str = str.tostring(vol, format.volume)
    string delta_str = is_bull ? "+" + vol_str : "-" + vol_str
    string vol_info ="\n═════════════" + "\n〣 Vol: " + vol_str + "\n▲ Delta: " + delta_str + "\nϟ Range: " + str.tostring(range_val, format.mintick) + "\n═════════════"
    vol_info
bool isNewHtfBar = ta.change(htf_O) != 0
var int[] htf_bar_starts = array.new_int()
if isNewHtfBar
    array.push(htf_bar_starts, bar_index)
    if array.size(htf_bar_starts) > 50
        array.shift(htf_bar_starts)

// Candle Condition
// ===> HTF (FIXED: Menggunakan variabel explicit dari request.security)
bool htf_bull_0 = htf_C > htf_O
bool htf_bear_0 = htf_C < htf_O
bool htf_bull_1 = htf_C1 > htf_O1
bool htf_bear_1 = htf_C1 < htf_O1
bool htf_bull_2 = htf_C2 > htf_O2
bool htf_bear_2 = htf_C2 < htf_O2
bool htf_bull_3 = htf_C3 > htf_O3
bool htf_bear_3 = htf_C3 < htf_O3
// ===> LTF (Tetap menggunakan logic original karena ini timeframe chart)
bool ltf_candle_bull = ltf_C > ltf_O
bool ltf_candle_bear = ltf_C < ltf_O
// Supply Demand And MS Condition
//===> HTF LTF SND FILTER MUNCUL BERKALI KALI 
bool htf_supply_fltr = (htf_C1 > htf_L2)
bool htf_demand_fltr = (htf_C1 < htf_H2)
bool ltf_supply_fltr = (ltf_C2 > ltf_L3)
bool ltf_demand_fltr = (ltf_C2 < ltf_H3)
//===> LOGIC 1/2 BODY CALCULATION
// HTF: Titik tengah body candle saat ini
htf_body_mid = (htf_O + htf_C) / 2
// LTF
ltf_body_mid = (ltf_O1 + ltf_C1) / 2
// Filter Logic: Jika filter ON, cek 1/2 body < Low[1]. Jika OFF, abaikan (true).
htf_supply_filter_ok = use_snd_mid_filter ? (htf_body_mid < htf_L1) : true
htf_demand_filter_ok = use_snd_mid_filter ? (htf_body_mid > htf_H1) : true
ltf_supply_filter_ok = use_snd_mid_filter ? (ltf_body_mid < ltf_L2) : true
ltf_demand_filter_ok = use_snd_mid_filter ? (ltf_body_mid > ltf_H2) : true

//===> HTF SND
bool htf_supply_cond = htf_supply_fltr and (htf_C < htf_last_bull_L) and htf_supply_filter_ok and htf_bear_0
bool htf_demand_cond = htf_demand_fltr and (htf_C > htf_last_bear_H) and htf_demand_filter_ok and htf_bull_0
//===> LTF SND
bool ltf_supply_cond = ta.crossunder(ltf_C1 , ltf_last_bull_L[1]) and ltf_supply_filter_ok and ltf_candle_bear[1]
bool ltf_demand_cond = ta.crossover(ltf_C1 , ltf_last_bear_H[1]) and ltf_demand_filter_ok and ltf_candle_bull[1]

// FVG Condition
//===> LTF FVG
bool down_fvg_condLtf = ltf_L3 > ltf_H1
bool up_fvg_condLtf = ltf_H3 < ltf_L1
//======> Detect Line Down And Up FVG with Enhanced Filtering Ltf
current_priceLtf = ltf_C
pct_thresholdLtf = current_priceLtf * gap_threshold
gap_size_down_fvgLtf = ltf_L3 - ltf_H1
gap_size_up_fvgLtf = ltf_L1 - ltf_H3
down_fvg_midpointLtf = (ltf_L3 + ltf_H1) / 2
up_fvg_midpointLtf = (ltf_L1 + ltf_H3) / 2
//===> HTF FVG 
bool down_fvg_condHtf = htf_L2 > htf_H
bool up_fvg_condHtf = htf_H2 < htf_L
//======> Detect Line Down And Up FVG with Enhanced Filtering Htf
current_priceHtf = htf_C
pct_thresholdHtf = current_priceHtf * gap_threshold
gap_size_down_fvgHtf = htf_L2 - htf_H
gap_size_up_fvgHtf = htf_L - htf_H2
down_fvg_midpointHtf = (htf_L2 + htf_H) / 2
up_fvg_midpointHtf = (htf_L + htf_H2) / 2
//═══════════════════════════════════════════════════════════════════════════════
// OPTIMIZED DRAWING ASSETS & LOGIC
//═══════════════════════════════════════════════════════════════════════════════
// --- 1. Global Calculation & Safety Checks ---
// FIX: Gunakan fungsi f_str_to_minutes agar support timeframe D/W/M
float ltf_val_float = float(f_str_to_minutes(ltf_in))
// Safety check jika hasil 0 (mencegah pembagian dengan nol)
ltf_val_float := ltf_val_float <= 0 ? 1.0 : ltf_val_float

// Kalkulasi Multiplier dengan batasan min 1
int multiplier = math.max(1, int(minutes_val / ltf_val_float - 1))

// Kalkulasi Index yang aman (mencegah error 'negative index')
// Menggunakan math.max untuk memastikan index tidak kurang dari 0
int htf_first_bar       = array.size(htf_bar_starts) >= 2 ? array.get(htf_bar_starts, array.size(htf_bar_starts) - 2) : bar_index
int htf_first_FVG       = array.size(htf_bar_starts) >= 3 ? array.get(htf_bar_starts, array.size(htf_bar_starts) - 3) : bar_index
int ltf_first_bar       = math.max(0, bar_index >= 2 ? bar_index[2] : bar_index)

// Right Margin Offset Constants
OFF_ZONES    = 10
OFF_BREAKERS = 25
OFF_EQ       = 40
OFF_HL_AUTO  = 55
OFF_PD       = 80
OFF_LOGO     = 130

int target_right_bar    = last_bar_index + OFF_ZONES // Extend ke masa depan

//═══════════════════════════════════════════════════════════════════════════════
// HELPER FUNCTIONS (MODULAR SYSTEM)
//═══════════════════════════════════════════════════════════════════════════════

// Fungsi tunggal untuk menangani Supply & Demand (HTF & LTF)
// Ini menggantikan 4 fungsi terpisah yang Anda miliki sebelumnya.
f_draw_snd_block(bool _is_supply, bool _is_htf, bool _cond, float _top, float _btm, float _vol, float _trigger_high, float _trigger_low) =>
    if _cond
        // Tentukan atribut berdasarkan Supply/Demand dan HTF/LTF
        string _type_txt    = _is_supply ? "SUPPLY" : "DEMAND"
        string _tf_txt      = _is_htf ? "HTF" : "LTF"
        string _symbol      = _is_supply ? "▼" : "▲"
        string _ms_sym     = _is_htf ? "●" : "〇"
        
        // Warna dinamis
        color _bg_col       = _is_supply ? box_col_bear : box_col_bull
        color _main_col     = _is_supply ? col_bear : col_bull
        
        // Logika seleksi warna (simplified ternary logic)
        bool _is_selected   = _is_htf ? htf_snd_created_selected : ltf_snd_created_selected
        // Cek kompleksitas warna teks
        bool _show_txt_col  = (_is_htf and htf_snd_created_selected) or (not _is_htf and ((htf_snd_created_selected or htf_snd_mitigated_selected or htf_fvg_mitigated_selected) and ltf_snd_created_selected))
        
        color _final_bg     = _is_selected ? _bg_col : Transparent_Color
        color _final_txt    = _show_txt_col ? _main_col : (_is_selected ? _main_col : Transparent_Color)
        color _final_border = Transparent_Color

        // Koordinat X
        int _x1 = _is_htf ? (htf_first_bar - multiplier) : ltf_first_bar
        
        // Info Text
        string _info = get_info_text(_vol, _trigger_high, _trigger_low, not _is_supply) // Asumsi fungsi get_info_text ada
        string _full_text = (showms == 'Symbol' ? (_symbol + " " + _tf_txt) : (_tf_txt + " " + _type_txt + " ⦿ " + _info ))
        
        // Posisi Teks
        string _valign = _is_supply ? text.align_top : text.align_bottom

        // --- DRAWING ---
        // 1. Box
        box _b = box.new(_x1, _top, last_bar_index + OFF_ZONES, _btm, 
             text = _full_text, 
             text_size = size.tiny, 
             text_valign = _valign, 
             text_halign = text.align_right, 
             bgcolor = _final_bg, 
             text_color = _final_txt, 
             border_color = _final_border, 
             border_width = 0)
        
        // 2. MS Line
        float _line_y = _is_supply ? _top : _btm // Supply line di High, Demand di Low (biasanya untuk break)
        // Perbaiki logika Y line sesuai kebutuhan (Supply biasanya HH, Demand LL untuk struktur)
        float _draw_y = _is_supply ? _trigger_high : _trigger_low 
        
        line _l = line.new(_x1, _draw_y, last_bar_index + OFF_ZONES, _draw_y, 
             color = _is_selected ? _main_col : Transparent_Color, 
             style = _is_htf ? line.style_solid : line.style_dotted, 
             width = 1)
             
        // 3. Label MSB/MSC
        label _lbl = label.new(_x1, _draw_y, 
             text = showms == 'Symbol' ? _ms_sym : (_tf_txt + " MS " + _ms_sym),
             size = _is_htf ? size.tiny : size.tiny, 
             yloc = yloc.price, 
             textcolor = Transparent_Color, 
             color = _is_selected ? _main_col : Transparent_Color, 
             style = label.style_none)

        // --- ARRAY MANAGEMENT ---
        // Push ke array yang sesuai (Pointer Reference)
        // Catatan: Karena variable array global, kita harus if/else push manual di luar atau passing array id.
        // Untuk efisiensi kode di sini, saya return objectnya, push dilakukan saat pemanggilan.
        [_b, _l, _lbl]
    else
        [box(na), line(na), label(na)]

// Fungsi Universal FVG (FLEXIBLE FIX)
f_draw_fvg_block(bool _is_up, bool _is_htf, bool _cond, float _p1, float _p2, float _mid, float _gap_size) =>
    // Auto-Sort: Tentukan mana yang lebih tinggi (Top) dan rendah (Bot) secara otomatis
    float _top = math.max(_p1, _p2)
    float _btm = math.min(_p1, _p2)
    
    // Validasi Gap: Pastikan Gap > 0 (Top tidak sama dengan Bot)
    if _top > _btm and _cond
        bool _is_selected = _is_htf ? htf_fvg_mitigated_selected : ltf_fvg_mitigated_selected
        // Check threshold
        bool _valid_size = _is_htf ? true : (_gap_size >= pct_thresholdLtf)
        
        if _valid_size and _is_selected
            string _tf_txt = _is_htf ? "HTF" : "LTF"
            string _dir_sym = _is_up ? "▲" : "▼"
            color _col = _is_up ? col_bull : col_bear
            color _bg_col = _is_up ? box_col_bull : box_col_bear
            
            // Logic Warna
            bool _complex_color_logic = (htf_fvg_mitigated_selected or htf_snd_created_selected or htf_snd_mitigated_selected) and _is_selected
            color _txt_col = _is_htf ? (_is_selected ? _col : Transparent_Color) : (_complex_color_logic ? _col : (_is_selected ? _col : Transparent_Color))

            // Koordinat X
            int _x1 = _is_htf ? htf_first_FVG : bar_index[2]
            if _x1 < 0 
                _x1 := bar_index
            
            // Draw Box dengan koordinat yang sudah diurutkan (_top, _btm)
            box _b = box.new(_x1, _top, last_bar_index + OFF_ZONES, _btm, 
                 text = showms == 'Symbol' ? _tf_txt + " FVG" + _dir_sym : _dir_sym + " " + _tf_txt + " FVG\n═══════\n[" + str.tostring(_gap_size, format.mintick) + "]\n═══════", 
                 text_size = size.tiny, 
                 text_valign = text.align_center, 
                 text_halign = text.align_right, 
                 bgcolor = _is_selected ? _bg_col : Transparent_Color, 
                 text_color = _txt_col, 
                 border_color = Transparent_Color, 
                 border_width = 1)
                 
            line _l = line.new(_is_htf ? _x1 : bar_index[1], _mid, last_bar_index + OFF_ZONES, _mid, 
                 color = _col, width = 1, style = _is_htf ? line.style_dashed : line.style_dotted)
                 
            [_b, _l]
        else
            [box(na), line(na)]
    else
        [box(na), line(na)]

//═══════════════════════════════════════════════════════════════════════════════
// EXECUTION LOGIC
//═══════════════════════════════════════════════════════════════════════════════

// --- 1. Structure Candle Data ---
// Menggunakan tuple dan array push langsung untuk efisiensi baris
if ltf_candle_bull
    array.push(lastCandleBullishOpenLtf, ltf_O1), array.push(lastCandleBullishHighLtf, ltf_H1)
    array.push(lastCandleBullishLowLtf, ltf_L1), array.push(lastCandleBullishCloseLtf, ltf_C1)
if ltf_candle_bear
    array.push(lastCandleBearishOpenLtf, ltf_O1), array.push(lastCandleBearishHighLtf, ltf_H1)
    array.push(lastCandleBearishLowLtf, ltf_L1), array.push(lastCandleBearishCloseLtf, ltf_C1)

if htf_bull_0 
    array.push(lastCandleBullishOpenHtf, htf_O1), array.push(lastCandleBullishHighHtf, htf_H1)
    array.push(lastCandleBullishLowHtf, htf_L1), array.push(lastCandleBullishCloseHtf, htf_C1)
if htf_bear_0
    array.push(lastCandleBearishOpenHtf, htf_O1), array.push(lastCandleBearishHighHtf, htf_H1)
    array.push(lastCandleBearishLowHtf, htf_L1), array.push(lastCandleBearishCloseHtf, htf_C1)


// --- 2. SND Execution (HTF) ---
// Supply HTF
if isNewHtfBar
    // HTF Supply
    [b_hs, l_hs, lb_hs] = f_draw_snd_block(true, true, htf_supply_cond, htf_HH_value, htf_last_bull_L, htf_Vol_value, htf_HH_value, htf_last_bull_L)
    if not na(b_hs)
        array.push(htf_supply_high, htf_HH_value), array.push(htf_supply_low, htf_last_bull_L)
        array.push(htf_supply_mitigated, false), array.push(htf_ms_bull_breakout, false)
        array.push(htf_supply_box, b_hs), array.push(htf_ms_bull_line, l_hs), array.push(htf_ms_bull_label, lb_hs)

    // HTF Demand
    [b_hd, l_hd, lb_hd] = f_draw_snd_block(false, true, htf_demand_cond, htf_last_bear_H, htf_LW_value, htf_Vol_value, htf_last_bear_H, htf_LW_value)
    if not na(b_hd)
        array.push(htf_demand_high, htf_last_bear_H), array.push(htf_demand_low, htf_LW_value)
        array.push(htf_demand_mitigated, false), array.push(htf_ms_bear_breakout, false)
        array.push(htf_demand_box, b_hd), array.push(htf_ms_bear_line, l_hd), array.push(htf_ms_bear_label, lb_hd)


// --- 3. SND Execution (LTF) ---
// LTF Supply
[b_ls, l_ls, lb_ls] = f_draw_snd_block(true, false, ltf_supply_cond, ltf_HH_value, ltf_last_bull_L[1], ltf_Vol_value[1], ltf_HH_value, ltf_last_bull_L[1])
if not na(b_ls)
    array.push(ltf_supply_high, ltf_HH_value), array.push(ltf_supply_low, ltf_last_bull_L[1])
    array.push(ltf_supply_mitigated, false), array.push(ltf_ms_bull_breakout, false)
    array.push(ltf_supply_box, b_ls), array.push(ltf_ms_bull_line, l_ls), array.push(ltf_ms_bull_label, lb_ls)

// LTF Demand
[b_ld, l_ld, lb_ld] = f_draw_snd_block(false, false, ltf_demand_cond, ltf_last_bear_H[1], ltf_LW_value, ltf_Vol_value[1], ltf_last_bear_H[1], ltf_LW_value)
if not na(b_ld)
    array.push(ltf_demand_high, ltf_last_bear_H[1]), array.push(ltf_demand_low, ltf_LW_value)
    array.push(ltf_demand_mitigated, false), array.push(ltf_ms_bear_breakout, false)
    array.push(ltf_demand_box, b_ld), array.push(ltf_ms_bear_line, l_ld), array.push(ltf_ms_bear_label, lb_ld)

// --- 4. FVG Execution (AUTO-SORTED ARRAYS) ---
// LTF Down FVG
[b_lfd, l_lfd] = f_draw_fvg_block(false, false, down_fvg_condLtf, ltf_L3, ltf_H1, down_fvg_midpointLtf, gap_size_down_fvgLtf)
if not na(b_lfd)
    // Push Max ke Highs, Min ke Lows (Biar mitigasi akurat)
    array.push(down_fvg_highsLtf, math.max(ltf_L3, ltf_H1))
    array.push(down_fvg_lowsLtf, math.min(ltf_L3, ltf_H1))
    array.push(down_fvg_mitigatedLtf, false)
    array.push(down_fvg_boxLtf, b_lfd), array.push(down_fvg_midle_linesLtf, l_lfd)

// LTF Up FVG
[b_lfu, l_lfu] = f_draw_fvg_block(true, false, up_fvg_condLtf, ltf_L1, ltf_H3, up_fvg_midpointLtf, gap_size_up_fvgLtf)
if not na(b_lfu)
    array.push(up_fvg_highsLtf, math.max(ltf_L1, ltf_H3))
    array.push(up_fvg_lowsLtf, math.min(ltf_L1, ltf_H3))
    array.push(up_fvg_mitigatedLtf, false)
    array.push(up_fvg_boxLtf, b_lfu), array.push(up_fvg_midle_linesLtf, l_lfu)

// HTF FVG (Only on New Bar)
if isNewHtfBar
    // HTF Down (Bearish)
    [b_hfd, l_hfd] = f_draw_fvg_block(false, true, down_fvg_condHtf, htf_L2, htf_H, down_fvg_midpointHtf, gap_size_down_fvgHtf)
    if not na(b_hfd)
        // Gunakan Math.max/min saat push ke array agar konsisten
        array.push(down_fvg_highsHtf, math.max(htf_L2, htf_H))
        array.push(down_fvg_lowsHtf, math.min(htf_L2, htf_H))
        array.push(down_fvg_mitigatedHtf, false)
        array.push(down_fvg_boxHtf, b_hfd), array.push(down_fvg_midle_linesHtf, l_hfd)

    // HTF Up (Bullish) - Ini yang tadi bermasalah
    [b_hfu, l_hfu] = f_draw_fvg_block(true, true, up_fvg_condHtf, htf_L, htf_H2, up_fvg_midpointHtf, gap_size_up_fvgHtf)
    if not na(b_hfu)
        // Gunakan Math.max/min saat push ke array agar konsisten
        array.push(up_fvg_highsHtf, math.max(htf_L, htf_H2))
        array.push(up_fvg_lowsHtf, math.min(htf_L, htf_H2))
        array.push(up_fvg_mitigatedHtf, false)
        array.push(up_fvg_boxHtf, b_hfu), array.push(up_fvg_midle_linesHtf, l_hfu)
//═══════════════════════════════════════════════════════════════════════════════
// 1. OPTIMIZED LOGIC HELPER FUNCTIONS (CORRECTED)
//═══════════════════════════════════════════════════════════════════════════════

// A. Universal PD Array (Premium/Discount) Updater
// FIX: Menambahkan argumen '_target_idx' untuk menggantikan 'last_bar'
f_update_pd_zones(bool _show, float[] _arr_high, float[] _arr_low, line _mid_line, box _prem_box, box _disc_box, label _l_top, label _l_mid, label _l_bot, string _tf_txt, int _target_idx) =>
    if _show and array.size(_arr_high) > 0 and array.size(_arr_low) > 0
        float _h = array.get(_arr_high, array.size(_arr_high) - 1)
        float _l = array.get(_arr_low, array.size(_arr_low) - 1)
        float _eq = (_h + _l) / 2
        
        int _start = _target_idx - 15 // Mundur sedikit dari target kanan
        int _end   = _target_idx

        // Update Visuals
        // Pastikan objek tidak NA sebelum di-set
        if not na(_mid_line)
            line.set_xy1(_mid_line, _start, _eq), line.set_xy2(_mid_line, _end, _eq)
        if not na(_prem_box)
            box.set_lefttop(_prem_box, _start, _h), box.set_rightbottom(_prem_box, _end, _eq)
            box.set_bgcolor(_prem_box, color.new(col_bear, 80))
        if not na(_disc_box)
            box.set_lefttop(_disc_box, _start, _eq), box.set_rightbottom(_disc_box, _end, _l)
            box.set_bgcolor(_disc_box, color.new(col_bull, 80))
        if not na(_l_top)
            label.set_xy(_l_top, _end , _h), label.set_text(_l_top, _tf_txt + " PREMIUM (1)")
        if not na(_l_mid)
            label.set_xy(_l_mid, _end , _eq), label.set_text(_l_mid, _tf_txt + " EQ (0.5)")
        if not na(_l_bot)
            label.set_xy(_l_bot, _end , _l), label.set_text(_l_bot, _tf_txt + " DISCOUNT (0)")

// B. Universal SND Mitigation
f_mitigate_snd_universal(bool _is_supply, bool _is_htf, float[] _levels, bool[] _mit_status, box[] _boxes, line[] _lines, float _price_trigger) =>
    if array.size(_levels) > 0
        for i = 0 to array.size(_levels) - 1
            if not array.get(_mit_status, i)
                bool _mitigated = _is_supply ? (_price_trigger > array.get(_levels, i)) : (_price_trigger < array.get(_levels, i))
                if _mitigated
                    array.set(_mit_status, i, true)
                    string _tf_str = _is_htf ? "HTF" : "LTF"
                    string _dir_str = _is_supply ? "▼" : "▲"
                    string _type_str = _is_supply ? "SUPPLY" : "DEMAND"
                    bool _is_sel_mit = _is_htf ? htf_snd_mitigated_selected : ltf_snd_mitigated_selected
                    bool _complex_col = (not _is_htf) and ((htf_fvg_mitigated_selected or htf_snd_created_selected or htf_snd_mitigated_selected) and ltf_snd_mitigated_selected)
                    color _c_bg = _is_sel_mit ? mitigated_box_color : Transparent_Color
                    color _c_txt = _complex_col ? mitigated_box_color : (_is_sel_mit ? mitigated_color : Transparent_Color)
                    color _c_line = _is_sel_mit ? (_is_supply ? col_bear : col_bull) : Transparent_Color 
                    
                    box _b = array.get(_boxes, i)
                    box.set_text(_b, showms == 'Symbol' ? (_tf_str + " " + _dir_str + "  ") : (_tf_str + " " + _type_str + "    "))
                    box.set_text_size(_b, size.tiny)
                    box.set_right(_b, bar_index)
                    box.set_bgcolor(_b, _c_bg)
                    box.set_text_color(_b, _c_txt)
                    
                    line _l = array.get(_lines, i)
                    line.set_x2(_l, bar_index)
                    line.set_color(_l, _c_line)

// C. Universal FVG Mitigation
f_mitigate_fvg_universal(bool _is_up, bool _is_htf, float[] _highs, float[] _lows, bool[] _mits, box[] _boxes, line[] _midlines, float _price_trigger) =>
    if array.size(_highs) > 0
        for i = 0 to array.size(_highs) - 1
            if not array.get(_mits, i)
                float _h = array.get(_highs, i)
                float _l = array.get(_lows, i)
                bool _mitigated = _is_up ? (_price_trigger <= _h) : (_price_trigger >= _l)
                if _mitigated
                    array.set(_mits, i, true)
                    float _gap = _h - _l
                    string _size_txt = "\n[" + str.tostring(_gap, format.mintick) + "]"
                    string _tf_str = _is_htf ? "HTF" : "LTF"
                    string _sym = _is_up ? "▲" : "▼"
                    bool _is_sel = _is_htf ? htf_fvg_mitigated_selected : ltf_fvg_mitigated_selected
                    color _c_bg = _is_sel ? mitigated_box_color : Transparent_Color
                    color _c_main = _is_sel ? mitigated_color : Transparent_Color
                    
                    box _b = array.get(_boxes, i)
                    box.set_text(_b,showms == 'Symbol' ? _sym + _tf_str + " FVG" : _sym + " " + _tf_str + (_is_htf ? "" : " FVG") + "\n═══════" + _size_txt + "\n═══════")
                    box.set_right(_b, bar_index)
                    box.set_bgcolor(_b, _c_bg)
                    box.set_text_color(_b, _c_main)
                    
                    line _l = array.get(_midlines, i)
                    line.set_x2(_l, bar_index)
                    line.set_color(_l, _c_main)

// D. Management Breaker Function (RE-ADDED)
manage_breakers(line[] _lns, label[] _lbls, float[] _lvls, bool[] _is_bulls, bool[] _mits, int[] _cr_ats, bool _show, string _tf_txt) =>
    if _show and array.size(_lns) > 0
        for i = array.size(_lns) - 1 to 0
            line l = array.get(_lns, i)
            label lb = array.get(_lbls, i)
            float lvl = array.get(_lvls, i)
            bool is_bull = array.get(_is_bulls, i)
            bool is_mit = array.get(_mits, i)
            int created_at_idx = array.get(_cr_ats, i)
            
            if not is_mit
                if bar_index > created_at_idx
                    bool mitigated = false
                    if is_bull and low <= lvl
                        mitigated := true
                    if not is_bull and high >= lvl
                        mitigated := true      
                    
                    if mitigated
                        array.set(_mits, i, true)             
                        string type_txt = is_bull ? "▲" : "▼"             
                        label.set_text(lb, _tf_txt + " " + type_txt + "\n❒ " + "")            
                        label.set_textcolor(lb, mitigated_color)           
                        line.set_x2(l, bar_index)
                        line.set_color(l, mitigated_color) 
                        label.set_x(lb, bar_index)
                        label.set_color(lb, mitigated_box_color)
                    else
                        line.set_x2(l, last_bar_index + OFF_BREAKERS)
                        label.set_x(lb, last_bar_index + OFF_BREAKERS)
                else
                    // Keep extending on creation bar
                    line.set_x2(l, last_bar_index + OFF_BREAKERS)
                    label.set_x(lb, last_bar_index + OFF_BREAKERS)
// E. Universal IFVG Detection & Drawing
detect_and_draw_ifvg(float[] _arr_highs, float[] _arr_lows, box[] _arr_boxes, line[] _arr_lines, bool[] _arr_mits, bool[] _arr_is_ifvg, bool[] _arr_mit_ifvg, bool _is_bull_origin, string _tf_label, float _check_price, float _threshold, bool _is_sel) =>
    if _is_sel and array.size(_arr_boxes) > 0
        // Sync Arrays (memastikan ukuran array IFVG sama dengan array FVG)
        while array.size(_arr_is_ifvg) < array.size(_arr_boxes)
            array.push(_arr_is_ifvg, false), array.push(_arr_mit_ifvg, false)

        for i = array.size(_arr_boxes) - 1 to 0
            box b = array.get(_arr_boxes, i)
            line l = array.get(_arr_lines, i)
            float top = array.get(_arr_highs, i)
            float bot = array.get(_arr_lows, i)
            bool is_ifvg = array.get(_arr_is_ifvg, i)
            bool is_mit_ifvg = array.get(_arr_mit_ifvg, i)
            float gap = math.abs(top - bot)

            // Filter High Probability (Gap size minimal 2x threshold)
            bool is_valid_prob = ifvg_selected_high_prob ? (gap >= _threshold * 2) : true
            // Label Logic: Bull Origin (Demand) -> Break Bawah -> Jadi Bearish IFVG (Resistance)
            string base_txt = _is_bull_origin ? (_tf_label + " ▼ IFVG") : (_tf_label + " ▲ IFVG") 

            // A. Creation Logic (Terjadi Breakout)
            if not is_ifvg and is_valid_prob
                bool triggered = false
                if not _is_bull_origin // Asli Bearish (Supply) -> Break Atas -> Bullish IFVG
                    if _check_price > top
                        triggered := true
                        box.set_text_color(b, col_bull), line.set_color(l, col_bull)
                else // Asli Bullish (Demand) -> Break Bawah -> Bearish IFVG
                    if _check_price < bot
                        triggered := true
                        box.set_text_color(b, col_bear), line.set_color(l, col_bear)

                if triggered
                    array.set(_arr_is_ifvg, i, true)
                    array.set(_arr_mits, i, true) // Tandai FVG asli sebagai 'invalid/mitigated' agar logika FVG biasa berhenti
                    
                    // Visual Change untuk Inversion
                    box.set_bgcolor(b, Transparent_Color), box.set_border_color(b, Transparent_Color)
                    box.set_text(b, base_txt), box.set_text_size(b, size.tiny)
                    box.set_right(b, last_bar_index + OFF_ZONES), line.set_x2(l, last_bar_index + OFF_ZONES)

            // B. Mitigation Logic (Retest ke zona IFVG)
            if is_ifvg and not is_mit_ifvg
                bool mitigated = false
                if not _is_bull_origin // Bullish IFVG (Support)
                    if low <= top
                        mitigated := true
                else // Bearish IFVG (Resistance)
                    if high >= bot
                        mitigated := true

                if mitigated
                    array.set(_arr_mit_ifvg, i, true)
                    // Visual Mitigated (Pudar)
                    box.set_text(b, base_txt + " "), box.set_text_color(b, mitigated_color)
                    line.set_color(l, mitigated_color)
                    box.set_right(b, bar_index), line.set_x2(l, bar_index)
                else
                    // Extend ke kanan jika belum retest
                    box.set_right(b, last_bar_index + OFF_ZONES), line.set_x2(l, last_bar_index + OFF_ZONES)

//═══════════════════════════════════════════════════════════════════════════════
// 2. EXECUTION LOGIC (RUNS GLOBALLY)
//═══════════════════════════════════════════════════════════════════════════════

// --- A. PREMIUM / DISCOUNT ZONES ---
// FIX: Variabel ini sudah dideklarasikan di Global Assets (biasanya). 
// Kita inisialisasi hanya jika belum ada (NA), agar tidak error "Already Defined".
if na(ltf_mid_line)
    ltf_mid_line := line.new(na, na, na, na, style=line.style_dashed, color=mitigated_color)
    ltf_premium_box := box.new(na, na, na, na, border_width=0)
    ltf_discount_box := box.new(na, na, na, na, border_width=0)
    ltf_pd_label_top := label.new(na, na, style=label.style_none, textcolor=mitigated_color, size=size.tiny)
    ltf_pd_label_mid := label.new(na, na, style=label.style_none, textcolor=mitigated_color, size=size.tiny)
    ltf_pd_label_bot := label.new(na, na, style=label.style_none, textcolor=mitigated_color, size=size.tiny)

if na(htf_mid_line)
    htf_mid_line := line.new(na, na, na, na, style=line.style_dashed, width=2, color=mitigated_color)
    htf_premium_box := box.new(na, na, na, na, border_width=1, border_color=box_col_bear)
    htf_discount_box := box.new(na, na, na, na, border_width=1, border_color=box_col_bull)
    htf_pd_label_top := label.new(na, na, style=label.style_label_center, textcolor=dark, size=size.tiny,color = col_bear,text_formatting = text.format_bold)
    htf_pd_label_mid := label.new(na, na, style=label.style_label_center, textcolor=dark, size=size.tiny,color = mitigated_color,text_formatting = text.format_bold)
    htf_pd_label_bot := label.new(na, na, style=label.style_label_center, textcolor=dark, size=size.tiny,color = col_bull,text_formatting = text.format_bold)

// Update Zones (Standardized OFF_PD)
f_update_pd_zones(show_pd_ltf, ltf_supply_high, ltf_demand_low, ltf_mid_line, ltf_premium_box, ltf_discount_box, ltf_pd_label_top, ltf_pd_label_mid, ltf_pd_label_bot, "LTF", last_bar_index + OFF_PD)
f_update_pd_zones(show_pd_htf, htf_supply_high, htf_demand_low, htf_mid_line, htf_premium_box, htf_discount_box, htf_pd_label_top, htf_pd_label_mid, htf_pd_label_bot, "HTF", last_bar_index + OFF_PD)

// ==========================================
// 1. DETECT LOGIC (GLOBAL SCOPE)
// ==========================================
if show_eq
    // --- DETECT EQUAL HIGHS (EQH) ---
    if not na(ph_eq)
        // Cek apakah ada pivot sebelumnya
        if not na(last_pivot_h)
            // Hitung persentase perbedaan
            float diff_per = math.abs(ph_eq - last_pivot_h) / ph_eq * 100
            
            // Jika perbedaan masuk dalam toleransi
            if diff_per <= eq_threshold_per
                // A. Create Connector Line (Garis dari Pivot Lama ke Pivot Baru)
                if show_connector
                    line.new(last_pivot_h_idx, last_pivot_h, bar_index - eq_len, ph_eq, color=col_bear, style=line.style_dotted, width=1)

                // B. Create Projection Line (Garis Horizontal ke Depan / Likuiditas)
                line l = line.new(last_pivot_h_idx, last_pivot_h, last_bar_index + OFF_EQ, last_pivot_h, color=col_bear, style=line.style_dotted, width=1)
                label lbl = label.new(last_bar_index + OFF_EQ, last_pivot_h, text="EQH", style=label.style_none, textcolor=col_bear, size=size.tiny)
                
                // Push to arrays for tracking
                array.push(eq_lines, l)
                array.push(eq_labels, lbl)
                array.push(eq_levels, last_pivot_h) // Level harga
                array.push(eq_types, "EQH")
                array.push(eq_swept, false)

        // Update Last Pivot Data
        last_pivot_h := ph_eq
        last_pivot_h_idx := bar_index - eq_len

    // --- DETECT EQUAL LOWS (EQL) ---
    if not na(pl_eq)
        // Cek apakah ada pivot sebelumnya
        if not na(last_pivot_l)
            // Hitung persentase perbedaan
            float diff_per = math.abs(pl_eq - last_pivot_l) / pl_eq * 100
            
            // Jika perbedaan masuk dalam toleransi
            if diff_per <= eq_threshold_per
                // A. Create Connector Line (Garis dari Pivot Lama ke Pivot Baru)
                if show_connector
                    line.new(last_pivot_l_idx, last_pivot_l, bar_index - eq_len, pl_eq, color=col_bull, style=line.style_dotted, width=1)

                // B. Create Projection Line (Garis Horizontal ke Depan / Likuiditas)
                line l = line.new(last_pivot_l_idx, last_pivot_l, last_bar_index + OFF_EQ, last_pivot_l, color=col_bull, style=line.style_dotted, width=1)
                label lbl = label.new(last_bar_index + OFF_EQ, last_pivot_l, text="EQL", style=label.style_none, textcolor=col_bull, size=size.tiny)
                
                // Push to arrays for tracking
                array.push(eq_lines, l)
                array.push(eq_labels, lbl)
                array.push(eq_levels, last_pivot_l)
                array.push(eq_types, "EQL")
                array.push(eq_swept, false)

        // Update Last Pivot Data
        last_pivot_l := pl_eq
        last_pivot_l_idx := bar_index - eq_len

// ==========================================
// 2. MANAGEMENT LOGIC (SWEEP CHECK)
// ==========================================
if array.size(eq_lines) > 0
    // Loop backwards to update status
    for i = array.size(eq_lines) - 1 to 0
        bool already_swept = array.get(eq_swept, i)
        
        if not already_swept
            line l = array.get(eq_lines, i)
            label lbl = array.get(eq_labels, i)
            float lvl = array.get(eq_levels, i)
            string typ = array.get(eq_types, i)
            
            bool is_swept = false

            // Check Sweep Condition
            if typ == "EQH" and high > lvl
                is_swept := true
            if typ == "EQL" and low < lvl
                is_swept := true

            if is_swept
                // Mark as Swept (Visual Change)
                line.set_color(l, mitigated_color) // Pudar
                line.set_style(l, line.style_dotted)
                line.set_x2(l, bar_index) // Stop di candle sweep
                label.set_text(lbl, "✖")
                label.set_textcolor(lbl, mitigated_color)
                label.set_x(lbl, bar_index)

                // Update status array
                array.set(eq_swept, i, true)
            else
                // Extend line if not swept
                line.set_x2(l, last_bar_index + OFF_EQ)
                label.set_x(lbl, last_bar_index + OFF_EQ)

// --- C. MITIGASI SUPPLY & DEMAND ---
// HTF
f_mitigate_snd_universal(true, true, htf_supply_low, htf_supply_mitigated, htf_supply_box, htf_ms_bull_line, high)
f_mitigate_snd_universal(false, true, htf_demand_high, htf_demand_mitigated, htf_demand_box, htf_ms_bear_line, low)
// LTF
f_mitigate_snd_universal(true, false, ltf_supply_low, ltf_supply_mitigated, ltf_supply_box, ltf_ms_bull_line, high)
f_mitigate_snd_universal(false, false, ltf_demand_high, ltf_demand_mitigated, ltf_demand_box, ltf_ms_bear_line, low)


// --- D. MITIGASI FVG ---
// LTF
f_mitigate_fvg_universal(false, false, down_fvg_highsLtf, down_fvg_lowsLtf, down_fvg_mitigatedLtf, down_fvg_boxLtf, down_fvg_midle_linesLtf, high)
f_mitigate_fvg_universal(true, false, up_fvg_highsLtf, up_fvg_lowsLtf, up_fvg_mitigatedLtf, up_fvg_boxLtf, up_fvg_midle_linesLtf, low)
// HTF
f_mitigate_fvg_universal(false, true, down_fvg_highsHtf, down_fvg_lowsHtf, down_fvg_mitigatedHtf, down_fvg_boxHtf, down_fvg_midle_linesHtf, high)
f_mitigate_fvg_universal(true, true, up_fvg_highsHtf, up_fvg_lowsHtf, up_fvg_mitigatedHtf, up_fvg_boxHtf, up_fvg_midle_linesHtf, low)


//═══════════════════════════════════════════════════════════════════════════════
// 1. HELPER FUNCTIONS (GLOBAL)
//═══════════════════════════════════════════════════════════════════════════════
// Helper: Get Last MS Index untuk menentukan Trend
get_last_valid_ms_idx(bool[] breakout_arr, label[] lbl_arr) =>
    int idx = -1
    int sz = array.size(breakout_arr)
    if sz > 0
        for i = sz - 1 to 0
            if array.get(breakout_arr, i)
                if i < array.size(lbl_arr)
                    idx := label.get_x(array.get(lbl_arr, i))
                break
    idx

// Helper: Zone Status
get_synchronized_zone_status(float[] arr_sup_h, float[] arr_sup_l, float[] arr_dem_h, float[] arr_dem_l, float[] arr_fvgb_h, float[] arr_fvgb_l, float[] arr_fvgm_h, float[] arr_fvgm_l) =>
    int status = 0
    bool in_supply = false
    bool in_demand = false

    // Check Supply / Bear FVG
    if array.size(arr_sup_h) > 0
        for i = 0 to array.size(arr_sup_h) - 1
            if high >= array.get(arr_sup_l, i) and low <= array.get(arr_sup_h, i)
                in_supply := true
                break
    if not in_supply and array.size(arr_fvgb_h) > 0
        for i = 0 to array.size(arr_fvgb_h) - 1
            if high >= array.get(arr_fvgb_l, i) and low <= array.get(arr_fvgb_h, i)
                in_supply := true
                break
    // Check Demand / Bull FVG
    if array.size(arr_dem_h) > 0
        for i = 0 to array.size(arr_dem_h) - 1
            if high >= array.get(arr_dem_l, i) and low <= array.get(arr_dem_h, i)
                in_demand := true
                break
    if not in_demand and array.size(arr_fvgm_h) > 0
        for i = 0 to array.size(arr_fvgm_h) - 1
            if high >= array.get(arr_fvgm_l, i) and low <= array.get(arr_fvgm_h, i)
                in_demand := true
                break
    // Final Logic
    if in_supply and in_demand
        status := 999
    else if in_supply
        status := -1
    else if in_demand
        status := 1
    status

//═══════════════════════════════════════════════════════════════════════════════
// 2. GLOBAL TREND CALCULATION
//═══════════════════════════════════════════════════════════════════════════════
// Kita hitung Trend HTF di sini agar bisa dipakai oleh Candle Color & Dashboard
int htf_bull_idx_g = get_last_valid_ms_idx(htf_ms_bull_breakout, htf_ms_bull_label)
int htf_bear_idx_g = get_last_valid_ms_idx(htf_ms_bear_breakout, htf_ms_bear_label)
int ltf_bull_idx_g = get_last_valid_ms_idx(ltf_ms_bull_breakout, ltf_ms_bull_label)
int ltf_bear_idx_g = get_last_valid_ms_idx(ltf_ms_bear_breakout, ltf_ms_bear_label)

// 1 = Bull, -1 = Bear, 0 = Neutral
int htf_trend_bias = htf_bull_idx_g > htf_bear_idx_g ? 1 : (htf_bear_idx_g > htf_bull_idx_g ? -1 : 0)
int ltf_trend_bias = ltf_bull_idx_g > ltf_bear_idx_g ? 1 : (ltf_bear_idx_g > ltf_bull_idx_g ? -1 : 0)

// --- E. MSB/MSC & BREAKER LOGIC ---
// Helper delete opposite
delete_opposite_breakers(bool _is_new_bull, line[] _lns, label[] _lbls, float[] _lvls, bool[] _is_bulls, bool[] _mits, int[] _cr_ats) =>
    if array.size(_lns) > 0
        for i = array.size(_lns) - 1 to 0
            if (_is_new_bull != array.get(_is_bulls, i)) and not array.get(_mits, i)
                line.delete(array.get(_lns, i)), label.delete(array.get(_lbls, i))
                array.remove(_lns, i), array.remove(_lbls, i), array.remove(_lvls, i)
                array.remove(_is_bulls, i), array.remove(_mits, i), array.remove(_cr_ats, i)

// HTF MSB/MSC
if array.size(htf_supply_high) > 0
    int i = array.size(htf_supply_high) - 1
    float _lvl = array.get(htf_supply_high, i)
    // Breakout Bullish
    if not array.get(htf_ms_bull_breakout, i) and ta.crossover(htf_C, _lvl)
        array.set(htf_ms_bull_breakout, i, true)
        // Visual
        bool is_msb = htf_trend_bias != 1
        bool is_sel = is_msb ? htf_MSB_selected : htf_MSC_selected
        string ms_txt_short = is_msb ? "MSB" : "MSC"
        string ms_txt = is_msb ? "MSB(Market Structure Break)" : "MSC(Market Structure Continues)"
        line.set_x2(array.get(htf_ms_bull_line, i), bar_index), line.set_color(array.get(htf_ms_bull_line, i), is_sel ? col_bull : Transparent_Color)
        label.set_text(array.get(htf_ms_bull_label, i), showms == 'Symbol' ? ms_txt_short + ' ●' : 'HTF ' + ms_txt + ' ▲'), label.set_textcolor(array.get(htf_ms_bull_label, i), is_sel ? col_bull : Transparent_Color)
        // Breaker
        if breaker_htf_selected
            delete_opposite_breakers(true, htf_bk_lines, htf_bk_labels, htf_bk_levels, htf_bk_is_bull, htf_bk_mitigated, htf_bk_created_at)
            array.push(htf_bk_lines, line.new(bar_index, _lvl, last_bar_index + OFF_BREAKERS, _lvl, color=col_bull)), array.push(htf_bk_levels, _lvl)
            array.push(htf_bk_labels, label.new(last_bar_index + OFF_BREAKERS, _lvl, text="HTF BREAKER ▲", textcolor=col_bull, style=label.style_label_left, size=size.tiny,color = box_col_bull))
            array.push(htf_bk_is_bull, true), array.push(htf_bk_mitigated, false), array.push(htf_bk_created_at, bar_index)
    // LQS Logic
    else if not array.get(htf_ms_bull_breakout, i) and high >= _lvl
        line.set_x2(array.get(htf_ms_bull_line, i), bar_index), line.set_color(array.get(htf_ms_bull_line, i), Htf_lqs_selected ? col_bear : Transparent_Color)
        label.set_text(array.get(htf_ms_bull_label, i), showms == 'Symbol' ? '✖' : 'HTF BSL SWEEP'), label.set_textcolor(array.get(htf_ms_bull_label, i), Htf_lqs_selected ? col_bear : Transparent_Color)

if array.size(htf_demand_low) > 0
    int i = array.size(htf_demand_low) - 1
    float _lvl = array.get(htf_demand_low, i)
    // Breakout Bearish
    if not array.get(htf_ms_bear_breakout, i) and ta.crossunder(htf_C, _lvl)
        array.set(htf_ms_bear_breakout, i, true)
        // Visual
        bool is_msb = htf_trend_bias != -1
        bool is_sel = is_msb ? htf_MSB_selected : htf_MSC_selected
        string ms_txt_short = is_msb ? "MSB" : "MSC"
        string ms_txt = is_msb ? "MSB(Market Structure Break)" : "MSC(Market Structure Continues)"
        line.set_x2(array.get(htf_ms_bear_line, i), bar_index), line.set_color(array.get(htf_ms_bear_line, i), is_sel ? col_bear : Transparent_Color)
        label.set_text(array.get(htf_ms_bear_label, i), showms == 'Symbol' ? ms_txt_short + ' ●' : 'HTF ' + ms_txt + ' ▼'), label.set_textcolor(array.get(htf_ms_bear_label, i), is_sel ? col_bear : Transparent_Color)
        // Breaker
        if breaker_htf_selected
            delete_opposite_breakers(false, htf_bk_lines, htf_bk_labels, htf_bk_levels, htf_bk_is_bull, htf_bk_mitigated, htf_bk_created_at)
            array.push(htf_bk_lines, line.new(bar_index, _lvl, last_bar_index + OFF_BREAKERS, _lvl, color=col_bear)), array.push(htf_bk_levels, _lvl)
            array.push(htf_bk_labels, label.new(last_bar_index + OFF_BREAKERS, _lvl, text="HTF BREAKER ▼", textcolor=col_bear, style=label.style_label_left, size=size.tiny,color = box_col_bear ))
            array.push(htf_bk_is_bull, false), array.push(htf_bk_mitigated, false), array.push(htf_bk_created_at, bar_index)
    // LQS Logic
    else if not array.get(htf_ms_bear_breakout, i) and low <= _lvl
        line.set_x2(array.get(htf_ms_bear_line, i), bar_index), line.set_color(array.get(htf_ms_bear_line, i), Htf_lqs_selected ? col_bull : Transparent_Color)
        label.set_text(array.get(htf_ms_bear_label, i), showms == 'Symbol' ? '✖' : 'HTF SSL SWEEP'), label.set_textcolor(array.get(htf_ms_bear_label, i), Htf_lqs_selected ? col_bull : Transparent_Color)

// LTF MSB/MSC
if array.size(ltf_supply_high) > 0
    int i = array.size(ltf_supply_high) - 1
    float _lvl = array.get(ltf_supply_high, i)
    if not array.get(ltf_ms_bull_breakout, i) and ta.crossover(close, _lvl)
        array.set(ltf_ms_bull_breakout, i, true)
        bool is_msb = ltf_trend_bias != 1
        bool is_sel = is_msb ? ltf_MSB_selected : ltf_MSC_selected
        string ms_txt_short = is_msb ? "MSB" : "MSC"
        string ms_txt = is_msb ? "MSB(Market Structure Break)" : "MSC(Market Structure Continues)"
        line.set_x2(array.get(ltf_ms_bull_line, i), bar_index), line.set_color(array.get(ltf_ms_bull_line, i), is_sel ? col_bull : Transparent_Color)
        label.set_text(array.get(ltf_ms_bull_label, i), showms == 'Symbol' ? ms_txt_short + ' 〇' : 'LTF ' + ms_txt + ' ▲'), label.set_textcolor(array.get(ltf_ms_bull_label, i), is_sel ? col_bull : Transparent_Color)
        if breaker_ltf_selected
            delete_opposite_breakers(true, ltf_bk_lines, ltf_bk_labels, ltf_bk_levels, ltf_bk_is_bull, ltf_bk_mitigated, ltf_bk_created_at)
            array.push(ltf_bk_lines, line.new(bar_index, _lvl, last_bar_index + OFF_BREAKERS, _lvl, color=col_bull, style=line.style_dotted)), array.push(ltf_bk_levels, _lvl)
            array.push(ltf_bk_labels, label.new(last_bar_index + OFF_BREAKERS, _lvl, text="LTF BREAKER ▲", textcolor=col_bull, style=label.style_label_left, size=size.tiny,color = box_col_bull))
            array.push(ltf_bk_is_bull, true), array.push(ltf_bk_mitigated, false), array.push(ltf_bk_created_at, bar_index)
    else if not array.get(ltf_ms_bull_breakout, i) and high >= _lvl
        line.set_x2(array.get(ltf_ms_bull_line, i), bar_index), line.set_color(array.get(ltf_ms_bull_line, i), ltf_lqs_selected ? col_bear : Transparent_Color)
        label.set_text(array.get(ltf_ms_bull_label, i), showms == 'Symbol' ? '✖' : 'LTF BSL SWEEP'), label.set_textcolor(array.get(ltf_ms_bull_label, i), ltf_lqs_selected ? col_bear : Transparent_Color)

if array.size(ltf_demand_low) > 0
    int i = array.size(ltf_demand_low) - 1
    float _lvl = array.get(ltf_demand_low, i)
    if not array.get(ltf_ms_bear_breakout, i) and ta.crossunder(close, _lvl)
        array.set(ltf_ms_bear_breakout, i, true)
        bool is_msb = ltf_trend_bias != -1
        bool is_sel = is_msb ? ltf_MSB_selected : ltf_MSC_selected
        string ms_txt_short = is_msb ? "MSB" : "MSC"
        string ms_txt = is_msb ? "MSB(Market Structure Break)" : "MSC(Market Structure Continues)"
        line.set_x2(array.get(ltf_ms_bear_line, i), bar_index), line.set_color(array.get(ltf_ms_bear_line, i), is_sel ? col_bear : Transparent_Color)
        label.set_text(array.get(ltf_ms_bear_label, i), showms == 'Symbol' ? ms_txt_short + ' 〇' : 'LTF ' + ms_txt + ' ▼'), label.set_textcolor(array.get(ltf_ms_bear_label, i), is_sel ? col_bear : Transparent_Color)
        if breaker_ltf_selected
            delete_opposite_breakers(false, ltf_bk_lines, ltf_bk_labels, ltf_bk_levels, ltf_bk_is_bull, ltf_bk_mitigated, ltf_bk_created_at)
            array.push(ltf_bk_lines, line.new(bar_index, _lvl, last_bar_index + OFF_BREAKERS, _lvl, color=col_bear, style=line.style_dotted)), array.push(ltf_bk_levels, _lvl)
            array.push(ltf_bk_labels, label.new(last_bar_index + OFF_BREAKERS, _lvl, text="LTF BREAKER ▼", textcolor=col_bear, style=label.style_label_left, size=size.tiny,color = box_col_bear))
            array.push(ltf_bk_is_bull, false), array.push(ltf_bk_mitigated, false), array.push(ltf_bk_created_at, bar_index)
    else if not array.get(ltf_ms_bear_breakout, i) and low <= _lvl
        line.set_x2(array.get(ltf_ms_bear_line, i), bar_index), line.set_color(array.get(ltf_ms_bear_line, i), ltf_lqs_selected ? col_bull : Transparent_Color)
        label.set_text(array.get(ltf_ms_bear_label, i), showms == 'Symbol' ? '✖' : 'LTF SSL SWEEP'), label.set_textcolor(array.get(ltf_ms_bear_label, i), ltf_lqs_selected ? col_bull : Transparent_Color)

// --- F. BREAKER MANAGEMENT ---
manage_breakers(htf_bk_lines, htf_bk_labels, htf_bk_levels, htf_bk_is_bull, htf_bk_mitigated, htf_bk_created_at, breaker_htf_selected, "HTF")
manage_breakers(ltf_bk_lines, ltf_bk_labels, ltf_bk_levels, ltf_bk_is_bull, ltf_bk_mitigated, ltf_bk_created_at, breaker_ltf_selected, "LTF")

// --- G. IFVG ---
detect_and_draw_ifvg(down_fvg_highsLtf, down_fvg_lowsLtf, down_fvg_boxLtf, down_fvg_midle_linesLtf, down_fvg_mitigatedLtf, down_fvg_is_ifvgLtf, down_fvg_mit_ifvgLtf, false, "LTF", close, pct_thresholdLtf, ltf_ifvg_selected)
detect_and_draw_ifvg(up_fvg_highsLtf, up_fvg_lowsLtf, up_fvg_boxLtf, up_fvg_midle_linesLtf, up_fvg_mitigatedLtf, up_fvg_is_ifvgLtf, up_fvg_mit_ifvgLtf, true, "LTF", close, pct_thresholdLtf, ltf_ifvg_selected)
detect_and_draw_ifvg(down_fvg_highsHtf, down_fvg_lowsHtf, down_fvg_boxHtf, down_fvg_midle_linesHtf, down_fvg_mitigatedHtf, down_fvg_is_ifvgHtf, down_fvg_mit_ifvgHtf, false, "HTF", htf_C, pct_thresholdHtf, htf_ifvg_selected)
detect_and_draw_ifvg(up_fvg_highsHtf, up_fvg_lowsHtf, up_fvg_boxHtf, up_fvg_midle_linesHtf, up_fvg_mitigatedHtf, up_fvg_is_ifvgHtf, up_fvg_mit_ifvgHtf, true, "HTF", htf_C, pct_thresholdHtf, htf_ifvg_selected)

//═══════════════════════════════════════════════════════════════════════════════
// 3. CLEANUP (GARBAGE COLLECTION)
//═══════════════════════════════════════════════════════════════════════════════
f_clean_arrays() =>
    // FVG LTF
    if array.size(down_fvg_highsLtf) > x_show
        box.delete(array.shift(down_fvg_boxLtf)), line.delete(array.shift(down_fvg_midle_linesLtf))
        array.shift(down_fvg_highsLtf), array.shift(down_fvg_lowsLtf), array.shift(down_fvg_mitigatedLtf)
        if array.size(down_fvg_is_ifvgLtf) > 0 
            array.shift(down_fvg_is_ifvgLtf), array.shift(down_fvg_mit_ifvgLtf)

    if array.size(up_fvg_highsLtf) > x_show
        box.delete(array.shift(up_fvg_boxLtf)), line.delete(array.shift(up_fvg_midle_linesLtf))
        array.shift(up_fvg_highsLtf), array.shift(up_fvg_lowsLtf), array.shift(up_fvg_mitigatedLtf)
        if array.size(up_fvg_is_ifvgLtf) > 0 
            array.shift(up_fvg_is_ifvgLtf), array.shift(up_fvg_mit_ifvgLtf)
            
    // FVG HTF 
    if array.size(down_fvg_highsHtf) > x_show
        box.delete(array.shift(down_fvg_boxHtf)), line.delete(array.shift(down_fvg_midle_linesHtf))
        array.shift(down_fvg_highsHtf), array.shift(down_fvg_lowsHtf), array.shift(down_fvg_mitigatedHtf)
        if array.size(down_fvg_is_ifvgHtf) > 0 
            array.shift(down_fvg_is_ifvgHtf), array.shift(down_fvg_mit_ifvgHtf)

    if array.size(up_fvg_highsHtf) > x_show
        box.delete(array.shift(up_fvg_boxHtf)), line.delete(array.shift(up_fvg_midle_linesHtf))
        array.shift(up_fvg_highsHtf), array.shift(up_fvg_lowsHtf), array.shift(up_fvg_mitigatedHtf)
        if array.size(up_fvg_is_ifvgHtf) > 0 
            array.shift(up_fvg_is_ifvgHtf), array.shift(up_fvg_mit_ifvgHtf)

    // SND HTF
    if array.size(htf_supply_box) > x_show
        box.delete(array.shift(htf_supply_box)), line.delete(array.shift(htf_ms_bull_line))
        if array.size(htf_ms_bull_label) > 0
            label.delete(array.shift(htf_ms_bull_label))
        array.shift(htf_supply_high), array.shift(htf_supply_low), array.shift(htf_supply_mitigated), array.shift(htf_ms_bull_breakout)
        
    if array.size(htf_demand_box) > x_show
        box.delete(array.shift(htf_demand_box)), line.delete(array.shift(htf_ms_bear_line))
        if array.size(htf_ms_bear_label) > 0
            label.delete(array.shift(htf_ms_bear_label))
        array.shift(htf_demand_high), array.shift(htf_demand_low), array.shift(htf_demand_mitigated), array.shift(htf_ms_bear_breakout)

    // SND LTF
    if array.size(ltf_supply_box) > x_show
        box.delete(array.shift(ltf_supply_box)), line.delete(array.shift(ltf_ms_bull_line))
        if array.size(ltf_ms_bull_label) > 0
            label.delete(array.shift(ltf_ms_bull_label))
        array.shift(ltf_supply_high), array.shift(ltf_supply_low), array.shift(ltf_supply_mitigated), array.shift(ltf_ms_bull_breakout)

    if array.size(ltf_demand_box) > x_show
        box.delete(array.shift(ltf_demand_box)), line.delete(array.shift(ltf_ms_bear_line))
        if array.size(ltf_ms_bear_label) > 0
            label.delete(array.shift(ltf_ms_bear_label))
        array.shift(ltf_demand_high), array.shift(ltf_demand_low), array.shift(ltf_demand_mitigated), array.shift(ltf_ms_bear_breakout)

    // Breakers
    if array.size(htf_bk_lines) > x_show
        line.delete(array.shift(htf_bk_lines)), label.delete(array.shift(htf_bk_labels))
        array.shift(htf_bk_levels), array.shift(htf_bk_is_bull), array.shift(htf_bk_mitigated), array.shift(htf_bk_created_at)
        
    if array.size(ltf_bk_lines) > x_show
        line.delete(array.shift(ltf_bk_lines)), label.delete(array.shift(ltf_bk_labels))
        array.shift(ltf_bk_levels), array.shift(ltf_bk_is_bull), array.shift(ltf_bk_mitigated), array.shift(ltf_bk_created_at)

    // EQH / EQL
    if array.size(eq_lines) > x_show
        line.delete(array.shift(eq_lines))
        label.delete(array.shift(eq_labels))
        array.shift(eq_levels)
        array.shift(eq_types)
        array.shift(eq_swept)

f_clean_arrays()
//═══════════════════════════════════════════════════════════════════════════════
//              EMA 𝙍𝙄𝘽𝘽𝙊𝙉 V.1
//═══════════════════════════════════════════════════════════════════════════════
EmaGroup = "EMA Ribbon"
// EMA RIBON SETTINGS ____________________________________________________________________
ema1_length                = input.int(30,'● EMA length 1',group = EmaGroup)
ema2_length                = input.int(40,'● EMA length 2',group = EmaGroup)
ema3_length                = input.int(50,'● EMA length 3',group = EmaGroup)
ema4_length                = input.int(60,'● EMA length 4',group = EmaGroup)

// SMOOTHING FUNCTION TO REDUCE PLOT ROUGHNESS FOR EMA RIBON ____________________________________________________________________
smooth(src, length) =>
    ta.ema(ta.ema(ta.ema(src, length), length), length)

// CALCULATING SMOOTHED EMA RIBON ____________________________________________________________________
ema1                       = smooth(close, ema1_length)
ema2                       = smooth(close, ema2_length)
ema3                       = smooth(close, ema3_length)
ema4                       = smooth(close, ema4_length)

// PLOTTING EMA LINES WITH SMOOTHING AND COLOR TRANSITION ____________________________________________________________________
plotema1_                  = plot(ema_ribbon_selected ? ema1 : na, title="● EMA 1", color=ema3 >= ema4 ? color.new(col_bull, 90) : color.new(col_bear, 90), linewidth=1)
plotema2_                  = plot(ema_ribbon_selected ? ema2 : na, title="● EMA 2", color=ema3 >= ema4 ? color.new(col_bull, 70) : color.new(col_bear, 70), linewidth=1)
plotema3_                  = plot(ema_ribbon_selected ? ema3 : na, title="● EMA 3", color=ema3 >= ema4 ? color.new(col_bull, 50) : color.new(col_bear, 50), linewidth=1)
plotema4_                  = plot(ema_ribbon_selected ? ema4 : na, title="● EMA 4", color=ema3 >= ema4 ? color.new(mitigated_color, 0) : color.new(mitigated_color, 0), linewidth=1)
plotema4_a                  = plot(ema_ribbon_selected ? ema4 : na, title="● EMA 4", color=ema3 >= ema4 ? color.new(mitigated_color, 90) : color.new(mitigated_color, 90), linewidth=4)
plotema4_b                  = plot(ema_ribbon_selected ? ema4 : na, title="● EMA 4", color=ema3 >= ema4 ? color.new(mitigated_color, 90) : color.new(mitigated_color, 90), linewidth=8)
plotema4_c                  = plot(ema_ribbon_selected ? ema4 : na, title="● EMA 4", color=ema3 >= ema4 ? color.new(mitigated_color, 90) : color.new(mitigated_color, 90), linewidth=16)

// FILL BETWEEN EMAS FOR VISUAL CLARITY ____________________________________________________________________
fill(plotema1_, plotema2_, color=ema_ribbon_selected ? (ema3 >= ema4 ? color.new(col_bull, 90) : color.new(col_bear, 90)) : na)
fill(plotema2_, plotema3_, color=ema_ribbon_selected ? (ema3 >= ema4 ? color.new(col_bull, 85) : color.new(col_bear, 85)) : na)
fill(plotema3_, plotema4_, color=ema_ribbon_selected ? (ema3 >= ema4 ? color.new(col_bull, 80) : color.new(col_bear, 80)) : na)
//═══════════════════════════════════════════════════════════════════════════════
//        EMA SMOOTHED BASED SNR
//═══════════════════════════════════════════════════════════════════════════════
// CALCULATE SNR LEVELS _________________________________________
length                    = input.int(1,'● SNR differences',group = EmaGroup)
lengthsnr                    = input.int(200,'● SNR length',group = EmaGroup)
support                   = ta.lowest(low, length)
resistance                = ta.highest(high, length)

emaS                       = smooth(support,lengthsnr)
emaR                       = smooth(resistance,lengthsnr)
plotemaS1                   = plot(emaS, title="SUPPORT LINE", color=ema_snr_selected ? (ema4 <= emaS ? mitigated_color : col_bull) : Transparent_Color , linewidth=2)
plotemaS2                   = plot(emaS, title="SUPPORT LINE", color=ema_snr_selected ? (ema4 <= emaS ? mitigated_box_color : box_col_bull) : Transparent_Color, linewidth=8)
plotemaS3                   = plot(emaS, title="SUPPORT LINE", color=ema_snr_selected ? (ema4 <= emaS ? mitigated_box_color : box_col_bull) : Transparent_Color, linewidth=16)
plotemaR1                   = plot(emaR, title="RESISTANCE LINE", color=ema_snr_selected ? (ema4 >= emaR ? mitigated_color : col_bear) : Transparent_Color, linewidth=2)
plotemaR2                   = plot(emaR, title="RESISTANCE LINE", color=ema_snr_selected ? (ema4 >= emaR ? mitigated_box_color : box_col_bear) : Transparent_Color, linewidth=8)
plotemaR3                   = plot(emaR, title="RESISTANCE LINE", color=ema_snr_selected ? (ema4 >= emaR ? mitigated_box_color : box_col_bear) : Transparent_Color, linewidth=16)

xbull_line = (ema_snr_selected and ta.crossover(ema4,emaS)) ? emaS : na
xbear_line = (ema_snr_selected and ta.crossunder(ema4,emaR)) ? emaR : na

xbull1                       = plot(xbull_line, title="x", color= (ema_snr_selected and ta.crossover(ema4,emaS)) ? col_bull : Transparent_Color ,style = plot.style_circles , linewidth=4)
xbull2                       = plot(xbull_line, title="x", color= (ema_snr_selected and ta.crossover(ema4,emaS)) ? box_col_bull : Transparent_Color ,style = plot.style_circles , linewidth=10)
xbull3                       = plot(xbull_line, title="x", color= (ema_snr_selected and ta.crossover(ema4,emaS)) ? box_col_bull : Transparent_Color ,style = plot.style_circles , linewidth=20)
xbear1                       = plot(xbear_line, title="x", color= (ema_snr_selected and ta.crossunder(ema4,emaR)) ? col_bear : Transparent_Color ,style = plot.style_circles , linewidth=4)
xbear2                       = plot(xbear_line, title="x", color= (ema_snr_selected and ta.crossunder(ema4,emaR)) ? box_col_bear : Transparent_Color ,style = plot.style_circles , linewidth=10)
xbear3                       = plot(xbear_line, title="x", color= (ema_snr_selected and ta.crossunder(ema4,emaR)) ? box_col_bear : Transparent_Color ,style = plot.style_circles , linewidth=20)

//═══════════════════════════════════════════════════════════════════════════════
// AUTOMATIC HIGH/LOW (DAY/WEEK/MONTH) - FINAL FIX
//═══════════════════════════════════════════════════════════════════════════════

// 1. Logic Penentuan Timeframe Target (Otomatis)
var string tf_target = ""
var string txt_lbl_per = ""

if timeframe.isseconds or (timeframe.isminutes and timeframe.multiplier < 60)
    tf_target := "D"
    txt_lbl_per := "D" // Daily
else if (timeframe.isminutes and timeframe.multiplier >= 60) and timeframe.multiplier < 1440
    tf_target := "W"
    txt_lbl_per := "W" // Weekly
else
    tf_target := "M"
    txt_lbl_per := "M" // Monthly

// 2. Fetch Data (Current & Previous)
[htf_h_cur, htf_l_cur, htf_h_prev, htf_l_prev] = request.security(syminfo.tickerid, tf_target, [high, low, high[1], low[1]], lookahead=barmerge.lookahead_off)

// 3. Seleksi Nilai Berdasarkan Input User
float final_h = hl_mode_opt == "CURRENT" ? htf_h_cur : htf_h_prev
float final_l = hl_mode_opt == "CURRENT" ? htf_l_cur : htf_l_prev
string final_lbl_txt = (hl_mode_opt == "CURRENT" ? "C" : "P") + txt_lbl_per 

// 4. Hitung Mundur Bar Index (FIXED)
// Perubahan: Menambahkan '!= 0' agar hasil ta.change menjadi boolean (True/False)
bool is_new_auto_period = ta.change(time(tf_target)) != 0
int bars_since_start = ta.barssince(is_new_auto_period)
int safe_bars_since_start = math.min(nz(bars_since_start, 10), 1900)

// Koordinat X1: Mundur ke awal sesi
int x1_loc = bar_index - safe_bars_since_start

// 5. Drawing Lines & Labels (Update Realtime)
var line l_high_auto = na
var line l_low_auto  = na
var label lb_high_auto = na
var label lb_low_auto  = na

if show_hl_auto and barstate.islast
    // Hapus gambar lama
    line.delete(l_high_auto), line.delete(l_low_auto)
    label.delete(lb_high_auto), label.delete(lb_low_auto)

    // --- DRAW HIGH ---
    l_high_auto := line.new(x1_loc, final_h, last_bar_index + OFF_HL_AUTO, final_h, color=white, style=line.style_solid, width=1)
    lb_high_auto := label.new(last_bar_index + OFF_HL_AUTO, final_h, text=final_lbl_txt + "H", style=label.style_none, textcolor=white, size=size.small)
    
    // --- DRAW LOW ---
    l_low_auto := line.new(x1_loc, final_l, last_bar_index + OFF_HL_AUTO, final_l, color=white, style=line.style_solid, width=1)
    lb_low_auto := label.new(last_bar_index + OFF_HL_AUTO, final_l, text=final_lbl_txt + "L", style=label.style_none, textcolor=white, size=size.small)

//════════════════════════════════════════════════════════════════════════
//═══════════════════════════════════════════════════════════════════════════════
// 3. DISPLACEMENT CANDLE (REPLACED MOMENTUM)
//═══════════════════════════════════════════════════════════════════════════════
// Displacement = Big Range + Big Body (Small Wicks) + Breakout intention
float dsp_range_size = high - low
float dsp_body_size  = math.abs(close - open)
float dsp_avg_range  = ta.atr(dsp_len) // Menggunakan ATR untuk volatilitas yang lebih akurat

bool dsp_buy_signal  = false
bool dsp_sell_signal = false

if show_dsp_candle
    // Syarat 1: Ukuran candle harus lebih besar dari rata-rata * multiplier
    bool is_expanded_range = dsp_range_size > (dsp_avg_range * dsp_mult)
    
    // Syarat 2: Body candle harus dominan (memenuhi rasio input) untuk validasi 'Displacement'
    bool is_full_body      = dsp_body_size > (dsp_range_size * dsp_body_min)
    
    // Sinyal
    dsp_buy_signal  := close > open and is_expanded_range and is_full_body
    dsp_sell_signal := close < open and is_expanded_range and is_full_body

// Plotting Icon Displacement
plotshape(dsp_buy_signal, title="Disp Buy", style=shape.triangleup, location=location.belowbar, color=col_dsp_buy, size=size.auto, text="D",textcolor = col_bull)
plotshape(dsp_sell_signal, title="Disp Sell", style=shape.triangledown, location=location.abovebar, color=col_dsp_sell, size=size.auto, text="D",textcolor = col_bear)
//═══════════════════════════════════════════════════════════════════════════════
// 4. CENTRALIZED COLOR LOGIC (UPDATED WITH HTF TREND)
//═══════════════════════════════════════════════════════════════════════════════
float rsi_val = ta.rsi(close, 14)
float k_val   = ta.sma(ta.stoch(rsi_val, rsi_val, rsi_val, 14), 3)
avg_vol_hud   = ta.sma(volume, 20)

get_candle_color(string _type) =>
    color _c_main = na
    color _c_trans = na
    
    // TYPE 1: STOCHASTIC RSI
    if _type == 'Based Stochastic RSI'
        float rsi_norm = math.max(math.min(k_val / 100, 1), 0)
        _c_main  := color.from_gradient(rsi_norm, 0, 1, col_bull, col_bear)
        _c_trans := color.from_gradient(rsi_norm, 0, 1, box_col_bull, box_col_bear)
        
    // TYPE 2: FOLLOW HTF TREND (NEW!)
    // Pastikan di input.string Anda menambahkan opsi: "FOLLOW HTF TREND"
    else if _type == 'Follow HTF Trend'
        if htf_trend_bias == 1 // HTF BULLISH
            // Naik = Bull Color, Turun = Abu-abu (Koreksi)
            _c_main  := close >= open ? col_bull : mitigated_color
            _c_trans := close >= open ? box_col_bull : mitigated_box_color
        else if htf_trend_bias == -1 // HTF BEARISH
            // Turun = Bear Color, Naik = Abu-abu (Koreksi)
            _c_main  := close < open ? col_bear : mitigated_color
            _c_trans := close < open ? box_col_bear : mitigated_box_color
        else // NEUTRAL
            _c_main  := close >= open ? col_bull : col_bear
            _c_trans := close >= open ? box_col_bull : box_col_bear

    // TYPE 3: FOLLOW LTF TREND
    else if _type == 'Follow LTF Trend'
        if ltf_trend_bias == 1
            _c_main  := close >= open ? col_bull : mitigated_color
            _c_trans := close >= open ? box_col_bull : mitigated_box_color
        else if ltf_trend_bias == -1
            _c_main  := close < open ? col_bear : mitigated_color
            _c_trans := close < open ? box_col_bear : mitigated_box_color
        else
            _c_main  := close >= open ? col_bull : col_bear
            _c_trans := close >= open ? box_col_bull : box_col_bear
            
    // [UPDATED] TYPE 3: BASED EMA RIBBON (SUPER GRADIENT SMOOTH - FIXED)
    else if _type == 'Based Ema Ribbon & SNR'
        // 1. Hitung Delta (Jarak) antara EMA3 dan EMA4
        float ribbon_delta = math.abs(ema4 - ((emaS + emaR)/2))
        
        // 2. Normalisasi Kekuatan (0.0 sampai 1.0)
        float max_ribbon = ta.highest(ribbon_delta, 100)
        // Cegah pembagian dengan nol
        float div_val = (max_ribbon == 0 ? 1.0 : max_ribbon)
        float intensity  = math.max(0, math.min(ribbon_delta / div_val, 1))
        
        // 3. Tentukan Arah Tren
        bool is_ribbon_bull = ema4 >= emaS and ema4 >= emaR
        
        // 4. Definisikan Warna Dasar
        color base_c = is_ribbon_bull ? col_bull : col_bear
        
        // 5. SUPER GRADIENT LOGIC (Menggunakan color.from_gradient sebagai pengganti mix)
        // Kita mencampur warna dasar dengan 'mitigated_color' (warna pudar)
        // Rasio 0.4 (40%) meniru fungsi color.mix
        color weak_c = is_ribbon_bull ? color.from_gradient(1, 0, 1, col_bull, mitigated_color) : color.from_gradient(1, 0, 1, col_bear, mitigated_color)
        
        // Warna Main: Gradasi dari Weak ke Strong (Neon) berdasarkan intensitas tren
        _c_main := color.from_gradient(intensity, 0, 1, weak_c, base_c)
        
        // Warna Transparansi: Gradasi dari sangat transparan ke agak solid
        color trans_weak = color.new(base_c, 90)
        color trans_strong = color.new(base_c, 30)
        _c_trans := color.from_gradient(intensity, 0, 1, trans_weak, trans_strong)

    // TYPE 4: BASED EMA RIBBON
    else if _type == 'Based Ema Ribbon'
        _c_main  := ema3 >= ema4 ? col_bull : col_bear
        _c_trans := ema3 >= ema4 ? box_col_bull : box_col_bear

    // TYPE 5: REGULAR (DEFAULT)
    else 
        _c_main  := close >= open ? col_bull : col_bear
        _c_trans := close >= open ? box_col_bull : box_col_bear
    
    [_c_main, _c_trans]

// Get Current Colors
[current_main_col, current_trans_col] = get_candle_color(type_ltf_color_candle)

//═══════════════════════════════════════════════════════════════════════════════
// 5. LTF CANDLE PLOTTING
//═══════════════════════════════════════════════════════════════════════════════
if show_ltf_plot_candle
    if type_ltf_plot_candle == 'Custom Candles'
        box.new(bar_index, high, bar_index + 1, low, border_color = dark, bgcolor = current_trans_col, border_width = 1)
        box.new(bar_index, open, bar_index + 1, close, border_color = dark, bgcolor = current_trans_col, border_width = 1)
    
// Plot Regular Candle
// Logic: Jika Custom Candle nyala, kita matikan plotcandle biasa (color=na)
color plot_col = (show_ltf_plot_candle and type_ltf_plot_candle == 'Regular Candles') ? current_trans_col : na
color plot_border = (show_ltf_plot_candle and type_ltf_plot_candle == 'Regular Candles') ? current_main_col : na
plotcandle(open, high, low, close, color=plot_col, wickcolor=plot_border, bordercolor=plot_border, title='Main Candle')

//═══════════════════════════════════════════════════════════════════════════════
// 6. HTF CANDLE BOX (AGGREGATION)
//═══════════════════════════════════════════════════════════════════════════════
int htf_start_time = request.security(syminfo.tickerid, htf_str, time, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)

var array<box> htf_bodyBoxes = array.new_box()
var array<box> htf_wickBoxes = array.new_box()
var int MAX_HTF_HISTORY = 280 
var float my_htf_open = na
var float my_htf_high = na
var float my_htf_low  = na

if show_htf_plot_candle
    bool is_New_HTF = ta.change(htf_start_time) != 0
    
    if is_New_HTF
        my_htf_open := open
        my_htf_high := high
        my_htf_low  := low
        
        // WARNA HTF BOX JUGA MENGIKUTI LOGIKA GLOBAL
        // close > my_htf_open artinya Candle HTF-nya Bullish
        bool is_htf_candle_bull = close >= my_htf_open
        color c_htf = na
        
        if type_ltf_color_candle == 'Follow HTF Trend'
            if htf_trend_bias == 1 // Trend Global Bull
                c_htf := is_htf_candle_bull ? box_col_bull : mitigated_box_color
            else if htf_trend_bias == -1 // Trend Global Bear
                c_htf := not is_htf_candle_bull ? box_col_bear : mitigated_box_color
            else
                c_htf := is_htf_candle_bull ? box_col_bull : box_col_bear
        else if type_ltf_color_candle == 'Follow LTF Trend'
            if ltf_trend_bias == 1
                c_htf := is_htf_candle_bull ? box_col_bull : mitigated_box_color
            else if ltf_trend_bias == -1
                c_htf := not is_htf_candle_bull ? box_col_bear : mitigated_box_color
            else
                c_htf := is_htf_candle_bull ? box_col_bull : box_col_bear
        else
            c_htf := is_htf_candle_bull ? box_col_bull : box_col_bear

        array.push(htf_wickBoxes, box.new(htf_start_time, my_htf_high, time_close, my_htf_low, xloc=xloc.bar_time, bgcolor=c_htf, border_color=na))
        array.push(htf_bodyBoxes, box.new(htf_start_time, my_htf_open, time_close, close, xloc=xloc.bar_time, bgcolor=c_htf, border_color=c_htf, border_width=1))
        
        if array.size(htf_bodyBoxes) > MAX_HTF_HISTORY
            box.delete(array.shift(htf_bodyBoxes))
            box.delete(array.shift(htf_wickBoxes))
    else
        // Update Existing
        my_htf_high := math.max(my_htf_high, high)
        my_htf_low  := math.min(my_htf_low, low)
        
        if array.size(htf_bodyBoxes) > 0
            box cur_wick = array.get(htf_wickBoxes, array.size(htf_wickBoxes)-1)
            box cur_body = array.get(htf_bodyBoxes, array.size(htf_bodyBoxes)-1)
            
            bool is_htf_candle_bull = close >= my_htf_open
            color c_htf = na
            
            // Logic Warna Update Realtime
            if type_ltf_color_candle == 'Follow HTF Trend'
                if htf_trend_bias == 1 
                    c_htf := is_htf_candle_bull ? box_col_bull : mitigated_box_color
                else if htf_trend_bias == -1 
                    c_htf := not is_htf_candle_bull ? box_col_bear : mitigated_box_color
                else
                    c_htf := is_htf_candle_bull ? box_col_bull : box_col_bear
            else if type_ltf_color_candle == 'Follow LTF Trend'
                if ltf_trend_bias == 1
                    c_htf := is_htf_candle_bull ? box_col_bull : mitigated_box_color
                else if ltf_trend_bias == -1
                    c_htf := not is_htf_candle_bull ? box_col_bear : mitigated_box_color
                else
                    c_htf := is_htf_candle_bull ? box_col_bull : box_col_bear
            else
                c_htf := is_htf_candle_bull ? box_col_bull : box_col_bear

            box.set_top(cur_wick, my_htf_high), box.set_bottom(cur_wick, my_htf_low), box.set_right(cur_wick, time_close), box.set_bgcolor(cur_wick, c_htf)
            box.set_top(cur_body, math.max(my_htf_open, close)), box.set_bottom(cur_body, math.min(my_htf_open, close)), box.set_right(cur_body, time_close)
            box.set_bgcolor(cur_body, c_htf), box.set_border_color(cur_body, c_htf)
//═══════════════════════════════════════════════════════════════════════════════
// KILL ZONE VERTICAL LINES LOGIC
//═══════════════════════════════════════════════════════════════════════════════
// Function to draw Vertical Lines & Background
f_draw_kz(string _sess, color _col, string _txt) =>
    // Cek apakah bar saat ini masuk dalam sesi sesuai Timezone yang dipilih
    bool in_session = not na(time(timeframe.period, _sess, kz_timezone))
    
    // Detect Start Session (Vertical Line)
    if in_session and not in_session[1]
        line.new(bar_index, high, bar_index, low, extend=extend.both, color=_col, style=line.style_solid, width=1)
        label.new(bar_index, high, text=_txt, yloc=yloc.abovebar, color=color.new(white, 100), style=label.style_none, textcolor=_col, size=size.normal)
    
    // Detect End Session (Vertical Line)
    if not in_session and in_session[1]
        line.new(bar_index, high, bar_index, low, extend=extend.both, color=_col, style=line.style_dashed, width=1)

    // Background Highlight (Optional - agar area terlihat)
    color bg_c = in_session ? color.new(_col, 92) : na

// Execution
if show_kz
    f_draw_kz(sess_asia, col_kz_asia, "Asia")
    f_draw_kz(sess_london, col_kz_lon, "London")
    f_draw_kz(sess_ny, col_kz_ny, "New York")
//═══════════════════════════════════════════════════════════════════════════════
// HELPER: SESSION COUNTDOWN LOGIC
//═══════════════════════════════════════════════════════════════════════════════
f_get_session_countdown(string _sess_str, string _tz) =>
    string _result = "Closed"
    // Cek apakah sekarang sedang dalam sesi
    bool _is_active = not na(time(timeframe.period, _sess_str, _tz))
    
    if _is_active
        // 1. Ambil Waktu Sekarang di Timezone Target
        int _now_h = hour(timenow, _tz)
        int _now_m = minute(timenow, _tz)
        int _now_total_min = (_now_h * 60) + _now_m

        // 2. Parsing Waktu Selesai dari String Input (Format "0700-1400")
        // Kita cari posisi tanda "-"
        int _split_idx = str.pos(_sess_str, "-")
        string _end_str = str.substring(_sess_str, _split_idx + 1) // Ambil bagian kanan (1400)
        
        // Konversi string "1400" jadi angka jam dan menit
        // Menggunakan substring fixed position (asumsi format input 4 digit HHMM)
        // Jika user input "14:00", logic ini perlu penyesuaian, tapi standar input session adalah "1400"
        float _end_h_f = str.tonumber(str.substring(_end_str, 0, 2))
        float _end_m_f = str.tonumber(str.substring(_end_str, 2, 4))
        
        // Safety check jika parsing gagal (misal user input aneh)
        int _end_h = na(_end_h_f) ? 0 : int(_end_h_f)
        int _end_m = na(_end_m_f) ? 0 : int(_end_m_f)
        int _end_total_min = (_end_h * 60) + _end_m

        // 3. Hitung Selisih (Handle Midnight Crossing 1900-0300)
        int _diff_min = 0
        
        if _end_total_min < _now_total_min 
            // Kasus Midnight Crossing (Contoh: Now 20:00, End 03:00)
            // Tambahkan 24 jam (1440 menit) ke waktu end
            _diff_min := (_end_total_min + 1440) - _now_total_min
        else
            // Kasus Normal (Contoh: Now 09:00, End 14:00)
            _diff_min := _end_total_min - _now_total_min

        // 4. Format ke Jam:Menit
        int _left_h = math.floor(_diff_min / 60)
        int _left_m = _diff_min % 60
        
        _result := str.tostring(_left_h, "00") + ":" + str.tostring(_left_m, "00")
    
    _result
//═══════════════════════════════════════════════════════════════════════════════
//═══════════════════════════════════════════════════════════════════════════════
// 7. DASHBOARD (MULTI-SESSION TRACKING - V.8.2.3 PRO)
//═══════════════════════════════════════════════════════════════════════════════

// --- Helper Functions Global Scope (Wajib di luar IF) ---
f_is_inside(float p, float _h, float _l) =>
    p <= math.max(_h, _l) and p >= math.min(_h, _l)

// Fungsi Deteksi Cepat
f_get_fast_zone_status(float p, float[] _sup_h, float[] _sup_l, float[] _dem_h, float[] _dem_l, float[] _ifvg_h, float[] _ifvg_l, bool[] _is_ifvg) =>
    string _s = "FREE SPACE"
    color _c = color.new(mitigated_color, 50)

    // 1. PRIORITY: INVERSION FVG (DITAMBAHKAN SAFETY CHECK)
    int _ifvg_size = array.size(_ifvg_h)
    int _stat_size = array.size(_is_ifvg)

    if _ifvg_size > 0 and _stat_size == _ifvg_size
        for i = _ifvg_size - 1 to 0
            // Cek apakah indeks aman sebelum diambil
            bool _stat = array.get(_is_ifvg, i)
            if _stat and f_is_inside(p, array.get(_ifvg_h, i), array.get(_ifvg_l, i))
                _s := "INVERSION FVG"
                _c := yellow
                break

    // 2. PRIORITY: SUPPLY
    if _s == "FREE SPACE" and array.size(_sup_h) > 0
        for i = array.size(_sup_h) - 1 to 0
            if f_is_inside(p, array.get(_sup_h, i), array.get(_sup_l, i))
                _s := "IN SUPPLY"
                _c := col_bear
                break

    // 3. PRIORITY: DEMAND
    if _s == "FREE SPACE" and array.size(_dem_h) > 0
        for i = array.size(_dem_h) - 1 to 0
            if f_is_inside(p, array.get(_dem_h, i), array.get(_dem_l, i))
                _s := "IN DEMAND"
                _c := col_bull
                break
    [_s, _c]

if show_table and barstate.islast
    // --- A. BIAS & TREND CALCULATION ---
    // 1. HTF Bias
    string htf_txt = htf_trend_bias == 1 ? "BULLISH" : (htf_trend_bias == -1 ? "BEARISH" : "NEUTRAL")
    color htf_col = htf_trend_bias == 1 ? col_bull : (htf_trend_bias == -1 ? col_bear : mitigated_color)

    // 2. LTF Trend
    int ltf_bull_idx = get_last_valid_ms_idx(ltf_ms_bull_breakout, ltf_ms_bull_label)
    int ltf_bear_idx = get_last_valid_ms_idx(ltf_ms_bear_breakout, ltf_ms_bear_label)
    string ltf_txt = ltf_bull_idx > ltf_bear_idx ? "BULLISH" : (ltf_bear_idx > ltf_bull_idx ? "BEARISH" : "NEUTRAL")
    color ltf_col = ltf_bull_idx > ltf_bear_idx ? col_bull : (ltf_bear_idx > ltf_bull_idx ? col_bear : mitigated_color)

    // --- B. HYPER FAST CONTEXT ---

    // 1. Market Pressure
    float body_range = high - low
    float body_p = (body_range == 0 ? 0 : (math.abs(close - open) / body_range) * 100)
    string pressure_txt = "NEUTRAL"
    color pressure_col = mitigated_color
    if close > open
        if close > high[1]
            pressure_txt := "BREAKOUT UP (" + str.tostring(body_p, "0") + "%)"
            pressure_col := col_bull
        else
            pressure_txt := "BUY PRESSURE (" + str.tostring(body_p, "0") + "%)"
            pressure_col := color.new(col_bull, 20)
    else if close < open
        if close < low[1]
            pressure_txt := "BREAKDOWN (" + str.tostring(body_p, "0") + "%)"
            pressure_col := col_bear
        else
            pressure_txt := "SELL PRESSURE (" + str.tostring(body_p, "0") + "%)"
            pressure_col := color.new(col_bear, 20)

    // 2. Zone Scanning
    [stat_txt_ltf, stat_col_ltf] = f_get_fast_zone_status(close, ltf_supply_high, ltf_supply_low, ltf_demand_high, ltf_demand_low, down_fvg_highsLtf, down_fvg_lowsLtf, down_fvg_is_ifvgLtf)
    [stat_txt_htf, stat_col_htf] = f_get_fast_zone_status(close, htf_supply_high, htf_supply_low, htf_demand_high, htf_demand_low, down_fvg_highsHtf, down_fvg_lowsHtf, down_fvg_is_ifvgHtf)

    string final_zone_txt = "FREE SPACE"
    color final_zone_col = color.new(mitigated_color, 50)

    if stat_txt_ltf != "FREE SPACE" and stat_txt_htf != "FREE SPACE"
        if stat_txt_ltf == stat_txt_htf
            final_zone_txt := stat_txt_ltf + " (BOTH)"
            final_zone_col := stat_col_ltf
        else
            final_zone_txt := "CONFLUENCE"
            final_zone_col := yellow
    else if stat_txt_ltf != "FREE SPACE"
        final_zone_txt := stat_txt_ltf + " (LTF)"
        final_zone_col := stat_col_ltf
    else if stat_txt_htf != "FREE SPACE"
        final_zone_txt := stat_txt_htf + " (HTF)"
        final_zone_col := stat_col_htf

    // 3. COMPLETE LIQUIDITY STATUS
    int eq_cnt = array.size(eq_types)

    string liq_warn = eq_cnt > 0 ? str.tostring(eq_cnt) + " EQ " : "✓ CLEAN"
    color liq_col = eq_cnt > 0 ? yellow : col_bull

    // 4. MULTI-SESSION STATUS LOGIC
    // Ambil semua countdown
    string cd_ny_str   = f_get_session_countdown(sess_ny, kz_timezone)
    string cd_lon_str  = f_get_session_countdown(sess_london, kz_timezone)
    string cd_asia_str = f_get_session_countdown(sess_asia, kz_timezone)

    // Variable penampung
    string sess_stat = ""
    color sess_col = mitigated_color

    // Cek Asia
    if cd_asia_str != "CLOSED"
        sess_stat := "ASIA [" + cd_asia_str + "]" + "\n"
        sess_col := col_kz_asia

    // Cek London (Accumulate)
    if cd_lon_str != "CLOSED"
        if sess_stat != ""
            sess_stat := sess_stat + "\n" // Tambahkan baris baru jika Asia juga aktif
        sess_stat := sess_stat + "LON [" + cd_lon_str + "]" + "\n"
        sess_col := col_kz_lon // Update warna prioritas ke London

    // Cek NY (Accumulate)
    if cd_ny_str != "CLOSED"
        if sess_stat != ""
            sess_stat := sess_stat + "\n" // Tambahkan baris baru jika London/Asia juga aktif
        sess_stat := sess_stat + "NY [" + cd_ny_str + "]"
        sess_col := col_kz_ny // Update warna prioritas ke NY (Tertinggi)

    // Jika Kosong (Tidak ada sesi)
    if sess_stat == ""
        sess_stat := "QUIET HOURS"
        sess_col := mitigated_color

    string time_now_str = str.format_time(timenow, "HH:mm", kz_timezone)

    // --- C. DRAW TABLE ---
    // Increased row count for a more spaced out, professional layout
    var table hud = table.new(table_pos, 2, 22, bgcolor=color.new(mitigated_color,80), border_color=color.new(mitigated_color, 60), border_width=0, frame_color=mitigated_color, frame_width=1)

    // 1. EMA Ribbon Condition
    float rib_spread = math.abs(ema3 - ema4)
    string rib_txt = (ema3 >= ema4 ? "BULLISH" : "BEARISH") + " [" + str.tostring(rib_spread, format.mintick) + "]"
    color rib_col = ema3 >= ema4 ? col_bull : col_bear

    // 2. EMA Based SNR Condition
    float snr_dist = math.abs(close - (close > emaS ? emaS : emaR))
    string snr_txt_hud = (close > emaS ? "BULLISH" : (close < emaR ? "BEARISH" : "NEUTRAL")) + " (" + str.tostring(snr_dist, format.mintick) + ")"
    color snr_col_hud = close > emaS ? col_bull : (close < emaR ? col_bear : mitigated_color)

    // 3. Stochastic RSI Condition
    string stoch_txt = str.tostring(k_val, "0.0") + " | " + (k_val > 80 ? "OB" : (k_val < 20 ? "OS" : (k_val > 50 ? "BULL" : "BEAR")))
    color stoch_col = k_val > 80 ? col_bear : (k_val < 20 ? col_bull : (k_val > 50 ? col_bull : col_bear))

    // 5. Volume Analysis
    float vol_ratio = volume / (nz(avg_vol_hud) == 0 ? 1 : avg_vol_hud)
    string vol_txt = str.tostring(vol_ratio, "0.0x")
    color vol_col = vol_ratio > 1.5 ? col_bull : (vol_ratio < 0.5 ? col_bear : white)

    // 6. Trend Confluence
    string conf_txt = "DIVERGENT"
    color conf_col = yellow
    if htf_trend_bias == 1 and (ltf_bull_idx > ltf_bear_idx)
        conf_txt := "STRONG BULLISH"
        conf_col := col_bull
    else if htf_trend_bias == -1 and (ltf_bear_idx > ltf_bull_idx)
        conf_txt := "STRONG BEARISH"
        conf_col := col_bear

    // ROW 0: Ticker & Price (HEADER)
    table.cell(hud, 0, 0, "SYMBOL", text_color=white, text_halign=text.align_left, text_size=size.tiny, text_formatting = text.format_bold, bgcolor=mitigated_color)
    table.cell(hud, 1, 0, syminfo.ticker + " @ " + str.tostring(close, format.mintick), text_color=white, text_halign=text.align_right, text_size=size.tiny, text_formatting=text.format_bold, bgcolor=mitigated_color)

    // ROW 1: MARKET BIAS SECTION
    table.merge_cells(hud, 0, 1, 1, 1)
    table.cell(hud, 0, 1, "● MARKET BIAS ANALYSIS", text_color=white, text_halign=text.align_left, text_size=size.tiny,  bgcolor=color.new(mitigated_color, 80))

    table.cell(hud, 0, 2, "HTF Trend Bias", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 2, (htf_trend_bias == 1 ? "↗ " : (htf_trend_bias == -1 ? "↘ " : "→ ")) + htf_txt, text_color=htf_col, text_halign=text.align_right, text_size=size.tiny)

    table.cell(hud, 0, 3, "LTF Trend Bias", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 3, (ltf_bull_idx > ltf_bear_idx ? "↗ " : (ltf_bear_idx > ltf_bull_idx ? "↘ " : "→ ")) + ltf_txt, text_color=ltf_col, text_halign=text.align_right, text_size=size.tiny)

    table.cell(hud, 0, 4, "Trend Confluence", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 4, conf_txt, text_color=conf_col, text_halign=text.align_right, text_size=size.tiny)

    table.cell(hud, 0, 5, "Market Pressure", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 5, pressure_txt, text_color=pressure_col, text_halign=text.align_right, text_size=size.tiny)

    // ROW 6: TECHNICAL CONTEXT SECTION
    table.merge_cells(hud, 0, 6, 1, 6)
    table.cell(hud, 0, 6, "● TECHNICAL INDICATORS", text_color=white, text_halign=text.align_left, text_size=size.tiny,  bgcolor=color.new(white, 80))

    table.cell(hud, 0, 7, "EMA Ribbon", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 7, rib_txt, text_color=rib_col, text_halign=text.align_right, text_size=size.tiny )

    table.cell(hud, 0, 8, "EMA SNR Level", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 8, snr_txt_hud, text_color=snr_col_hud, text_halign=text.align_right, text_size=size.tiny )

    table.cell(hud, 0, 9, "Stoch RSI (K)", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 9, stoch_txt, text_color=stoch_col, text_halign=text.align_right, text_size=size.tiny )

    table.cell(hud, 0, 10, "Volume Intensity", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 10, vol_txt, text_color=vol_col, text_halign=text.align_right, text_size=size.tiny)

    // ROW 11: LIQUIDITY & ZONES SECTION
    table.merge_cells(hud, 0, 11, 1, 11)
    table.cell(hud, 0, 11, "● LIQUIDITY & ZONES", text_color=white, text_halign=text.align_left, text_size=size.tiny,  bgcolor=color.new(white, 80))

    table.cell(hud, 0, 12, "Current Zone", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 12, final_zone_txt, text_color=final_zone_col, text_halign=text.align_right, text_size=size.tiny )

    table.cell(hud, 0, 13, "Liquidity", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 13, liq_warn, text_color=liq_col, text_halign=text.align_right, text_size=size.tiny )

    // ROW 15: TIME & SESSION SECTION
    table.merge_cells(hud, 0, 15, 1, 15)
    table.cell(hud, 0, 15, "● MARKET TIME & SESSION", text_color=white, text_halign=text.align_left, text_size=size.tiny,  bgcolor=color.new(white, 80))

    table.cell(hud, 0, 16, "Market Session", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 16, sess_stat, text_color=white, text_halign=text.align_right, text_size=size.tiny )

    table.cell(hud, 0, 17, "Local Time", text_color=white, text_halign=text.align_left, text_size=size.tiny)
    table.cell(hud, 1, 17, time_now_str, text_color=white, text_halign=text.align_right, text_size=size.tiny)

    // ROW 18: FOOTER
    table.merge_cells(hud, 0, 18, 1, 18)
    table.cell(hud, 0, 18, "𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤 | CLASIC V.9.5.0 PRO", text_color=white, text_size=size.tiny, text_formatting = text.format_bold, text_halign=text.align_center)
//═══════════════════════════════════════════════════════════════════════════════
// LOGO GRADIENT ENHANCED - TOTAL SYNC (LINES & FILL)
//═══════════════════════════════════════════════════════════════════════════════

color bull_c1 = col_bull
color bull_c2 = col_bear
color bear_c1 = col_bull
color bear_c2 = col_bear

// --- 2. LOGIKA ANIMASI & TREND ---
bool  trend_check = ta.ema(close, 2) > ta.ema(open, 2) 
color c_start     = trend_check ? bull_c1 : bear_c1
color c_end       = trend_check ? bull_c2 : bear_c2

// Animasi "Breathing"
float time_cycle = timenow / 1000 
float breathe    = (math.sin(time_cycle * 3) + 1) / 2 

int LG_Line_Widthb = 1
int periodb        = 200

// --- 3. PERHITUNGAN TITIK (PRESISI ORIGINAL 100%) ---
float lowest1b = ta.lowest(low, periodb)
float lowest2b = ta.lowest(low, periodb - 1)
float lowest3b = ta.lowest(low, periodb - 2)
float lowest4b = ta.lowest(low, periodb - 3)

float point1b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.99
float point2b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.994
float point3b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.9915
float point4b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.9955
float point5b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.986
float point6b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.99
float point7b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.9975
float point8b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.997
float point9b  = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.99
float point1b0 = (lowest1b + lowest2b + lowest3b + lowest4b) / 3.988

// Logo Visual Objects
var line Line1b  = na
var line Line2b  = na
var line Line3b  = na
var line Line4b  = na
var line Line5b  = na
var line Line6b  = na
var line Line7b  = na
var line Line8b  = na
var line Line9b  = na
var line Line1b0 = na
var line Line1b1 = na
var line Line1b2 = na
var line Line1b3 = na
var line Line1b4 = na
var line Line1b5 = na
var line Line1b6 = na
var line Line1b7 = na
var line Line1b8 = na
var label[] brand_labels = array.new_label()

// Hapus Garis Sebelumnya (Selalu dijalankan agar bersih saat dimatikan)
if not na(Line1b)
    line.delete(Line1b)
    line.delete(Line2b)
    line.delete(Line3b)
    line.delete(Line4b)
    line.delete(Line5b)
    line.delete(Line6b)
    line.delete(Line7b)
    line.delete(Line8b)
    line.delete(Line9b)
    line.delete(Line1b0)
    line.delete(Line1b1)
    line.delete(Line1b2)
    line.delete(Line1b3)
    line.delete(Line1b4)
    line.delete(Line1b5)
    line.delete(Line1b6)
    line.delete(Line1b7)
    line.delete(Line1b8)
    while array.size(brand_labels) > 0
        label.delete(array.pop(brand_labels))

// --- FUNGSI WARNA ---
get_adv_color(step) => 
    float ratio = step / 18.0
    float dynamic_ratio = ratio + (breathe * 0.15) 
    if dynamic_ratio > 1
        dynamic_ratio := 1
    color.from_gradient(dynamic_ratio, 0, 1, c_start, c_end)

// Variable Transparansi Dinamis
int dynamic_alpha = math.round(70 + (breathe * 20))

// --- PEMBUATAN GARIS (HANYA JIKA SHOW_LOGO AKTIF) ---
if show_logo and barstate.islast
    // Bagian Atas & Tengah (Head Structure) - REFERENCE COLOR (Step 1)
    color c_head_sync = get_adv_color(1) // Kita simpan warna referensi ini

    Line1b := line.new(x1 = bar_index + OFF_LOGO + 4, y1 = point7b, x2 = bar_index + OFF_LOGO + 11, y2 = point1b, color = get_adv_color(1), width = LG_Line_Widthb)
    Line2b := line.new(x1 = bar_index + OFF_LOGO + 8, y1 = point7b, x2 = bar_index + OFF_LOGO + 11, y2 = point2b, color = get_adv_color(2), width = LG_Line_Widthb)
    linefill.new(Line1b, Line2b, color = color.new(c_head_sync, dynamic_alpha))

    Line3b := line.new(x1 = bar_index + OFF_LOGO + 11, y1 = point1b, x2 = bar_index + OFF_LOGO + 13, y2 = point3b, color = get_adv_color(3), width = LG_Line_Widthb)
    Line4b := line.new(x1 = bar_index + OFF_LOGO + 11, y1 = point2b, x2 = bar_index + OFF_LOGO + 13, y2 = point4b, color = get_adv_color(4), width = LG_Line_Widthb)
    linefill.new(Line3b, Line4b, color = color.new(get_adv_color(3), dynamic_alpha))

    Line5b := line.new(x1 = bar_index + OFF_LOGO + 13, y1 = point3b, x2 = bar_index + OFF_LOGO + 19, y2 = point5b, color = get_adv_color(5), width = LG_Line_Widthb)
    Line6b := line.new(x1 = bar_index + OFF_LOGO + 13, y1 = point4b, x2 = bar_index + OFF_LOGO + 19, y2 = point6b, color = get_adv_color(6), width = LG_Line_Widthb)
    linefill.new(Line5b, Line6b, color = color.new(get_adv_color(5), dynamic_alpha))

    Line7b := line.new(x1 = bar_index + OFF_LOGO + 19, y1 = point5b, x2 = bar_index + OFF_LOGO + 24, y2 = point3b, color = get_adv_color(7), width = LG_Line_Widthb)
    Line8b := line.new(x1 = bar_index + OFF_LOGO + 19, y1 = point6b, x2 = bar_index + OFF_LOGO + 24, y2 = point4b, color = get_adv_color(8), width = LG_Line_Widthb)
    linefill.new(Line7b, Line8b, color = color.new(get_adv_color(7), dynamic_alpha))

    Line9b := line.new(x1 = bar_index + OFF_LOGO + 24, y1 = point3b, x2 = bar_index + OFF_LOGO + 26, y2 = point1b, color = get_adv_color(9), width = LG_Line_Widthb)
    Line1b0 := line.new(x1 = bar_index + OFF_LOGO + 24, y1 = point4b, x2 = bar_index + OFF_LOGO + 26, y2 = point2b, color = get_adv_color(10), width = LG_Line_Widthb)
    linefill.new(Line9b, Line1b0, color = color.new(get_adv_color(9), dynamic_alpha))

    Line1b1 := line.new(x1 = bar_index + OFF_LOGO + 26, y1 = point1b, x2 = bar_index + OFF_LOGO + 36, y2 = lowest1b, color = get_adv_color(11), width = LG_Line_Widthb)
    Line1b2 := line.new(x1 = bar_index + OFF_LOGO + 26, y1 = point2b, x2 = bar_index + OFF_LOGO + 32, y2 = lowest1b, color = get_adv_color(12), width = LG_Line_Widthb)
    linefill.new(Line1b1, Line1b2, color = color.new(get_adv_color(11), dynamic_alpha))

    // --- BAGIAN BASE HORIZONTAL (TOTAL SYNC) ---
    Line1b3 := line.new(x1 = bar_index + OFF_LOGO + 2, y1 = point7b, x2 = bar_index + OFF_LOGO + 26, y2 = point7b, color = get_adv_color(1), width = LG_Line_Widthb)
    Line1b4 := line.new(x1 = bar_index + OFF_LOGO + 0, y1 = lowest1b, x2 = bar_index + OFF_LOGO + 24, y2 = lowest1b, color = get_adv_color(1), width = LG_Line_Widthb)

    // Warna Fill juga menggunakan 'c_head_sync'
    linefill.new(Line1b3, Line1b4, color = color.new(c_head_sync, dynamic_alpha)) 

    // Tutup Depan & Belakang Base
    Line1b5 := line.new(x1 = bar_index + OFF_LOGO + 2, y1 = point7b, x2 = bar_index + OFF_LOGO + 0, y2 = lowest1b, color = get_adv_color(1), width = LG_Line_Widthb)
    Line1b6 := line.new(x1 = bar_index + OFF_LOGO + 26, y1 = point7b, x2 = bar_index + OFF_LOGO + 24, y2 = lowest1b, color = get_adv_color(1), width = LG_Line_Widthb)

    // Ekor Tambahan & Label
    Line1b7 := line.new(x1 = bar_index + OFF_LOGO + 32, y1 = lowest1b, x2 = bar_index + OFF_LOGO + 36, y2 = lowest1b, color = get_adv_color(17), width = LG_Line_Widthb)
    
    // Gradient Text Logic
    array<string> chars = array.from("𝙈     "," ", "𝙤     "," ", "𝙪     "," ", "𝙣     "," ", "𝙩     "," ", "𝘼     "," ", "𝙡     "," ", "𝙜     "," ", "𝙤     ")
    for i = 0 to array.size(chars) - 1
        string char = array.get(chars, i)
        // Adjust x-offset based on character position
        int x_off = OFF_LOGO + 32 + i * 2
        label l = label.new(bar_index + x_off, point2b, char, style=label.style_none, textcolor=get_adv_color(8 + i), size=size.large)
        array.push(brand_labels, l)

// --- PLOT GLOW ---
// Warna di-set ke NA jika show_logo = false
color glow_c = get_adv_color(2)

plot(point1b0, show_last = 1, offset = OFF_LOGO + 13, color = show_logo ? color.new(c_start, 0) : na, linewidth = 4, style = plot.style_circles)
plot(point1b0, show_last = 1, offset = OFF_LOGO + 13, color = show_logo ? color.new(glow_c, 60 + (breathe * 20)) : na, linewidth = 15, style = plot.style_circles)
plot(point1b0, show_last = 1, offset = OFF_LOGO + 13, color = show_logo ? color.new(glow_c, 75 + (breathe * 15)) : na, linewidth = 30, style = plot.style_circles)
plot(point1b0, show_last = 1, offset = OFF_LOGO + 13, color = show_logo ? color.new(glow_c, 85 + (breathe * 10)) : na, linewidth = 50, style = plot.style_circles)
plot(point1b0, show_last = 1, offset = OFF_LOGO + 13, color = show_logo ? color.new(c_end, 95) : na, linewidth = 80, style = plot.style_circles)
