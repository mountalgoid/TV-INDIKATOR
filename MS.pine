var int last_pivot_l_idx = na
// Calculate Pivots
ph_eq = ta.pivothigh(high, eq_len, eq_len)
pl_eq = ta.pivotlow(low, eq_len, eq_len)
// ===> IFVG TRACKING ARRAYS (Simpan Status IFVG)
// LTF
var array<bool> down_fvg_is_ifvgLtf = array.new_bool(0)    // Apakah sudah jadi IFVG?
var array<bool> down_fvg_mit_ifvgLtf = array.new_bool(0)   // Apakah IFVG sudah dimitigasi?
