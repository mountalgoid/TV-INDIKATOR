//𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤
//@version=6
//═══════════════════════════════════════════════════════════════════════════════
indicator(title            = "EMA Based SNR.MTFS Clasic V.8.2 𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤"
  , shorttitle             = "EMA Based SNR.MTFS Clasic V.8.2 𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤"
, overlay                = true
, max_bars_back          = 5000
, max_lines_count        = 500
, max_boxes_count        = 500
, max_labels_count       = 500)
//════════════════════════════════════════════════════════════════════════
// COLOR TYPE
//════════════════════════════════════════════════════════════════════════
dark = #000000
white = #c4d3ff
green = #179c74
purple = #5134ff
gray = #3d4c74
red = #f23645
yellow = #f3ba2f
orange = #ff9800
brown = #6a5635
blue = #1848cc
Transparent_Color = color.new(color.new(white, 0), 100)
//════════════════════════════════════════════════════════════════════════
// GROUP
//════════════════════════════════════════════════════════════════════════
GlobalGroup = 'Global Settings'
//════════════════════════════════════════════════════════════════════════
// INPUT COLOR TYPE THEME
//════════════════════════════════════════════════════════════════════════
color_theme = input.string(defval = 'MountAlgo Themes', title = '⬤ Select Color Theme', options = ['Spartan Edge Theme', 'MountAlgo Themes', 'Standard Spartan Edge Theme', 'Dark ICT Theme', 'Garuda Gold', 'MountAlgo Super Premium Theme', 'MountAlgo Orange White Theme', 'DEX Deep', 'Deep Sea'], group=GlobalGroup)
type_ltf_plot_candle = input.string(defval = 'Regular Candles', title = '⬤ Type LTF Plot Candle', options = ['Regular Candles', 'Custom Candles'], group = GlobalGroup)
type_ltf_color_candle = input.string('Follow HTF Trend',title = '⬤ Type LTF Color Candle', options=['Regular Color Candles', 'Based Stochastic RSI', 'Follow HTF Trend', 'Follow LTF Trend','Based Ema Ribbon & SNR', 'Based Ema Ribbon'],group = GlobalGroup)
// UPDATED: Default set to FALSE
show_ltf_plot_candle = input.bool(defval = true, title = 'Show LTF Plot Candle', group = GlobalGroup)
show_htf_plot_candle = input.bool(defval = false, title = 'Show HTF Plot Candle', group = GlobalGroup)
//════════════════════════════════════════════════════════════════════════
// COLOR BASED ON THEME
//════════════════════════════════════════════════════════════════════════
color col_bull = switch color_theme
    'Spartan Edge Theme' => white
    'MountAlgo Themes' => purple
    'Standard Spartan Edge Theme' => green
    'Dark ICT Theme' => green
    'Garuda Gold' => yellow
    'MountAlgo Super Premium Theme' => purple
    'MountAlgo Orange White Theme' => orange
    'DEX Deep' => #a1ff3b
    'Deep Sea' => blue
    => blue
color col_bear = switch color_theme
    'Spartan Edge Theme' => gray
    'MountAlgo Themes' => green
    'Standard Spartan Edge Theme' => red
    'Dark ICT Theme' => gray
    'Garuda Gold' => gray
    'MountAlgo Super Premium Theme' => yellow
    'MountAlgo Orange White Theme' => white
    'DEX Deep' => #ff009a
    'Deep Sea' => white
    => white
color col_poc = switch color_theme
    'Spartan Edge Theme' => yellow
    'MountAlgo Themes' => white
    'Standard Spartan Edge Theme' => yellow
    'Dark ICT Theme' => yellow
    'Garuda Gold' => white
    'MountAlgo Super Premium Theme' => white
    'MountAlgo Orange White Theme' => white
    'DEX Deep' => yellow
    'Deep Sea' => purple
    => yellow
color box_col_bull = color.new(col_bull, 80)
color box_col_bear = color.new(col_bear, 80)
mitigated_color = brown
mitigated_box_color = color.new(brown, 80)
//═══════════════════════════════════════════════════════════════════════════════
// USER INPUTS GLOBAL
//═══════════════════════════════════════════════════════════════════════════════
// Global Input
auto_tooltip = "Enabling this feature will ignore the manual input below.\n\n" +
           "Auto Configuration (Chart ➔ HTF):\n" +
           "• 1s - 2m ➔ HTF 15 Minutes\n" +
           "• 3m - 4m ➔ HTF 1 hour\n" +
           "• 5m - 14m ➔ HTF 4 Hour (1H)\n" +
           "• 15m - 1H ➔ HTF 4 Hour (4H)\n" +
           "• > 1H (2H+) ➔ HTF Daily (1D)\n" +
           "• Daily (1D) ➔ HTF Weekly (1W)\n" +
           "• Weekly ➔ HTF Monthly (1M)\n\n" +
           "NOTE: The LTF (Lower Timeframe) will always be the same as the current chart."
// UPDATED: Default set to FALSE
auto_htf_mode = input.bool(true, '⬤ Auto Mode (HTF & LTF)', tooltip = auto_tooltip, group = GlobalGroup)
// 2. INPUT MANUAL (Hanya berfungsi jika Auto Mode = OFF)
HTFtime_opt = input.string("1H", '⬤ Manual HTF', tooltip = "Only works if Auto Mode = OFF", group = GlobalGroup, options = ["15m","30m","45m","1H","2H","4H","1D","3D","1W","2W","1M","3M","6M"])
ltf_in_input = input.timeframe('5', '⬤ Manual LTF', tooltip = "Only works if Auto Mode = OFF", group = GlobalGroup)
// ==========================
// LOGIC HELPER: CONVERT STRING TO MINUTES (INT)
// ==========================
f_str_to_minutes(tf_str) =>
    if tf_str == "D" or tf_str == "1D"
        1440
    else if tf_str == "3D"
        4320
    else if tf_str == "W" or tf_str == "1W"
        10080
    else if tf_str == "2W"
        20160
    else if tf_str == "M" or tf_str == "1M"
        43200
    else if tf_str == "3M"
        129600
    else if tf_str == "6M"
        259200
    else 
        nz(str.tonumber(tf_str), timeframe.multiplier)
// ==========================
// LOGIC 1: MANUAL HTF MAPPING
// ==========================
get_manual_tf_string(opt) =>
    switch opt
        "15m" => "15"
        "30m" => "30"
        "45m" => "45"
        "1H"  => "60"
        "2H"  => "120"
        "4H"  => "240"
        "1D"  => "D"
        "3D"  => "3D"
        "1W"  => "W"
        "2W"  => "2W"
        "1M"  => "M"
        "3M"  => "3M"
        "6M"  => "6M"
        => "60"
// ==========================
// LOGIC 2: AUTO HTF MAPPING (SMART LOGIC)
// ==========================
get_auto_htf() =>
    if timeframe.isseconds
        "15" // Detik -> 15m
    else if timeframe.isminutes
        int m = timeframe.multiplier
        if m <= 2
            "60"  // 1m-2m -> 1H
        else if m <= 4
            "60"  // 3m-4m -> 1H
        else if m <= 14
            "240"  // 5m-14m -> 4H
        else if m <= 30
            "240" // 15m s/d 60m (1H) -> 4H
        else 
            "D"   // Di atas 1H -> Daily
    else if timeframe.isdaily
        "W"       // Daily -> Weekly
    else
        "M"       // Weekly+ -> Monthly
// ==========================
// FINAL EXECUTION VARIABLES
// ==========================
ltf_in = auto_htf_mode ? timeframe.period : (ltf_in_input == "" ? timeframe.period : ltf_in_input)
htf_str = auto_htf_mode ? get_auto_htf() : get_manual_tf_string(HTFtime_opt)
minutes_val = f_str_to_minutes(htf_str)
x_show = input.int(4, '⬤ Show MS Structures', minval = 1, group = GlobalGroup)
showms = input.string('Symbol', '⬤ Type Events', options = ['Symbol', 'Name'], group = GlobalGroup)
gap_threshold = input.float(0.00006, '⬤ Minimum Gap Percentage', minval = 0.0, step = 0.005, tooltip = 'Minimum gap size as a percentage of current price', group = GlobalGroup)
// UPDATED: Default set to FALSE
ifvg_selected_high_prob = input.bool(false, 'High Prob IFVG Only', tooltip = "Only displays IFVG if the Gap size is large enough (2x Threshold)", group = GlobalGroup)
use_snd_mid_filter = input.bool(false, 'Filter 1/2 Body (Strong Imbalance)', tooltip = 'If active: Demand = 1/2 Body Candle > Previous High, Supply = 1/2 Body Candle < Previous Low', group = GlobalGroup)
pd_group = 'Premium & Discount'
show_pd_ltf = input.bool(false, 'Show LTF P/D Zones', group = pd_group)
// UPDATED: Default set to FALSE
show_pd_htf = input.bool(true, 'Show HTF P/D Zones', group = pd_group)
eq_group = 'EQH / EQL Settings'
// UPDATED: Default set to FALSE
show_eq = input.bool(true, 'Show EQH/EQL', group = eq_group)
eq_threshold_per = input.float(0.1, '● Tolerance (%)', step=0.01, tooltip="Maximum price difference (percentage) to be considered 'Equal'", group = eq_group)
eq_len = input.int(4, '● Pivot Length', minval=2, group = eq_group)
show_connector = true

dsp_group = 'Displacement Candle'
// UPDATED: Default set to FALSE
show_dsp_candle = input.bool(true, 'Show Displacement', group=dsp_group)
dsp_len         = input.int(20, '● ATR Length', minval=1, tooltip="The average period of the candle range", group=dsp_group)
dsp_mult        = input.float(1.2, '● Range Multiplier', step=0.1, tooltip="The minimum candle size must be X times the average.", group=dsp_group)
dsp_body_min    = input.float(0.60, '● Min Body Ratio (0-1)', step=0.05, maxval=1.0, tooltip="Minimum percentage of body compared to total range", group=dsp_group)
col_dsp_buy     = box_col_bull
col_dsp_sell    = box_col_bear
// NEW: INPUT KILL ZONES (VERTICAL LINES)
kz_group = 'Kill Zone Sessions'
// UPDATED: Default set to FALSE
show_kz      = input.bool(false, 'Show Kill Zones', group=kz_group)
kz_timezone  = input.string("Asia/Jakarta", "● Timezone", options=["Asia/Jakarta", "America/New_York", "Europe/London", "UTC"], tooltip="Select Asia/Jakarta for WIB", group=kz_group)
sess_asia    = input.session("0700-1400", "● Asia Time", group=kz_group)
sess_london  = input.session("1400-2200", "● London Time", group=kz_group)
sess_ny      = input.session("1900-0300", "● New York Time", group=kz_group)
col_kz_asia  = mitigated_color
col_kz_lon   = col_bull
col_kz_ny    = col_bear
hl_group = 'Point High/Low (Day/Week/Month) (Auto)'
show_hl_auto = input.bool(true, 'Show High/Low Auto', group=hl_group)
hl_mode_opt  = input.string("Previous", "⬤ Mode", options=["Previous", "Current"], group=hl_group, tooltip="Previous: High/Low candle then\nCurrent: High/Low candle now")
// 1. DASHBOARD INPUTS
table_group = 'Dashboard Panel'
// UPDATED: Default set to FALSE
show_table = input.bool(true, 'Show Dashboard', group=table_group)
table_pos  = input.string(position.top_right, '● Position', options=[position.top_right, position.bottom_right, position.top_left, position.bottom_left], group=table_group)
table_size = input.string(size.small, '● Size', options=[size.tiny, size.small, size.normal, size.large], group=table_group)
// --- 0. PENGATURAN TAMPILAN (MODIFIKASI) ---
show_logo = input.bool(true, "Show Logo", group = "Logo Settings", tooltip = "Enable/Disable visual logo display")
//═══════════════════════════════════════════════════════════════════════════════
// STRATEGY INPUTS
//═══════════════════════════════════════════════════════════════════════════════
strategyGroup = 'Strategy'
strategy1_Rules_Group = 'Select Rules Strategy'
// Strategy Input
//===> input_strategy rules 1-15 (UPDATED TO "NONE")
input_rule1_stg1 = input.string(defval = 'None', title = '➤ Rules 1', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule2_stg1 = input.string(defval = 'None', title = '➤ Rules 2', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule3_stg1 = input.string(defval = 'None', title = '➤ Rules 3', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule4_stg1 = input.string(defval = 'None', title = '➤ Rules 4', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule5_stg1 = input.string(defval = 'None', title = '➤ Rules 5', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule6_stg1 = input.string(defval = 'None', title = '➤ Rules 6', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule7_stg1 = input.string(defval = 'None', title = '➤ Rules 7', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule8_stg1 = input.string(defval = 'None', title = '➤ Rules 8', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule9_stg1 = input.string(defval = 'None', title = '➤ Rules 9', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule10_stg1 = input.string(defval = 'None', title = '➤ Rules 10', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule11_stg1 = input.string(defval = 'None', title = '➤ Rules 11', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
input_rule12_stg1 = input.string(defval = 'None', title = '➤ Rules 12', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'EMA Based SNR', 'EMA Ribbon', 'None'], group = strategy1_Rules_Group)
