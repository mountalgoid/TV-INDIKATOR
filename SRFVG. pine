//════════════════════════════════════════════════════════════════════════
// DATA GATHERING (LTF)
//════════════════════════════════════════════════════════════════════════
ltf_o = use_ltf ? request.security_lower_tf(syminfo.tickerid, "1", open) : na
ltf_h = use_ltf ? request.security_lower_tf(syminfo.tickerid, "1", high) : na
ltf_l = use_ltf ? request.security_lower_tf(syminfo.tickerid, "1", low) : na
ltf_c = use_ltf ? request.security_lower_tf(syminfo.tickerid, "1", close) : na
ltf_v = use_ltf ? request.security_lower_tf(syminfo.tickerid, "1", volume) : na

//════════════════════════════════════════════════════════════════════════
// UTILITIES
//════════════════════════════════════════════════════════════════════════
calc_vol_partition(float _v, float _o, float _h, float _l, float _c) =>
    float range_size = _h - _l
    float b_vol = 0.0
    float s_vol = 0.0
    if range_size > 0
        float body_high = math.max(_o, _c)
        float body_low  = math.min(_o, _c)
        float body_size = body_high - body_low
        float upper_wick = _h - body_high
        float lower_wick = body_low - _l
        float w_body = body_size / range_size
        float w_upper = upper_wick / range_size
        float w_lower = lower_wick / range_size
        float body_buy_ratio = _c > _o ? 0.8 : (_c < _o ? 0.2 : 0.5)
        b_vol := _v * (w_body * body_buy_ratio + w_lower * 0.9 + w_upper * 0.1)
        s_vol := _v * (w_body * (1 - body_buy_ratio) + w_upper * 0.9 + w_lower * 0.1)
    else
        b_vol := _v * 0.5
        s_vol := _v * 0.5
    [b_vol, s_vol]

get_precise_vol(int bar_idx_back) =>
    float b_v = 0.0
    float s_v = 0.0
    bool has_ltf = false
    if use_ltf and not na(ltf_v)
        float[] v_arr = ltf_v[bar_idx_back]
        float[] c_arr = ltf_c[bar_idx_back]
        float[] o_arr = ltf_o[bar_idx_back]
        if not na(v_arr) and array.size(v_arr) > 0
            has_ltf := true
            for i = 0 to array.size(v_arr) - 1
                float v = array.get(v_arr, i)
                float c = array.get(c_arr, i)
                float o = array.get(o_arr, i)
                if c > o
                    b_v += v
                else if c < o
                    s_v += v
                else
                    b_v += v * 0.5
                    s_v += v * 0.5
    if not has_ltf
        [hb_v, hs_v] = calc_vol_partition(volume[bar_idx_back], open[bar_idx_back], high[bar_idx_back], low[bar_idx_back], close[bar_idx_back])
        b_v := hb_v
        s_v := hs_v
    [b_v, s_v]

format_vol(float v) =>
    float abs_v = math.abs(v)
    if abs_v >= 1000000
        str.tostring(v / 1000000, "#.##") + "M"
    else if abs_v >= 1000
        str.tostring(v / 1000, "#.#") + "K"
    else
        str.tostring(v, "0")

//════════════════════════════════════════════════════════════════════════
// TREND CALCULATION
//════════════════════════════════════════════════════════════════════════
ema_val = ta.ema(close, ema_len)
[st_val, st_dir] = ta.supertrend(st_factor, st_period)

// Determine trend direction series
trend_is_bull = trend_type == "EMA" ? (close >= ema_val) : (trend_type == "Supertrend" ? (st_dir < 0) : true)
trend_is_bear = trend_type == "EMA" ? (close < ema_val) : (trend_type == "Supertrend" ? (st_dir > 0) : true)

//════════════════════════════════════════════════════════════════════════
// CANDLE LOGIC
//════════════════════════════════════════════════════════════════════════
[curr_b_v, curr_s_v] = get_precise_vol(0)
delta_bull = curr_b_v >= curr_s_v
normal_bull = close >= open

bull_c = candle_mode == "Normal" ? normal_bull : delta_bull
c_col = bull_c ? col_bull : col_bear
c_body = bull_c ? color.new(col_bull, 70) : color.new(col_bear, 70)

plotcandle(open, high, low, close, title="Custom Candles", color=show_candles ? c_body : na, wickcolor=show_candles ? c_col : na, bordercolor=show_candles ? c_col : na)

// Plot Trend Visuals
trend_line_val = trend_type == "EMA" ? ema_val : (trend_type == "Supertrend" ? st_val : na)
trend_line_color = trend_type == "EMA" ? (close >= ema_val ? col_bull : col_bear) : (st_dir < 0 ? col_bull : col_bear)
plot(show_trend_visual ? trend_line_val : na, "Trend Line", color=trend_line_color, linewidth=2)

//════════════════════════════════════════════════════════════════════════
// TYPE & ARRAYS
//════════════════════════════════════════════════════════════════════════
type Zone
    box main_box
    box buy_vol_box
    box sell_vol_box
    float top
    float bottom
    float buy_vol
    float sell_vol
    bool is_bull
    bool is_fvg
    bool active
    int start_bar

var array<Zone> zones = array.new<Zone>()
var float latest_supply_top = na
var float latest_demand_bottom = na
var int latest_supply_idx = na
var int latest_demand_idx = na

//════════════════════════════════════════════════════════════════════════
// DETECTION
//════════════════════════════════════════════════════════════════════════
// S/R Detection
ph = ta.pivothigh(high, lookback, lookback)
pl = ta.pivotlow(low, lookback, lookback)

if show_sr and not na(ph) and (not filter_by_trend or trend_is_bear[lookback])
    [b_v, s_v] = get_precise_vol(lookback)
    float z_top = high[lookback]
    float z_bottom = math.max(open[lookback], close[lookback])
    latest_supply_top := z_top
    latest_supply_idx := bar_index[lookback]
    float b_ratio = (b_v + s_v) > 0 ? b_v / (b_v + s_v) : 0.5
    string info = show_vol_details ? "SUPPLY | B:" + format_vol(b_v) + " S:" + format_vol(s_v) : ""
    box mb = box.new(bar_index[lookback], z_top, bar_index + extend_len, z_bottom, bgcolor=color.new(col_bear, 90), border_color=col_bear, text=info, text_color=white, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
    box bvb = na, box svb = na
    if show_vol_details
        bvb := box.new(bar_index[lookback], z_top, bar_index[lookback] + math.round(extend_len * b_ratio), z_bottom, bgcolor=color.new(col_bull, 70), border_color=na)
        svb := box.new(bar_index[lookback] + math.round(extend_len * b_ratio), z_top, bar_index + extend_len, z_bottom, bgcolor=color.new(col_bear, 70), border_color=na)
    array.push(zones, Zone.new(main_box=mb, buy_vol_box=bvb, sell_vol_box=svb, top=z_top, bottom=z_bottom, buy_vol=b_v, sell_vol=s_v, is_bull=false, is_fvg=false, active=true, start_bar=bar_index[lookback]))

if show_sr and not na(pl) and (not filter_by_trend or trend_is_bull[lookback])
    [b_v, s_v] = get_precise_vol(lookback)
    float z_top = math.min(open[lookback], close[lookback])
    float z_bottom = low[lookback]
    latest_demand_bottom := z_bottom
    latest_demand_idx := bar_index[lookback]
    float b_ratio = (b_v + s_v) > 0 ? b_v / (b_v + s_v) : 0.5
    string info = show_vol_details ? "DEMAND | B:" + format_vol(b_v) + " S:" + format_vol(s_v) : ""
    box mb = box.new(bar_index[lookback], z_top, bar_index + extend_len, z_bottom, bgcolor=color.new(col_bull, 90), border_color=col_bull, text=info, text_color=white, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
    box bvb = na, box svb = na
    if show_vol_details
        bvb := box.new(bar_index[lookback], z_top, bar_index[lookback] + math.round(extend_len * b_ratio), z_bottom, bgcolor=color.new(col_bull, 70), border_color=na)
        svb := box.new(bar_index[lookback] + math.round(extend_len * b_ratio), z_top, bar_index + extend_len, z_bottom, bgcolor=color.new(col_bear, 70), border_color=na)
    array.push(zones, Zone.new(main_box=mb, buy_vol_box=bvb, sell_vol_box=svb, top=z_top, bottom=z_bottom, buy_vol=b_v, sell_vol=s_v, is_bull=true, is_fvg=false, active=true, start_bar=bar_index[lookback]))

// FVG Detection
bull_fvg = show_fvg and low > high[2] and close[1] > high[2] and (not filter_by_trend or trend_is_bull[1])
bear_fvg = show_fvg and high < low[2] and close[1] < low[2] and (not filter_by_trend or trend_is_bear[1])

if bull_fvg
    [b_v, s_v] = get_precise_vol(1)
    float z_t = low, z_b = high[2]
    float b_ratio = (b_v + s_v) > 0 ? b_v / (b_v + s_v) : 0.5
    string info = show_vol_details ? "BULL FVG | B:" + format_vol(b_v) + " S:" + format_vol(s_v) : ""
    box mb = box.new(bar_index - 1, z_t, bar_index + extend_len, z_b, bgcolor=color.new(col_bull, 90), border_color=dark, text=info, text_color=white, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
    box bvb = na, box svb = na
    if show_vol_details
        bvb := box.new(bar_index - 1, z_t, bar_index - 1 + math.round(extend_len * b_ratio), z_b, bgcolor=color.new(col_bull, 70), border_color=na)
        svb := box.new(bar_index - 1 + math.round(extend_len * b_ratio), z_t, bar_index + extend_len, z_b, bgcolor=color.new(col_bear, 70), border_color=na)
    array.push(zones, Zone.new(main_box=mb, buy_vol_box=bvb, sell_vol_box=svb, top=z_t, bottom=z_b, buy_vol=b_v, sell_vol=s_v, is_bull=true, is_fvg=true, active=true, start_bar=bar_index - 1))

if bear_fvg
    [b_v, s_v] = get_precise_vol(1)
    float z_t = low[2], z_b = high
    float b_ratio = (b_v + s_v) > 0 ? b_v / (b_v + s_v) : 0.5
    string info = show_vol_details ? "BEAR FVG | B:" + format_vol(b_v) + " S:" + format_vol(s_v) : ""
    box mb = box.new(bar_index - 1, z_t, bar_index + extend_len, z_b, bgcolor=color.new(col_bear, 90), border_color=dark, text=info, text_color=white, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
    box bvb = na, box svb = na
    if show_vol_details
        bvb := box.new(bar_index - 1, z_t, bar_index - 1 + math.round(extend_len * b_ratio), z_b, bgcolor=color.new(col_bull, 70), border_color=na)
        svb := box.new(bar_index - 1 + math.round(extend_len * b_ratio), z_t, bar_index + extend_len, z_b, bgcolor=color.new(col_bear, 70), border_color=na)
    array.push(zones, Zone.new(main_box=mb, buy_vol_box=bvb, sell_vol_box=svb, top=z_t, bottom=z_b, buy_vol=b_v, sell_vol=s_v, is_bull=false, is_fvg=true, active=true, start_bar=bar_index - 1))

//════════════════════════════════════════════════════════════════════════
// MITIGATION LOGIC
//════════════════════════════════════════════════════════════════════════
if array.size(zones) > 0
    for i = array.size(zones) - 1 to 0
        Zone z = array.get(zones, i)
        if z.active
            int target_r = bar_index + 10
            box.set_right(z.main_box, target_r)
            if not na(z.buy_vol_box)
                float b_ratio = z.buy_vol / (z.buy_vol + z.sell_vol)
                int split_x = z.start_bar + math.round((target_r - z.start_bar) * b_ratio)
                box.set_right(z.buy_vol_box, split_x)
                box.set_left(z.sell_vol_box, split_x)
                box.set_right(z.sell_vol_box, target_r)
            bool mit = z.is_bull ? low < z.bottom : high > z.top
            if mit
                z.active := false
                int mit_r = bar_index
                box.set_right(z.main_box, mit_r)
                if not na(z.buy_vol_box)
                    float b_ratio = z.buy_vol / (z.buy_vol + z.sell_vol)
                    int split_x = z.start_bar + math.round((mit_r - z.start_bar) * b_ratio)
                    box.set_right(z.buy_vol_box, split_x)
                    box.set_left(z.sell_vol_box, split_x)
                    box.set_right(z.sell_vol_box, mit_r)
                if show_mitigated
                    box.set_bgcolor(z.main_box, color.new(mitigated_color, 90))
                    box.set_border_color(z.main_box,color.new( mitigated_color,40))
                    if not na(z.buy_vol_box)
                        box.set_bgcolor(z.buy_vol_box, color.new(mitigated_color, 60))
                        box.set_bgcolor(z.sell_vol_box, color.new(dark, 80))
                else
                    box.delete(z.main_box)
                    box.delete(z.buy_vol_box)
                    box.delete(z.sell_vol_box)

if array.size(zones) > max_zones
    Zone old = array.shift(zones)
    box.delete(old.main_box)
    box.delete(old.buy_vol_box)
    box.delete(old.sell_vol_box)

//════════════════════════════════════════════════════════════════════════
// PREMIUM & DISCOUNT WITH VOLUME PROFILE
//════════════════════════════════════════════════════════════════════════
var box prem_box = na
var box disc_box = na
var line mid_line = na
var box[] vp_boxes = array.new_box()
var line[] vp_lines = array.new_line()
var label[] vp_labels = array.new_label()

if show_pd and barstate.islast and not na(latest_supply_top) and not na(latest_demand_bottom)
    box.delete(prem_box)
    box.delete(disc_box)
    line.delete(mid_line)
    while array.size(vp_boxes) > 0
        box.delete(array.shift(vp_boxes))
    while array.size(vp_lines) > 0
        line.delete(array.shift(vp_lines))
    while array.size(vp_labels) > 0
        label.delete(array.shift(vp_labels))
    float eq = (latest_supply_top + latest_demand_bottom) / 2
    int x1 = bar_index + vp_offset
    int x2 = x1 + vp_width
    prem_box := box.new(x1, latest_supply_top, x2, eq, bgcolor=color.new(col_bear, 92), border_color=color.new(col_bear, 80), text="PREMIUM", text_size=size.auto, text_color=col_bear, text_valign=text.align_top, text_halign=text.align_right)
    disc_box := box.new(x1, eq, x2, latest_demand_bottom, bgcolor=color.new(col_bull, 92), border_color=color.new(col_bull, 80), text="DISCOUNT", text_size=size.auto, text_color=col_bull, text_valign=text.align_bottom, text_halign=text.align_right)
    mid_line := line.new(x1, eq, x2 + 20, eq, color=col_poc, style=line.style_dashed, width=1)
    int start_vp_idx = math.min(latest_supply_idx, latest_demand_idx)
    float highest_p = latest_supply_top, lowest_p = latest_demand_bottom
    float row_h = (highest_p - lowest_p) / vp_rows
    if row_h > 0
        array<float> buckets_total = array.new_float(vp_rows, 0.0)
        array<float> buckets_buy   = array.new_float(vp_rows, 0.0)
        array<float> buckets_sell  = array.new_float(vp_rows, 0.0)
        for i = 0 to (bar_index - start_vp_idx)
            int l_idx = i
            float v_val = volume[l_idx], o_val = open[l_idx], h_val = high[l_idx], l_val = low[l_idx], c_val = close[l_idx]
            bool has_ltf = false
            if not na(ltf_v)
                float[] l_v = ltf_v[l_idx], l_h = ltf_h[l_idx], l_l = ltf_l[l_idx], l_o = ltf_o[l_idx], l_c = ltf_c[l_idx]
                if not na(l_v) and array.size(l_v) > 0
                    has_ltf := true
                    for k = 0 to array.size(l_v) - 1
                        float sub_v = array.get(l_v, k), sub_h = array.get(l_h, k), sub_l = array.get(l_l, k), sub_o = array.get(l_o, k), sub_c = array.get(l_c, k)
                        [sub_bv, sub_sv] = calc_vol_partition(sub_v, sub_o, sub_h, sub_l, sub_c)
                        int b_idx_h = math.min(vp_rows - 1, math.max(0, math.floor((sub_h - lowest_p) / row_h)))
                        int b_idx_l = math.min(vp_rows - 1, math.max(0, math.floor((sub_l - lowest_p) / row_h)))
                        int num_b = math.max(1, b_idx_h - b_idx_l + 1)
                        for j = b_idx_l to b_idx_h
                            array.set(buckets_total, j, array.get(buckets_total, j) + sub_v / num_b)
                            array.set(buckets_buy, j, array.get(buckets_buy, j) + sub_bv / num_b)
                            array.set(buckets_sell, j, array.get(buckets_sell, j) + sub_sv / num_b)
            if not has_ltf
                [hb_v, hs_v] = calc_vol_partition(v_val, o_val, h_val, l_val, c_val)
                int b_idx_h = math.min(vp_rows - 1, math.max(0, math.floor((h_val - lowest_p) / row_h)))
                int b_idx_l = math.min(vp_rows - 1, math.max(0, math.floor((l_val - lowest_p) / row_h)))
                int num_b = math.max(1, b_idx_h - b_idx_l + 1)
                for j = b_idx_l to b_idx_h
                    array.set(buckets_total, j, array.get(buckets_total, j) + v_val / num_b)
                    array.set(buckets_buy, j, array.get(buckets_buy, j) + hb_v / num_b)
                    array.set(buckets_sell, j, array.get(buckets_sell, j) + hs_v / num_b)
        float max_vol = array.max(buckets_total), total_vol = array.sum(buckets_total)
        int poc_idx = array.indexof(buckets_total, max_vol)
        float poc_p = lowest_p + (poc_idx * row_h) + (row_h / 2)
        float va_target = total_vol * 0.7, va_vol = max_vol
        int va_top = poc_idx, va_bot = poc_idx, safety = 0
        while va_vol < va_target and safety < vp_rows
            safety += 1
            float v_up = (va_top < vp_rows - 1) ? array.get(buckets_total, va_top + 1) : 0
            float v_dn = (va_bot > 0) ? array.get(buckets_total, va_bot - 1) : 0
            if v_up >= v_dn and va_top < vp_rows - 1
                va_vol += v_up, va_top += 1
            else if va_bot > 0
                va_vol += v_dn, va_bot -= 1
            else if va_top < vp_rows - 1
                va_vol += v_up, va_top += 1
        float vah_p = lowest_p + (va_top * row_h) + row_h, val_p = lowest_p + (va_bot * row_h)
        for i = 0 to vp_rows - 1
            float b_vol = array.get(buckets_total, i)
            if b_vol > 0
                float b_buy = array.get(buckets_buy, i), b_sell = array.get(buckets_sell, i), b_delta = b_buy - b_sell
                float b_top = lowest_p + (i * row_h) + row_h, b_bot = lowest_p + (i * row_h)
                int b_len = math.round(vp_width * (b_vol / max_vol))
                bool is_va = (i >= va_bot and i <= va_top)
                color base_c = b_delta >= 0 ? col_bull : col_bear
                int transp = math.round(80 - (b_vol / max_vol) * 60)
                color bar_col = color.new(base_c, is_va ? math.max(0, transp - 20) : transp)
                string vp_text = format_vol(b_vol) + " (Δ:" + (b_delta >= 0 ? "+" : "") + format_vol(b_delta) + ")"
                array.push(vp_boxes, box.new(x1, b_top, x1 + b_len, b_bot, bgcolor=bar_col, border_color=na, text=vp_text, text_size=size.auto, text_color=white))
        array.push(vp_lines, line.new(x1, poc_p, x2 + 20, poc_p, color=col_poc, width=2))
        array.push(vp_labels, label.new(x2 + 20, poc_p, "POC: " + format_vol(max_vol), style=label.style_label_left, color=color.new(dark, 100), textcolor=col_poc, size=size.small))
        array.push(vp_lines, line.new(x1, vah_p, x2 + 10, vah_p, color=white, style=line.style_dotted))
        array.push(vp_labels, label.new(x2 + 10, vah_p, "VAH", style=label.style_label_left, color=color.new(dark, 100), textcolor=white, size=size.small))
        array.push(vp_lines, line.new(x1, val_p, x2 + 10, val_p, color=white, style=line.style_dotted))
        array.push(vp_labels, label.new(x2 + 10, val_p, "VAL", style=label.style_label_left, color=color.new(dark, 100), textcolor=white, size=size.small))

