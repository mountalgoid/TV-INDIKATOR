color_theme = input.string(defval = 'DEX Deep', title = 'Select Color Theme', options = ['Bookmap System Theme', 'Spartan Edge Theme', 'MountAlgo Themes', 'MountAlgo Neon', 'MountAlgo Frost', 'MountAlgo Cyber', 'Standard Spartan Edge Theme', 'Dark ICT Theme', 'Garuda Gold', 'MountAlgo Super Premium Theme', 'MountAlgo Orange White Theme', 'DEX Deep', 'Deep Sea', 'Gear Protocol'], group=GlobalGroup)

// Core Colors
color dark   = #000000
color white  = #c4d3ff
color green  = #179c74
color purple = #5134ff
color gray   = #62647a
color red    = #f23645
color yellow = #f3ba2f
color orange = #ff9800
color blue   = #1848cc
color brown  = #8b4513
color Transparent_Color = color.new(white, 100)

color col_bull = switch color_theme
    'Bookmap System Theme' => #a1ff3b
    'Spartan Edge Theme' => red
    'MountAlgo Themes' => purple
    'MountAlgo Neon' => #5134ff
    'MountAlgo Frost' => #5134ff
    'MountAlgo Cyber' => #1848cc
    'Standard Spartan Edge Theme' => green
    'Dark ICT Theme' => green
    'Garuda Gold' => yellow
    'MountAlgo Super Premium Theme' => purple
    'MountAlgo Orange White Theme' => orange
    'DEX Deep' => #a1ff3b
    'Deep Sea' => blue
    'Gear Protocol' => white
    => blue

color col_bear = switch color_theme
    'Bookmap System Theme' => #ff009a
    'Spartan Edge Theme' => gray
    'MountAlgo Themes' => green
    'MountAlgo Neon' => #ff009a
    'MountAlgo Frost' => #00e5ff
    'MountAlgo Cyber' => #ff009a
    'Standard Spartan Edge Theme' => red
    'Dark ICT Theme' => gray
    'Garuda Gold' => gray
    'MountAlgo Super Premium Theme' => yellow
    'MountAlgo Orange White Theme' => gray
    'DEX Deep' => #ff009a
    'Deep Sea' => gray
    'Gear Protocol' => gray
    => white

color col_poc = switch color_theme
    'Bookmap System Theme' => white
    'Spartan Edge Theme' => white
    'MountAlgo Themes' => white
    'MountAlgo Neon' => white
    'MountAlgo Frost' => white
    'MountAlgo Cyber' => white
    'Standard Spartan Edge Theme' => white
    'Dark ICT Theme' => white
    'Garuda Gold' => white
    'MountAlgo Super Premium Theme' => white
    'MountAlgo Orange White Theme' => white
    'DEX Deep' => white
    'Deep Sea' => white
    => white

color box_col_bull = color.new(col_bull, 85)
color box_col_bear = color.new(col_bear, 85)
color glass_glow_color = col_bear

//════════════════════════════════════════════════════════════════════════
// 1.5 GLOBAL HUD HELPERS
//════════════════════════════════════════════════════════════════════════
f_set_cell(tbl, c, r, txt, bg_color, txt_color) =>
    table.cell(tbl, c, r, txt, bgcolor=bg_color, text_color=txt_color, text_size=size.small, text_halign=c == 0 ? text.align_left : text.align_right)

f_get_hud_table_bg(c, r, total_c, total_r, col_bull_in, col_bear_in, dark_in) =>
    float ratio = (1.0 * c / math.max(1, total_c - 1) + 1.0 * r / math.max(1, total_r - 1)) / 2
    color base = color.from_gradient(ratio, 0, 1, col_bull_in, col_bear_in)
    color mixed_base = color.from_gradient(60, 0, 100, base, dark_in)
    color.new(mixed_base, 25)

//════════════════════════════════════════════════════════════════════════
// 2. INPUTS & CONFIGURATION
//════════════════════════════════════════════════════════════════════════
string grp_gann = "Gann Fan Pro Configuration"
gann_mode       = input.string("Auto Pivot", "Gann Anchor Mode", options=["Auto Pivot", "Manual Anchor"], group=grp_gann)
pivot_len       = input.int(10, "Auto Pivot Sensitivity (Bars)", minval=2, group=grp_gann)
manual_offset   = input.int(50, "Manual Anchor Offset (Bars Back)", minval=0, group=grp_gann)
manual_price    = input.float(0.0, "Manual Anchor Price (0 for Auto)", group=grp_gann)
manual_dir      = input.string("Bullish", "Manual Fan Direction", options=["Bullish", "Bearish"], group=grp_gann)
gann_scale_mode = input.string("Auto", "Gann Scale Mode", options=["Auto", "Manual"], group=grp_gann)
manual_scale    = input.float(1.0, "Manual Scale (Points per bar)", group=grp_gann)
gann_length     = input.int(150, "Gann Fan Ray Length (Bars)", minval=10, maxval=2000, group=grp_gann)
gann_style      = input.string("Solid", "Gann Ray Line Style", options=["Solid", "Dashed", "Dotted"], group=grp_gann)
gann_width      = input.int(1, "Gann Ray Line Width", minval=1, maxval=5, group=grp_gann)

show_ray_1x8    = input.bool(true, "Show 1x8 Ray", group=grp_gann)
show_ray_1x4    = input.bool(true, "Show 1x4 Ray", group=grp_gann)
show_ray_1x3    = input.bool(true, "Show 1x3 Ray", group=grp_gann)
show_ray_1x2    = input.bool(true, "Show 1x2 Ray", group=grp_gann)
show_ray_1x1    = input.bool(true, "Show 1x1 Ray", group=grp_gann)
show_ray_2x1    = input.bool(true, "Show 2x1 Ray", group=grp_gann)
show_ray_3x1    = input.bool(true, "Show 3x1 Ray", group=grp_gann)
show_ray_4x1    = input.bool(true, "Show 4x1 Ray", group=grp_gann)
show_ray_8x1    = input.bool(true, "Show 8x1 Ray", group=grp_gann)

string grp_vp   = "Volume Profile Grid Settings"
lookback        = input.int(200, "Lookback Window Length (Bars)", minval=10, maxval=3000, group=grp_vp, tooltip="The historical range ending at the Gann Fan anchor bar to calculate the volume profile.")
vp_resolution   = input.int(25, 'Profile Resolution (Rows)', minval=5, maxval=100, group=grp_vp)
vp_va_perc      = input.float(70.0, 'Value Area Volume %', minval=10.0, maxval=100.0, step=5.0, group=grp_vp)
max_blocks      = input.int(10, 'Max Blocks (Horizontal Width)', minval=3, maxval=25, group=grp_vp)
show_block_values = input.bool(false, "Show Volume Values inside Boxes", group=grp_vp)

string grp_grid = "Grid & Glass Aesthetics"
block_style     = input.string("Classic Glass Grid", "Block Style Mode", options=["Classic Glass Grid", "Theme Gradient", "Delta Volume"], group=grp_grid)
block_step      = input.int(2, "Block Horizontal Step (Bars)", minval=1, maxval=5, group=grp_grid)
block_size      = input.int(1, "Block Width (Bars)", minval=1, maxval=5, group=grp_grid)
gap_y_perc      = input.float(12.0, "Vertical Block Gap (%)", minval=0.0, maxval=49.0, step=2.0, group=grp_grid)
border_width_in = input.int(1, "Block Border Width", minval=0, maxval=3, group=grp_grid)
show_va_box     = input.bool(true, "Show Glass Value Area Container", group=grp_grid)
va_trans_in     = input.int(85, "Value Area Transparency", minval=30, maxval=98, group=grp_grid)
show_stats_boxes = input.bool(true, "Show Session Stats Boxes", group=grp_grid)
delta_box_width  = input.int(8, "Delta Box Width (Bars)", minval=2, maxval=20, group=grp_grid)

string grp_disp = "Display Controls"
show_poc_line   = input.bool(true, "Show POC Projected Line", group=grp_disp)
show_vah_val_lines = input.bool(true, "Show VAH/VAL Projected Lines", group=grp_disp)
show_labels     = input.bool(true, "Show VAH/VAL/POC Labels", group=grp_disp)
vp_h_offset     = input.int(12, "Horizontal Grid Offset (Bars)", minval=0, group=grp_disp)
show_hvn_lvn    = input.bool(true, "Identify HVN and LVN", group=grp_disp)
show_large_vol  = input.bool(true, "Show Large Volume Levels", group=grp_disp)
large_vol_mult  = input.float(1.5, "Large Volume Multiplier", minval=1.0, step=0.1, group=grp_disp)
show_table      = input.bool(true, "Show Glass HUD Table", group=grp_disp)
hud_position    = input.string("bottom_left", "HUD Table Position", options=["top_left", "top_right", "bottom_left", "bottom_right"], group=grp_disp)
show_logo       = input.bool(true, "Show Animated Logo", group="Logo Settings")

string grp_ltf_c  = "LTF Candle Plotting Settings"
show_ltf_candle   = input.bool(true, "Show LTF Plot Candles", group=grp_ltf_c)
ltf_candle_style  = input.string("Regular Theme Candles", "LTF Candle Plot Style", options=["Regular Theme Candles", "Custom Glass Candles"], group=grp_ltf_c)

//════════════════════════════════════════════════════════════════════════
// 4. PRECISION VOLUME PARTITIONING
//════════════════════════════════════════════════════════════════════════
distribute_bar_vol(int _rows, float _lowest_p, float _inv_row_h, float _o, float _h, float _l, float _c, float _v_total, float[] _bucket_total, float[] _bucket_buy, float[] _bucket_sell) =>
    float b_high = math.max(_o, _c)
    float b_low  = math.min(_o, _c)
    float _range_val = _h - _l
    int max_idx = _rows - 1

    if max_idx >= 0
        if _range_val <= 0
            int idx = math.min(max_idx, math.max(0, math.floor((_c - _lowest_p) * _inv_row_h)))
            array.set(_bucket_total, idx, array.get(_bucket_total, idx) + _v_total)
            float v_half = _v_total * 0.5
            array.set(_bucket_buy, idx, array.get(_bucket_buy, idx) + v_half)
            array.set(_bucket_sell, idx, array.get(_bucket_sell, idx) + v_half)
        else
            float inv_range = 1.0 / _range_val
            float w_l = (b_low - _l) * inv_range
            float w_b = (b_high - b_low) * inv_range
            float w_u = (_h - b_high) * inv_range

            float v_l = _v_total * w_l
            float v_b = _v_total * w_b
            float v_u = _v_total * w_u

            float b_center = (_o + _c) * 0.5
            float body_pos = (b_center - _l) * inv_range

            float br_b = _c > _o ? math.min(0.9, 0.6 + body_pos * 0.3) : (_c < _o ? math.max(0.1, 0.4 - (1.0 - body_pos) * 0.3) : 0.5)

            if v_l > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((_l - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_l / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.90
                    float v_j_sell = v_j * 0.10
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_b > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_b / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * br_b
                    float v_j_sell = v_j * (1.0 - br_b)
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_u > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((_h - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_u / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.10
                    float v_j_sell = v_j * 0.90
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)

//════════════════════════════════════════════════════════════════════════
// 5. STORAGE & CLEANUP
//════════════════════════════════════════════════════════════════════════
var box[] grid_boxes     = array.new<box>()
var box[] container_boxes = array.new<box>()
var line[] level_lines   = array.new<line>()
var label[] level_labels = array.new<label>()
var box[] ltf_candle_boxes = array.new<box>()

f_cleanup_drawings() =>
    while array.size(grid_boxes) > 0
        box.delete(array.pop(grid_boxes))
    while array.size(container_boxes) > 0
        box.delete(array.pop(container_boxes))
    while array.size(level_lines) > 0
        line.delete(array.pop(level_lines))
    while array.size(level_labels) > 0
        label.delete(array.pop(level_labels))

//════════════════════════════════════════════════════════════════════════
// 6. VOLUME PROFILE GRID RENDER
//════════════════════════════════════════════════════════════════════════
f_formatNumber(float number) =>
    float abs_number = math.abs(number)
    if abs_number >= 1000000
        str.tostring(number / 1000000, "#.##") + "M"
    else if abs_number >= 1000
        str.tostring(number / 1000, "#.#") + "K"
    else
        str.tostring(number, "#")

get_alphabet_letter(int idx) =>
    int code = idx % 26
    switch code
        0 => "A"
        1 => "B"
        2 => "C"
        3 => "D"
        4 => "E"
        5 => "F"
        6 => "G"
        7 => "H"
        8 => "I"
        9 => "J"
        10 => "K"
        11 => "L"
        12 => "M"
        13 => "N"
        14 => "O"
        15 => "P"
        16 => "Q"
        17 => "R"
        18 => "S"
        19 => "T"
        20 => "U"
        21 => "V"
        22 => "W"
        23 => "X"
        24 => "Y"
        25 => "Z"
        => ""

//════════════════════════════════════════════════════════════════════════
// 7. GANN FAN PRO CALCULATION & ANCHOR IDENTIFICATION
//════════════════════════════════════════════════════════════════════════
ph = ta.pivothigh(high, pivot_len, pivot_len)
pl = ta.pivotlow(low, pivot_len, pivot_len)

var int anchor_bar = na
var float anchor_price = na
var int anchor_dir = 1

if not na(ph)
    anchor_bar := bar_index - pivot_len
    anchor_price := ph
    anchor_dir := -1
if not na(pl) and (na(ph) or bar_index - pivot_len > anchor_bar)
    anchor_bar := bar_index - pivot_len
    anchor_price := pl
    anchor_dir := 1

int active_anchor_bar = gann_mode == "Manual Anchor" ? (bar_index - manual_offset) : anchor_bar
float active_anchor_price = gann_mode == "Manual Anchor" ? (manual_price == 0.0 ? close[manual_offset] : manual_price) : anchor_price
int active_anchor_dir = gann_mode == "Manual Anchor" ? (manual_dir == "Bullish" ? 1 : -1) : anchor_dir

float auto_scale = (ta.highest(high, 100) - ta.lowest(low, 100)) / 100
float active_scale = gann_scale_mode == "Auto" ? auto_scale : manual_scale

// Execute profile renders and Gann Fan drawing on the last bar
var float rt_total_vol = 0.0
var float rt_max_vol = 0.0
var float rt_poc_price = na
var float rt_vah_price = na
var float rt_val_price = na

f_draw_gann_ray_clipped(int x1, float y1, int length, float scale, int direction, float ratio, string name, color col, string style_str, int width, float y_min, float y_max, line[] level_lines, label[] level_labels) =>
    int x2 = x1 + length
    float m = direction * scale * ratio
    float y2 = y1 + m * length

    float x_clipped = x2
    float y_clipped = y2

    if m != 0.0
        if y2 > y_max
            x_clipped := x1 + (y_max - y1) / m
            y_clipped := y_max
        else if y2 < y_min
            x_clipped := x1 + (y_min - y1) / m
            y_clipped := y_min

    int x2_clipped = math.round(x_clipped)

    style_val = switch style_str
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

    line l = line.new(x1, y1, x2_clipped, y_clipped, color=col, style=style_val, width=width)
    label lbl = label.new(x2_clipped, y_clipped, name, color=color.new(#c4d3ff, 100), textcolor=col, style=label.style_none, size=size.tiny)

    array.push(level_lines, l)
    array.push(level_labels, lbl)

if barstate.islast and not na(active_anchor_bar) and not na(active_anchor_price)
    f_cleanup_drawings()

    // --- 1. CALCULATE GANN FAN FRAME BOUNDARIES ---
    int anchor_offset = bar_index - active_anchor_bar
    float gann_high = high[anchor_offset]
    float gann_low = low[anchor_offset]
    int max_i = math.min(anchor_offset, gann_length)
    if max_i > 0
        for i = 0 to max_i
            gann_high := math.max(gann_high, high[anchor_offset - i])
            gann_low := math.min(gann_low, low[anchor_offset - i])

    // Draw Gann Fan Frame Boundary
    box gann_frame = box.new(left=active_anchor_bar, top=gann_high, right=active_anchor_bar + gann_length, bottom=gann_low, bgcolor=color.new(dark, 95), border_color=color.new(white, 70), border_width=1)
    array.push(container_boxes, gann_frame)

    // --- 2. GANN FAN CLIPPED RAYS DRAWING ---
    color gann_col_up = col_bull
    color gann_col_dn = col_bear
    color gann_col_main = col_poc
    color active_gann_color = active_anchor_dir == 1 ? gann_col_up : gann_col_dn

    if show_ray_1x8
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, gann_length, active_scale, active_anchor_dir, 0.125, "1x8", active_gann_color, gann_style, gann_width, gann_low, gann_high, level_lines, level_labels)
    if show_ray_1x4
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, gann_length, active_scale, active_anchor_dir, 0.25, "1x4", active_gann_color, gann_style, gann_width, gann_low, gann_high, level_lines, level_labels)
    if show_ray_1x3
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, gann_length, active_scale, active_anchor_dir, 0.333, "1x3", active_gann_color, gann_style, gann_width, gann_low, gann_high, level_lines, level_labels)
    if show_ray_1x2
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, gann_length, active_scale, active_anchor_dir, 0.5, "1x2", active_gann_color, gann_style, gann_width, gann_low, gann_high, level_lines, level_labels)
    if show_ray_1x1
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, gann_length, active_scale, active_anchor_dir, 1.0, "1x1", gann_col_main, gann_style, gann_width + 1, gann_low, gann_high, level_lines, level_labels)
    if show_ray_2x1
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, gann_length, active_scale, active_anchor_dir, 2.0, "2x1", active_gann_color, gann_style, gann_width, gann_low, gann_high, level_lines, level_labels)
    if show_ray_3x1
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, gann_length, active_scale, active_anchor_dir, 3.0, "3x1", active_gann_color, gann_style, gann_width, gann_low, gann_high, level_lines, level_labels)
    if show_ray_4x1
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, gann_length, active_scale, active_anchor_dir, 4.0, "4x1", active_gann_color, gann_style, gann_width, gann_low, gann_high, level_lines, level_labels)
    if show_ray_8x1
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, gann_length, active_scale, active_anchor_dir, 8.0, "8x1", active_gann_color, gann_style, gann_width, gann_low, gann_high, level_lines, level_labels)

    // --- 3. VOLUME PROFILE CALCULATION (Ending exactly at active_anchor_bar) ---
    int actual_lookback = math.min(lookback, active_anchor_bar + 1)
    float vp_high = gann_high
    float vp_low = gann_low

    float range_p = vp_high - vp_low
    float row_h = range_p > 0 ? range_p / vp_resolution : syminfo.mintick * 10
    float inv_row_h = 1.0 / row_h

    bucket_total = array.new_float(vp_resolution, 0.0)
    bucket_buy   = array.new_float(vp_resolution, 0.0)
    bucket_sell  = array.new_float(vp_resolution, 0.0)

    for i = 0 to actual_lookback - 1
        int idx = anchor_offset + i
        // If idx is 0, we can use the latest live realtime prices and volume which updates on every tick
        float o_price = idx == 0 ? open : open[idx]
        float h_price = idx == 0 ? high : high[idx]
        float l_price = idx == 0 ? low : low[idx]
        float c_price = idx == 0 ? close : close[idx]
        float v_val = idx == 0 ? volume : nz(volume[idx])
        distribute_bar_vol(vp_resolution, vp_low, inv_row_h, o_price, h_price, l_price, c_price, v_val, bucket_total, bucket_buy, bucket_sell)

    float max_vol = array.max(bucket_total)
    float total_vol = array.sum(bucket_total)
    float total_buy_vol = array.sum(bucket_buy)
    float total_sell_vol = array.sum(bucket_sell)
    float total_delta_vol = total_buy_vol - total_sell_vol
    int poc_idx = array.indexof(bucket_total, max_vol)

    // Value Area Calculation
    int va_top = poc_idx
    int va_bot = poc_idx
    float target_va = total_vol * (vp_va_perc / 100.0)
    float va_vol = max_vol

    int loop_safety = 0
    while va_vol < target_va and loop_safety < vp_resolution
        loop_safety += 1
        float v_up = (va_top < vp_resolution - 1) ? array.get(bucket_total, va_top + 1) : 0.0
        float v_dn = (va_bot > 0) ? array.get(bucket_total, va_bot - 1) : 0.0
        if v_up >= v_dn and va_top < vp_resolution - 1
            va_vol += v_up
            va_top += 1
        else if va_bot > 0
            va_vol += v_dn
            va_bot -= 1
        else if va_top < vp_resolution - 1
            va_vol += v_up
            va_top += 1

    float vah_price = vp_low + (va_top + 1) * row_h
    float val_price = vp_low + va_bot * row_h
    float poc_price = vp_low + poc_idx * row_h + (row_h / 2)

    rt_total_vol := total_vol
    rt_max_vol := max_vol
    rt_poc_price := poc_price
    rt_vah_price := vah_price
    rt_val_price := val_price

    // --- 4. VOLUME PROFILE GLASS GRID RENDERING (Positioned left of Gann anchor) ---
    int profile_spine_x = active_anchor_bar - 2
    int profile_left_boundary = profile_spine_x - max_blocks * block_step

    // Bounding Frame Box
    box session_frame = box.new(left=profile_left_boundary - 5, top=vp_high, right=profile_spine_x, bottom=vp_low, bgcolor=color.new(dark, 94), border_color=color.new(white, 80), border_width=1)
    array.push(container_boxes, session_frame)

    // Vertical Spine Line
    line left_spine = line.new(profile_spine_x, vp_low, profile_spine_x, vp_high, color=color.new(white, 40), width=3)
    array.push(level_lines, left_spine)

    // Render Stats Boxes Above and Below the profile frame if enabled
    if show_stats_boxes
        color buy_col_theme  = color.new(col_bull, 85)
        color sell_col_theme = color.new(col_bear, 85)
        color delta_col_theme = total_delta_vol >= 0 ? color.new(col_bull, 85) : color.new(col_bear, 85)
        color border_theme_c = color.new(white, 70)

        string str_buy_val   = "Buy: " + f_formatNumber(total_buy_vol)
        string str_sell_val  = "Sell: " + f_formatNumber(total_sell_vol)
        string str_delta_val = "Δ: " + (total_delta_vol >= 0 ? "+" : "") + f_formatNumber(total_delta_vol)

        float stats_box_h = row_h * 1.5
        int buy_box_left   = profile_left_boundary
        int buy_box_right  = buy_box_left
        int sell_box_left  = buy_box_left
        int sell_box_right = buy_box_left
        int delta_box_left  = profile_spine_x - delta_box_width
        int delta_box_right = profile_spine_x

        int remaining_width = math.max(0, delta_box_left - buy_box_left)
        float total_buysell_sum = total_buy_vol + total_sell_vol
        if total_buysell_sum > 0
            int computed_buy_w = math.round(remaining_width * (total_buy_vol / total_buysell_sum))
            buy_box_right  := buy_box_left + computed_buy_w
            sell_box_left  := buy_box_right
            sell_box_right := delta_box_left
        else
            int half_w = math.round(remaining_width * 0.5)
            buy_box_right  := buy_box_left + half_w
            sell_box_left  := buy_box_right
            sell_box_right := delta_box_left

        if total_delta_vol < 0
            float top_box_y1 = vp_high + stats_box_h
            float top_box_y2 = vp_high
            if buy_box_right > buy_box_left
                box top_buy_b = box.new(left=buy_box_left, top=top_box_y1, right=buy_box_right, bottom=top_box_y2, bgcolor=buy_col_theme, border_color=border_theme_c, border_width=1, text=str_buy_val, text_color=white, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
                array.push(container_boxes, top_buy_b)
            if sell_box_right > sell_box_left
                box top_sell_b = box.new(left=sell_box_left, top=top_box_y1, right=sell_box_right, bottom=top_box_y2, bgcolor=sell_col_theme, border_color=border_theme_c, border_width=1, text=str_sell_val, text_color=white, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
                array.push(container_boxes, top_sell_b)
            if delta_box_right > delta_box_left
                box top_delta_b = box.new(left=delta_box_left, top=top_box_y1, right=delta_box_right, bottom=top_box_y2, bgcolor=delta_col_theme, border_color=border_theme_c, border_width=1, text=str_delta_val, text_color=white, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
                array.push(container_boxes, top_delta_b)
        else
            float btm_box_y1 = vp_low
            float btm_box_y2 = vp_low - stats_box_h
            if buy_box_right > buy_box_left
                box btm_buy_b = box.new(left=buy_box_left, top=btm_box_y1, right=buy_box_right, bottom=btm_box_y2, bgcolor=buy_col_theme, border_color=border_theme_c, border_width=1, text=str_buy_val, text_color=white, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
                array.push(container_boxes, btm_buy_b)
            if sell_box_right > sell_box_left
                box btm_sell_b = box.new(left=sell_box_left, top=btm_box_y1, right=sell_box_right, bottom=btm_box_y2, bgcolor=sell_col_theme, border_color=border_theme_c, border_width=1, text=str_sell_val, text_color=white, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
                array.push(container_boxes, btm_sell_b)
            if delta_box_right > delta_box_left
                box btm_delta_b = box.new(left=delta_box_left, top=btm_box_y1, right=delta_box_right, bottom=btm_box_y2, bgcolor=delta_col_theme, border_color=border_theme_c, border_width=1, text=str_delta_val, text_color=white, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
                array.push(container_boxes, btm_delta_b)

    // Draw Glass Blocks
    float pad_y = row_h * (gap_y_perc / 100.0)
    int box_draw_count = 0

    for r = 0 to vp_resolution - 1
        float r_tot_vol = array.get(bucket_total, r)
        if r_tot_vol > 0
            float r_buy_vol = array.get(bucket_buy, r)
            float r_sell_vol = array.get(bucket_sell, r)
            float r_delta = r_buy_vol - r_sell_vol

            float p_level_bot = vp_low + r * row_h
            float p_level_top = p_level_bot + row_h

            int num_blocks_to_draw = math.round((r_tot_vol / max_vol) * max_blocks)
            num_blocks_to_draw := math.max(1, math.min(max_blocks, num_blocks_to_draw))

            // Identify Large Volume levels dynamically
            if show_large_vol
                float avg_vol = total_vol / vp_resolution
                if r_tot_vol > avg_vol * large_vol_mult
                    color line_col = r_buy_vol >= r_sell_vol ? col_bull : col_bear
                    float center_p = p_level_bot + row_h / 2
                    line lg_vol_ln = line.new(profile_left_boundary, center_p, profile_spine_x, center_p, color=line_col, width=3, style=line.style_dotted)
                    array.push(level_lines, lg_vol_ln)

            for b = 0 to num_blocks_to_draw - 1
                int x_right = profile_spine_x - b * block_step
                int x_left = x_right - block_size

                color blk_fill = color.new(#ffffff, 0)
                color blk_border = color.new(#ffffff, 0)

                if block_style == "Classic Glass Grid"
                    if r == poc_idx
                        blk_fill := color.new(col_bear, 0)
                        blk_border := color.new(col_bear, 0)
                    else
                        blk_fill := color.new(#ffffff, 0)
                        blk_border := color.new(#ffffff, 0)
                else if block_style == "Theme Gradient"
                    float buy_ratio = r_tot_vol > 0 ? r_buy_vol / r_tot_vol : 0.5
                    color mix_base = color.from_gradient(buy_ratio, 0, 1, col_bear, col_bull)
                    blk_fill := color.new(mix_base, 0)
                    blk_border := color.new(mix_base, 0)
                else if block_style == "Delta Volume"
                    color mix_base = r_delta >= 0 ? col_bull : col_bear
                    blk_fill := color.new(mix_base, 0)
                    blk_border := color.new(mix_base, 0)

                // Highlight HVN / LVNs uniquely as premium full-width translucent area boxes
                if show_hvn_lvn and r != poc_idx and b == 0
                    float avg_vol = total_vol / vp_resolution
                    bool is_hvn = false
                    bool is_lvn = false
                    if r > 0 and r < vp_resolution - 1
                        float prev_v = array.get(bucket_total, r - 1)
                        float next_v = array.get(bucket_total, r + 1)
                        if r_tot_vol > prev_v and r_tot_vol > next_v and r_tot_vol > avg_vol * 1.3
                            is_hvn := true
                        if r_tot_vol < prev_v and r_tot_vol < next_v and r_tot_vol < avg_vol * 0.5
                            is_lvn := true

                    if is_hvn
                        box hvn_box = box.new(left=profile_left_boundary, top=p_level_top, right=profile_spine_x, bottom=p_level_bot, bgcolor=color.new(col_bull, 0), border_color=color.new(col_bull, 0), border_width=1, border_style=line.style_solid, text="HVN", text_color=dark, text_size=size.tiny, text_halign=text.align_center, text_valign=text.align_center)
                        array.push(container_boxes, hvn_box)
                    else if is_lvn
                        box lvn_box = box.new(left=profile_left_boundary, top=p_level_top, right=profile_spine_x, bottom=p_level_bot, bgcolor=color.new(col_bear, 0), border_color=color.new(col_bear, 0), border_width=1, border_style=line.style_dashed, text="LVN", text_color=dark, text_size=size.tiny, text_halign=text.align_center, text_valign=text.align_center)
                        array.push(container_boxes, lvn_box)

                string blk_text = show_block_values ? f_formatNumber(r_tot_vol) : get_alphabet_letter(box_draw_count)
                box_draw_count += 1
                color blk_text_color = dark
                box blk = box.new(left=x_left, top=p_level_top - pad_y, right=x_right, bottom=p_level_bot + pad_y, bgcolor=blk_fill, border_color=blk_border, border_width=border_width_in, text=blk_text, text_color=blk_text_color, text_size=size.auto, text_halign=text.align_center, text_valign=text.align_center)
                array.push(grid_boxes, blk)

    // Render Glowing Value Area Container Glass Box
    if show_va_box
        color container_bg = color.new(#7a113a, va_trans_in)
        if color_theme != "DEX Deep"
            container_bg := color.new(col_bear, va_trans_in)

        box glass_container = box.new(left=profile_left_boundary, top=vah_price, right=profile_spine_x, bottom=val_price, bgcolor=container_bg, border_color=color.new(glass_glow_color, 45), border_width=2)
        array.push(container_boxes, glass_container)

    // Projected Lines & Labels (terminating at the Gann start line)
    int end_line_bar = active_anchor_bar
    if show_poc_line
        line poc_ln = line.new(profile_left_boundary, poc_price, end_line_bar, poc_price, color=color.new(col_bear, 10), width=1)
        array.push(level_lines, poc_ln)
    if show_vah_val_lines
        line vah_ln = line.new(profile_left_boundary, vah_price, end_line_bar, vah_price, color=color.new(col_bull, 20), width=1, style=line.style_dashed)
        line val_ln = line.new(profile_left_boundary, val_price, end_line_bar, val_price, color=color.new(col_bear, 20), width=1, style=line.style_dashed)
        array.push(level_lines, vah_ln)
        array.push(level_lines, val_ln)
    if show_labels
        label lbl_poc = label.new(end_line_bar, poc_price, "POC: " + str.tostring(poc_price, format.mintick) + " (" + f_formatNumber(max_vol) + ")", color=color.new(col_bear, 100), textcolor=col_bear, size=size.tiny, style=label.style_label_left)
        label lbl_vah = label.new(end_line_bar, vah_price, "VAH: " + str.tostring(vah_price, format.mintick), color=color.new(col_bull, 100), textcolor=col_bull, size=size.tiny, style=label.style_label_left)
        label lbl_val = label.new(end_line_bar, val_price, "VAL: " + str.tostring(val_price, format.mintick), color=color.new(col_bear, 100), textcolor=col_bear, size=size.tiny, style=label.style_label_left)
        array.push(level_labels, lbl_poc)
        array.push(level_labels, lbl_vah)
        array.push(level_labels, lbl_val)

//════════════════════════════════════════════════════════════════════════
// 8. GLASS HUD TABLE DASHBOARD
//════════════════════════════════════════════════════════════════════════
var table info_table = na
if show_table and barstate.islast
    string pos = switch hud_position
        "top_left"     => position.top_left
        "top_right"    => position.top_right
        "bottom_left"  => position.bottom_left
        "bottom_right" => position.bottom_right
        => position.bottom_left

    if na(info_table)
        info_table := table.new(pos, 2, 7, bgcolor=color.new(dark, 100), border_width=1, border_color=color.new(col_poc, 90), frame_color=color.new(brown, 40), frame_width=1)

    table.merge_cells(info_table, 0, 0, 1, 0)
    table.cell(info_table, 0, 0, "GANN FAN & VP PRO | " + str.tostring(syminfo.ticker), bgcolor=color.new(brown, 75), text_color=white, text_size=size.normal, text_formatting=text.format_bold)

    f_set_cell(info_table, 0, 1, "Lookback Window Length", f_get_hud_table_bg(0, 1, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 1, str.tostring(lookback), f_get_hud_table_bg(1, 1, 2, 7, col_bull, col_bear, dark), col_poc)

    f_set_cell(info_table, 0, 2, "Anchor Price", f_get_hud_table_bg(0, 2, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 2, str.tostring(active_anchor_price, format.mintick), f_get_hud_table_bg(1, 2, 2, 7, col_bull, col_bear, dark), col_bull)

    f_set_cell(info_table, 0, 3, "Total Volume Profile", f_get_hud_table_bg(0, 3, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 3, f_formatNumber(rt_total_vol), f_get_hud_table_bg(1, 3, 2, 7, col_bull, col_bear, dark), col_bull)

    f_set_cell(info_table, 0, 4, "Value Area High (VAH)", f_get_hud_table_bg(0, 4, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 4, str.tostring(rt_vah_price, format.mintick), f_get_hud_table_bg(1, 4, 2, 7, col_bull, col_bear, dark), col_bull)

    f_set_cell(info_table, 0, 5, "Point of Control (POC)", f_get_hud_table_bg(0, 5, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 5, str.tostring(rt_poc_price, format.mintick), f_get_hud_table_bg(1, 5, 2, 7, col_bull, col_bear, dark), col_bear)

    f_set_cell(info_table, 0, 6, "Value Area Low (VAL)", f_get_hud_table_bg(0, 6, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 6, str.tostring(rt_val_price, format.mintick), f_get_hud_table_bg(1, 6, 2, 7, col_bull, col_bear, dark), col_bear)

//═══════════════════════════════════════════════════════════════════════════════
// 8.5 LTF PLOT CANDLE IMPLEMENTATION
//═══════════════════════════════════════════════════════════════════════════════
color ltf_base_col = close >= open ? col_bull : col_bear
color ltf_col_body = color.new(ltf_base_col, 80)
color ltf_col_wick = ltf_base_col

bool use_regular_plot = show_ltf_candle and ltf_candle_style == "Regular Theme Candles"
float ltf_p_open  = use_regular_plot ? open : na
float ltf_p_high  = use_regular_plot ? high : na
float ltf_p_low   = use_regular_plot ? low : na
float ltf_p_close = use_regular_plot ? close : na

plotcandle(ltf_p_open, ltf_p_high, ltf_p_low, ltf_p_close, color=ltf_col_body, wickcolor=ltf_col_wick, bordercolor=ltf_col_wick, title="LTF Theme Candle")

var box rt_body_bx = na
var box rt_wick_bx = na

if show_ltf_candle and ltf_candle_style == "Custom Glass Candles"
    if barstate.isconfirmed
        box body_bx = box.new(left=bar_index, top=math.max(open, close), right=bar_index + 1, bottom=math.min(open, close), bgcolor=ltf_col_body, border_color=color.new(ltf_base_col, 65), border_width=1)
        box wick_bx = box.new(left=bar_index, top=high, right=bar_index, bottom=low, bgcolor=ltf_col_body, border_color=color.new(ltf_base_col, 65), border_width=1)
        array.push(ltf_candle_boxes, body_bx)
        array.push(ltf_candle_boxes, wick_bx)
        if array.size(ltf_candle_boxes) > 300
            box.delete(array.shift(ltf_candle_boxes))
            box.delete(array.shift(ltf_candle_boxes))
    else if barstate.isrealtime
        if not na(rt_body_bx)
            box.delete(rt_body_bx)
        if not na(rt_wick_bx)
            box.delete(rt_wick_bx)
        rt_body_bx := box.new(left=bar_index, top=math.max(open, close), right=bar_index + 1, bottom=math.min(open, close), bgcolor=ltf_col_body, border_color=color.new(ltf_base_col, 65), border_width=1)
        rt_wick_bx := box.new(left=bar_index, top=high, right=bar_index, bottom=low, bgcolor=ltf_col_body, border_color=color.new(ltf_base_col, 65), border_width=1)

//═══════════════════════════════════════════════════════════════════════════════
// 9. LOGO GRADIENT ENHANCED (BREATHING MOUNTALGO BRAND SYSTEM)
//═══════════════════════════════════════════════════════════════════════════════
color bull_c1 = col_bull
color bull_c2 = col_bear
color bear_c1 = col_bull
color bear_c2 = col_bear

bool  trend_check = ta.ema(close, 2) > ta.ema(open, 2)
color c_start     = trend_check ? bull_c1 : bear_c1
color c_end       = trend_check ? bull_c2 : bear_c2

float time_cycle = timenow / 1000
float breathe    = (math.sin(time_cycle * 3) + 1) / 2

int LG_Line_Widthb = 1
int periodb        = 200

float logo_base_raw = ta.lowest(low, periodb)
float logo_range    = ta.highest(high, periodb) - logo_base_raw
var float h_unit    = na

float target_h = math.max(ta.atr(periodb) * 1.5, logo_range * 0.22)
h_unit := na(h_unit) ? target_h : h_unit * 0.98 + target_h * 0.02
float logo_base = logo_base_raw - h_unit * 0.2

float point1b  = logo_base + h_unit * 0.71
float point2b  = logo_base + h_unit * 0.43
float point3b  = logo_base + h_unit * 0.61
float point4b  = logo_base + h_unit * 0.32
float point5b  = logo_base + h_unit * 1.00
float point6b  = logo_base + h_unit * 0.71
float point7b  = logo_base + h_unit * 0.18
float point8b  = logo_base + h_unit * 0.21
float point9b  = logo_base + h_unit * 0.71
float point1b0 = logo_base + h_unit * 0.86

var line Line1b  = na
var line Line2b  = na
var line Line3b  = na
var line Line4b  = na
var line Line5b  = na
var line Line6b  = na
var line Line7b  = na
var line Line8b  = na
var line Line9b  = na
var line Line1b0 = na
var line Line1b1 = na
var line Line1b2 = na
var line Line1b3 = na
var line Line1b4 = na
var line Line1b5 = na
var line Line1b6 = na
var line Line1b7 = na
var line Line1b8 = na
var label[] brand_labels = array.new<label>()

if barstate.islast
    line.delete(Line1b)
    line.delete(Line2b)
    line.delete(Line3b)
    line.delete(Line4b)
    line.delete(Line5b)
    line.delete(Line6b)
    line.delete(Line7b)
    line.delete(Line8b)
    line.delete(Line9b)
    line.delete(Line1b0)
    line.delete(Line1b1)
    line.delete(Line1b2)
    line.delete(Line1b3)
    line.delete(Line1b4)
    line.delete(Line1b5)
    line.delete(Line1b6)
    line.delete(Line1b7)
    line.delete(Line1b8)
    while array.size(brand_labels) > 0
        label.delete(array.pop(brand_labels))

get_adv_color(step) =>
    float ratio = step / 18.0
    float dynamic_ratio = ratio + (breathe * 0.15)
    if dynamic_ratio > 1
        dynamic_ratio := 1
    color.from_gradient(dynamic_ratio, 0, 1, c_start, c_end)

get_fade_alpha(float x_rel) =>
    float dist = math.abs(x_rel - 32)
    float ratio = dist / 32.0
    math.round(80 * (1 - ratio))

int logo_offset = vp_h_offset + max_blocks * block_step + 42

if show_logo and barstate.islast
    color c_head_sync = get_adv_color(1)

    Line1b := line.new(x1 = bar_index + logo_offset + 4, y1 = point7b, x2 = bar_index + logo_offset + 11, y2 = point1b, color = col_poc, width = LG_Line_Widthb)
    Line2b := line.new(x1 = bar_index + logo_offset + 8, y1 = point7b, x2 = bar_index + logo_offset + 11, y2 = point2b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b, Line2b, color = color.new(c_head_sync, get_fade_alpha(7.5)))

    Line3b := line.new(x1 = bar_index + logo_offset + 11, y1 = point1b, x2 = bar_index + logo_offset + 13, y2 = point3b, color = col_poc, width = LG_Line_Widthb)
    Line4b := line.new(x1 = bar_index + logo_offset + 11, y1 = point2b, x2 = bar_index + logo_offset + 13, y2 = point4b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line3b, Line4b, color = color.new(get_adv_color(3), get_fade_alpha(12.0)))

    Line5b := line.new(x1 = bar_index + logo_offset + 13, y1 = point3b, x2 = bar_index + logo_offset + 19, y2 = point5b, color = col_poc, width = LG_Line_Widthb)
    Line6b := line.new(x1 = bar_index + logo_offset + 13, y1 = point4b, x2 = bar_index + logo_offset + 19, y2 = point6b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line5b, Line6b, color = color.new(get_adv_color(5), get_fade_alpha(16.0)))

    Line7b := line.new(x1 = bar_index + logo_offset + 19, y1 = point5b, x2 = bar_index + logo_offset + 24, y2 = point3b, color = col_poc, width = LG_Line_Widthb)
    Line8b := line.new(x1 = bar_index + logo_offset + 19, y1 = point6b, x2 = bar_index + logo_offset + 24, y2 = point4b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line7b, Line8b, color = color.new(get_adv_color(7), get_fade_alpha(21.5)))

    Line9b := line.new(x1 = bar_index + logo_offset + 24, y1 = point3b, x2 = bar_index + logo_offset + 26, y2 = point1b, color = col_poc, width = LG_Line_Widthb)
    Line1b0 := line.new(x1 = bar_index + logo_offset + 24, y1 = point4b, x2 = bar_index + logo_offset + 26, y2 = point2b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line9b, Line1b0, color = color.new(get_adv_color(9), get_fade_alpha(25.0)))

    Line1b1 := line.new(x1 = bar_index + logo_offset + 26, y1 = point1b, x2 = bar_index + logo_offset + 36, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b2 := line.new(x1 = bar_index + logo_offset + 26, y1 = point2b, x2 = bar_index + logo_offset + 32, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b1, Line1b2, color = color.new(get_adv_color(11), get_fade_alpha(31.0)))

    Line1b3 := line.new(x1 = bar_index + logo_offset + 2, y1 = point7b, x2 = bar_index + logo_offset + 26, y2 = point7b, color = col_poc, width = LG_Line_Widthb)
    Line1b4 := line.new(x1 = bar_index + logo_offset + 0, y1 = logo_base, x2 = bar_index + logo_offset + 24, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b3, Line1b4, color = color.new(c_head_sync, get_fade_alpha(13.0)))

    Line1b5 := line.new(x1 = bar_index + logo_offset + 2, y1 = point7b, x2 = bar_index + logo_offset + 0, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b6 := line.new(x1 = bar_index + logo_offset + 26, y1 = point7b, x2 = bar_index + logo_offset + 24, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b7 := line.new(x1 = bar_index + logo_offset + 32, y1 = logo_base, x2 = bar_index + logo_offset + 36, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)

    label l = label.new(bar_index + logo_offset + 54, point2b, "𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤\nGANN FAN & VP GLASS PRO", style=label.style_none, textcolor=col_poc, size=size.normal)
    array.push(brand_labels, l)

    label glow1 = label.new(bar_index + logo_offset + 13, point1b0, "●", style=label.style_none, textcolor=color.new(get_adv_color(2), get_fade_alpha(13.0)), size=size.huge)
    label glow2 = label.new(bar_index + logo_offset + 13, point1b0, "〇", style=label.style_none, textcolor=col_poc, size=size.huge)
    array.push(brand_labels, glow1)
    array.push(brand_labels, glow2)
