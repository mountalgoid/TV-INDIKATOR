// Effective Theme Colors
color col_bull_eff = col_bull
color col_bear_eff = col_bear
color col_poc_eff  = col_poc
color col_va_eff   = color.new(col_poc, 20)
color spine_col    = color.new(white, 50)

// ===== WINDOW LOGIC =====
windowStart = int(bar_index / length) * length
isWindowEnd = bar_index == windowStart + length - 1

// Track exact highest high, lowest low, and their occurrences within the current window segment
var float windowHi = na
var float windowLo = na
var int segment_hi_bar = na
var int segment_lo_bar = na

if bar_index == windowStart
    windowHi := high
    windowLo := low
    segment_hi_bar := bar_index
    segment_lo_bar := bar_index
else
    if high >= windowHi
        windowHi := high
        segment_hi_bar := bar_index
    if low <= windowLo
        windowLo := low
        segment_lo_bar := bar_index

hi_val = na(windowHi) ? high : windowHi
lo_val = na(windowLo) ? low : windowLo

// ===== STORAGE =====
var array<float> volBins  = array.new_float(rows, 0.0)
var array<float> buyBins  = array.new_float(rows, 0.0)
var array<float> sellBins = array.new_float(rows, 0.0)

// Storage for "Live" objects (to clean and redraw)
var array<box> liveBoxes   = array.new_box(0)
var array<line> liveLines  = array.new_line(0)
var array<label> liveLabels = array.new_label(0)

// Heuristic Volume Partitioning
calc_vol_partition(float vol) =>
    float range_size = high - low
    float b_vol = 0.0
    float s_vol = 0.0

    if range_size > 0
        float b_high = math.max(open, close)
        float b_low  = math.min(open, close)
        float body_size = b_high - b_low
        float upper_wick = high - b_high
        float lower_wick = b_low - low

        float w_body = body_size / range_size
        float w_upper = upper_wick / range_size
        float w_lower = lower_wick / range_size

        float b_center = (open + close) / 2
        float body_pos = (b_center - low) / range_size
        float br_b = close > open ? math.min(0.9, 0.6 + body_pos * 0.3) : (close < open ? math.max(0.1, 0.4 - (1-body_pos) * 0.3) : 0.5)

        b_vol := vol * (w_body * br_b + w_lower * 0.9 + w_upper * 0.1)
        s_vol := vol * (w_body * (1 - br_b) + w_upper * 0.9 + w_lower * 0.1)
    else
        b_vol := vol * 0.5
        s_vol := vol * 0.5
    [b_vol, s_vol]

// Distribution Heuristic for Profile Bins
distribute_vol(int _rows, float _lowest_p, float _inv_row_h, float _o, float _h, float _l, float _c, float _v_total, array<float> _bucket_total, array<float> _bucket_buy, array<float> _bucket_sell) =>
    float b_high = math.max(_o, _c)
    float b_low  = math.min(_o, _c)
    float _range_val = _h - _l
    int max_idx = _rows - 1

    if max_idx >= 0
        if _range_val <= 0
            int idx = math.min(max_idx, math.max(0, math.floor((_c - _lowest_p) * _inv_row_h)))
            array.set(_bucket_total, idx, array.get(_bucket_total, idx) + _v_total)
            float v_half = _v_total * 0.5
            array.set(_bucket_buy, idx, array.get(_bucket_buy, idx) + v_half)
            array.set(_bucket_sell, idx, array.get(_bucket_sell, idx) + v_half)
        else
            float inv_range = 1.0 / _range_val
            float w_l = (b_low - _l) * inv_range
            float w_b = (b_high - b_low) * inv_range
            float w_u = (_h - b_high) * inv_range

            float v_l = _v_total * w_l
            float v_b = _v_total * w_b
            float v_u = _v_total * w_u

            float b_center = (_o + _c) * 0.5
            float body_pos = (b_center - _l) * inv_range

            float br_b = _c > _o ? math.min(0.9, 0.6 + body_pos * 0.3) : (_c < _o ? math.max(0.1, 0.4 - (1-body_pos) * 0.3) : 0.5)

            if v_l > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((_l - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_l / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.90
                    float v_j_sell = v_j * 0.10
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_b > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_b / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * br_b
                    float v_j_sell = v_j * (1.0 - br_b)
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_u > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((_h - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_u / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.10
                    float v_j_sell = v_j * 0.90
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)

// ===== LTF PRECISION ENGINE =====
get_ltf_v() =>
    [b, s] = calc_vol_partition(volume)
    [open, high, low, close, volume, b, s]

[ltf_o, ltf_h, ltf_l, ltf_c, ltf_v, ltf_b, ltf_s] = request.security_lower_tf(syminfo.tickerid, "1", get_ltf_v())

// ===== GLOBAL POC & CUSTOM CANDLE CALCULATION =====
var array<float> localVolBins  = array.new_float(rows, 0.0)
var array<float> localBuyBins  = array.new_float(rows, 0.0)
var array<float> localSellBins = array.new_float(rows, 0.0)

// Range and segment change tracking
var float last_hi = na
var float last_lo = na
bool range_changed = (hi_val != last_hi) or (lo_val != last_lo)

float local_rng = math.max(hi_val - lo_val, syminfo.mintick * 10)
float local_step = local_rng / rows
float local_inv_step = 1.0 / local_step

bool needs_calculations = (candle_mode == "Based Previous POC") or (candle_mode == "Based Current POC") or (candle_mode == "Based Previous VAH/VAL")

float curr_poc = na
float curr_vah = na
float curr_val = na

if needs_calculations
    if bar_index == windowStart or range_changed
        // Recalculate full segment up to current bar because range changed or segment reset
        array.fill(localVolBins, 0.0)
        array.fill(localBuyBins, 0.0)
        array.fill(localSellBins, 0.0)

        int local_currentLen = bar_index - windowStart + 1
        for i = 0 to local_currentLen - 1
            distribute_vol(rows, lo_val, local_inv_step, open[i], high[i], low[i], close[i], volume[i], localVolBins, localBuyBins, localSellBins)

        last_hi := hi_val
        last_lo := lo_val
    else
        // Range didn't change! Just incrementally add the current bar's volume
        distribute_vol(rows, lo_val, local_inv_step, open, high, low, close, volume, localVolBins, localBuyBins, localSellBins)

    float local_maxVol = array.max(localVolBins)
    int local_pocIdx = array.indexof(localVolBins, local_maxVol)
    curr_poc := lo_val + (local_pocIdx * local_step) + (local_step * 0.5)

    // ===== VAH & VAL LOGIC =====
    float curr_totalVol = array.sum(localVolBins)
    float targetVA = curr_totalVol * va_pct
    float currentVA = local_maxVol
    int hIdx = local_pocIdx
    int lIdx = local_pocIdx

    int loopC = 0
    while currentVA < targetVA and loopC < rows
        float vUp = (hIdx < rows - 1) ? array.get(localVolBins, hIdx + 1) : 0.0
        float vDn = (lIdx > 0) ? array.get(localVolBins, lIdx - 1) : 0.0
        if vUp >= vDn and hIdx < rows - 1
            currentVA += vUp
            hIdx := math.min(rows - 1, hIdx + 1)
        else if lIdx > 0
            currentVA += vDn
            lIdx := math.max(0, lIdx - 1)
        else if hIdx < rows - 1
            currentVA += vUp
            hIdx := math.min(rows - 1, hIdx + 1)
        loopC += 1

    curr_vah := lo_val + ((hIdx + 1) * local_step)
    curr_val := lo_val + (lIdx * local_step)

// Persistent Previous POC & VAH/VAL tracking across window segments
var float prev_poc = na
var float last_finished_poc = na

var float prev_vah = na
var float last_finished_vah = na

var float prev_val = na
var float last_finished_val = na

if bar_index == windowStart and bar_index > 0
    prev_poc := last_finished_poc
    prev_vah := last_finished_vah
    prev_val := last_finished_val

if isWindowEnd
    last_finished_poc := curr_poc
    last_finished_vah := curr_vah
    last_finished_val := curr_val

// Calculate custom candle state
bool is_bull = false
if candle_mode == "Based Normal"
    is_bull := close >= open
else if candle_mode == "Based Previous POC"
    is_bull := na(prev_poc) ? (close >= open) : (close >= prev_poc)
else if candle_mode == "Based Current POC"
    is_bull := close >= curr_poc
else if candle_mode == "Based Previous VAH/VAL"
    if na(prev_vah) or na(prev_val)
        is_bull := close >= open
    else if close >= prev_vah
        is_bull := true
    else if close <= prev_val
        is_bull := false
    else
        is_bull := close >= open
else if candle_mode == "Based Delta Volume"
    [b_v, s_v] = calc_vol_partition(volume)
    is_bull := b_v >= s_v

plot_candle_body = show_candles ? (is_bull ? color.new(col_bull_eff, 80) : color.new(col_bear_eff, 80)) : na
plot_candle_wick = show_candles ? (is_bull ? col_bull_eff : col_bear_eff) : na

plotcandle(open, high, low, close, title="Custom Volume Profile Candles",
           color=plot_candle_body, wickcolor=plot_candle_wick, bordercolor=plot_candle_wick)

// Volume formatting helper function
format_vol(float v) =>
    float abs_v = math.abs(v)
    string res = ""
    if abs_v >= 1000000000
        res := str.tostring(v / 1000000000, "#.##") + "B"
    else if abs_v >= 1000000
        res := str.tostring(v / 1000000, "#.##") + "M"
    else if abs_v >= 1000
        res := str.tostring(v / 1000, "#.#") + "K"
    else
        res := str.tostring(v, "0.##")
    res

// Real-time HUD and calculations state
var float rt_total_vol = 0.0
var float rt_max_vol = 0.0
var float rt_poc_price = na
var float rt_vah_price = na
var float rt_val_price = na

//════════════════════════════════════════════════════════════════════════
// 3. GANN FAN DRAWING AND CLIPPING UTILITY
//════════════════════════════════════════════════════════════════════════
f_draw_gann_ray_clipped(x1, y1, len_val, scale, direction, ratio, name, col, style_str, width, y_min, y_max, level_lines, level_labels) =>
    int x2 = x1 + len_val
    float m = direction * scale * ratio
    float y2 = y1 + m * len_val
    
    float x_clipped = float(x2)
    float y_clipped = y2
    
    if m != 0.0
        if y2 > y_max
            x_clipped := x1 + (y_max - y1) / m
            y_clipped := y_max
        else if y2 < y_min
            x_clipped := x1 + (y_min - y1) / m
            y_clipped := y_min
            
    int x2_clipped = math.round(x_clipped)
    
    style_val = switch style_str
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid
        
    line l = line.new(x1, y1, x2_clipped, y_clipped, color=col, style=style_val, width=width)
    label lbl = label.new(x2_clipped, y_clipped, name, color=color.new(#c4d3ff, 100), textcolor=col, style=label.style_none, size=size.tiny)
    
    if not na(level_lines)
        array.push(level_lines, l)
    if not na(level_labels)
        array.push(level_labels, lbl)

// ===== FUNGSI GAMBAR (DRAWING FUNCTION) =====
draw_profile(bool is_live) =>
    // Jika Live, hapus dulu gambar detik sebelumnya agar tidak numpuk
    if is_live
        while array.size(liveBoxes) > 0
            box.delete(array.pop(liveBoxes))
        while array.size(liveLines) > 0
            line.delete(array.pop(liveLines))
        while array.size(liveLabels) > 0
            label.delete(array.pop(liveLabels))

    // 1. CALCULATE HIGH-PRECISION DYNAMIC VOLUME PROFILE
    array.fill(volBins, 0.0)
    array.fill(buyBins, 0.0)
    array.fill(sellBins, 0.0)

    float rng = math.max(hi_val - lo_val, syminfo.mintick * 10)
    float step = rng / rows
    float inv_step = 1.0 / step
    int currentLen = bar_index - windowStart + 1

    if is_live
        // Distribute historical bars of the current window segment
        if currentLen > 1
            for i = 1 to currentLen - 1
                distribute_vol(rows, lo_val, inv_step, open[i], high[i], low[i], close[i], volume[i], volBins, buyBins, sellBins)

        // Distribute the live bar using precise LTF 1m data
        int ltf_count = not na(ltf_v) ? array.size(ltf_v) : 0
        float ltf_v_total = 0.0
        if ltf_count > 0
            for j = 0 to ltf_count - 1
                float _o = array.get(ltf_o, j)
                float _h = array.get(ltf_h, j)
                float _l = array.get(ltf_l, j)
                float _c = array.get(ltf_c, j)
                float _v = array.get(ltf_v, j)
                ltf_v_total += _v
                distribute_vol(rows, lo_val, inv_step, _o, _h, _l, _c, _v, volBins, buyBins, sellBins)

        // Accumulate missing volume if real-time feeds are faster than LTF ticks
        float missing_v = math.max(0, volume - ltf_v_total)
        if missing_v > 0
            distribute_vol(rows, lo_val, inv_step, open, high, low, close, missing_v, volBins, buyBins, sellBins)
    else
        // Historical finished window segment
        for i = 0 to currentLen - 1
            distribute_vol(rows, lo_val, inv_step, open[i], high[i], low[i], close[i], volume[i], volBins, buyBins, sellBins)

    maxVol   = array.max(volBins)
    totalVol = array.sum(volBins)
    maxWidth = int(length * width_pct)

    // 2. DRAW SPINE & OUTER PROFILE FRAME BOX
    l_spine = line.new(windowStart, lo_val, windowStart, hi_val, color=spine_col, width=4)
    b_frame = box.new(left=windowStart, bottom=lo_val, right=windowStart + length, top=hi_val,
                      bgcolor=na, border_color=color.new(spine_col, 60), border_width=1, border_style=line.style_solid)
    if is_live
        array.push(liveLines, l_spine)
        array.push(liveBoxes, b_frame)

    prevX = windowStart
    prevY = lo_val

    // 3. DRAW PROFILE ROWS
    for r = 0 to rows - 1
        v = array.get(volBins, r)
        pct = maxVol == 0 ? 0 : v / maxVol

        // Heatmap & Theme Logic
        color c_base = na
        float r_delta = 0.0
        if vp_type == "Delta"
            float r_buy = array.get(buyBins, r)
            float r_sell = array.get(sellBins, r)
            r_delta := r_buy - r_sell
            c_base := r_delta > 0 ? col_bull_eff : col_bear_eff
        else
            c_base := color.from_gradient(r, 0, rows - 1, col_bull_eff, col_bear_eff)

        // Fully transparent profile box background and border for 0 opacity clean design
        color c_fill_heatmap = color.new(c_base, 100)
        color c_border_heatmap = color.new(c_base, 100)

        // Coordinates
        currX = windowStart + int(pct * maxWidth)
        y_bot = lo_val + (r * step)
        y_top = lo_val + ((r + 1) * step)
        currY_center = lo_val + (r * step) + (step * 0.5)

        // Draw Fill with volume text & clean borders
        if currX > windowStart
            string row_txt = format_vol(v)
            if vp_type == "Delta"
                row_txt += " | " + (r_delta >= 0 ? "+" : "") + format_vol(r_delta)

            // Text color unconditionally set to dark for high contrast aesthetic transparency
            color row_text_color = dark

            b = box.new(left=windowStart, bottom=y_bot, right=currX, top=y_top,
                        bgcolor=c_fill_heatmap, border_color=c_border_heatmap, border_width=0,
                        text=row_txt, text_color=row_text_color, text_size=size.auto,
                        text_halign=text.align_left, text_valign=text.align_center)
            if is_live
                array.push(liveBoxes, b)

        // Draw Outline curve
        l = line.new(prevX, prevY, currX, currY_center, color=c_base, width=2)
        if is_live
            array.push(liveLines, l)

        prevX := currX
        prevY := currY_center

    // Draw Top Cap
    l_top = line.new(prevX, prevY, windowStart, hi_val, color=col_bear_eff, width=2)
    if is_live
        array.push(liveLines, l_top)

    // ===== POC & VA LOGIC =====
    pocIdx = array.indexof(volBins, maxVol)
    targetVA = totalVol * va_pct
    currentVA = maxVol
    hIdx = pocIdx
    lIdx = pocIdx

    loopC = 0
    while currentVA < targetVA and loopC < rows
        vUp = (hIdx < rows - 1) ? array.get(volBins, hIdx + 1) : 0.0
        vDn = (lIdx > 0) ? array.get(volBins, lIdx - 1) : 0.0
        if vUp >= vDn and hIdx < rows - 1
            currentVA += vUp
            hIdx := math.min(rows - 1, hIdx + 1)
        else if lIdx > 0
            currentVA += vDn
            lIdx := math.max(0, lIdx - 1)
        else if hIdx < rows - 1
            currentVA += vUp
            hIdx := math.min(rows - 1, hIdx + 1)
        loopC += 1

    pocPrice = lo_val + (pocIdx * step) + (step * 0.5)
    vahPrice = lo_val + ((hIdx + 1) * step)
    valPrice = lo_val + (lIdx * step)

    // Draw solid levels lines
    if show_poc_line
        l_poc = line.new(windowStart, pocPrice, windowStart + length, pocPrice, color=col_poc_eff, width=3, style=line.style_solid)
        if is_live
            array.push(liveLines, l_poc)
    if show_vah_val_lines
        l_vah = line.new(windowStart, vahPrice, windowStart + length, vahPrice, color=col_va_eff, style=line.style_solid, width=1)
        l_val = line.new(windowStart, valPrice, windowStart + length, valPrice, color=col_va_eff, style=line.style_solid, width=1)
        if is_live
            array.push(liveLines, l_vah)
            array.push(liveLines, l_val)

    // Draw highly aesthetic subtle backgrounds for VAH-to-Top and VAL-to-Bottom regions
    color top_bg = color.new(col_bear_eff, 96)
    color bot_bg = color.new(col_bull_eff, 96)

    b_vah_top = box.new(left=windowStart, top=hi_val, right=windowStart + length, bottom=vahPrice,
                        bgcolor=top_bg, border_color=na)
    b_val_bot = box.new(left=windowStart, top=valPrice, right=windowStart + length, bottom=lo_val,
                        bgcolor=bot_bg, border_color=na)

    if is_live
        array.push(liveBoxes, b_vah_top)
        array.push(liveBoxes, b_val_bot)

    // Boundaries for right badges
    boxLeft = windowStart + length
    boxRight = windowStart + length + int(length * 0.12)
    box_height_half = step * 0.4
    color badge_bg = color.new(#0c0d12, 15) // Deep contrast background

    // Draw elegant VAH/VAL/POC labels on the right side of the profile window
    if show_labels
        b_poc = box.new(left=boxLeft, top=pocPrice + box_height_half, right=boxRight, bottom=pocPrice - box_height_half,
                        border_color=col_poc_eff, border_width=1, border_style=line.style_solid,
                        bgcolor=col_poc_eff,
                        text="POC\n" + str.tostring(pocPrice, format.mintick), text_color=dark, text_size=size.auto,
                        text_halign=text.align_center, text_valign=text.align_center)

        b_vah = box.new(left=boxLeft, top=vahPrice + box_height_half, right=boxRight, bottom=vahPrice - box_height_half,
                        border_color=col_poc_eff, border_width=1, border_style=line.style_solid,
                        bgcolor=col_poc_eff,
                        text="VAH\n" + str.tostring(vahPrice, format.mintick), text_color=dark, text_size=size.auto,
                        text_halign=text.align_center, text_valign=text.align_center)

        b_val = box.new(left=boxLeft, top=valPrice + box_height_half, right=boxRight, bottom=valPrice - box_height_half,
                        border_color=col_poc_eff, border_width=1, border_style=line.style_solid,
                        bgcolor=col_poc_eff,
                        text="VAL\n" + str.tostring(valPrice, format.mintick), text_color=dark, text_size=size.auto,
                        text_halign=text.align_center, text_valign=text.align_center)

        if is_live
            array.push(liveBoxes, b_poc)
            array.push(liveBoxes, b_vah)
            array.push(liveBoxes, b_val)

    // ===== HVN / LVN IDENTIFICATION & DRAWING =====
    // Style and place HVN and LVN badges directly at the right boundary of the volume profile
    if show_lvn_hvn and totalVol > 0
        float avg_profile_vol = array.avg(volBins)
        float thresh_lvn = maxVol * lvn_threshold

        for r = 1 to rows - 2
            float v_prev = array.get(volBins, r - 1)
            float v_curr = array.get(volBins, r)
            float v_next = array.get(volBins, r + 1)

            float y_bot = lo_val + (r * step)
            float y_top = lo_val + ((r + 1) * step)

            // HVN detection (Local Maxima above threshold multiplier of average volume) - Rendered as elegant right badges
            if v_curr > v_prev and v_curr > v_next and v_curr > avg_profile_vol * hvn_threshold and r != pocIdx
                color hvn_border_c = col_bull_eff
                box b_hvn = box.new(left=boxLeft, top=y_top, right=boxRight, bottom=y_bot,
                                    border_color=hvn_border_c, border_width=1, border_style=line.style_solid,
                                    bgcolor=badge_bg, text="HVN", text_color=col_bull_eff, text_size=size.auto,
                                    text_halign=text.align_center, text_valign=text.align_center)
                if is_live
                    array.push(liveBoxes, b_hvn)

            // LVN detection (Local Minima below threshold volume) - Rendered as elegant right badges
            if v_curr < v_prev and v_curr < v_next and v_curr < thresh_lvn
                color lvn_border_c = col_bear_eff
                box b_lvn = box.new(left=boxLeft, top=y_top, right=boxRight, bottom=y_bot,
                                    border_color=lvn_border_c, border_width=1, border_style=line.style_solid,
                                    bgcolor=badge_bg, text="LVN", text_color=col_bear_eff, text_size=size.auto,
                                    text_halign=text.align_center, text_valign=text.align_center)
                if is_live
                    array.push(liveBoxes, b_lvn)

    // ===== AUTOMATIC GANN FAN ANCHOR AND DIRECTION LOGIC =====
    // Anchoring automatically at the absolute pivot point (lowest low / highest high) of the current profile segment
    int active_anchor_bar = segment_lo_bar <= segment_hi_bar ? segment_lo_bar : segment_hi_bar
    float active_anchor_price = segment_lo_bar <= segment_hi_bar ? lo_val : hi_val
    int active_anchor_dir = segment_lo_bar <= segment_hi_bar ? 1 : -1

    // Scale dynamically optimized to ensure beautiful spacing of the fans within the segment boundary
    float active_scale = gann_scale_mode == "Auto" ? (hi_val - lo_val) / (length * 1.5) : manual_scale
    int fan_length = (windowStart + length) - active_anchor_bar

    color gann_col_up = col_bull_eff
    color gann_col_dn = col_bear_eff
    color gann_col_main = col_poc_eff
    color active_gann_color = active_anchor_dir == 1 ? gann_col_up : gann_col_dn

    if show_ray_1x8
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, fan_length, active_scale, active_anchor_dir, 0.125, "1x8", active_gann_color, gann_style, gann_width, lo_val, hi_val, is_live ? liveLines : na, is_live ? liveLabels : na)
    if show_ray_1x4
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, fan_length, active_scale, active_anchor_dir, 0.25, "1x4", active_gann_color, gann_style, gann_width, lo_val, hi_val, is_live ? liveLines : na, is_live ? liveLabels : na)
    if show_ray_1x3
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, fan_length, active_scale, active_anchor_dir, 0.333, "1x3", active_gann_color, gann_style, gann_width, lo_val, hi_val, is_live ? liveLines : na, is_live ? liveLabels : na)
    if show_ray_1x2
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, fan_length, active_scale, active_anchor_dir, 0.5, "1x2", active_gann_color, gann_style, gann_width, lo_val, hi_val, is_live ? liveLines : na, is_live ? liveLabels : na)
    if show_ray_1x1
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, fan_length, active_scale, active_anchor_dir, 1.0, "1x1", gann_col_main, gann_style, gann_width + 1, lo_val, hi_val, is_live ? liveLines : na, is_live ? liveLabels : na)
    if show_ray_2x1
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, fan_length, active_scale, active_anchor_dir, 2.0, "2x1", active_gann_color, gann_style, gann_width, lo_val, hi_val, is_live ? liveLines : na, is_live ? liveLabels : na)
    if show_ray_3x1
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, fan_length, active_scale, active_anchor_dir, 3.0, "3x1", active_gann_color, gann_style, gann_width, lo_val, hi_val, is_live ? liveLines : na, is_live ? liveLabels : na)
    if show_ray_4x1
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, fan_length, active_scale, active_anchor_dir, 4.0, "4x1", active_gann_color, gann_style, gann_width, lo_val, hi_val, is_live ? liveLines : na, is_live ? liveLabels : na)
    if show_ray_8x1
        f_draw_gann_ray_clipped(active_anchor_bar, active_anchor_price, fan_length, active_scale, active_anchor_dir, 8.0, "8x1", active_gann_color, gann_style, gann_width, lo_val, hi_val, is_live ? liveLines : na, is_live ? liveLabels : na)

    [totalVol, maxVol, pocPrice, vahPrice, valPrice]

// ===== EXECUTION LOGIC =====
// Only calculate and draw on the last bar to prevent chart scaling/squeezing and enable perfectly responsive real-time zooming
if barstate.islast
    [tot, mx, poc, vah, val] = draw_profile(true)
    rt_total_vol := tot
    rt_max_vol := mx
    rt_poc_price := poc
    rt_vah_price := vah
    rt_val_price := val

//════════════════════════════════════════════════════════════════════════
// 8. GLASS HUD TABLE DASHBOARD
//════════════════════════════════════════════════════════════════════════
var table info_table = na
if show_table and barstate.islast
    string pos = switch hud_position
        "top_left"     => position.top_left
        "top_right"    => position.top_right
        "bottom_left"  => position.bottom_left
        "bottom_right" => position.bottom_right
        => position.bottom_left

    if na(info_table)
        info_table := table.new(pos, 2, 7, bgcolor=color.new(dark, 100), border_width=1, border_color=color.new(col_poc, 90), frame_color=color.new(brown, 40), frame_width=1)

    table.merge_cells(info_table, 0, 0, 1, 0)
    table.cell(info_table, 0, 0, "GANN FAN & VP PRO | " + str.tostring(syminfo.ticker), bgcolor=color.new(brown, 75), text_color=white, text_size=size.normal, text_formatting=text.format_bold)

    f_set_cell(info_table, 0, 1, "Lookback Window Length", f_get_hud_table_bg(0, 1, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 1, str.tostring(length), f_get_hud_table_bg(1, 1, 2, 7, col_bull, col_bear, dark), col_poc)

    f_set_cell(info_table, 0, 2, "Segment Low Price", f_get_hud_table_bg(0, 2, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 2, str.tostring(lo_val, format.mintick), f_get_hud_table_bg(1, 2, 2, 7, col_bull, col_bear, dark), col_bull)

    f_set_cell(info_table, 0, 3, "Total Volume Profile", f_get_hud_table_bg(0, 3, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 3, format_vol(rt_total_vol), f_get_hud_table_bg(1, 3, 2, 7, col_bull, col_bear, dark), col_bull)

    f_set_cell(info_table, 0, 4, "Value Area High (VAH)", f_get_hud_table_bg(0, 4, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 4, str.tostring(rt_vah_price, format.mintick), f_get_hud_table_bg(1, 4, 2, 7, col_bull, col_bear, dark), col_bull)

    f_set_cell(info_table, 0, 5, "Point of Control (POC)", f_get_hud_table_bg(0, 5, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 5, str.tostring(rt_poc_price, format.mintick), f_get_hud_table_bg(1, 5, 2, 7, col_bull, col_bear, dark), col_bear)

    f_set_cell(info_table, 0, 6, "Value Area Low (VAL)", f_get_hud_table_bg(0, 6, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 6, str.tostring(rt_val_price, format.mintick), f_get_hud_table_bg(1, 6, 2, 7, col_bull, col_bear, dark), col_bear)

//═══════════════════════════════════════════════════════════════════════════════
// 9. LOGO GRADIENT ENHANCED (BREATHING MOUNTALGO BRAND SYSTEM)
//═══════════════════════════════════════════════════════════════════════════════
color bull_c1 = col_bull
color bull_c2 = col_bear
color bear_c1 = col_bull
color bear_c2 = col_bear

bool  trend_check = ta.ema(close, 2) > ta.ema(open, 2)
color c_start     = trend_check ? bull_c1 : bear_c1
color c_end       = trend_check ? bull_c2 : bear_c2

float time_cycle = timenow / 1000
float breathe    = (math.sin(time_cycle * 3) + 1) / 2

int LG_Line_Widthb = 1
int periodb        = 200

float logo_base_raw = ta.lowest(low, periodb)
float logo_range    = ta.highest(high, periodb) - logo_base_raw
var float h_unit    = na

float target_h = math.max(ta.atr(periodb) * 1.5, logo_range * 0.22)
h_unit := na(h_unit) ? target_h : h_unit * 0.98 + target_h * 0.02
float logo_base = logo_base_raw - h_unit * 0.2

float point1b  = logo_base + h_unit * 0.71
float point2b  = logo_base + h_unit * 0.43
float point3b  = logo_base + h_unit * 0.61
float point4b  = logo_base + h_unit * 0.32
float point5b  = logo_base + h_unit * 1.00
float point6b  = logo_base + h_unit * 0.71
float point7b  = logo_base + h_unit * 0.18
float point8b  = logo_base + h_unit * 0.21
float point9b  = logo_base + h_unit * 0.71
float point1b0 = logo_base + h_unit * 0.86

var line Line1b  = na
var line Line2b  = na
var line Line3b  = na
var line Line4b  = na
var line Line5b  = na
var line Line6b  = na
var line Line7b  = na
var line Line8b  = na
var line Line9b  = na
var line Line1b0 = na
var line Line1b1 = na
var line Line1b2 = na
var line Line1b3 = na
var line Line1b4 = na
var line Line1b5 = na
var line Line1b6 = na
var line Line1b7 = na
var line Line1b8 = na
var label[] brand_labels = array.new<label>()

if barstate.islast
    line.delete(Line1b)
    line.delete(Line2b)
    line.delete(Line3b)
    line.delete(Line4b)
    line.delete(Line5b)
    line.delete(Line6b)
    line.delete(Line7b)
    line.delete(Line8b)
    line.delete(Line9b)
    line.delete(Line1b0)
    line.delete(Line1b1)
    line.delete(Line1b2)
    line.delete(Line1b3)
    line.delete(Line1b4)
    line.delete(Line1b5)
    line.delete(Line1b6)
    line.delete(Line1b7)
    line.delete(Line1b8)
    while array.size(brand_labels) > 0
        label.delete(array.pop(brand_labels))

get_adv_color(step) =>
    float ratio = step / 18.0
    float dynamic_ratio = ratio + (breathe * 0.15)
    if dynamic_ratio > 1
        dynamic_ratio := 1
    color.from_gradient(dynamic_ratio, 0, 1, c_start, c_end)

get_fade_alpha(float x_rel) =>
    float dist = math.abs(x_rel - 32)
    float ratio = dist / 32.0
    math.round(80 * (1 - ratio))

int logo_offset = OFF_LOGO

if show_logo and barstate.islast
    color c_head_sync = get_adv_color(1)

    Line1b := line.new(x1 = bar_index + logo_offset + 4, y1 = point7b, x2 = bar_index + logo_offset + 11, y2 = point1b, color = col_poc, width = LG_Line_Widthb)
    Line2b := line.new(x1 = bar_index + logo_offset + 8, y1 = point7b, x2 = bar_index + logo_offset + 11, y2 = point2b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b, Line2b, color = color.new(c_head_sync, get_fade_alpha(7.5)))

    Line3b := line.new(x1 = bar_index + logo_offset + 11, y1 = point1b, x2 = bar_index + logo_offset + 13, y2 = point3b, color = col_poc, width = LG_Line_Widthb)
    Line4b := line.new(x1 = bar_index + logo_offset + 11, y1 = point2b, x2 = bar_index + logo_offset + 13, y2 = point4b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line3b, Line4b, color = color.new(get_adv_color(3), get_fade_alpha(12.0)))

    Line5b := line.new(x1 = bar_index + logo_offset + 13, y1 = point3b, x2 = bar_index + logo_offset + 19, y2 = point5b, color = col_poc, width = LG_Line_Widthb)
    Line6b := line.new(x1 = bar_index + logo_offset + 13, y1 = point4b, x2 = bar_index + logo_offset + 19, y2 = point6b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line5b, Line6b, color = color.new(get_adv_color(5), get_fade_alpha(16.0)))

    Line7b := line.new(x1 = bar_index + logo_offset + 19, y1 = point5b, x2 = bar_index + logo_offset + 24, y2 = point3b, color = col_poc, width = LG_Line_Widthb)
    Line8b := line.new(x1 = bar_index + logo_offset + 19, y1 = point6b, x2 = bar_index + logo_offset + 24, y2 = point4b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line7b, Line8b, color = color.new(get_adv_color(7), get_fade_alpha(21.5)))

    Line9b := line.new(x1 = bar_index + logo_offset + 24, y1 = point3b, x2 = bar_index + logo_offset + 26, y2 = point1b, color = col_poc, width = LG_Line_Widthb)
    Line1b0 := line.new(x1 = bar_index + logo_offset + 24, y1 = point4b, x2 = bar_index + logo_offset + 26, y2 = point2b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line9b, Line1b0, color = color.new(get_adv_color(9), get_fade_alpha(25.0)))

    Line1b1 := line.new(x1 = bar_index + logo_offset + 26, y1 = point1b, x2 = bar_index + logo_offset + 36, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b2 := line.new(x1 = bar_index + logo_offset + 26, y1 = point2b, x2 = bar_index + logo_offset + 32, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b1, Line1b2, color = color.new(get_adv_color(11), get_fade_alpha(31.0)))

    Line1b3 := line.new(x1 = bar_index + logo_offset + 2, y1 = point7b, x2 = bar_index + logo_offset + 26, y2 = point7b, color = col_poc, width = LG_Line_Widthb)
    Line1b4 := line.new(x1 = bar_index + logo_offset + 0, y1 = logo_base, x2 = bar_index + logo_offset + 24, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b3, Line1b4, color = color.new(c_head_sync, get_fade_alpha(13.0)))

    Line1b5 := line.new(x1 = bar_index + logo_offset + 2, y1 = point7b, x2 = bar_index + logo_offset + 0, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b6 := line.new(x1 = bar_index + logo_offset + 26, y1 = point7b, x2 = bar_index + logo_offset + 24, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b7 := line.new(x1 = bar_index + logo_offset + 32, y1 = logo_base, x2 = bar_index + logo_offset + 36, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)

    label l = label.new(bar_index + logo_offset + 54, point2b, "𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤\nGANN FAN & VP GLASS PRO", style=label.style_none, textcolor=col_poc, size=size.normal)
    array.push(brand_labels, l)

    label glow1 = label.new(bar_index + logo_offset + 13, point1b0, "●", style=label.style_none, textcolor=color.new(get_adv_color(2), get_fade_alpha(13.0)), size=size.huge)
    label glow2 = label.new(bar_index + logo_offset + 13, point1b0, "〇", style=label.style_none, textcolor=col_poc, size=size.huge)
    array.push(brand_labels, glow1)
    array.push(brand_labels, glow2)
