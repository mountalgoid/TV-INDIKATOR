//@version=6
indicator("Liquidation Heatmap 𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜ο", shorttitle="Liq Heatmap", overlay=true, max_lines_count=500, max_boxes_count=500, max_bars_back=2000)

// -----------------------------------------------------------------------------
// 0. USER DEFINED TYPES
// -----------------------------------------------------------------------------
type LiqZone
    line t_ln
    line b_ln
    linefill f_id
    float level
    float step
    int strength
    bool is_long_liq
    bool active
    int last_update_bar

// -----------------------------------------------------------------------------
// 1. INPUTS & CONFIGURATION
// -----------------------------------------------------------------------------
string GlobalGroup = "Visual Themes & Global"
string grp_liq    = "Liquidation Boxes"

// --- THEME SYSTEM ---
string color_theme = input.string(defval = 'DEX Deep', title = 'Select Color Theme', options = ['Spartan Edge Theme', 'MountAlgo Themes', 'MountAlgo Neon', 'MountAlgo Frost', 'MountAlgo Cyber', 'Standard Spartan Edge Theme', 'Dark ICT Theme', 'Garuda Gold', 'MountAlgo Super Premium Theme', 'MountAlgo Orange White Theme', 'DEX Deep', 'Deep Sea'], group=GlobalGroup)

// Colors
color dark   = #000000
color white  = #c4d3ff
color green  = #179c74
color purple = #5134ff
color gray   = #62647a
color red    = #f23645
color yellow = #f3ba2f
color orange = #ff9800
color blue   = #1848cc

color col_bull = switch color_theme
    'Spartan Edge Theme' => red
    'MountAlgo Themes' => purple
    'MountAlgo Neon' => #5134ff
    'MountAlgo Frost' => #5134ff
    'MountAlgo Cyber' => #1848cc
    'Standard Spartan Edge Theme' => green
    'Dark ICT Theme' => green
    'Garuda Gold' => yellow
    'MountAlgo Super Premium Theme' => purple
    'MountAlgo Orange White Theme' => orange
    'DEX Deep' => #a1ff3b
    'Deep Sea' => blue
    => blue
color col_bear = switch color_theme
    'Spartan Edge Theme' => gray
    'MountAlgo Themes' => green
    'MountAlgo Neon' => #ff009a
    'MountAlgo Frost' => #00e5ff
    'MountAlgo Cyber' => #ff009a
    'Standard Spartan Edge Theme' => red
    'Dark ICT Theme' => gray
    'Garuda Gold' => gray
    'MountAlgo Super Premium Theme' => yellow
    'MountAlgo Orange White Theme' => gray
    'DEX Deep' => #ff009a
    'Deep Sea' => gray
    => white
color col_poc = switch color_theme
    'Spartan Edge Theme' => white
    'MountAlgo Themes' => white
    'MountAlgo Neon' => white
    'MountAlgo Frost' => white
    'MountAlgo Cyber' => white
    'Standard Spartan Edge Theme' => white
    'Dark ICT Theme' => white
    'Garuda Gold' => white
    'MountAlgo Super Premium Theme' => white
    'MountAlgo Orange White Theme' => white
    'DEX Deep' => white
    'Deep Sea' => white
    => white

color transparent_col = color.new(dark, 100)

// Liquidation Heatmap Settings
bool   auto_mode        = input.bool(true, "Auto Mode (Dynamic Settings)", group=grp_liq)
bool   show_liq_heatmap = input.bool(true, "Show Liquidation Heatmap", group=grp_liq)
string liq_method       = input.string("Volume Profile", "Liquidation Method", options=["Pivots", "Accumulation Base", "Volume Profile"], group=grp_liq)
int    liq_length       = input.int(2, "Pivot Lookback", minval=0, group=grp_liq)
float  heatmap_sens     = input.float(1, "Heatmap Price Step (%)", minval=0.01, step=0.01, group=grp_liq)
float  maint_margin     = input.float(0.5, "Maintenance Margin (%)", minval=0.0, maxval=5.0, step=0.1, group=grp_liq) / 100

// Volume Profile Settings
string grp_vp           = "Volume Profile Settings"
int    vp_period        = input.int(100, "Volume Profile Lookback Period", minval=10, maxval=500, group=grp_vp)
int    vp_resolution    = input.int(50, "Volume Profile Rows", minval=10, maxval=200, group=grp_vp)
string delta_tf         = input.timeframe("1", "Volume Profile Lower Timeframe", group=grp_vp)

// Leverage Multipliers
float lev1 = input.float(25.0, "Leverage 1", group=grp_liq)
float lev2 = input.float(50.0, "Leverage 2", group=grp_liq)
float lev3 = input.float(100.0, "Leverage 3", group=grp_liq)

// -----------------------------------------------------------------------------
// 2. LIQUIDATION HEATMAP ENGINE
// -----------------------------------------------------------------------------
var array<LiqZone> liq_zones = array.new<LiqZone>()
var array<line> liq_lines_hist = array.new_line()
var array<linefill> liq_fills_hist = array.new<linefill>()

// Persistent arrays to track drawing objects for the Volume Profile liquidation system
var array<line> vp_liq_lines = array.new_line()
var array<linefill> vp_liq_fills = array.new<linefill>()

// Precision detection: Multi-bar pivot
float ph = ta.pivothigh(high, liq_length, liq_length)
float pl = ta.pivotlow(low, liq_length, liq_length)

// Accumulation Base Detection
[bb_mid, bb_upper, bb_lower] = ta.bb(close, liq_length, 2)
float bb_width = (bb_upper - bb_lower) / bb_mid
float range_atr = ta.atr(liq_length)
float range_high = ta.highest(high, liq_length)
float range_low = ta.lowest(low, liq_length)
float range_diff = range_high - range_low
bool is_base = range_diff < range_atr * 1.0 and bb_width < ta.sma(bb_width, liq_length * 2)

float base_sum_pv = 0.0
float base_sum_v = 0.0
for i = 0 to liq_length - 1
    float p = (high[i] + low[i] + close[i]) / 3
    float v = volume[i]
    base_sum_pv += p * v
    base_sum_v += v
float base_vwap = base_sum_v > 0 ? base_sum_pv / base_sum_v : (range_high + range_low) / 2

// -----------------------------------------------------------------------------
// Volume Profile Engine Setup
// -----------------------------------------------------------------------------
get_ltf_v() =>
    [open, high, low, close, volume]

// Safety check to prevent unrecoverable runtime crash on charts matching lower timeframe
string safe_ltf = timeframe.isminutes and timeframe.multiplier <= 1 ? "30S" : (timeframe.isseconds ? "1S" : delta_tf)
[ltf_o, ltf_h, ltf_l, ltf_c, ltf_v] = request.security_lower_tf(syminfo.tickerid, safe_ltf, get_ltf_v())

// Sophisticated 3-part wick/body anatomical partitioning heuristic for HTF/fallback
distribute_vol(int _rows, float _lowest_p, float _inv_row_h, float _o, float _h, float _l, float _c, float _v_total, float[] _bucket_total, float[] _bucket_buy, float[] _bucket_sell) =>
    float b_high = math.max(_o, _c)
    float b_low  = math.min(_o, _c)
    float _range_val = _h - _l
    int max_idx = _rows - 1

    if max_idx >= 0
        if _range_val <= 0
            int idx = math.min(max_idx, math.max(0, math.floor((_c - _lowest_p) * _inv_row_h)))
            array.set(_bucket_total, idx, array.get(_bucket_total, idx) + _v_total)
            float v_half = _v_total * 0.5
            array.set(_bucket_buy, idx, array.get(_bucket_buy, idx) + v_half)
            array.set(_bucket_sell, idx, array.get(_bucket_sell, idx) + v_half)
        else
            float inv_range = 1.0 / _range_val
            float w_l = (b_low - _l) * inv_range
            float w_b = (b_high - b_low) * inv_range
            float w_u = (_h - b_high) * inv_range

            float v_l = _v_total * w_l
            float v_b = _v_total * w_b
            float v_u = _v_total * w_u

            float b_center = (_o + _c) * 0.5
            float body_pos = (b_center - _l) * inv_range

            float br_b = _c > _o ? math.min(0.9, 0.6 + body_pos * 0.3) : (_c < _o ? math.max(0.1, 0.4 - (1-body_pos) * 0.3) : 0.5)

            if v_l > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((_l - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_l / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.90
                    float v_j_sell = v_j * 0.10
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_b > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_b / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * br_b
                    float v_j_sell = v_j * (1.0 - br_b)
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_u > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((_h - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_u / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.10
                    float v_j_sell = v_j * 0.90
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)

// Grid Step Calculation
float atr_step = ta.atr(14) * 0.4
float auto_sens = (atr_step / close) * 100
float final_sens = auto_mode ? math.max(0.01, auto_sens) : heatmap_sens
float liq_step = (close * final_sens / 100)
float inv_liq_step = 1.0 / liq_step
float inv_fade_range_liq = 1.0 / (80 * liq_step)

// Register Heat Color Function
get_heatmap_color(float s, bool is_long, float level) =>
    float val = math.min(s, 20.0)
    color c_low  = is_long ? color.new(col_bull, 85) : color.new(col_bear, 85)
    color c_mid  = is_long ? col_bull : col_bear
    color c_high = col_poc
    color res = val <= 10.0 ? color.from_gradient(val, 1, 10.0, c_low, c_mid) : color.from_gradient(val, 10.0, 20.0, c_mid, c_high)
    
    float q_weight = math.pow(math.max(0, (val - 1.0) * 0.0526315789), 0.8)
    int base_alpha = math.round((1.0 - q_weight) * 80)
    float smooth_f = math.pow(math.min(1.0, math.abs(level - close) * inv_fade_range_liq), 2.0)
    color.new(res, math.round(base_alpha + smooth_f * (80 - base_alpha)))

add_or_update_liq(float raw_price, bool is_long, int bar_idx) =>
    float grid_price = math.round(raw_price * inv_liq_step) * liq_step
    bool found = false
    int sz_liq = array.size(liq_zones)
    if sz_liq > 0
        for i = 0 to sz_liq - 1
            LiqZone z = array.get(liq_zones, i)
            if z.active and z.is_long_liq == is_long and math.abs(z.level - grid_price) < (z.step * 0.75)
                if z.last_update_bar != bar_index
                    z.strength += 1
                    z.last_update_bar := bar_index
                color c = get_heatmap_color(z.strength, is_long, z.level)
                if line.get_x1(z.t_ln) == bar_index
                    linefill.set_color(z.f_id, c)
                else
                    line.set_x2(z.t_ln, bar_index)
                    line.set_x2(z.b_ln, bar_index)
                    array.push(liq_lines_hist, z.t_ln)
                    array.push(liq_lines_hist, z.b_ln)
                    array.push(liq_fills_hist, z.f_id)
                    
                    z.t_ln := line.new(bar_index, z.level + z.step/2, bar_index + 10, z.level + z.step/2, color=na, width=1)
                    z.b_ln := line.new(bar_index, z.level - z.step/2, bar_index + 10, z.level - z.step/2, color=na, width=1)
                    z.f_id := linefill.new(z.t_ln, z.b_ln, color=c)
                found := true
                break
    if not found
        color c = get_heatmap_color(1, is_long, grid_price)
        l_t = line.new(bar_idx, grid_price + liq_step/2, bar_index + 10, grid_price + liq_step/2, color=na, width=1)
        l_b = line.new(bar_idx, grid_price - liq_step/2, bar_index + 10, grid_price - liq_step/2, color=na, width=1)
        f = linefill.new(l_t, l_b, color=c)
        array.push(liq_zones, LiqZone.new(l_t, l_b, f, grid_price, liq_step, 1, is_long, true, bar_index))

draw_vp_liq(float raw_price, bool is_long, float strength_ratio) =>
    float grid_price = math.round(raw_price * inv_liq_step) * liq_step
    float strength = 1.0 + strength_ratio * 19.0
    color c = get_heatmap_color(strength, is_long, grid_price)

    int start_bar = bar_index - vp_period + 1
    int end_bar = bar_index + 10

    // Sweep Detection logic scans forward within the lookback window
    bool swept = false
    int sweep_bar = na
    for k = 1 to vp_period - 1
        float l_val = low[k]
        float h_val = high[k]
        bool is_swept = is_long ? l_val <= (grid_price + liq_step * 0.1) : h_val >= (grid_price - liq_step * 0.1)
        if is_swept
            swept := true
            sweep_bar := bar_index - k
            break

    if not swept
        bool is_swept = is_long ? low <= (grid_price + liq_step * 0.1) : high >= (grid_price - liq_step * 0.1)
        if is_swept
            swept := true
            sweep_bar := bar_index

    int actual_end = swept ? sweep_bar : end_bar

    line t_ln = line.new(start_bar, grid_price + liq_step/2, actual_end, grid_price + liq_step/2, color=na, width=1)
    line b_ln = line.new(start_bar, grid_price - liq_step/2, actual_end, grid_price - liq_step/2, color=na, width=1)
    linefill f_id = linefill.new(t_ln, b_ln, color=c)

    array.push(vp_liq_lines, t_ln)
    array.push(vp_liq_lines, b_ln)
    array.push(vp_liq_fills, f_id)

// -----------------------------------------------------------------------------
// MAIN RENDERING ENGINE
// -----------------------------------------------------------------------------
if show_liq_heatmap
    if liq_method == "Volume Profile"
        // Under Volume Profile Mode, run CPU-intensive processing strictly on the last bar
        if barstate.islast
            // Clean up previous real-time drawing objects
            if array.size(vp_liq_lines) > 0
                for i = 0 to array.size(vp_liq_lines) - 1
                    line.delete(array.get(vp_liq_lines, i))
                array.clear(vp_liq_lines)
            if array.size(vp_liq_fills) > 0
                for i = 0 to array.size(vp_liq_fills) - 1
                    linefill.delete(array.get(vp_liq_fills, i))
                array.clear(vp_liq_fills)

            float vp_high = ta.highest(high, vp_period)
            float vp_low = ta.lowest(low, vp_period)
            float price_range = vp_high - vp_low
            float price_step = price_range > 0 ? price_range / vp_resolution : 0
            float inv_price_step = price_range > 0 ? 1.0 / price_step : 0

            if price_range > 0 and not na(vp_low)
                float[] buy_at_price = array.new_float(vp_resolution, 0.0)
                float[] sell_at_price = array.new_float(vp_resolution, 0.0)
                float[] volume_at_price = array.new_float(vp_resolution, 0.0)

                // Loop through recent historical bars
                for i = 1 to vp_period - 1
                    distribute_vol(vp_resolution, vp_low, inv_price_step, open[i], high[i], low[i], close[i], volume[i], volume_at_price, buy_at_price, sell_at_price)

                // Distribute current bar (index 0)
                float ltf_v_total = 0.0
                int ltf_count = not na(ltf_v) ? array.size(ltf_v) : 0
                if ltf_count > 0
                    for i = 0 to ltf_count - 1
                        float o_val = array.get(ltf_o, i)
                        float h_val = array.get(ltf_h, i)
                        float l_val = array.get(ltf_l, i)
                        float c_val = array.get(ltf_c, i)
                        float v_val = array.get(ltf_v, i)
                        ltf_v_total += v_val

                        float b_val = c_val >= o_val ? v_val : 0.0
                        float s_val = c_val < o_val ? v_val : 0.0

                        int idx_l = math.min(vp_resolution - 1, math.max(0, math.floor((l_val - vp_low) * inv_price_step)))
                        int idx_h = math.min(vp_resolution - 1, math.max(0, math.floor((h_val - vp_low) * inv_price_step)))
                        int bins_covered = math.max(1, idx_h - idx_l + 1)
                        float vol_per_bin = v_val / bins_covered
                        float buy_per_bin = b_val / bins_covered
                        float sell_per_bin = s_val / bins_covered
                        for j = idx_l to idx_h
                            array.set(volume_at_price, j, array.get(volume_at_price, j) + vol_per_bin)
                            array.set(buy_at_price, j, array.get(buy_at_price, j) + buy_per_bin)
                            array.set(sell_at_price, j, array.get(sell_at_price, j) + sell_per_bin)
                float missing_v = math.max(0.0, volume - ltf_v_total)
                if missing_v > 0
                    distribute_vol(vp_resolution, vp_low, inv_price_step, open, high, low, close, missing_v, volume_at_price, buy_at_price, sell_at_price)

                float avg_vol = array.avg(volume_at_price)
                float max_vol = array.max(volume_at_price)
                int poc_index = array.indexof(volume_at_price, max_vol)

                if max_vol > 0
                    for i = 0 to vp_resolution - 1
                        float bin_vol = array.get(volume_at_price, i)
                        if bin_vol > 0
                            bool is_hvn = false
                            if i > 0 and i < vp_resolution - 1
                                float v_prev = array.get(volume_at_price, i - 1)
                                float v_next = array.get(volume_at_price, i + 1)
                                if bin_vol > v_prev and bin_vol > v_next and bin_vol > avg_vol * 1.5
                                    is_hvn := true

                            if i == poc_index or is_hvn
                                float bin_price = vp_low + i * price_step + price_step * 0.5
                                float buy_vol = array.get(buy_at_price, i)
                                float sell_vol = array.get(sell_at_price, i)
                                float strength_ratio = bin_vol / max_vol

                                if buy_vol > 0
                                    draw_vp_liq(bin_price * (1.0 - 1.0/lev1 + maint_margin), true, strength_ratio)
                                    draw_vp_liq(bin_price * (1.0 - 1.0/lev2 + maint_margin), true, strength_ratio)
                                    draw_vp_liq(bin_price * (1.0 - 1.0/lev3 + maint_margin), true, strength_ratio)
                                if sell_vol > 0
                                    draw_vp_liq(bin_price * (1.0 + 1.0/lev1 - maint_margin), false, strength_ratio)
                                    draw_vp_liq(bin_price * (1.0 + 1.0/lev2 - maint_margin), false, strength_ratio)
                                    draw_vp_liq(bin_price * (1.0 + 1.0/lev3 - maint_margin), false, strength_ratio)
    else
        // Historical Pivots and Accumulation Base engine (runs on every bar)
        if not na(ph)
            add_or_update_liq(ph * (1 + 1/lev1 - maint_margin), false, bar_index[liq_length])
            add_or_update_liq(ph * (1 + 1/lev2 - maint_margin), false, bar_index[liq_length])
            add_or_update_liq(ph * (1 + 1/lev3 - maint_margin), false, bar_index[liq_length])
        if not na(pl)
            add_or_update_liq(pl * (1 - 1/lev1 + maint_margin), true, bar_index[liq_length])
            add_or_update_liq(pl * (1 - 1/lev2 + maint_margin), true, bar_index[liq_length])
            add_or_update_liq(pl * (1 - 1/lev3 + maint_margin), true, bar_index[liq_length])
        if is_base and bar_index % 5 == 0
            add_or_update_liq(base_vwap * (1 + 1/lev1 - maint_margin), false, bar_index)
            add_or_update_liq(base_vwap * (1 - 1/lev1 + maint_margin), true, bar_index)
            
        int sz_liq_z = array.size(liq_zones)
        if sz_liq_z > 0
            for i = sz_liq_z - 1 to 0
                LiqZone z = array.get(liq_zones, i)
                bool remove = false
                if z.active
                    line.set_x2(z.t_ln, bar_index + 10)
                    line.set_x2(z.b_ln, bar_index + 10)
                    linefill.set_color(z.f_id, get_heatmap_color(z.strength, z.is_long_liq, z.level))
                    
                    bool swept = z.is_long_liq ? low <= (z.level + z.step * 0.1) : high >= (z.level - z.step * 0.1)
                    if swept and bar_index > line.get_x1(z.t_ln)
                        line.set_x2(z.t_ln, bar_index)
                        line.set_x2(z.b_ln, bar_index)
                        z.active := false
                        array.push(liq_lines_hist, z.t_ln)
                        array.push(liq_lines_hist, z.b_ln)
                        array.push(liq_fills_hist, z.f_id)
                        remove := true
                
                if not remove and line.get_x1(z.t_ln) < bar_index - 300
                    line.delete(z.t_ln)
                    line.delete(z.b_ln)
                    remove := true
                
                if remove
                    array.remove(liq_zones, i)
        if array.size(liq_lines_hist) > 0
            for i = array.size(liq_lines_hist) - 1 to 0
                ln = array.get(liq_lines_hist, i)
                if line.get_x1(ln) < bar_index - 500
                    line.delete(ln)
                    array.remove(liq_lines_hist, i)
        if array.size(liq_fills_hist) > 250
            linefill.delete(array.shift(liq_fills_hist))