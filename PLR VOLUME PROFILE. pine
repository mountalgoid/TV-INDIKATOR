// -----------------------------------------------------------------------------
// 4. CURVE ALGEBRA & SOLVER (Cramer's Rule Implementation)
// -----------------------------------------------------------------------------
// Parameterized Volume Partitioning to avoid current-bar global reference bugs
calc_vol_partition(float op, float hi, float lo, float cl, float vol) =>
    float range_size = hi - lo
    float b_vol = 0.0
    float s_vol = 0.0

    if range_size > 0
        float b_high = math.max(op, cl)
        float b_low  = math.min(op, cl)
        float body_size = b_high - b_low
        float upper_wick = hi - b_high
        float lower_wick = b_low - lo

        float w_body = body_size / range_size
        float w_upper = upper_wick / range_size
        float w_lower = lower_wick / range_size

        float b_center = (op + cl) / 2
        float body_pos = (b_center - lo) / range_size
        float br_b = cl > op ? math.min(0.9, 0.6 + body_pos * 0.3) : (cl < op ? math.max(0.1, 0.4 - (1.0 - body_pos) * 0.3) : 0.5)

        b_vol := vol * (w_body * br_b + w_lower * 0.9 + w_upper * 0.1)
        s_vol := vol * (w_body * (1.0 - br_b) + w_upper * 0.9 + w_lower * 0.1)
    else
        b_vol := vol * 0.5
        s_vol := vol * 0.5
    [b_vol, s_vol]

// --- LTF PRECISION ENGINE ---
get_ltf_v() =>
    [b, s] = calc_vol_partition(open, high, low, close, volume)
    [open, high, low, close, volume, b, s]

[ltf_o, ltf_h, ltf_l, ltf_c, ltf_v, ltf_b, ltf_s] = request.security_lower_tf(syminfo.tickerid, "1", get_ltf_v())

// Accumulate precise buy and sell volume statistics on each bar globally to ensure high precision
var float[] bar_buy_vol_arr  = array.new_float(3000, 0.0)
var float[] bar_sell_vol_arr = array.new_float(3000, 0.0)

// Shift and store values dynamically on each bar
if barstate.isfirst
    array.fill(bar_buy_vol_arr, 0.0)
    array.fill(bar_sell_vol_arr, 0.0)

// Calculate and record exact buy/sell statistics for current bar
float cur_buy_sum  = 0.0
float cur_sell_sum = 0.0
int ltf_count = array.size(ltf_v)
float ltf_v_total = 0.0

if ltf_count > 0
    for i = 0 to ltf_count - 1
        cur_buy_sum  += array.get(ltf_b, i)
        cur_sell_sum += array.get(ltf_s, i)
        ltf_v_total  += array.get(ltf_v, i)

// Account for any remaining volume gap
float missing_v = math.max(0.0, nz(volume) - ltf_v_total)
[miss_b, miss_s] = calc_vol_partition(open, high, low, close, missing_v)

float exact_buy_vol  = cur_buy_sum + miss_b
float exact_sell_vol = cur_sell_sum + miss_s

// Push to persistent arrays
array.push(bar_buy_vol_arr, exact_buy_vol)
array.push(bar_sell_vol_arr, exact_sell_vol)
if array.size(bar_buy_vol_arr) > 3000
    array.shift(bar_buy_vol_arr)
    array.shift(bar_sell_vol_arr)

// Formatter helper
f_formatNumber(float number) =>
    float abs_number = math.abs(number)
    if abs_number >= 1000000
        str.tostring(number / 1000000, "#.##") + "M"
    else if abs_number >= 1000
        str.tostring(number / 1000, "#.#") + "K"
    else
        str.tostring(number, "#")

// 3x3 Determinant Helper for Cramer's Rule solver
det3x3(float a11, float a12, float a13,
       float a21, float a22, float a23,
       float a31, float a32, float a33) => a11 * (a22 * a33 - a23 * a32) - a12 * (a21 * a33 - a23 * a31) + a13 * (a21 * a32 - a22 * a31)

// Solver for Degree 1 (Linear): y = a0 + a1 * t
solve_linear(int n) =>
    float sum_t = 0.0
    float sum_t2 = 0.0
    float sum_y = 0.0
    float sum_ty = 0.0
    
    for i = 0 to n - 1
        float t = i - (n - 1)
        float y = close[n - 1 - i]
        sum_t  += t
        sum_t2 += t * t
        sum_y  += y
        sum_ty += t * y
        
    float denom = n * sum_t2 - sum_t * sum_t
    float a0 = 0.0
    float a1 = 0.0
    if denom != 0
        a0 := (sum_y * sum_t2 - sum_t * sum_ty) / denom
        a1 := (n * sum_ty - sum_t * sum_y) / denom
    [a0, a1, 0.0]

// Solver for Degree 2 (Quadratic): y = a0 + a1 * t + a2 * t^2
solve_quadratic(int n) =>
    float sum_t  = 0.0
    float sum_t2 = 0.0
    float sum_t3 = 0.0
    float sum_t4 = 0.0
    float sum_y  = 0.0
    float sum_ty = 0.0
    float sum_t2y= 0.0
    
    for i = 0 to n - 1
        float t = i - (n - 1)
        float y = close[n - 1 - i]
        float t2 = t * t
        sum_t   += t
        sum_t2  += t2
        sum_t3  += t2 * t
        sum_t4  += t2 * t2
        sum_y   += y
        sum_ty  += t * y
        sum_t2y += t2 * y
        
    // System of Equations:
    // [  n       sum_t   sum_t2 ] [ a0 ]   [ sum_y   ]
    // [ sum_t   sum_t2  sum_t3 ] [ a1 ] = [ sum_ty  ]
    // [ sum_t2  sum_t3  sum_t4 ] [ a2 ]   [ sum_t2y ]
    float D = det3x3(n, sum_t, sum_t2,
                     sum_t, sum_t2, sum_t3,
                     sum_t2, sum_t3, sum_t4)
                     
    float a0 = 0.0
    float a1 = 0.0
    float a2 = 0.0
    
    if D != 0
        a0 := det3x3(sum_y, sum_t, sum_t2,
                     sum_ty, sum_t2, sum_t3,
                     sum_t2y, sum_t3, sum_t4) / D
        a1 := det3x3(n, sum_y, sum_t2,
                     sum_t, sum_ty, sum_t3,
                     sum_t2, sum_t2y, sum_t4) / D
        a2 := det3x3(n, sum_t, sum_y,
                     sum_t, sum_t2, sum_ty,
                     sum_t2, sum_t3, sum_t2y) / D
                     
    [a0, a1, a2]

// High-precision volume distribution helper for detrended curves
distribute_vol_plr(int _rows, float _lowest_p, float _inv_row_h, float _o, float _h, float _l, float _c, float _b_total, float _s_total, float[] _bucket_buy, float[] _bucket_sell) =>
    float b_high = math.max(_o, _c)
    float b_low  = math.min(_o, _c)
    float _range_val = _h - _l
    int max_idx = _rows - 1

    if max_idx >= 0
        if _range_val <= 0
            int idx = math.min(max_idx, math.max(0, math.floor((_c - _lowest_p) * _inv_row_h)))
            array.set(_bucket_buy, idx, array.get(_bucket_buy, idx) + _b_total)
            array.set(_bucket_sell, idx, array.get(_bucket_sell, idx) + _s_total)
        else
            float inv_range = 1.0 / _range_val
            float w_l = (b_low - _l) * inv_range
            float w_b = (b_high - b_low) * inv_range
            float w_u = (_h - b_high) * inv_range

            float b_center = (_o + _c) * 0.5
            float body_pos = (b_center - _l) * inv_range
            float br_b = _c > _o ? math.min(0.9, 0.6 + body_pos * 0.3) : (_c < _o ? math.max(0.1, 0.4 - (1.0 - body_pos) * 0.3) : 0.5)

            if w_l > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((_l - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float denom_count = idx_h - idx_l + 1
                    float v_j_buy = (_b_total * w_l * 0.90 + _s_total * w_l * 0.10) / denom_count
                    float v_j_sell = (_b_total * w_l * 0.10 + _s_total * w_l * 0.90) / denom_count
                    for j = idx_l to idx_h
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if w_b > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float denom_count = idx_h - idx_l + 1
                    float v_j_buy = (_b_total * w_b * br_b + _s_total * w_b * br_b) / denom_count
                    float v_j_sell = (_b_total * w_b * (1.0 - br_b) + _s_total * w_b * (1.0 - br_b)) / denom_count
                    for j = idx_l to idx_h
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if w_u > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((_h - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float denom_count = idx_h - idx_l + 1
                    float v_j_buy = (_b_total * w_u * 0.10 + _s_total * w_u * 0.90) / denom_count
                    float v_j_sell = (_b_total * w_u * 0.90 + _s_total * w_u * 0.10) / denom_count
                    for j = idx_l to idx_h
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)

// Execute profile calculations on the last bar
var float direction_bias = 0.0
var float current_poc_level = na
var float current_poc_vol = na
var float current_chan_high = na
var float current_chan_low = na
var string direction_str = "Neutral"

if barstate.islast
    cleanup_drawings()
    
    // Fit curve coefficients
    float a0 = 0.0
    float a1 = 0.0
    float a2 = 0.0
    
    if regression_mode == "Linear (Degree 1)"
        [c0, c1, c2] = solve_linear(reg_lookback)
        a0 := c0
        a1 := c1
        a2 := c2
    else
        [c0, c1, c2] = solve_quadratic(reg_lookback)
        a0 := c0
        a1 := c1
        a2 := c2
        
    // Calculate regression fitted curves and standard deviation residuals
    float sum_sq_residuals = 0.0
    array<float> fitted_y = array.new_float(reg_lookback)
    
    for i = 0 to reg_lookback - 1
        float t = i - (reg_lookback - 1)
        float fit = a0 + a1 * t + a2 * t * t
        array.set(fitted_y, i, fit)
        float residual = close[reg_lookback - 1 - i] - fit
        sum_sq_residuals += math.pow(residual, 2)
        
    float sd = math.sqrt(sum_sq_residuals / reg_lookback)
    
    // Direction bias defined by derivative/slope at t = 0 (current bar)
    // f'(t) = a1 + 2 * a2 * t. At t = 0, slope is exactly a1.
    direction_bias := a1
    direction_str := a1 > 0 ? "Bullish ↗" : "Bearish ↘"
    
    // Right alignment coordinate for the volume profile and edge labels
    // perfectly aligned with the right edge of the regression channel (from top to bottom)
    int right_x = bar_index

    // -------------------------------------------------------------------------
    // 5. CHANNEL DRAWING WITH STEP OPTIMIZATION AND CONTINUOUS LINEFILL
    // -------------------------------------------------------------------------
    line l_center_prev = na
    line l_p1_prev = na
    line l_p2_prev = na
    line l_p3_prev = na
    line l_m1_prev = na
    line l_m2_prev = na
    line l_m3_prev = na
    
    for i = 0 to reg_lookback - 1 by step_size
        int idx = math.min(reg_lookback - 1, i)
        float t = idx - (reg_lookback - 1)
        int bar_x = bar_index - (reg_lookback - 1 - idx)
        
        float yc = array.get(fitted_y, idx)
        float yp1 = yc + 1 * sd
        float yp2 = yc + 2 * sd
        float yp3 = yc + 3 * sd
        float ym1 = yc - 1 * sd
        float ym2 = yc - 2 * sd
        float ym3 = yc - 3 * sd
        
        if idx > 0
            int prev_idx = math.max(0, idx - step_size)
            int bar_x_prev = bar_index - (reg_lookback - 1 - prev_idx)
            float yc_prev = array.get(fitted_y, prev_idx)
            
            color base_line_col = a1 > 0 ? col_bull : col_bear
            
            line lc = line.new(bar_x_prev, yc_prev, bar_x, yc, color=base_line_col, width=2)
            line lp1 = line.new(bar_x_prev, yc_prev + 1 * sd, bar_x, yp1, color=color.new(white, 40), width=1, style=line.style_dashed)
            line lp2 = line.new(bar_x_prev, yc_prev + 2 * sd, bar_x, yp2, color=color.new(white, 60), width=1, style=line.style_dashed)
            line lp3 = line.new(bar_x_prev, yc_prev + 3 * sd, bar_x, yp3, color=color.new(white, 80), width=1, style=line.style_dotted)
            line lm1 = line.new(bar_x_prev, yc_prev - 1 * sd, bar_x, ym1, color=color.new(white, 40), width=1, style=line.style_dashed)
            line lm2 = line.new(bar_x_prev, yc_prev - 2 * sd, bar_x, ym2, color=color.new(white, 60), width=1, style=line.style_dashed)
            line lm3 = line.new(bar_x_prev, yc_prev - 3 * sd, bar_x, ym3, color=color.new(white, 80), width=1, style=line.style_dotted)
            
            array.push(reg_lines, lc)
            array.push(reg_lines, lp1)
            array.push(reg_lines, lp2)
            array.push(reg_lines, lp3)
            array.push(reg_lines, lm1)
            array.push(reg_lines, lm2)
            array.push(reg_lines, lm3)
            
            // Continuous segment filling for value area
            if show_fill
                color fill_color = a1 > 0 ? color.new(col_bull, fill_trans) : color.new(col_bear, fill_trans)
                linefill.new(lp1, lm1, color=fill_color)
                
        if idx == reg_lookback - 1
            current_chan_high := yp3
            current_chan_low := ym3
            
            // Right edge indicators aligned with right_x
            label.new(right_x + 2, yp3, "Channel High (+3 SD): " + str.tostring(yp3, format.mintick), color=color.new(dark, 100), textcolor=col_bear, size=size.tiny, style=label.style_label_left)
            label.new(right_x + 2, yp2, "+2 SD", color=color.new(dark, 100), textcolor=color.new(white, 50), size=size.tiny, style=label.style_label_left)
            label.new(right_x + 2, yp1, "+1 SD", color=color.new(dark, 100), textcolor=color.new(white, 40), size=size.tiny, style=label.style_label_left)
            label.new(right_x + 2, ym1, "-1 SD", color=color.new(dark, 100), textcolor=color.new(white, 40), size=size.tiny, style=label.style_label_left)
            label.new(right_x + 2, ym2, "-2 SD", color=color.new(dark, 100), textcolor=color.new(white, 50), size=size.tiny, style=label.style_label_left)
            label.new(right_x + 2, ym3, "Channel Low (-3 SD): " + str.tostring(ym3, format.mintick), color=color.new(dark, 100), textcolor=col_bull, size=size.tiny, style=label.style_label_left)

    // -------------------------------------------------------------------------
    // 6. CURVED/SLANTED VOLUME PROFILE (SE-PRESISI MUNGKIN DENGAN SLOPE & POLY/LINEAR)
    // -------------------------------------------------------------------------
    // Reset volume buckets
    array.fill(row_buy_vol, 0.0)
    array.fill(row_sell_vol, 0.0)

    // Calculate row heights stretching across the entire width of the regression channel
    float yp3 = a0 + 3 * sd
    float ym3 = a0 - 3 * sd
    float channel_height = yp3 - ym3
    float row_step = channel_height / vp_bars_count
    float inv_row_step = 1.0 / row_step

    // Distribute the high-precision volume of the rightmost bars
    for k = 0 to vp_bars_count - 1
        int idx = reg_lookback - vp_bars_count + k
        if idx >= 0 and idx < reg_lookback
            int hist_offset = reg_lookback - 1 - idx
            float b_vol = nz(array.get(bar_buy_vol_arr, array.size(bar_buy_vol_arr) - 1 - hist_offset))
            float s_vol = nz(array.get(bar_sell_vol_arr, array.size(bar_sell_vol_arr) - 1 - hist_offset))

            float h_op = open[hist_offset]
            float h_hi = high[hist_offset]
            float h_lo = low[hist_offset]
            float h_cl = close[hist_offset]

            // Detrend prices to align with flat row coordinates at right_x
            float t_offset = idx - (reg_lookback - 1)
            float curve_yc = a0 + a1 * t_offset + a2 * t_offset * t_offset
            float curve_delta = curve_yc - a0

            float d_op = h_op - curve_delta
            float d_hi = h_hi - curve_delta
            float d_lo = h_lo - curve_delta
            float d_cl = h_cl - curve_delta

            distribute_vol_plr(vp_bars_count, ym3, inv_row_step, d_op, d_hi, d_lo, d_cl, b_vol, s_vol, row_buy_vol, row_sell_vol)

    // Find the Point of Control (POC) among the rows
    float max_row_vol = 0.0
    int poc_row_idx = 0
    for r = 0 to vp_bars_count - 1
        float row_tot = array.get(row_buy_vol, r) + array.get(row_sell_vol, r)
        if row_tot > max_row_vol
            max_row_vol := row_tot
            poc_row_idx := r

    // Calculate Value Area (VAH/VAL) indices using standard 70% volume expansion
    float total_profile_vol = array.sum(row_buy_vol) + array.sum(row_sell_vol)
    int va_high_idx = poc_row_idx
    int va_low_idx = poc_row_idx
    float target_va_vol = total_profile_vol * (vp_val_percent / 100.0)
    float current_va_vol = array.get(row_buy_vol, poc_row_idx) + array.get(row_sell_vol, poc_row_idx)

    while current_va_vol < target_va_vol
        float up_vol = (va_high_idx < vp_bars_count - 1) ? (array.get(row_buy_vol, va_high_idx + 1) + array.get(row_sell_vol, va_high_idx + 1)) : 0.0
        float down_vol = (va_low_idx > 0) ? (array.get(row_buy_vol, va_low_idx - 1) + array.get(row_sell_vol, va_low_idx - 1)) : 0.0
        if up_vol == 0.0 and down_vol == 0.0
            break
        if up_vol >= down_vol
            current_va_vol += up_vol
            va_high_idx += 1
        else
            current_va_vol += down_vol
            va_low_idx -= 1

    float avg_row_vol = total_profile_vol / vp_bars_count

    // Render slanted/curved glass blocks following the regression curvature
    for r = 0 to vp_bars_count - 1
        float b_vol = array.get(row_buy_vol, r)
        float s_vol = array.get(row_sell_vol, r)
        float total_vol = b_vol + s_vol

        if total_vol > 0
            bool is_poc = r == poc_row_idx

            // Define standard flat row limits at right_x
            float y_bot_relative = ym3 + r * row_step
            float y_top_relative = ym3 + (r + 1) * row_step
            float y_center_relative = ym3 + (r + 0.5) * row_step

            if is_poc
                current_poc_level := y_center_relative
                current_poc_vol := total_vol

            // Compute lengths proportional to total volume
            float total_proportion = total_vol / max_row_vol
            float buy_proportion  = b_vol / total_vol
            float sell_proportion = s_vol / total_vol

            float total_length_bars = total_proportion * max_width_bars
            float buy_length_bars  = total_length_bars * buy_proportion
            float sell_length_bars = total_length_bars * sell_proportion

            if buy_length_bars == 0.0 and b_vol > 0
                buy_length_bars := 0.2
            if sell_length_bars == 0.0 and s_vol > 0
                sell_length_bars := 0.2

            // Apply customizable bar thickness with spacing/gap factor
            float h_half = (row_step / 2) * (1.0 - gap_factor) * (box_height_factor / 0.08)

            if vp_mode_view == "Delta"
                // Delta View Mode: stacked buy and sell blocks
                int sell_end_x = right_x
                int sell_start_x = math.round(right_x - sell_length_bars)
                int buy_end_x = sell_start_x
                int buy_start_x = math.round(sell_start_x - buy_length_bars)

                // Evaluate polynomial/linear curvature at each boundary point
                float t_sell = -sell_length_bars
                float curve_sell = a1 * t_sell + a2 * t_sell * t_sell

                float t_buy = -(sell_length_bars + buy_length_bars)
                float curve_buy = a1 * t_buy + a2 * t_buy * t_buy

                // Sell boundaries
                float sell_top_right = y_center_relative + h_half
                float sell_bot_right = y_center_relative - h_half
                float sell_top_left  = y_center_relative + curve_sell + h_half
                float sell_bot_left  = y_center_relative + curve_sell - h_half

                // Buy boundaries
                float buy_top_right = y_center_relative + curve_sell + h_half
                float buy_bot_right = y_center_relative + curve_sell - h_half
                float buy_top_left  = y_center_relative + curve_buy + h_half
                float buy_bot_left  = y_center_relative + curve_buy - h_half

                // Draw Sell lines & fill
                color s_line_col = is_poc ? color.new(col_poc, 30) : color.new(col_bear, 20)
                color s_fill_col = is_poc ? color.new(col_poc, 50) : color.new(col_bear, 60)
                int s_line_w = is_poc ? volume_line_width : 1

                line sell_top_line = line.new(x1=sell_start_x, y1=sell_top_left, x2=sell_end_x, y2=sell_top_right,
                                              color=s_line_col, width=s_line_w, style=line.style_solid)
                line sell_bot_line = line.new(x1=sell_start_x, y1=sell_bot_left, x2=sell_end_x, y2=sell_bot_right,
                                              color=s_line_col, width=s_line_w, style=line.style_solid)
                array.push(vp_lines, sell_top_line)
                array.push(vp_lines, sell_bot_line)
                linefill.new(sell_top_line, sell_bot_line, color=s_fill_col)

                // Draw Buy lines & fill
                color b_line_col = is_poc ? color.new(col_poc, 0) : color.new(col_bull, 20)
                color b_fill_col = is_poc ? color.new(col_poc, 30) : color.new(col_bull, 60)
                int b_line_w = is_poc ? volume_line_width : 1

                line buy_top_line = line.new(x1=buy_start_x, y1=buy_top_left, x2=buy_end_x, y2=buy_top_right,
                                             color=b_line_col, width=b_line_w, style=line.style_solid)
                line buy_bot_line = line.new(x1=buy_start_x, y1=buy_bot_left, x2=buy_end_x, y2=buy_bot_right,
                                             color=b_line_col, width=b_line_w, style=line.style_solid)
                array.push(vp_lines, buy_top_line)
                array.push(vp_lines, buy_bot_line)
                linefill.new(buy_top_line, buy_bot_line, color=b_fill_col)

                // Label text drawing
                if show_block_val
                    float y_center_left = y_center_relative + curve_buy
                    label val_lbl = label.new(x=buy_start_x, y=y_center_left, text=f_formatNumber(total_vol),
                                              color=color.new(dark, 100), textcolor=white,
                                              style=label.style_label_right, size=size.tiny)
                    array.push(vp_labels, val_lbl)

            else
                // Normal View Mode: single dominant volume block
                int total_end_x = right_x
                int total_start_x = math.round(right_x - total_length_bars)

                float t_tot = -total_length_bars
                float curve_tot = a1 * t_tot + a2 * t_tot * t_tot

                float top_right = y_center_relative + h_half
                float bot_right = y_center_relative - h_half
                float top_left  = y_center_relative + curve_tot + h_half
                float bot_left  = y_center_relative + curve_tot - h_half

                bool is_bull_dom = b_vol >= s_vol
                color line_col = is_poc ? color.new(col_poc, 0) : (is_bull_dom ? color.new(col_bull, 20) : color.new(col_bear, 20))
                color fill_col = is_poc ? color.new(col_poc, 30) : (is_bull_dom ? color.new(col_bull, 60) : color.new(col_bear, 60))
                int normal_line_w = is_poc ? volume_line_width : 1

                line top_line = line.new(x1=total_start_x, y1=top_left, x2=total_end_x, y2=top_right,
                                         color=line_col, width=normal_line_w, style=line.style_solid)
                line bot_line = line.new(x1=total_start_x, y1=bot_left, x2=total_end_x, y2=bot_right,
                                         color=line_col, width=normal_line_w, style=line.style_solid)
                array.push(vp_lines, top_line)
                array.push(vp_lines, bot_line)
                linefill.new(top_line, bot_line, color=fill_col)

                // Label text drawing
                if show_block_val
                    float y_center_left = y_center_relative + curve_tot
                    label val_lbl = label.new(x=total_start_x, y=y_center_left, text=f_formatNumber(total_vol),
                                              color=color.new(dark, 100), textcolor=white,
                                              style=label.style_label_right, size=size.tiny)
                    array.push(vp_labels, val_lbl)

            if is_poc and show_poc_label
                label poc_badge = label.new(x=right_x + 1, y=y_center_relative,
                                            text="<- POC Vol: " + f_formatNumber(total_vol),
                                            color=color.new(col_bear, 10), textcolor=dark,
                                            style=label.style_label_left, size=size.tiny,
                                            text_formatting=text.format_bold)
                array.push(vp_labels, poc_badge)

    // Render VAH and VAL slanted/curved lines
    if show_vah_val
        // VAH
        float yc_vah = ym3 + (va_high_idx + 0.5) * row_step
        string vah_text = "VAH (" + str.tostring(ym3 + (va_high_idx + 0.5) * row_step, format.mintick) + ")"
        for step = 0 to vp_bars_count by step_size
            int offset = math.min(vp_bars_count, step)
            int x_curr = right_x - (vp_bars_count - offset)
            float t_curr = - (vp_bars_count - offset)
            float y_curr = yc_vah + a1 * t_curr + a2 * t_curr * t_curr

            if offset > 0
                int prev_offset = math.max(0, offset - step_size)
                int x_prev = right_x - (vp_bars_count - prev_offset)
                float t_prev = - (vp_bars_count - prev_offset)
                float y_prev = yc_vah + a1 * t_prev + a2 * t_prev * t_prev

                line seg = line.new(x1=x_prev, y1=y_prev, x2=x_curr, y2=y_curr,
                                    color=col_bull, width=1, style=line.style_dashed)
                array.push(vp_lines, seg)

            if offset == vp_bars_count
                label lbl = label.new(x=right_x + 1, y=y_curr, text=vah_text,
                                      color=color.new(dark, 100), textcolor=col_bull,
                                      style=label.style_label_left, size=size.tiny,
                                      text_formatting=text.format_bold)
                array.push(vp_labels, lbl)

        // VAL
        float yc_val = ym3 + (va_low_idx + 0.5) * row_step
        string val_text = "VAL (" + str.tostring(ym3 + (va_low_idx + 0.5) * row_step, format.mintick) + ")"
        for step = 0 to vp_bars_count by step_size
            int offset = math.min(vp_bars_count, step)
            int x_curr = right_x - (vp_bars_count - offset)
            float t_curr = - (vp_bars_count - offset)
            float y_curr = yc_val + a1 * t_curr + a2 * t_curr * t_curr

            if offset > 0
                int prev_offset = math.max(0, offset - step_size)
                int x_prev = right_x - (vp_bars_count - prev_offset)
                float t_prev = - (vp_bars_count - prev_offset)
                float y_prev = yc_val + a1 * t_prev + a2 * t_prev * t_prev

                line seg = line.new(x1=x_prev, y1=y_prev, x2=x_curr, y2=y_curr,
                                    color=col_bear, width=1, style=line.style_dashed)
                array.push(vp_lines, seg)

            if offset == vp_bars_count
                label lbl = label.new(x=right_x + 1, y=y_curr, text=val_text,
                                      color=color.new(dark, 100), textcolor=col_bear,
                                      style=label.style_label_left, size=size.tiny,
                                      text_formatting=text.format_bold)
                array.push(vp_labels, lbl)

    // Render HVN and LVN slanted/curved lines
    if show_hvn_lvn
        for r = 1 to vp_bars_count - 2
            float v_prev = array.get(row_buy_vol, r - 1) + array.get(row_sell_vol, r - 1)
            float v_curr = array.get(row_buy_vol, r) + array.get(row_sell_vol, r)
            float v_next = array.get(row_buy_vol, r + 1) + array.get(row_sell_vol, r + 1)

            if v_curr > v_prev and v_curr > v_next and v_curr > avg_row_vol * 1.3
                // Draw HVN
                float yc_hvn = ym3 + (r + 0.5) * row_step
                for step = 0 to vp_bars_count by step_size
                    int offset = math.min(vp_bars_count, step)
                    int x_curr = right_x - (vp_bars_count - offset)
                    float t_curr = - (vp_bars_count - offset)
                    float y_curr = yc_hvn + a1 * t_curr + a2 * t_curr * t_curr

                    if offset > 0
                        int prev_offset = math.max(0, offset - step_size)
                        int x_prev = right_x - (vp_bars_count - prev_offset)
                        float t_prev = - (vp_bars_count - prev_offset)
                        float y_prev = yc_hvn + a1 * t_prev + a2 * t_prev * t_prev

                        line seg = line.new(x1=x_prev, y1=y_prev, x2=x_curr, y2=y_curr,
                                            color=col_bull, width=1, style=line.style_dotted)
                        array.push(vp_lines, seg)

                    if offset == vp_bars_count
                        label lbl = label.new(x=right_x + 1, y=y_curr, text="HVN",
                                              color=color.new(dark, 100), textcolor=col_bull,
                                              style=label.style_label_left, size=size.tiny,
                                              text_formatting=text.format_bold)
                        array.push(vp_labels, lbl)

            if v_curr < v_prev and v_curr < v_next and v_curr < avg_row_vol * 0.5
                // Draw LVN
                float yc_lvn = ym3 + (r + 0.5) * row_step
                for step = 0 to vp_bars_count by step_size
                    int offset = math.min(vp_bars_count, step)
                    int x_curr = right_x - (vp_bars_count - offset)
                    float t_curr = - (vp_bars_count - offset)
                    float y_curr = yc_lvn + a1 * t_curr + a2 * t_curr * t_curr

                    if offset > 0
                        int prev_offset = math.max(0, offset - step_size)
                        int x_prev = right_x - (vp_bars_count - prev_offset)
                        float t_prev = - (vp_bars_count - prev_offset)
                        float y_prev = yc_lvn + a1 * t_prev + a2 * t_prev * t_prev

                        line seg = line.new(x1=x_prev, y1=y_prev, x2=x_curr, y2=y_curr,
                                            color=col_bear, width=1, style=line.style_dotted)
                        array.push(vp_lines, seg)

                    if offset == vp_bars_count
                        label lbl = label.new(x=right_x + 1, y=y_curr, text="LVN",
                                              color=color.new(dark, 100), textcolor=col_bear,
                                              style=label.style_label_left, size=size.tiny,
                                              text_formatting=text.format_bold)
                        array.push(vp_labels, lbl)

    // Render Large Volume slanted/curved lines
    if show_large_vol
        for r = 0 to vp_bars_count - 1
            float b_v = array.get(row_buy_vol, r)
            float s_v = array.get(row_sell_vol, r)
            float total_v = b_v + s_v

            if total_v > avg_row_vol * large_vol_mult
                bool is_bull_dom = b_v >= s_v
                color lv_col = is_bull_dom ? col_bull : col_bear
                string lv_text = is_bull_dom ? "LG BUY" : "LG SELL"
                float yc_lv = ym3 + (r + 0.5) * row_step

                for step = 0 to vp_bars_count by step_size
                    int offset = math.min(vp_bars_count, step)
                    int x_curr = right_x - (vp_bars_count - offset)
                    float t_curr = - (vp_bars_count - offset)
                    float y_curr = yc_lv + a1 * t_curr + a2 * t_curr * t_curr

                    if offset > 0
                        int prev_offset = math.max(0, offset - step_size)
                        int x_prev = right_x - (vp_bars_count - prev_offset)
                        float t_prev = - (vp_bars_count - prev_offset)
                        float y_prev = yc_lv + a1 * t_prev + a2 * t_prev * t_prev

                        line seg = line.new(x1=x_prev, y1=y_prev, x2=x_curr, y2=y_curr,
                                            color=lv_col, width=1, style=line.style_solid)
                        array.push(vp_lines, seg)

                    if offset == vp_bars_count
                        label lbl = label.new(x=right_x + 1, y=y_curr, text=lv_text,
                                              color=color.new(dark, 100), textcolor=lv_col,
                                              style=label.style_label_left, size=size.tiny,
                                              text_formatting=text.format_bold)
                        array.push(vp_labels, lbl)

