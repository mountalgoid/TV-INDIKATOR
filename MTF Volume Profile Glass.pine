//𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤
//@version=6
//═══════════════════════════════════════════════════════════════════════════════
indicator(title            = "MTF Volume Profile Glass Pro 𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤"
  , shorttitle             = "MTF VP Glass Pro"
  , overlay                = true
  , max_bars_back          = 4000
  , max_lines_count        = 500
  , max_boxes_count        = 500
  , max_labels_count       = 500)

//════════════════════════════════════════════════════════════════════════
// 1. COLORS & THEME SYSTEM
//════════════════════════════════════════════════════════════════════════
string GlobalGroup = "Visual Themes & Global Settings"
color_theme = input.string(defval = 'DEX Deep', title = 'Select Color Theme', options = ['Bookmap System Theme', 'Spartan Edge Theme', 'MountAlgo Themes', 'MountAlgo Neon', 'MountAlgo Frost', 'MountAlgo Cyber', 'Standard Spartan Edge Theme', 'Dark ICT Theme', 'Garuda Gold', 'MountAlgo Super Premium Theme', 'MountAlgo Orange White Theme', 'DEX Deep', 'Deep Sea', 'Gear Protocol'], group=GlobalGroup)

// Core Colors
color dark   = #000000
color white  = #c4d3ff
color green  = #179c74
color purple = #5134ff
color gray   = #62647a
color red    = #f23645
color yellow = #f3ba2f
color orange = #ff9800
color blue   = #1848cc
color brown  = #8b4513
color Transparent_Color = color.new(white, 100)

color col_bull = switch color_theme
    'Bookmap System Theme' => #a1ff3b
    'Spartan Edge Theme' => red
    'MountAlgo Themes' => purple
    'MountAlgo Neon' => #5134ff
    'MountAlgo Frost' => #5134ff
    'MountAlgo Cyber' => #1848cc
    'Standard Spartan Edge Theme' => green
    'Dark ICT Theme' => green
    'Garuda Gold' => yellow
    'MountAlgo Super Premium Theme' => purple
    'MountAlgo Orange White Theme' => orange
    'DEX Deep' => #a1ff3b
    'Deep Sea' => blue
    'Gear Protocol' => white
    => blue

color col_bear = switch color_theme
    'Bookmap System Theme' => #ff009a
    'Spartan Edge Theme' => gray
    'MountAlgo Themes' => green
    'MountAlgo Neon' => #ff009a
    'MountAlgo Frost' => #00e5ff
    'MountAlgo Cyber' => #ff009a
    'Standard Spartan Edge Theme' => red
    'Dark ICT Theme' => gray
    'Garuda Gold' => gray
    'MountAlgo Super Premium Theme' => yellow
    'MountAlgo Orange White Theme' => gray
    'DEX Deep' => #ff009a
    'Deep Sea' => gray
    'Gear Protocol' => gray
    => white

color col_poc = switch color_theme
    'Bookmap System Theme' => white
    'Spartan Edge Theme' => white
    'MountAlgo Themes' => white
    'MountAlgo Neon' => white
    'MountAlgo Frost' => white
    'MountAlgo Cyber' => white
    'Standard Spartan Edge Theme' => white
    'Dark ICT Theme' => white
    'Garuda Gold' => white
    'MountAlgo Super Premium Theme' => white
    'MountAlgo Orange White Theme' => white
    'DEX Deep' => white
    'Deep Sea' => white
    => white

color box_col_bull = color.new(col_bull, 85)
color box_col_bear = color.new(col_bear, 85)
color glass_glow_color = col_bear // Default glowing pink/magenta in DEX Deep theme

//════════════════════════════════════════════════════════════════════════
// 1.5 GLOBAL HUD HELPERS
//════════════════════════════════════════════════════════════════════════
f_set_cell(tbl, c, r, txt, bg_color, txt_color) =>
    table.cell(tbl, c, r, txt, bgcolor=bg_color, text_color=txt_color, text_size=size.small, text_halign=c == 0 ? text.align_left : text.align_right)

f_get_hud_table_bg(c, r, total_c, total_r, col_bull_in, col_bear_in, dark_in) =>
    float ratio = (1.0 * c / math.max(1, total_c - 1) + 1.0 * r / math.max(1, total_r - 1)) / 2
    color base = color.from_gradient(ratio, 0, 1, col_bull_in, col_bear_in)
    color mixed_base = color.from_gradient(60, 0, 100, base, dark_in)
    color.new(mixed_base, 25)

//════════════════════════════════════════════════════════════════════════
// 2. INPUTS & CONFIGURATION
//════════════════════════════════════════════════════════════════════════
string grp_mtf  = "Multi-Timeframe Configuration"
auto_htf_mode   = input.bool(true, 'Auto HTF Mode', tooltip="Selects HTF session dynamically based on current timeframe multiplier", group=grp_mtf)
HTFtime_opt     = input.string("1H", 'Manual HTF Timeframe', tooltip="Only works if Auto HTF Mode is OFF", options=["15m","30m","45m","1H","2H","4H","1D","1W"], group=grp_mtf)

string grp_vp   = "Volume Profile Grid Settings"
profile_mode    = input.string("Current Session", "Profile Mode", options=["Current Session", "Previous Session", "Both (Current & Previous)", "Session Staircase"], group=grp_vp)
vp_resolution   = input.int(20, 'Profile Resolution (Rows)', minval=5, maxval=100, group=grp_vp)
vp_va_perc      = input.float(70.0, 'Value Area Volume %', minval=10.0, maxval=100.0, step=5.0, group=grp_vp)
max_blocks      = input.int(10, 'Max Blocks (Horizontal Width)', minval=3, maxval=25, group=grp_vp)

string grp_grid = "Grid & Glass Aesthetics"
block_style     = input.string("Classic Glass Grid", "Block Style Mode", options=["Classic Glass Grid", "Theme Gradient", "Delta Volume"], group=grp_grid, tooltip="Classic Glass Grid matches the reference image layout. Theme Gradient maps colors using gradients. Delta Volume highlights buy/sell net delta.")
block_step      = input.int(2, "Block Horizontal Step (Bars)", minval=1, maxval=5, group=grp_grid, tooltip="Horizontal step interval between adjacent blocks.")
block_size      = input.int(1, "Block Width (Bars)", minval=1, maxval=5, group=grp_grid, tooltip="Width in bars of each individual square block.")
gap_y_perc      = input.float(12.0, "Vertical Block Gap (%)", minval=0.0, maxval=49.0, step=2.0, group=grp_grid, tooltip="Vertical spacing inside each row block to enhance the grid layout.")
border_width_in = input.int(1, "Block Border Width", minval=0, maxval=3, group=grp_grid)
show_va_box     = input.bool(true, "Show Glass Value Area Container", group=grp_grid, tooltip="Draws a translucent glowing container spanning VAH to VAL.")
va_trans_in     = input.int(85, "Value Area Transparency", minval=30, maxval=98, group=grp_grid)

string grp_disp = "Display Controls"
show_poc_line   = input.bool(true, "Show POC Projected Line", group=grp_disp)
show_labels     = input.bool(true, "Show VAH/VAL/POC Labels", group=grp_disp)
vp_h_offset     = input.int(12, "Horizontal Grid Offset (Bars)", minval=0, group=grp_disp)
show_hvn_lvn    = input.bool(true, "Identify HVN and LVN", group=grp_disp)
show_table      = input.bool(true, "Show Glass HUD Table", group=grp_disp)
hud_position    = input.string("bottom_left", "HUD Table Position", options=["top_left", "top_right", "bottom_left", "bottom_right"], group=grp_disp)
show_logo       = input.bool(true, "Show Animated Logo", group="Logo Settings")

//════════════════════════════════════════════════════════════════════════
// 3. MULTI-TIMEFRAME ENGINE
//════════════════════════════════════════════════════════════════════════
get_manual_tf_string(opt) =>
    switch opt
        "15m" => "15"
        "30m" => "30"
        "45m" => "45"
        "1H"  => "60"
        "2H"  => "120"
        "4H"  => "240"
        "1D"  => "D"
        "1W"  => "W"
        => "60"

get_auto_htf() =>
    if timeframe.isseconds
        "15"
    else if timeframe.isminutes
        int m = timeframe.multiplier
        if m <= 2
            "60"
        else if m <= 4
            "60"
        else if m <= 14
            "240"
        else if m <= 30
            "D"
        else
            "D"
    else if timeframe.isdaily
        "W"
    else
        "M"

htf_tf = auto_htf_mode ? get_auto_htf() : get_manual_tf_string(HTFtime_opt)
bool is_new_session = ta.change(time(htf_tf)) != 0

//════════════════════════════════════════════════════════════════════════
// 4. PRECISION VOLUME PARTITIONING
//════════════════════════════════════════════════════════════════════════
distribute_bar_vol(_rows, _lowest_p, _inv_row_h, _o, _h, _l, _c, _v_total, _bucket_total, _bucket_buy, _bucket_sell) =>
    float b_high = math.max(_o, _c)
    float b_low  = math.min(_o, _c)
    float _range_val = _h - _l
    int max_idx = _rows - 1

    if max_idx >= 0
        if _range_val <= 0
            int idx = math.min(max_idx, math.max(0, math.floor((_c - _lowest_p) * _inv_row_h)))
            array.set(_bucket_total, idx, array.get(_bucket_total, idx) + _v_total)
            float v_half = _v_total * 0.5
            array.set(_bucket_buy, idx, array.get(_bucket_buy, idx) + v_half)
            array.set(_bucket_sell, idx, array.get(_bucket_sell, idx) + v_half)
        else
            float inv_range = 1.0 / _range_val
            float w_l = (b_low - _l) * inv_range
            float w_b = (b_high - b_low) * inv_range
            float w_u = (_h - b_high) * inv_range

            float v_l = _v_total * w_l
            float v_b = _v_total * w_b
            float v_u = _v_total * w_u

            float b_center = (_o + _c) * 0.5
            float body_pos = (b_center - _l) * inv_range

            float br_b = _c > _o ? math.min(0.9, 0.6 + body_pos * 0.3) : (_c < _o ? math.max(0.1, 0.4 - (1.0 - body_pos) * 0.3) : 0.5)

            if v_l > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((_l - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_l / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.90
                    float v_j_sell = v_j * 0.10
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_b > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_b / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * br_b
                    float v_j_sell = v_j * (1.0 - br_b)
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_u > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((_h - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_u / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.10
                    float v_j_sell = v_j * 0.90
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)

//════════════════════════════════════════════════════════════════════════
// 5. STORAGE & CLEANUP
//════════════════════════════════════════════════════════════════════════
var box[] grid_boxes     = array.new<box>()
var box[] container_boxes = array.new<box>()
var line[] level_lines   = array.new<line>()
var label[] level_labels = array.new<label>()

f_cleanup_drawings() =>
    while array.size(grid_boxes) > 0
        box.delete(array.pop(grid_boxes))
    while array.size(container_boxes) > 0
        box.delete(array.pop(container_boxes))
    while array.size(level_lines) > 0
        line.delete(array.pop(level_lines))
    while array.size(level_labels) > 0
        label.delete(array.pop(level_labels))

// Track indices for real-time tracking using persistent state arrays
var int[] session_start_indices = array.new<int>()
if is_new_session or bar_index == 0
    if array.size(session_start_indices) == 0 or array.get(session_start_indices, array.size(session_start_indices) - 1) != bar_index
        array.push(session_start_indices, bar_index)
        if array.size(session_start_indices) > 10
            array.shift(session_start_indices)

int bars_since_start = ta.barssince(is_new_session)

//════════════════════════════════════════════════════════════════════════
// 6. VOLUME PROFILE GRID RENDER
//════════════════════════════════════════════════════════════════════════
f_formatNumber(float number) =>
    float abs_number = math.abs(number)
    if abs_number >= 1000000
        str.tostring(number / 1000000, "#.##") + "M"
    else if abs_number >= 1000
        str.tostring(number / 1000, "#.#") + "K"
    else
        str.tostring(number, "#")

f_render_session_profile(int start_offset, int duration, int x_align_offset, bool is_current_sess) =>
    // Gather session high, low, open and close
    float session_high = high[start_offset]
    float session_low = low[start_offset]

    if duration > 1
        for i = 0 to duration - 1
            session_high := math.max(session_high, high[start_offset - i])
            session_low := math.min(session_low, low[start_offset - i])

    float session_open = open[start_offset]
    float session_close = close[start_offset - (duration - 1)]
    bool is_bull_candle = session_close >= session_open

    float range_p = session_high - session_low
    float row_h = range_p > 0 ? range_p / vp_resolution : syminfo.mintick * 10
    float inv_row_h = 1.0 / row_h

    // Arrays for profile calculation
    bucket_total = array.new_float(vp_resolution, 0.0)
    bucket_buy   = array.new_float(vp_resolution, 0.0)
    bucket_sell  = array.new_float(vp_resolution, 0.0)

    // Distribute historical session bars
    for i = 0 to duration - 1
        int idx = start_offset - i
        distribute_bar_vol(vp_resolution, session_low, inv_row_h, open[idx], high[idx], low[idx], close[idx], nz(volume[idx]), bucket_total, bucket_buy, bucket_sell)

    float max_vol = array.max(bucket_total)
    float total_vol = array.sum(bucket_total)
    int poc_idx = array.indexof(bucket_total, max_vol)

    // Value Area Identification (VAH/VAL)
    int va_top = poc_idx
    int va_bot = poc_idx
    float target_va = total_vol * (vp_va_perc / 100.0)
    float va_vol = max_vol

    int loop_safety = 0
    while va_vol < target_va and loop_safety < vp_resolution
        loop_safety += 1
        float v_up = (va_top < vp_resolution - 1) ? array.get(bucket_total, va_top + 1) : 0.0
        float v_dn = (va_bot > 0) ? array.get(bucket_total, va_bot - 1) : 0.0
        if v_up >= v_dn and va_top < vp_resolution - 1
            va_vol += v_up
            va_top += 1
        else if va_bot > 0
            va_vol += v_dn
            va_bot -= 1
        else if va_top < vp_resolution - 1
            va_vol += v_up
            va_top += 1

    float vah_price = session_low + (va_top + 1) * row_h
    float val_price = session_low + va_bot * row_h
    float poc_price = session_low + poc_idx * row_h + (row_h / 2)

    // Draw Beautiful Glass Card Frame boundaries around the entire Volume Profile session
    int profile_right_boundary = bar_index + x_align_offset + max_blocks * block_step - (block_step - block_size)
    box session_frame = box.new(left=bar_index + x_align_offset - 5, top=session_high, right=profile_right_boundary, bottom=session_low, bgcolor=color.new(dark, 94), border_color=color.new(white, 80), border_width=1)
    array.push(container_boxes, session_frame)

    // Draw Thick Glowing Vertical Spine Line at the left of the Volume Profile
    line left_spine = line.new(bar_index + x_align_offset, session_low, bar_index + x_align_offset, session_high, color=color.new(white, 40), width=3)
    array.push(level_lines, left_spine)

    // Draw HTF Candle on the left of the Volume Profile with a clean gap
    color htf_candle_col = is_bull_candle ? col_bull : col_bear
    color htf_candle_bg  = color.new(htf_candle_col, 85)
    color htf_candle_border = color.new(htf_candle_col, 45)

    box htf_body = box.new(left=bar_index + x_align_offset - 4, top=math.max(session_open, session_close), right=bar_index + x_align_offset - 2, bottom=math.min(session_open, session_close), bgcolor=htf_candle_bg, border_color=htf_candle_border, border_width=1)
    box htf_wick = box.new(left=bar_index + x_align_offset - 3, top=session_high, right=bar_index + x_align_offset - 3, bottom=session_low, bgcolor=htf_candle_bg, border_color=htf_candle_border, border_width=1)

    array.push(grid_boxes, htf_body)
    array.push(grid_boxes, htf_wick)

    // Draw Glass Blocks
    float pad_y = row_h * (gap_y_perc / 100.0)

    for r = 0 to vp_resolution - 1
        float r_tot_vol = array.get(bucket_total, r)
        if r_tot_vol > 0
            float r_buy_vol = array.get(bucket_buy, r)
            float r_sell_vol = array.get(bucket_sell, r)
            float r_delta = r_buy_vol - r_sell_vol

            float p_level_bot = session_low + r * row_h
            float p_level_top = p_level_bot + row_h

            int num_blocks_to_draw = math.round((r_tot_vol / max_vol) * max_blocks)
            num_blocks_to_draw := math.max(1, math.min(max_blocks, num_blocks_to_draw))

            for b = 0 to num_blocks_to_draw - 1
                int x_left = bar_index + x_align_offset + b * block_step
                int x_right = x_left + block_size

                // Color mapping logic
                color blk_fill = color.new(#ffffff, 92)
                color blk_border = color.new(#ffffff, 70)

                if block_style == "Classic Glass Grid"
                    if r == poc_idx
                        blk_fill := color.new(col_bear, 65) // Reference pink/magenta POC blocks
                        blk_border := color.new(col_bear, 30)
                    else
                        // Normal gray glass block
                        blk_fill := color.new(#ffffff, 92)
                        blk_border := color.new(#ffffff, 70)
                else if block_style == "Theme Gradient"
                    float buy_ratio = r_tot_vol > 0 ? r_buy_vol / r_tot_vol : 0.5
                    color mix_base = color.from_gradient(buy_ratio, 0, 1, col_bear, col_bull)
                    blk_fill := color.new(mix_base, 80)
                    blk_border := color.new(mix_base, 40)
                else if block_style == "Delta Volume"
                    color mix_base = r_delta >= 0 ? col_bull : col_bear
                    float delta_intensity = math.max(0.1, math.min(1.0, math.abs(r_delta) / math.max(1.0, r_tot_vol)))
                    blk_fill := color.new(mix_base, math.round(95 - delta_intensity * 40))
                    blk_border := color.new(mix_base, math.round(75 - delta_intensity * 45))

                // Highlight HVN / LVNs uniquely
                if show_hvn_lvn and r != poc_idx
                    float avg_vol = total_vol / vp_resolution
                    bool is_hvn = false
                    bool is_lvn = false
                    if r > 0 and r < vp_resolution - 1
                        float prev_v = array.get(bucket_total, r - 1)
                        float next_v = array.get(bucket_total, r + 1)
                        if r_tot_vol > prev_v and r_tot_vol > next_v and r_tot_vol > avg_vol * 1.3
                            is_hvn := true
                        if r_tot_vol < prev_v and r_tot_vol < next_v and r_tot_vol < avg_vol * 0.5
                            is_lvn := true

                    if is_hvn
                        blk_border := color.new(col_bull, 20)
                    else if is_lvn
                        blk_border := color.new(col_bear, 40)

                box blk = box.new(left=x_left, top=p_level_top - pad_y, right=x_right, bottom=p_level_bot + pad_y, bgcolor=blk_fill, border_color=blk_border, border_width=border_width_in)
                array.push(grid_boxes, blk)

    // Render Glowing Value Area Container Glass Box
    if show_va_box
        int end_width_bar = bar_index + x_align_offset + max_blocks * block_step - (block_step - block_size)
        // Draw VAH-VAL glowing translucent box (overlapping elements turn beautifully burgundy/red!)
        color container_bg = color.new(#7a113a, va_trans_in) // Reference deep burgundy
        if color_theme != "DEX Deep"
            container_bg := color.new(col_bear, va_trans_in)

        box glass_container = box.new(left=bar_index + x_align_offset, top=vah_price, right=end_width_bar, bottom=val_price, bgcolor=container_bg, border_color=color.new(glass_glow_color, 45), border_width=2)
        array.push(container_boxes, glass_container)

    // Projected Lines & Labels (Only for current session or real-time focus)
    if is_current_sess
        int end_line_bar = bar_index + x_align_offset + max_blocks * block_step + 10
        if show_poc_line
            line poc_ln = line.new(bar_index + x_align_offset, poc_price, end_line_bar, poc_price, color=color.new(col_bear, 10), width=1)
            array.push(level_lines, poc_ln)
        if show_labels
            label lbl_poc = label.new(end_line_bar, poc_price, "POC: " + str.tostring(poc_price, format.mintick) + " (" + f_formatNumber(max_vol) + ")", color=color.new(col_bear, 100), textcolor=col_bear, size=size.tiny, style=label.style_label_left)
            label lbl_vah = label.new(end_line_bar, vah_price, "VAH: " + str.tostring(vah_price, format.mintick), color=color.new(col_bull, 100), textcolor=col_bull, size=size.tiny, style=label.style_label_left)
            label lbl_val = label.new(end_line_bar, val_price, "VAL: " + str.tostring(val_price, format.mintick), color=color.new(col_bear, 100), textcolor=col_bear, size=size.tiny, style=label.style_label_left)
            array.push(level_labels, lbl_poc)
            array.push(level_labels, lbl_vah)
            array.push(level_labels, lbl_val)

    [total_vol, max_vol, poc_price, vah_price, val_price]

// Execute profile renders on the last bar
var float rt_total_vol = 0.0
var float rt_max_vol = 0.0
var float rt_poc_price = na
var float rt_vah_price = na
var float rt_val_price = na

if barstate.islast
    f_cleanup_drawings()
    int num_sessions = array.size(session_start_indices)

    if num_sessions >= 1
        if profile_mode == "Current Session" or profile_mode == "Both (Current & Previous)"
            int cur_start = array.get(session_start_indices, num_sessions - 1)
            int cur_dur = bar_index - cur_start + 1
            int cur_offset = bar_index - cur_start
            [tot, mx, poc, vah, val] = f_render_session_profile(cur_offset, cur_dur, vp_h_offset, true)
            rt_total_vol := tot
            rt_max_vol := mx
            rt_poc_price := poc
            rt_vah_price := vah
            rt_val_price := val

        if profile_mode == "Previous Session" or profile_mode == "Both (Current & Previous)"
            if num_sessions >= 2
                int prev_start = array.get(session_start_indices, num_sessions - 2)
                int prev_end = array.get(session_start_indices, num_sessions - 1) - 1
                int prev_dur = prev_end - prev_start + 1
                int prev_offset = bar_index - prev_start
                int align_prev = vp_h_offset + max_blocks * block_step + 4
                f_render_session_profile(prev_offset, prev_dur, align_prev, false)

        if profile_mode == "Session Staircase"
            int max_s = math.min(3, num_sessions - 1)
            for s = 0 to max_s
                int sess_start = array.get(session_start_indices, num_sessions - 1 - s)
                int sess_end = s == 0 ? bar_index : array.get(session_start_indices, num_sessions - s) - 1
                int sess_dur = sess_end - sess_start + 1
                int sess_offset = bar_index - sess_start
                // Place each historical session cleanly over its actual chart bars
                f_render_session_profile(sess_offset, sess_dur, -sess_offset, false)

//════════════════════════════════════════════════════════════════════════
// 7. GLASS HUD TABLE DASHBOARD
//════════════════════════════════════════════════════════════════════════
var table info_table = na
if show_table and barstate.islast
    string pos = switch hud_position
        "top_left"     => position.top_left
        "top_right"    => position.top_right
        "bottom_left"  => position.bottom_left
        "bottom_right" => position.bottom_right
        => position.bottom_left

    if na(info_table)
        info_table := table.new(pos, 2, 7, bgcolor=color.new(dark, 100), border_width=1, border_color=color.new(col_poc, 90), frame_color=color.new(brown, 40), frame_width=1)

    // Table Contents
    table.merge_cells(info_table, 0, 0, 1, 0)
    table.cell(info_table, 0, 0, "MTF VP GLASS PRO | " + str.tostring(syminfo.ticker), bgcolor=color.new(brown, 75), text_color=white, text_size=size.normal, text_formatting=text.format_bold)

    f_set_cell(info_table, 0, 1, "Session HTF Timeframe", f_get_hud_table_bg(0, 1, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 1, htf_tf, f_get_hud_table_bg(1, 1, 2, 7, col_bull, col_bear, dark), col_poc)

    f_set_cell(info_table, 0, 2, "Session Total Bars (LTF)", f_get_hud_table_bg(0, 2, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 2, str.tostring(bars_since_start + 1), f_get_hud_table_bg(1, 2, 2, 7, col_bull, col_bear, dark), col_bull)

    f_set_cell(info_table, 0, 3, "Total Volume Profile", f_get_hud_table_bg(0, 3, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 3, f_formatNumber(rt_total_vol), f_get_hud_table_bg(1, 3, 2, 7, col_bull, col_bear, dark), col_bull)

    f_set_cell(info_table, 0, 4, "Value Area High (VAH)", f_get_hud_table_bg(0, 4, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 4, str.tostring(rt_vah_price, format.mintick), f_get_hud_table_bg(1, 4, 2, 7, col_bull, col_bear, dark), col_bull)

    f_set_cell(info_table, 0, 5, "Point of Control (POC)", f_get_hud_table_bg(0, 5, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 5, str.tostring(rt_poc_price, format.mintick), f_get_hud_table_bg(1, 5, 2, 7, col_bull, col_bear, dark), col_bear)

    f_set_cell(info_table, 0, 6, "Value Area Low (VAL)", f_get_hud_table_bg(0, 6, 2, 7, col_bull, col_bear, dark), white)
    f_set_cell(info_table, 1, 6, str.tostring(rt_val_price, format.mintick), f_get_hud_table_bg(1, 6, 2, 7, col_bull, col_bear, dark), col_bear)

//═══════════════════════════════════════════════════════════════════════════════
// 8. LOGO GRADIENT ENHANCED (BREATHING MOUNTALGO BRAND SYSTEM)
//═══════════════════════════════════════════════════════════════════════════════
color bull_c1 = col_bull
color bull_c2 = col_bear
color bear_c1 = col_bull
color bear_c2 = col_bear

bool  trend_check = ta.ema(close, 2) > ta.ema(open, 2)
color c_start     = trend_check ? bull_c1 : bear_c1
color c_end       = trend_check ? bull_c2 : bear_c2

float time_cycle = timenow / 1000
float breathe    = (math.sin(time_cycle * 3) + 1) / 2

int LG_Line_Widthb = 1
int periodb        = 200

float logo_base_raw = ta.lowest(low, periodb)
float logo_range    = ta.highest(high, periodb) - logo_base_raw
var float h_unit    = na

float target_h = math.max(ta.atr(periodb) * 1.5, logo_range * 0.22)
h_unit := na(h_unit) ? target_h : h_unit * 0.98 + target_h * 0.02
float logo_base = logo_base_raw - h_unit * 0.2

float point1b  = logo_base + h_unit * 0.71
float point2b  = logo_base + h_unit * 0.43
float point3b  = logo_base + h_unit * 0.61
float point4b  = logo_base + h_unit * 0.32
float point5b  = logo_base + h_unit * 1.00
float point6b  = logo_base + h_unit * 0.71
float point7b  = logo_base + h_unit * 0.18
float point8b  = logo_base + h_unit * 0.21
float point9b  = logo_base + h_unit * 0.71
float point1b0 = logo_base + h_unit * 0.86

var line Line1b  = na
var line Line2b  = na
var line Line3b  = na
var line Line4b  = na
var line Line5b  = na
var line Line6b  = na
var line Line7b  = na
var line Line8b  = na
var line Line9b  = na
var line Line1b0 = na
var line Line1b1 = na
var line Line1b2 = na
var line Line1b3 = na
var line Line1b4 = na
var line Line1b5 = na
var line Line1b6 = na
var line Line1b7 = na
var line Line1b8 = na
var label[] brand_labels = array.new<label>()

if barstate.islast
    line.delete(Line1b)
    line.delete(Line2b)
    line.delete(Line3b)
    line.delete(Line4b)
    line.delete(Line5b)
    line.delete(Line6b)
    line.delete(Line7b)
    line.delete(Line8b)
    line.delete(Line9b)
    line.delete(Line1b0)
    line.delete(Line1b1)
    line.delete(Line1b2)
    line.delete(Line1b3)
    line.delete(Line1b4)
    line.delete(Line1b5)
    line.delete(Line1b6)
    line.delete(Line1b7)
    line.delete(Line1b8)
    while array.size(brand_labels) > 0
        label.delete(array.pop(brand_labels))

get_adv_color(step) =>
    float ratio = step / 18.0
    float dynamic_ratio = ratio + (breathe * 0.15)
    if dynamic_ratio > 1
        dynamic_ratio := 1
    color.from_gradient(dynamic_ratio, 0, 1, c_start, c_end)

get_fade_alpha(float x_rel) =>
    float dist = math.abs(x_rel - 32)
    float ratio = dist / 32.0
    math.round(80 * (1 - ratio))

int logo_offset = vp_h_offset + max_blocks * block_step + 42

if show_logo and barstate.islast
    color c_head_sync = get_adv_color(1)

    Line1b := line.new(x1 = bar_index + logo_offset + 4, y1 = point7b, x2 = bar_index + logo_offset + 11, y2 = point1b, color = col_poc, width = LG_Line_Widthb)
    Line2b := line.new(x1 = bar_index + logo_offset + 8, y1 = point7b, x2 = bar_index + logo_offset + 11, y2 = point2b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b, Line2b, color = color.new(c_head_sync, get_fade_alpha(7.5)))

    Line3b := line.new(x1 = bar_index + logo_offset + 11, y1 = point1b, x2 = bar_index + logo_offset + 13, y2 = point3b, color = col_poc, width = LG_Line_Widthb)
    Line4b := line.new(x1 = bar_index + logo_offset + 11, y1 = point2b, x2 = bar_index + logo_offset + 13, y2 = point4b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line3b, Line4b, color = color.new(get_adv_color(3), get_fade_alpha(12.0)))

    Line5b := line.new(x1 = bar_index + logo_offset + 13, y1 = point3b, x2 = bar_index + logo_offset + 19, y2 = point5b, color = col_poc, width = LG_Line_Widthb)
    Line6b := line.new(x1 = bar_index + logo_offset + 13, y1 = point4b, x2 = bar_index + logo_offset + 19, y2 = point6b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line5b, Line6b, color = color.new(get_adv_color(5), get_fade_alpha(16.0)))

    Line7b := line.new(x1 = bar_index + logo_offset + 19, y1 = point5b, x2 = bar_index + logo_offset + 24, y2 = point3b, color = col_poc, width = LG_Line_Widthb)
    Line8b := line.new(x1 = bar_index + logo_offset + 19, y1 = point6b, x2 = bar_index + logo_offset + 24, y2 = point4b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line7b, Line8b, color = color.new(get_adv_color(7), get_fade_alpha(21.5)))

    Line9b := line.new(x1 = bar_index + logo_offset + 24, y1 = point3b, x2 = bar_index + logo_offset + 26, y2 = point1b, color = col_poc, width = LG_Line_Widthb)
    Line1b0 := line.new(x1 = bar_index + logo_offset + 24, y1 = point4b, x2 = bar_index + logo_offset + 26, y2 = point2b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line9b, Line1b0, color = color.new(get_adv_color(9), get_fade_alpha(25.0)))

    Line1b1 := line.new(x1 = bar_index + logo_offset + 26, y1 = point1b, x2 = bar_index + logo_offset + 36, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b2 := line.new(x1 = bar_index + logo_offset + 26, y1 = point2b, x2 = bar_index + logo_offset + 32, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b1, Line1b2, color = color.new(get_adv_color(11), get_fade_alpha(31.0)))

    Line1b3 := line.new(x1 = bar_index + logo_offset + 2, y1 = point7b, x2 = bar_index + logo_offset + 26, y2 = point7b, color = col_poc, width = LG_Line_Widthb)
    Line1b4 := line.new(x1 = bar_index + logo_offset + 0, y1 = logo_base, x2 = bar_index + logo_offset + 24, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b3, Line1b4, color = color.new(c_head_sync, get_fade_alpha(13.0)))

    Line1b5 := line.new(x1 = bar_index + logo_offset + 2, y1 = point7b, x2 = bar_index + logo_offset + 0, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b6 := line.new(x1 = bar_index + logo_offset + 26, y1 = point7b, x2 = bar_index + logo_offset + 24, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b7 := line.new(x1 = bar_index + logo_offset + 32, y1 = logo_base, x2 = bar_index + logo_offset + 36, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)

    label l = label.new(bar_index + logo_offset + 54, point2b, "𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤\nMTF VP GLASS PRO", style=label.style_none, textcolor=col_poc, size=size.normal, text_align=text.align_left)
    array.push(brand_labels, l)

    label glow1 = label.new(bar_index + logo_offset + 13, point1b0, "●", style=label.style_none, textcolor=color.new(get_adv_color(2), get_fade_alpha(13.0)), size=size.huge)
    label glow2 = label.new(bar_index + logo_offset + 13, point1b0, "〇", style=label.style_none, textcolor=col_poc, size=size.huge)
    array.push(brand_labels, glow1)
    array.push(brand_labels, glow2)
