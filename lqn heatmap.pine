//@version=6
indicator("Liquidation Heatmap V4 𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤", shorttitle="LQN Heatmap V4 𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤", overlay=true, max_lines_count=500, max_boxes_count=500, max_bars_back=2000)

// -----------------------------------------------------------------------------
// 0. USER DEFINED TYPES
// -----------------------------------------------------------------------------
type LiqZone
    line t_ln
    line b_ln
    linefill f_id
    box va_bx
    float level
    float step
    int strength
    bool is_long_liq
    bool active

// -----------------------------------------------------------------------------
// 1. INPUTS & CONFIGURATION
// -----------------------------------------------------------------------------
string GlobalGroup = "Visual Themes & Global"
string grp_liq    = "Liquidation Boxes"

// --- THEME SYSTEM ---
string color_theme = input.string(defval = 'DEX Deep', title = 'Select Color Theme', options = ['Spartan Edge Theme', 'MountAlgo Themes', 'MountAlgo Neon', 'MountAlgo Frost', 'MountAlgo Cyber', 'Standard Spartan Edge Theme', 'Dark ICT Theme', 'Garuda Gold', 'MountAlgo Super Premium Theme', 'MountAlgo Orange White Theme', 'DEX Deep', 'Deep Sea'], group=GlobalGroup)

// Colors
color dark   = #000000
color white  = #c4d3ff
color green  = #179c74
color purple = #5134ff
color gray   = #62647a
color red    = #f23645
color yellow = #f3ba2f
color orange = #ff9800
color blue   = #1848cc

color col_bull = switch color_theme
    'Spartan Edge Theme' => red
    'MountAlgo Themes' => purple
    'MountAlgo Neon' => #5134ff
    'MountAlgo Frost' => #5134ff
    'MountAlgo Cyber' => #1848cc
    'Standard Spartan Edge Theme' => green
    'Dark ICT Theme' => green
    'Garuda Gold' => yellow
    'MountAlgo Super Premium Theme' => purple
    'MountAlgo Orange White Theme' => orange
    'DEX Deep' => #a1ff3b
    'Deep Sea' => blue
    => blue
color col_bear = switch color_theme
    'Spartan Edge Theme' => gray
    'MountAlgo Themes' => green
    'MountAlgo Neon' => #ff009a
    'MountAlgo Frost' => #00e5ff
    'MountAlgo Cyber' => #ff009a
    'Standard Spartan Edge Theme' => red
    'Dark ICT Theme' => gray
    'Garuda Gold' => gray
    'MountAlgo Super Premium Theme' => yellow
    'MountAlgo Orange White Theme' => gray
    'DEX Deep' => #ff009a
    'Deep Sea' => gray
    => white
color col_poc = switch color_theme
    'Spartan Edge Theme' => white
    'MountAlgo Themes' => white
    'MountAlgo Neon' => white
    'MountAlgo Frost' => white
    'MountAlgo Cyber' => white
    'Standard Spartan Edge Theme' => white
    'Dark ICT Theme' => white
    'Garuda Gold' => white
    'MountAlgo Super Premium Theme' => white
    'MountAlgo Orange White Theme' => white
    'DEX Deep' => white
    'Deep Sea' => white
    => white

color transparent_col = color.new(dark, 100)

// Liquidation Heatmap Settings
bool   auto_mode        = input.bool(true, "Auto Mode (Dynamic Settings)", group=grp_liq)
bool   show_liq_heatmap = input.bool(true, "Show Liquidation Heatmap", group=grp_liq)
string liq_style        = input.string("Precise (Boxes)", "Heatmap Style", options=["Precise (Boxes)", "Smooth (Plots)"], group=grp_liq)
string liq_method       = input.string("Pivots", "Liquidation Method", options=["Pivots", "Accumulation Base"], group=grp_liq)
int    liq_length       = input.int(2, "Pivot Lookback", minval=0, group=grp_liq)
float  heatmap_sens     = input.float(0.1, "Heatmap Price Step (%)", minval=0.01, step=0.01, group=grp_liq)
float  maint_margin     = input.float(0.5, "Maintenance Margin (%)", minval=0.0, maxval=5.0, step=0.1, group=grp_liq) / 100

// Leverage Multipliers
float lev1 = input.float(25.0, "Leverage 1", group=grp_liq)
float lev2 = input.float(50.0, "Leverage 2", group=grp_liq)
float lev3 = input.float(100.0, "Leverage 3", group=grp_liq)

// Value Area (VA) Settings
string grp_va    = "Value Area Settings"
bool show_va      = input.bool(true, "Show Value Area Highlights", group=grp_va)
float va_percent  = input.float(70.0, "Value Area Volume/Strength (%)", minval=10.0, maxval=100.0, step=5.0, group=grp_va)
color va_color_in = input.color(color.new(#179c74, 90), "Long VA Box Background", group=grp_va)
color va_color_sh = input.color(color.new(#f23645, 90), "Short VA Box Background", group=grp_va)
color va_border   = input.color(color.new(#ffffff, 50), "VA Box Border Color", group=grp_va)

// -----------------------------------------------------------------------------
// 2. LIQUIDATION HEATMAP ENGINE
// -----------------------------------------------------------------------------
var array<LiqZone> liq_zones = array.new<LiqZone>()
var array<line> liq_lines_hist = array.new_line()
var array<linefill> liq_fills_hist = array.new<linefill>()

// Persistent heat grid for "Smooth" mode
var float[] heat_grid = array.new_float(100, 0.0) // 50 above, 50 below
var float   heat_base_p = na

// Precision detection: Multi-bar pivot
float ph = ta.pivothigh(high, liq_length, liq_length)
float pl = ta.pivotlow(low, liq_length, liq_length)

// Accumulation Base Detection
[bb_mid, bb_upper, bb_lower] = ta.bb(close, liq_length, 2)
float bb_width = (bb_upper - bb_lower) / bb_mid
float range_atr = ta.atr(liq_length)
float range_high = ta.highest(high, liq_length)
float range_low = ta.lowest(low, liq_length)
float range_diff = range_high - range_low
bool is_base = range_diff < range_atr * 1.0 and bb_width < ta.sma(bb_width, liq_length * 2)

float base_sum_pv = 0.0
float base_sum_v = 0.0
for i = 0 to liq_length - 1
    float p = (high[i] + low[i] + close[i]) / 3
    float v = volume[i]
    base_sum_pv += p * v
    base_sum_v += v
float base_vwap = base_sum_v > 0 ? base_sum_pv / base_sum_v : (range_high + range_low) / 2

// Grid Step Calculation
float atr_step = ta.atr(14) * 0.4
float auto_sens = (atr_step / close) * 100
float final_sens = auto_mode ? math.max(0.01, auto_sens) : heatmap_sens
float liq_step = (close * final_sens / 100)
float inv_liq_step = 1.0 / liq_step
float inv_fade_range_liq = 1.0 / (80 * liq_step)

// Initialize or shift heat grid base
if na(heat_base_p) or math.abs(close - heat_base_p) > liq_step * 20
    heat_base_p := math.round(close * inv_liq_step) * liq_step
    array.fill(heat_grid, 0.0)

update_heat(float target_p, float amount) =>
    int idx = math.round((target_p - heat_base_p) * inv_liq_step) + 50
    if idx >= 0 and idx < 100
        array.set(heat_grid, idx, array.get(heat_grid, idx) + amount)

// Register Heat
get_heatmap_color(float s, bool is_long, float level) =>
    float val = math.min(s, 20.0)
    color c_low  = is_long ? color.new(col_bull, 85) : color.new(col_bear, 85)
    color c_mid  = is_long ? col_bull : col_bear
    color c_high = col_poc
    color res = val <= 10.0 ? color.from_gradient(val, 1, 10.0, c_low, c_mid) : color.from_gradient(val, 10.0, 20.0, c_mid, c_high)
    
    float q_weight = math.pow(math.max(0, (val - 1.0) * 0.0526315789), 0.8)
    int base_alpha = math.round((1.0 - q_weight) * 80)
    float smooth_f = math.pow(math.min(1.0, math.abs(level - close) * inv_fade_range_liq), 2.0)
    color.new(res, math.round(base_alpha + smooth_f * (80 - base_alpha)))

add_or_update_liq(float raw_price, bool is_long, int bar_idx) =>
    float grid_price = math.round(raw_price * inv_liq_step) * liq_step
    bool found = false
    int sz_liq = array.size(liq_zones)
    if sz_liq > 0
        for i = 0 to sz_liq - 1
            LiqZone z = array.get(liq_zones, i)
            if z.active and z.is_long_liq == is_long and math.abs(z.level - grid_price) < (z.step * 0.75)
                z.strength += 1
                color c = get_heatmap_color(z.strength, is_long, z.level)
                if line.get_x1(z.t_ln) == bar_index
                    linefill.set_color(z.f_id, c)
                else
                    line.set_x2(z.t_ln, bar_index)
                    line.set_x2(z.b_ln, bar_index)
                    if not na(z.va_bx)
                        box.set_right(z.va_bx, bar_index)
                    array.push(liq_lines_hist, z.t_ln)
                    array.push(liq_lines_hist, z.b_ln)
                    array.push(liq_fills_hist, z.f_id)
                    
                    z.t_ln := line.new(bar_index, z.level + z.step/2, bar_index + 10, z.level + z.step/2, color=na, width=1)
                    z.b_ln := line.new(bar_index, z.level - z.step/2, bar_index + 10, z.level - z.step/2, color=na, width=1)
                    z.f_id := linefill.new(z.t_ln, z.b_ln, color=c)
                    z.va_bx := na
                found := true
                break
    if not found
        color c = get_heatmap_color(1, is_long, grid_price)
        l_t = line.new(bar_idx, grid_price + liq_step/2, bar_index + 10, grid_price + liq_step/2, color=na, width=1)
        l_b = line.new(bar_idx, grid_price - liq_step/2, bar_index + 10, grid_price - liq_step/2, color=na, width=1)
        f = linefill.new(l_t, l_b, color=c)
        array.push(liq_zones, LiqZone.new(l_t, l_b, f, na, grid_price, liq_step, 1, is_long, true))

if show_liq_heatmap
    if liq_style == "Precise (Boxes)"
        if not na(ph)
            add_or_update_liq(ph * (1 + 1/lev1 - maint_margin), false, bar_index[liq_length])
            add_or_update_liq(ph * (1 + 1/lev2 - maint_margin), false, bar_index[liq_length])
            add_or_update_liq(ph * (1 + 1/lev3 - maint_margin), false, bar_index[liq_length])
        if not na(pl)
            add_or_update_liq(pl * (1 - 1/lev1 + maint_margin), true, bar_index[liq_length])
            add_or_update_liq(pl * (1 - 1/lev2 + maint_margin), true, bar_index[liq_length])
            add_or_update_liq(pl * (1 - 1/lev3 + maint_margin), true, bar_index[liq_length])
        if is_base and bar_index % 5 == 0
            add_or_update_liq(base_vwap * (1 + 1/lev1 - maint_margin), false, bar_index)
            add_or_update_liq(base_vwap * (1 - 1/lev1 + maint_margin), true, bar_index)
            
        int sz_liq_z = array.size(liq_zones)
        if sz_liq_z > 0
            for i = sz_liq_z - 1 to 0
                LiqZone z = array.get(liq_zones, i)
                bool remove = false
                if z.active
                    line.set_x2(z.t_ln, bar_index + 10)
                    line.set_x2(z.b_ln, bar_index + 10)
                    linefill.set_color(z.f_id, get_heatmap_color(z.strength, z.is_long_liq, z.level))
                    
                    bool swept = z.is_long_liq ? low <= (z.level + z.step * 0.1) : high >= (z.level - z.step * 0.1)
                    if swept and bar_index > line.get_x1(z.t_ln)
                        line.set_x2(z.t_ln, bar_index)
                        line.set_x2(z.b_ln, bar_index)
                        if not na(z.va_bx)
                            box.set_right(z.va_bx, bar_index)
                        z.active := false
                        array.push(liq_lines_hist, z.t_ln)
                        array.push(liq_lines_hist, z.b_ln)
                        array.push(liq_fills_hist, z.f_id)
                        remove := true
                
                if not remove and line.get_x1(z.t_ln) < bar_index - 300
                    line.delete(z.t_ln)
                    line.delete(z.b_ln)
                    if not na(z.va_bx)
                        box.delete(z.va_bx)
                    remove := true
                
                if remove
                    array.remove(liq_zones, i)
        if array.size(liq_lines_hist) > 0
            for i = array.size(liq_lines_hist) - 1 to 0
                ln = array.get(liq_lines_hist, i)
                if line.get_x1(ln) < bar_index - 500
                    line.delete(ln)
                    array.remove(liq_lines_hist, i)
        if array.size(liq_fills_hist) > 250
            linefill.delete(array.shift(liq_fills_hist))

        // ---------------------------------------------------------------------
        // VALUE AREA CALCULATION AND RENDERING FOR PRECISE (BOXES) MODE
        // ---------------------------------------------------------------------
        if show_va and array.size(liq_zones) > 0
            // Calculate total strength across all active liquidation zones
            float total_strength = 0.0
            int active_count = 0
            for i = 0 to array.size(liq_zones) - 1
                LiqZone z = array.get(liq_zones, i)
                if z.active
                    total_strength += z.strength
                    active_count += 1

            if total_strength > 0 and active_count > 0
                // Collect strengths of active zones and sort them descending to find the threshold strength
                float[] strengths = array.new_float(0)
                for i = 0 to array.size(liq_zones) - 1
                    LiqZone z = array.get(liq_zones, i)
                    if z.active
                        array.push(strengths, z.strength)
                array.sort(strengths, order.descending)

                // Find target cumulative strength based on va_percent
                float target_va_sum = total_strength * (va_percent / 100.0)
                float current_sum = 0.0
                float threshold_strength = 0.0
                for i = 0 to array.size(strengths) - 1
                    current_sum += array.get(strengths, i)
                    if current_sum >= target_va_sum
                        threshold_strength := array.get(strengths, i)
                        break

                // Draw/Update/Delete Value Area highlight boxes
                for i = 0 to array.size(liq_zones) - 1
                    LiqZone z = array.get(liq_zones, i)
                    if z.active
                        if z.strength >= threshold_strength
                            // In Value Area: Draw or update the transparent box
                            int x1 = line.get_x1(z.t_ln)
                            int x2 = bar_index + 10
                            float y_top = z.level + z.step/2
                            float y_bot = z.level - z.step/2
                            color bg_color = z.is_long_liq ? va_color_in : va_color_sh

                            if na(z.va_bx)
                                z.va_bx := box.new(x1, y_top, x2, y_bot,
                                                   bgcolor=bg_color,
                                                   border_color=va_border,
                                                   border_style=line.style_solid,
                                                   border_width=1)
                            else
                                box.set_left(z.va_bx, x1)
                                box.set_right(z.va_bx, x2)
                                box.set_top(z.va_bx, y_top)
                                box.set_bottom(z.va_bx, y_bot)
                                box.set_bgcolor(z.va_bx, bg_color)
                                box.set_border_color(z.va_bx, va_border)
                        else
                            // Outside Value Area: delete any existing box
                            if not na(z.va_bx)
                                box.delete(z.va_bx)
                                z.va_bx := na
        else
            // If show_va is toggled off, make sure any active boxes are cleaned up
            for i = 0 to array.size(liq_zones) - 1
                LiqZone z = array.get(liq_zones, i)
                if not na(z.va_bx)
                    box.delete(z.va_bx)
                    z.va_bx := na
    else
        // Smooth (Plots) mode
        if not na(ph)
            update_heat(ph * (1 + 1/lev1 - maint_margin), 1.0)
            update_heat(ph * (1 + 1/lev2 - maint_margin), 1.0)
            update_heat(ph * (1 + 1/lev3 - maint_margin), 1.0)
        if not na(pl)
            update_heat(pl * (1 - 1/lev1 + maint_margin), 1.0)
            update_heat(pl * (1 - 1/lev2 + maint_margin), 1.0)
            update_heat(pl * (1 - 1/lev3 + maint_margin), 1.0)
        if is_base and bar_index % 5 == 0
            update_heat(base_vwap * (1 + 1/lev1 - maint_margin), 0.5)
            update_heat(base_vwap * (1 - 1/lev1 + maint_margin), 0.5)

// Heat Decay & Sweeping
for i = 0 to 99
    float cur_heat = array.get(heat_grid, i)
    if cur_heat > 0
        float p_level = heat_base_p + (i - 50) * liq_step
        bool swept = (i >= 50 and high >= p_level) or (i < 50 and low <= p_level)
        if swept
            array.set(heat_grid, i, cur_heat * 0.3)
        else
            array.set(heat_grid, i, cur_heat * 0.998)

// Institutional Smooth Gradient Mapping
get_smooth_heat_color(float heat, bool is_above, float level) =>
    float val = math.min(heat, 15.0)
    color c_base = is_above ? color.new(col_bear, 90) : color.new(col_bull, 90)
    color c_mid  = is_above ? col_bear : col_bull
    color c_hot  = col_poc
    
    color res = c_base
    if val > 0
        if val <= 7.0
            res := color.from_gradient(val, 0, 7.0, c_base, c_mid)
        else
            res := color.from_gradient(val, 7.0, 15.0, c_mid, c_hot)
    
    float q_weight = math.pow(math.max(0, val * 0.0666666667), 0.7)
    int base_alpha = math.round((1.0 - q_weight) * 80)
    float smooth_f = math.pow(math.min(1.0, math.abs(level - close) * inv_fade_range_liq), 2.0)
    color.new(res, math.round(base_alpha + smooth_f * (80 - base_alpha)))

// Plotting the Grid
show_plots_liq = show_liq_heatmap and liq_style == "Smooth (Plots)"

p_up00 = plot(show_plots_liq ? heat_base_p + 0 * liq_step : na, "H+0", color=transparent_col, style=plot.style_linebr)
p_up08 = plot(show_plots_liq ? heat_base_p + 8 * liq_step : na, "H+8", color=transparent_col, style=plot.style_linebr)
p_up16 = plot(show_plots_liq ? heat_base_p + 16 * liq_step : na, "H+16", color=transparent_col, style=plot.style_linebr)
p_up32 = plot(show_plots_liq ? heat_base_p + 32 * liq_step : na, "H+32", color=transparent_col, style=plot.style_linebr)

fill(p_up00, p_up08, color=get_smooth_heat_color(array.get(heat_grid, 54), true, heat_base_p + 4 * liq_step))
fill(p_up08, p_up16, color=get_smooth_heat_color(array.get(heat_grid, 62), true, heat_base_p + 12 * liq_step))
fill(p_up16, p_up32, color=get_smooth_heat_color(array.get(heat_grid, 74), true, heat_base_p + 24 * liq_step))

p_dn00 = plot(show_plots_liq ? heat_base_p - 0 * liq_step : na, "H-0", color=transparent_col, style=plot.style_linebr)
p_dn08 = plot(show_plots_liq ? heat_base_p - 8 * liq_step : na, "H-8", color=transparent_col, style=plot.style_linebr)
p_dn16 = plot(show_plots_liq ? heat_base_p - 16 * liq_step : na, "H-16", color=transparent_col, style=plot.style_linebr)
p_dn32 = plot(show_plots_liq ? heat_base_p - 32 * liq_step : na, "H-32", color=transparent_col, style=plot.style_linebr)

fill(p_dn00, p_dn08, color=get_smooth_heat_color(array.get(heat_grid, 46), false, heat_base_p - 4 * liq_step))
fill(p_dn08, p_dn16, color=get_smooth_heat_color(array.get(heat_grid, 38), false, heat_base_p - 12 * liq_step))
fill(p_dn16, p_dn32, color=get_smooth_heat_color(array.get(heat_grid, 26), false, heat_base_p - 24 * liq_step))
