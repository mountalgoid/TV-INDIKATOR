input_rule2_stg1 = input.string(defval = 'HTF SnD Created', title = '➤ Rules 2', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'None'], group = strategy1_Rules_Group)
