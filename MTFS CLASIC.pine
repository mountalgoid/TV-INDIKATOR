input_rule8_stg1 = input.string(defval = 'LTF Liquidity Sweep', title = '➤ Rules 8', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'None'], group = strategy1_Rules_Group)
input_rule9_stg1 = input.string(defval = 'LTF SnD Created', title = '➤ Rules 9', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'None'], group = strategy1_Rules_Group)
input_rule10_stg1 = input.string(defval = 'LTF SnD Mitigated', title = '➤ Rules 10', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'None'], group = strategy1_Rules_Group)
input_rule11_stg1 = input.string(defval = 'LTF FVG Mitigated', title = '➤ Rules 11', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSB(Market Structure Break)', 'HTF MSC(Market Structure Continues)','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSB(Market Structure Break)', 'LTF MSC(Market Structure Continues)','LTF Breaker',  'HTF Inversion FVG', 'LTF Inversion FVG', 'None'], group = strategy1_Rules_Group)
