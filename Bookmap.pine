var table ladder_tbl = na

// Synchronized Lookback Calculations
int final_vp_lookback_s = sync_with_main_vp ? vp_lookback : vp_lookback_s
int final_bubble_lookback = sync_with_main_vp ? vp_lookback : lookback
int final_avg_plots_len = sync_with_main_vp ? vp_lookback : avg_plots_len

// -----------------------------------------------------------------------------
// 2. TREND & EMA ENGINE
// -----------------------------------------------------------------------------
float ema_long_val = ta.ema(close, ema_len)
float ema_slope    = (ema_long_val - ema_long_val[10]) / 10

// -----------------------------------------------------------------------------
// 2. VOLUME CALCULATION ENGINE
// -----------------------------------------------------------------------------
get_tick_volume() => math.max(volume, 0)

// Helper colors and functions for Volume Ladder
color mitigated_color = brown
color Transparent_Color = color.new(white, 100)

f_gradientColor(base_color, current_value, max_value) =>
    float ratio = max_value > 0 ? math.abs(current_value) / max_value : 0
    int transparency = math.round(85 - (ratio * 45))
    color.new(base_color, transparency)

f_formatNumber(number, add_sign) =>
    string sign = ""
    if add_sign
        sign := number >= 0 ? "+" : ""
    string res = na
    float abs_number = math.abs(number)
    if abs_number >= 1000000000
        res := sign + str.tostring(abs_number / 1000000000, "#.##") + "B"
    else if abs_number >= 1000000
        res := sign + str.tostring(abs_number / 1000000, "#.##") + "M"
    else if abs_number >= 1000
        res := sign + str.tostring(abs_number / 1000, "#.##") + "K"
    else
        res := sign + str.tostring(abs_number, "#")
    res

get_table_bg(int c, int r, int total_c, int total_r) =>
    float ratio = (1.0 * c / math.max(1, total_c - 1) + 1.0 * r / math.max(1, total_r - 1)) / 2
    color base = color.from_gradient(ratio, 0, 1, col_bull, col_bear)
    color mixed_base = color.from_gradient(60, 0, 100, base, dark)
    // 80 transparency = 20% opacity
    int t_alpha = 0
    color.new(mixed_base, t_alpha)

get_profile_alpha(float intensity, float level, float price_center, float inv_fade_range) =>
    float dist_ratio = math.min(1.0, math.abs(level - price_center) * inv_fade_range)
    float q_weight = math.pow(math.max(0, intensity), 0.7)
    int base_alpha = math.round((1.0 - q_weight) * 80)
    float smooth_f = math.pow(dist_ratio, 2.0)
    math.round(base_alpha + smooth_f * (80 - base_alpha))

format_vol(float v) =>
    float abs_v = math.abs(v)
    string res = ""
    if abs_v >= 1000000000
        res := str.tostring(v / 1000000000, "#.##") + "B"
    else if abs_v >= 1000000
        res := str.tostring(v / 1000000, "#.##") + "M"
    else if abs_v >= 1000
        res := str.tostring(v / 1000, "#.#") + "K"
    else
        res := str.tostring(v, "0.##")
    res

// Heuristic Volume Partitioning
calc_vol_partition(float vol) =>
    float range_size = high - low
    float b_vol = 0.0
    float s_vol = 0.0

    if range_size > 0
        float body_high = math.max(open, close)
        float body_low  = math.min(open, close)
        float body_size = body_high - body_low
        float upper_wick = high - body_high
        float lower_wick = body_low - low

        float w_body = body_size / range_size
        float w_upper = upper_wick / range_size
        float w_lower = lower_wick / range_size

        float b_center = (open + close) / 2
        float body_pos = (b_center - low) / range_size
        float br_b = close > open ? math.min(0.9, 0.6 + body_pos * 0.3) : (close < open ? math.max(0.1, 0.4 - (1-body_pos) * 0.3) : 0.5)

        b_vol := vol * (w_body * br_b + w_lower * 0.9 + w_upper * 0.1)
        s_vol := vol * (w_body * (1 - br_b) + w_upper * 0.9 + w_lower * 0.1)
    else
        b_vol := vol * 0.5
        s_vol := vol * 0.5
    [b_vol, s_vol]

[buy_vol_heuristic, sell_vol_heuristic] = calc_vol_partition(get_tick_volume())

// -----------------------------------------------------------------------------
// 2. LTF PRECISION ENGINE (HEDGE FUND LEVEL)
// -----------------------------------------------------------------------------
// We fetch 1-minute data for the current bar to achieve 100% distribution precision
get_ltf_v() =>
    [b, s] = calc_vol_partition(volume)
    [open, high, low, close, volume, b, s]

[ltf_o, ltf_h, ltf_l, ltf_c, ltf_v, ltf_b, ltf_s] = request.security_lower_tf(syminfo.tickerid, "1", get_ltf_v())

// Real-time accumulators
var float rt_buy_poc = na
var float rt_sell_poc = na

float ltf_buy_sum  = 0.0
float ltf_sell_sum = 0.0
float ltf_b_poc    = na
float ltf_s_poc    = na

int ltf_count = array.size(ltf_v)
float ltf_v_total = 0.0
if ltf_count > 0
    float sum_b_weighted = 0.0
    float sum_s_weighted = 0.0
    for i = 0 to ltf_count - 1
        float _b = array.get(ltf_b, i)
        float _s = array.get(ltf_s, i)
        float _v = array.get(ltf_v, i)
        ltf_buy_sum  += _b
        ltf_sell_sum += _s
        ltf_v_total  += _v
        
        float price_i = (array.get(ltf_o, i) + array.get(ltf_h, i) + array.get(ltf_l, i) + array.get(ltf_c, i)) / 4
        sum_b_weighted += _b * price_i
        sum_s_weighted += _s * price_i

    if ltf_buy_sum > 0
        ltf_b_poc := sum_b_weighted / ltf_buy_sum
    if ltf_sell_sum > 0
        ltf_s_poc := sum_s_weighted / ltf_sell_sum

// Responsive Volume Engine: Sync LTF with actual HTF volume
float missing_v = math.max(0, get_tick_volume() - ltf_v_total)
[miss_b, miss_s] = calc_vol_partition(missing_v)

// Heuristic fallback calculations (for maximum real-time precision)
float range_p    = high - low
float body_high  = math.max(open, close)
float body_low   = math.min(open, close)
float upper_wick = high - body_high
float lower_wick = body_low - low

float w_body  = (range_p > 0) ? (body_high - body_low) / range_p : 0
float w_upper = (range_p > 0) ? upper_wick / range_p : 0
float w_lower = (range_p > 0) ? lower_wick / range_p : 0

float b_center_p = (open + close) / 2
float b_pos_p = range_p > 0 ? (b_center_p - low) / range_p : 0.5
float br_b_p = close > open ? math.min(0.9, 0.6 + b_pos_p * 0.3) : (close < open ? math.max(0.1, 0.4 - (1-b_pos_p) * 0.3) : 0.5)

float buy_denom = w_lower * 0.9 + w_body * br_b_p + w_upper * 0.1
float buy_center = buy_denom > 0 ? (w_lower * 0.9 * (low + body_low)/2 + w_body * br_b_p * b_center_p + w_upper * 0.1 * (body_high + high)/2) / buy_denom : close

float sell_denom = w_upper * 0.9 + w_body * (1.0 - br_b_p) + w_lower * 0.1
float sell_center = sell_denom > 0 ? (w_upper * 0.9 * (high + body_high)/2 + w_body * (1.0 - br_b_p) * b_center_p + w_lower * 0.1 * (low + body_low)/2) / sell_denom : close

float buy_volume  = ltf_buy_sum + miss_b
float sell_volume = ltf_sell_sum + miss_s

if buy_volume > 0
    rt_buy_poc := ((not na(ltf_b_poc) ? ltf_b_poc * ltf_buy_sum : 0.0) + miss_b * buy_center) / buy_volume
else
    rt_buy_poc := buy_center

if sell_volume > 0
    rt_sell_poc := ((not na(ltf_s_poc) ? ltf_s_poc * ltf_sell_sum : 0.0) + miss_s * sell_center) / sell_volume
else
    rt_sell_poc := sell_center

float delta        = buy_volume - sell_volume
float total_volume = buy_volume + sell_volume

// Accurate Bubble Placement (Super Precise Volume-Weighted Price)
float buy_loc  = rt_buy_poc
float sell_loc = rt_sell_poc

// Distribution Heuristic for Profile
distribute_vol(int _rows, float _lowest_p, float _inv_row_h, float _o, float _h, float _l, float _c, float _v_total, array<float> _bucket_total, array<float> _bucket_buy, array<float> _bucket_sell) =>
    float b_high = math.max(_o, _c)
    float b_low  = math.min(_o, _c)
    float _range_val = _h - _l
    int max_idx = _rows - 1
    
    if max_idx >= 0
        if _range_val <= 0
            int idx = math.min(max_idx, math.max(0, math.floor((_c - _lowest_p) * _inv_row_h)))
            array.set(_bucket_total, idx, array.get(_bucket_total, idx) + _v_total)
            float v_half = _v_total * 0.5
            array.set(_bucket_buy, idx, array.get(_bucket_buy, idx) + v_half)
            array.set(_bucket_sell, idx, array.get(_bucket_sell, idx) + v_half)
        else
            float inv_range = 1.0 / _range_val
            float w_l = (b_low - _l) * inv_range
            float w_b = (b_high - b_low) * inv_range
            float w_u = (_h - b_high) * inv_range
            
            float v_l = _v_total * w_l
            float v_b = _v_total * w_b
            float v_u = _v_total * w_u
            
            float b_center = (_o + _c) * 0.5
            float body_pos = (b_center - _l) * inv_range
            
            float br_b = _c > _o ? math.min(0.9, 0.6 + body_pos * 0.3) : (_c < _o ? math.max(0.1, 0.4 - (1-body_pos) * 0.3) : 0.5)

            if v_l > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((_l - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_l / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.90
                    float v_j_sell = v_j * 0.10
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_b > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_low - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_b / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * br_b
                    float v_j_sell = v_j * (1.0 - br_b)
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)
            if v_u > 0
                int idx_l = math.min(max_idx, math.max(0, math.floor((b_high - _lowest_p) * _inv_row_h)))
                int idx_h = math.min(max_idx, math.max(0, math.floor((_h - _lowest_p) * _inv_row_h)))
                if idx_l <= idx_h
                    float v_j = v_u / (idx_h - idx_l + 1)
                    float v_j_buy = v_j * 0.10
                    float v_j_sell = v_j * 0.90
                    for j = idx_l to idx_h
                        array.set(_bucket_total, j, array.get(_bucket_total, j) + v_j)
                        array.set(_bucket_buy, j, array.get(_bucket_buy, j) + v_j_buy)
                        array.set(_bucket_sell, j, array.get(_bucket_sell, j) + v_j_sell)

// LTF Distribution Handler
add_ltf_vol(int _rows, float _lowest_p, float _inv_row_h, array<float> _bucket_total, array<float> _bucket_buy, array<float> _bucket_sell) =>
    int ltf_size = array.size(ltf_v)
    float ltf_b_sum = 0.0
    float ltf_s_sum = 0.0
    float ltf_v_sum = 0.0
    if ltf_size > 0
        for i = 0 to ltf_size - 1
            float _o = array.get(ltf_o, i)
            float _h = array.get(ltf_h, i)
            float _l = array.get(ltf_l, i)
            float _c = array.get(ltf_c, i)
            float _v = array.get(ltf_v, i)
            float _b = array.get(ltf_b, i)
            float _s = array.get(ltf_s, i)
            distribute_vol(_rows, _lowest_p, _inv_row_h, _o, _h, _l, _c, _v, _bucket_total, _bucket_buy, _bucket_sell)
            ltf_b_sum += _b
            ltf_s_sum += _s
            ltf_v_sum += _v
    
    // Distribute remaining volume (Responsive/Real-time sync)
    float remain_v = math.max(0, get_tick_volume() - ltf_v_sum)
    if remain_v > 0
        [rb, rs] = calc_vol_partition(remain_v)
        distribute_vol(_rows, _lowest_p, _inv_row_h, open, high, low, close, remain_v, _bucket_total, _bucket_buy, _bucket_sell)
        ltf_b_sum += rb
        ltf_s_sum += rs

    [ltf_b_sum, ltf_s_sum]

// -----------------------------------------------------------------------------
// 3. DATA STORAGE
// -----------------------------------------------------------------------------
var array<float> hist_buy_vol = array.new<float>()
var array<float> hist_sell_vol = array.new<float>()
var array<float> hist_high = array.new<float>()
var array<float> hist_low = array.new<float>()
var array<float> hist_open = array.new<float>()
var array<float> hist_close = array.new<float>()
var array<float> hist_buy_poc_arr = array.new<float>()
var array<float> hist_sell_poc_arr = array.new<float>()

if barstate.isconfirmed
    float final_b = buy_volume
    float final_s = sell_volume
    array.push(hist_buy_vol, final_b)
    array.push(hist_sell_vol, final_s)
    array.push(hist_high, high)
    array.push(hist_low, low)
    array.push(hist_open, open)
    array.push(hist_close, close)
    array.push(hist_buy_poc_arr, na(rt_buy_poc) ? buy_center : rt_buy_poc)
    array.push(hist_sell_poc_arr, na(rt_sell_poc) ? sell_center : rt_sell_poc)
    
    int max_lookback = math.max(vp_lookback, math.max(final_vp_lookback_s, final_bubble_lookback))
    if array.size(hist_close) >= max_lookback
        array.shift(hist_buy_vol)
        array.shift(hist_sell_vol)
        array.shift(hist_high)
        array.shift(hist_low)
        array.shift(hist_open)
        array.shift(hist_close)
        array.shift(hist_buy_poc_arr)
        array.shift(hist_sell_poc_arr)

// Historical Rolling POC Calculation (Sync with Volume Profile logic)
var float hpoc_val = na
if show_hpoc and (barstate.isconfirmed or barstate.islast)
    int data_size = array.size(hist_close)
    if data_size > 10
        float h_p = math.max(array.max(hist_high), high)
        float l_p = math.min(array.min(hist_low), low)
        
        int n_rows = vp_use_grain ? math.round((h_p - l_p) / (syminfo.mintick * vp_grain)) : hpoc_rows
        n_rows := math.min(500, math.max(10, n_rows))
        float r_h = (h_p - l_p) / n_rows
        if r_h > 0
            float inv_rh = 1.0 / r_h
            array<float> buckets = array.new_float(n_rows, 0.0)
            array<float> dummy_b = array.new_float(n_rows, 0.0)
            array<float> dummy_s = array.new_float(n_rows, 0.0)
            
            int start_idx = math.max(0, data_size - (vp_lookback - 1))
            for i = start_idx to data_size - 1
                distribute_vol(n_rows, l_p, inv_rh, array.get(hist_open, i), array.get(hist_high, i), array.get(hist_low, i), array.get(hist_close, i), array.get(hist_buy_vol, i) + array.get(hist_sell_vol, i), buckets, dummy_b, dummy_s)
            
            add_ltf_vol(n_rows, l_p, inv_rh, buckets, dummy_b, dummy_s)

            float max_v = 0.0
            int max_idx = 0
            for i = 0 to n_rows - 1
                float v = array.get(buckets, i)
                if v > max_v
                    max_v   := v
                    max_idx := i
            hpoc_val := l_p + (max_idx * r_h) + (r_h / 2)

// -----------------------------------------------------------------------------
// 3.5 GLOBAL MARKET METRICS
// -----------------------------------------------------------------------------
float daily_open = request.security(syminfo.tickerid, "D", open)
float daily_change_pct = ((close - daily_open) / daily_open) * 100

float mkt_atr_cur = ta.atr(14)
float mkt_atr_avg = ta.sma(mkt_atr_cur, 20)
float mkt_volatility = mkt_atr_avg > 0 ? mkt_atr_cur / mkt_atr_avg : 1.0

int _sz = array.size(hist_buy_vol)
float _last_b = _sz > 0 ? array.get(hist_buy_vol, _sz - 1) : 0.0
float _last_s = _sz > 0 ? array.get(hist_sell_vol, _sz - 1) : 0.0
float _prev_b = _sz > 1 ? array.get(hist_buy_vol, _sz - 2) : 0.0
float _prev_s = _sz > 1 ? array.get(hist_sell_vol, _sz - 2) : 0.0

float hist_buy_sum = array.sum(hist_buy_vol)
float hist_sell_sum = array.sum(hist_sell_vol)

float p_delta = 0.0
float p_agg_delta = 0.0

if barstate.isconfirmed
    p_delta     := _prev_b - _prev_s
    p_agg_delta := (hist_buy_sum - _last_b) - (hist_sell_sum - _last_s)
else
    p_delta     := _last_b - _last_s
    p_agg_delta := hist_buy_sum - hist_sell_sum

float agg_buy       = barstate.isconfirmed ? hist_buy_sum : hist_buy_sum + buy_volume
float agg_sell      = barstate.isconfirmed ? hist_sell_sum : hist_sell_sum + sell_volume
float agg_delta     = agg_buy - agg_sell
float agg_delta_pct = (agg_buy + agg_sell) > 0 ? (agg_delta / (agg_buy + agg_sell)) * 100 : 0

float p_agg_total = barstate.isconfirmed ? (hist_buy_sum + hist_sell_sum - _last_b - _last_s) : (hist_buy_sum + hist_sell_sum)
float p_agg_delta_pct = p_agg_total > 0 ? (p_agg_delta / p_agg_total) * 100 : 0

// -----------------------------------------------------------------------------
// 3.7 PREDICTION TREND ENGINE
// -----------------------------------------------------------------------------
// Historical Average Buy/Sell Calculations (Global for history)
// Use math.sum for precision and ensure it's synced with Volume Profile lookback
float rolling_buy_vol_g   = math.sum(buy_volume, final_avg_plots_len)
float rolling_buy_pvol_g  = math.sum(buy_loc * buy_volume, final_avg_plots_len)
float hist_avg_buy_g      = rolling_buy_vol_g > 0 ? rolling_buy_pvol_g / rolling_buy_vol_g : na

float rolling_sell_vol_g  = math.sum(sell_volume, final_avg_plots_len)
float rolling_sell_pvol_g = math.sum(sell_loc * sell_volume, final_avg_plots_len)
float hist_avg_sell_g     = rolling_sell_vol_g > 0 ? rolling_sell_pvol_g / rolling_sell_vol_g : na

// Normalized Slopes (%) for Prediction Analysis
float hpoc_cont = fixnan(hpoc_val)
float poc_slope = (hpoc_cont - hpoc_cont[20]) / (20 * close) * 100
float ab_slope  = (hist_avg_buy_g - hist_avg_buy_g[20]) / (20 * close) * 100
float as_slope  = (hist_avg_sell_g - hist_avg_sell_g[20]) / (20 * close) * 100
float ema_slope_pct = (ema_long_val - ema_long_val[20]) / (20 * close) * 100

// -----------------------------------------------------------------------------
// 4. BUBBLES & IMBALANCE BOXES
// -----------------------------------------------------------------------------
float raw_max_vol = ta.highest(total_volume, final_bubble_lookback)
float max_vol_history = not na(raw_max_vol) ? raw_max_vol : ta.highest(total_volume, bar_index + 1)

float vol_intensity_buy  = max_vol_history > 0 ? math.pow(math.min(buy_volume / max_vol_history * sensitivity, 1.0), 0.8) : 0
float vol_intensity_sell = max_vol_history > 0 ? math.pow(math.min(sell_volume / max_vol_history * sensitivity, 1.0), 0.8) : 0
bool is_imbalance_buy    = buy_volume > sell_volume * 3 and vol_intensity_buy > 0.3
bool is_imbalance_sell   = sell_volume > buy_volume * 3 and vol_intensity_sell > 0.3


// Imbalance Box Logic
type ImbalanceBox
    box id
    float level
    bool is_buy
    bool active

var array<ImbalanceBox> imbalance_boxes = array.new<ImbalanceBox>()

// Large Volume Mitigation Boxes
type LargeVolBox
    box id
    box b_vol_box
    box s_vol_box
    float level
    float b_vol
    float s_vol
    bool is_buy
    int bounces
    bool active
    float zone_size

var array<LargeVolBox> lv_boxes = array.new<LargeVolBox>()


if barstate.isconfirmed
    if show_imb_boxes and is_imbalance_buy
        b = box.new(bar_index, high, bar_index + 5, high - (range_p * 0.2),
             border_color=transparent_col, bgcolor=color.new(c_buy, 92), text="Buy Imb", text_size=size.tiny, text_color=col_poc)
        array.push(imbalance_boxes, ImbalanceBox.new(b, high - (range_p * 0.2), true, true))

    if show_imb_boxes and is_imbalance_sell
        b = box.new(bar_index, low + (range_p * 0.2), bar_index + 5, low,
             border_color=transparent_col, bgcolor=color.new(c_sell, 92), text="Sell Imb", text_size=size.tiny, text_color=col_poc)
        array.push(imbalance_boxes, ImbalanceBox.new(b, low + (range_p * 0.2), false, true))

    if show_mitigation_boxes
        float zone_size = not na(mkt_atr_cur) and mkt_atr_cur > 0 ? mkt_atr_cur * 0.15 : (high - low > 0 ? (high - low) * 0.15 : syminfo.mintick * 10)
        if vol_intensity_buy >= large_vol_threshold
            int dyn_alpha = math.round(100 - vol_intensity_buy * 70)
            b = box.new(bar_index, buy_loc + zone_size/2, bar_index + 10, buy_loc - zone_size/2, 
                 border_color=color.new(col_bull, 60), border_width=1, bgcolor=color.new(col_bull, 100),
                 text="LARGE BUY VOL", text_size=size.auto,text_formatting = text.format_bold, text_color=col_poc)
            bvb = box.new(bar_index, buy_loc + zone_size/2, bar_index + 10, buy_loc - zone_size/2, bgcolor=color.new(col_bull, dyn_alpha), border_color=na)
            svb = box.new(bar_index, buy_loc + zone_size/2, bar_index + 10, buy_loc - zone_size/2, bgcolor=color.new(col_bear, dyn_alpha), border_color=na)
            array.push(lv_boxes, LargeVolBox.new(b, bvb, svb, buy_loc, buy_volume, sell_volume, true, 0, true, zone_size))
        if vol_intensity_sell >= large_vol_threshold
            int dyn_alpha = math.round(100 - vol_intensity_sell * 70)
            b = box.new(bar_index, sell_loc + zone_size/2, bar_index + 10, sell_loc - zone_size/2, 
                 border_color=color.new(col_bear, 60), border_width=1, bgcolor=color.new(col_bear, 100),
                 text="LARGE SELL VOL", text_size=size.auto,text_formatting = text.format_bold, text_color=col_poc)
            bvb = box.new(bar_index, sell_loc + zone_size/2, bar_index + 10, sell_loc - zone_size/2, bgcolor=color.new(col_bull, dyn_alpha), border_color=na)
            svb = box.new(bar_index, sell_loc + zone_size/2, bar_index + 10, sell_loc - zone_size/2, bgcolor=color.new(col_bear, dyn_alpha), border_color=na)
            array.push(lv_boxes, LargeVolBox.new(b, bvb, svb, sell_loc, buy_volume, sell_volume, false, 0, true, zone_size))

// Mitigation Logic for Imbalance Boxes (Only check for bars AFTER the creation bar)
if array.size(imbalance_boxes) > 0
    for i = array.size(imbalance_boxes) - 1 to 0
        ImbalanceBox imb = array.get(imbalance_boxes, i)
        if imb.active and bar_index > box.get_left(imb.id)
            bool swept = false
            if imb.is_buy
                if low < imb.level
                    swept := true
            else
                if high > imb.level
                    swept := true

            if swept
                box.set_right(imb.id, bar_index)
                imb.active := false
            else
                box.set_right(imb.id, bar_index + 5)

        if box.get_left(imb.id) < bar_index - 500
            box.delete(imb.id)
            array.remove(imbalance_boxes, i)

// Logic for Large Volume Mitigation Boxes
if array.size(lv_boxes) > 0
    for i = array.size(lv_boxes) - 1 to 0
        LargeVolBox lvb = array.get(lv_boxes, i)
        if lvb.active
            // Extension
            int target_r = bar_index + 10
            box.set_right(lvb.id, target_r)
            
            // Internal Volume Split Extension
            float b_ratio = lvb.b_vol / (lvb.b_vol + lvb.s_vol)
            int start_x = box.get_left(lvb.id)
            int split_x = start_x + math.round((target_r - start_x) * b_ratio)
            box.set_right(lvb.b_vol_box, split_x)
            box.set_left(lvb.s_vol_box, split_x)
            box.set_right(lvb.s_vol_box, target_r)

            float zone_size = lvb.zone_size
            float zone_top = lvb.level + zone_size/2
            float zone_bot = lvb.level - zone_size/2
            
            // Check for bounce/touch
            bool touched = high >= zone_bot and low <= zone_top
            bool broken = lvb.is_buy ? close < zone_bot : close > zone_top
            
            if touched and not broken
                // Only increase bounce if it's a new "visit" to the zone?
                // For simplicity, let's just use a slow increment
                if bar_index % 2 == 0 // throttle the increment
                    lvb.bounces += 1
                
                color base_c = col_poc // lvb.is_buy ? col_bull : col_bear
                int transp = math.max(0, 50 - lvb.bounces)
                box.set_border_color(lvb.id, color.new(base_c, 40))
                box.set_border_width(lvb.id, 1)
                box.set_border_style(lvb.id,line.style_dotted)
            
            if broken and bar_index > box.get_left(lvb.id)
                box.set_right(lvb.id, bar_index)
                // Finalize internal boxes
                int mit_r = bar_index
                int f_split_x = start_x + math.round((mit_r - start_x) * b_ratio)
                box.set_right(lvb.b_vol_box, f_split_x)
                box.set_left(lvb.s_vol_box, f_split_x)
                box.set_right(lvb.s_vol_box, mit_r)
                lvb.active := false
        
        if box.get_left(lvb.id) < bar_index - 1000
            box.delete(lvb.id)
            box.delete(lvb.b_vol_box)
            box.delete(lvb.s_vol_box)
            array.remove(lv_boxes, i)

float t_buy  = auto_scaling ? 90 - (vol_intensity_buy * 80) : 40
float t_sell = auto_scaling ? 90 - (vol_intensity_sell * 80) : 40
color c_buy_plot  = is_imbalance_buy ? c_imb : color.new(c_buy, math.round(math.max(0, t_buy)))
color c_sell_plot = is_imbalance_sell ? c_imb : color.new(c_sell, math.round(math.max(0, t_sell)))

bool show_b = show_plots and vol_intensity_buy > 0.05
bool show_s = show_plots and vol_intensity_sell > 0.05

// Super Gradient Bubble Logic
get_bubble_color(float intensity, bool is_buy) =>
    color base = is_buy ? box_col_bull : box_col_bear
    color peak = is_buy ? col_bull : col_bear
    color res = color.from_gradient(intensity, 0, 1, base, peak)
    res

color c_buy_bubble  = get_bubble_color(vol_intensity_buy, true)
color c_sell_bubble = get_bubble_color(vol_intensity_sell, false)

// Bubble Labels Logic
var label[] bubble_labels = array.new_label()
var line[] bubble_lines = array.new_line()
var label[] bubble_summaries = array.new_label()

// Persistent variables for real-time bar
var label rt_lbl_buy = na
var label rt_lbl_sell = na
var label rt_lbl_sum = na

if show_bubble_labels
    if barstate.isconfirmed
        // Confirm Buy Side
        if vol_intensity_buy > 0
            label l  = na
            line li = na
            if not na(rt_lbl_buy)
                l := rt_lbl_buy
                rt_lbl_buy := na
                label.set_xy(l, bar_index, buy_loc)
                label.set_style(l, label.style_label_center)
            else
                string txt = bubble_label_type == "Symbol" ? "[B]" : ("B " + format_vol(buy_volume))
                l := label.new(bar_index, buy_loc, txt, color=color.new(dark, 70), textcolor=col_poc, style=label.style_label_center, size=size.auto, text_formatting=text.format_bold)
            array.push(bubble_labels, l)
        else
            label.delete(rt_lbl_buy)
            rt_lbl_buy := na

        // Confirm Sell Side
        if vol_intensity_sell > 0
            label l  = na
            line li = na
            if not na(rt_lbl_sell)
                l := rt_lbl_sell
                rt_lbl_sell := na
                label.set_xy(l, bar_index, sell_loc)
                label.set_style(l, label.style_label_center)
            else
                string txt = bubble_label_type == "Symbol" ? "[S]" : ("S " + format_vol(sell_volume))
                l := label.new(bar_index, sell_loc, txt, color=color.new(dark, 70), textcolor=col_poc, style=label.style_label_center, size=size.auto, text_formatting=text.format_bold)
            array.push(bubble_labels, l)
        else
            label.delete(rt_lbl_sell)
            rt_lbl_sell := na

        // Confirm Summary
        if vol_intensity_buy > 0 or vol_intensity_sell > 0
            label l_s = na
            float b_delta = buy_volume - sell_volume
            float b_total = buy_volume + sell_volume
            float b_delta_pct = b_total > 0 ? (b_delta / b_total) * 100 : 0
            string summary_txt = "\n\n" + (b_delta >= 0 ? "+" : "") + str.tostring(b_delta_pct, "#.#") + "%\n" + (b_delta >= 0 ? "+" : "") + format_vol(b_delta) + "\n\n"
            color summary_col = b_delta >= 0 ? col_bull : col_bear
            string summary_style = b_delta >= 0 ? label.style_label_up : label.style_label_down
            float summary_y = b_delta >= 0 ? low : high

            if not na(rt_lbl_sum)
                l_s := rt_lbl_sum
                rt_lbl_sum := na
                label.set_xy(l_s, bar_index, summary_y)
                label.set_text(l_s, summary_txt)
                label.set_textcolor(l_s, summary_col)
                label.set_style(l_s, summary_style)
            else
                l_s := label.new(bar_index, summary_y, summary_txt, color=color.new(dark, 100), textcolor=summary_col, style=summary_style, size=size.auto, text_formatting=text.format_bold)
            array.push(bubble_summaries, l_s)
        else
            label.delete(rt_lbl_sum)
            rt_lbl_sum := na

    if barstate.isrealtime and not barstate.isconfirmed
        // Update Buy Side RT (Centered on POC)
        if vol_intensity_buy > 0
            string txt = bubble_label_type == "Symbol" ? "[B]" : ("B " + format_vol(buy_volume))
            if na(rt_lbl_buy)
                rt_lbl_buy := label.new(bar_index, buy_loc, txt, color=color.new(dark, 70), textcolor=col_bull, style=label.style_label_center, size=size.auto, text_formatting=text.format_bold)
            else
                label.set_xy(rt_lbl_buy, bar_index, buy_loc)
                label.set_text(rt_lbl_buy, txt)
                label.set_textcolor(rt_lbl_buy, col_bull)
        else
            label.delete(rt_lbl_buy)
            rt_lbl_buy := na

        // Update Sell Side RT (Centered on POC)
        if vol_intensity_sell > 0
            string txt = bubble_label_type == "Symbol" ? "[S]" : ("S " + format_vol(sell_volume))
            if na(rt_lbl_sell)
                rt_lbl_sell := label.new(bar_index, sell_loc, txt, color=color.new(dark, 70), textcolor=col_bear, style=label.style_label_center, size=size.auto, text_formatting=text.format_bold)
            else
                label.set_xy(rt_lbl_sell, bar_index, sell_loc)
                label.set_text(rt_lbl_sell, txt)
                label.set_textcolor(rt_lbl_sell, col_bear)
        else
            label.delete(rt_lbl_sell)
            rt_lbl_sell := na

        // Update Summary RT
        if vol_intensity_buy > 0 or vol_intensity_sell > 0
            float b_delta = buy_volume - sell_volume
            float b_total = buy_volume + sell_volume
            float b_delta_pct = b_total > 0 ? (b_delta / b_total) * 100 : 0
            string summary_txt = "\n\n" + "B" + format_vol(buy_volume) + "/" + "S" + format_vol(sell_volume) + "\n" + (b_delta >= 0 ? "+" : "") + str.tostring(b_delta_pct, "#.#") + "%\n" + (b_delta >= 0 ? "+" : "") + format_vol(b_delta) + "\n\n"
            color summary_col = b_delta >= 0 ? col_bull : col_bear
            string summary_style = b_delta >= 0 ? label.style_label_up : label.style_label_down
            float summary_y = b_delta >= 0 ? low : high

            if na(rt_lbl_sum)
                rt_lbl_sum := label.new(bar_index, summary_y, summary_txt, color=color.new(dark, 100), textcolor=summary_col, style=summary_style, size=size.auto, text_formatting=text.format_bold)
            else
                label.set_xy(rt_lbl_sum, bar_index, summary_y)
                label.set_text(rt_lbl_sum, summary_txt)
                label.set_textcolor(rt_lbl_sum, summary_col)
                label.set_style(rt_lbl_sum, summary_style)
        else
            label.delete(rt_lbl_sum)
            rt_lbl_sum := na

// Cleanup old objects
if array.size(bubble_labels) > 400
    label.delete(array.shift(bubble_labels))
if array.size(bubble_lines) > 400
    line.delete(array.shift(bubble_lines))
if array.size(bubble_summaries) > 400
    label.delete(array.shift(bubble_summaries))

// Bubble (Optimized 3-tier Scaling for High Accuracy & Visual Depth)
plotchar(show_b and vol_intensity_buy > 0.75 ? buy_loc : na, "B1H", char="●", location=location.absolute, color=color.new(c_buy_bubble, 20), size=size.normal)
plotchar(show_b and vol_intensity_buy <= 0.75 and vol_intensity_buy > 0.3 ? buy_loc : na, "B2M", char="●", location=location.absolute, color=color.new(c_buy_bubble, 45), size=size.small)
plotchar(show_b and vol_intensity_buy <= 0.3 ? buy_loc : na, "B3L", char="●", location=location.absolute, color=color.new(c_buy_bubble, 70), size=size.tiny)

// Sell Side
plotchar(show_s and vol_intensity_sell > 0.75 ? sell_loc : na, "S1H", char="●", location=location.absolute, color=color.new(c_sell_bubble, 20), size=size.normal)
plotchar(show_s and vol_intensity_sell <= 0.75 and vol_intensity_sell > 0.3 ? sell_loc : na, "S2M", char="●", location=location.absolute, color=color.new(c_sell_bubble, 45), size=size.small)
plotchar(show_s and vol_intensity_sell <= 0.3 ? sell_loc : na, "S3L", char="●", location=location.absolute, color=color.new(c_sell_bubble, 70), size=size.tiny)

// -----------------------------------------------------------------------------
// 6. SUPER GRADIENT VP + DELTA
// -----------------------------------------------------------------------------
var box[] vp_boxes = array.new_box()
var box[] vp_s_boxes = array.new_box()
var box[] total_boxes = array.new_box()
var line[] total_grad_lines = array.new_line()
var linefill[] total_fills = array.new<linefill>()
var line[] vp_lines = array.new_line()
var label[] vp_labels = array.new_label()
var box[] lvn_boxes = array.new<box>()
var box[] lvn_s_boxes = array.new<box>()
var box[] hvn_boxes = array.new<box>()
var box[] hvn_s_boxes = array.new<box>()
var line[] vp_s_lines = array.new_line()
var label[] vp_s_labels = array.new_label()

var int vp_tick_count = 0
var float vp_live_h = 0.0
var float vp_live_l = 1e10
if barstate.isconfirmed
    vp_live_h := 0.0
    vp_live_l := 1e10

vp_tick_count += 1
bool vp_hl_expanded = high > vp_live_h or low < vp_live_l
if vp_hl_expanded
    vp_live_h := high
    vp_live_l := low

bool trigger_vp = barstate.isconfirmed or barstate.isrealtime

if barstate.islast and (trigger_vp or not show_vp or not show_predict)
    table.delete(ladder_tbl)
    if array.size(vp_boxes) > 0
        for i = 0 to array.size(vp_boxes) - 1
            box.delete(array.get(vp_boxes, i))
        array.clear(vp_boxes)
    if array.size(vp_s_boxes) > 0
        for i = 0 to array.size(vp_s_boxes) - 1
            box.delete(array.get(vp_s_boxes, i))
        array.clear(vp_s_boxes)
    if array.size(total_boxes) > 0
        for i = 0 to array.size(total_boxes) - 1
            box.delete(array.get(total_boxes, i))
        array.clear(total_boxes)
    if array.size(total_grad_lines) > 0
        for i = 0 to array.size(total_grad_lines) - 1
            line.delete(array.get(total_grad_lines, i))
        array.clear(total_grad_lines)
    if array.size(total_fills) > 0
        for i = 0 to array.size(total_fills) - 1
            linefill.delete(array.get(total_fills, i))
        array.clear(total_fills)
    if array.size(vp_lines) > 0
        for i = 0 to array.size(vp_lines) - 1
            line.delete(array.get(vp_lines, i))
        array.clear(vp_lines)
    if array.size(vp_labels) > 0
        for i = 0 to array.size(vp_labels) - 1
            label.delete(array.get(vp_labels, i))
        array.clear(vp_labels)
    if array.size(lvn_boxes) > 0
        for i = 0 to array.size(lvn_boxes) - 1
            box.delete(array.get(lvn_boxes, i))
        array.clear(lvn_boxes)
    if array.size(lvn_s_boxes) > 0
        for i = 0 to array.size(lvn_s_boxes) - 1
            box.delete(array.get(lvn_s_boxes, i))
        array.clear(lvn_s_boxes)
    if array.size(hvn_boxes) > 0
        for i = 0 to array.size(hvn_boxes) - 1
            box.delete(array.get(hvn_boxes, i))
        array.clear(hvn_boxes)
    if array.size(hvn_s_boxes) > 0
        for i = 0 to array.size(hvn_s_boxes) - 1
            box.delete(array.get(hvn_s_boxes, i))
        array.clear(hvn_s_boxes)
    if array.size(predict_lines) > 0
        for i = 0 to array.size(predict_lines) - 1
            line.delete(array.get(predict_lines, i))
        array.clear(predict_lines)
    if array.size(predict_labels) > 0
        for i = 0 to array.size(predict_labels) - 1
            label.delete(array.get(predict_labels, i))
        array.clear(predict_labels)
    if array.size(vp_s_lines) > 0
        for i = 0 to array.size(vp_s_lines) - 1
            line.delete(array.get(vp_s_lines, i))
        array.clear(vp_s_lines)
    if array.size(vp_s_labels) > 0
        for i = 0 to array.size(vp_s_labels) - 1
            label.delete(array.get(vp_s_labels, i))
        array.clear(vp_s_labels)

    int data_size = array.size(hist_close)
    if (show_vp or show_predict) and data_size > 10
        float highest_p = math.max(array.max(hist_high), high)
        float lowest_p = math.min(array.min(hist_low), low)
        int n_rows = vp_use_grain ? math.round((highest_p - lowest_p) / (syminfo.mintick * vp_grain)) : vp_rows
        n_rows := math.min(500, math.max(10, n_rows))
        float row_height = (highest_p - lowest_p) / n_rows
        
        if row_height > 0
            float inv_row_h = 1.0 / row_height
            
            // --- MAIN PROFILE CALCULATION ---
            array<float> bucket_vol_total = array.new_float(n_rows, 0.0)
            array<float> bucket_vol_buy   = array.new_float(n_rows, 0.0)
            array<float> bucket_vol_sell  = array.new_float(n_rows, 0.0)
            
            int hist_start = math.max(0, data_size - (vp_lookback - 1))
            for i = hist_start to data_size - 1
                distribute_vol(n_rows, lowest_p, inv_row_h, array.get(hist_open, i), array.get(hist_high, i), array.get(hist_low, i), array.get(hist_close, i), array.get(hist_buy_vol, i) + array.get(hist_sell_vol, i), bucket_vol_total, bucket_vol_buy, bucket_vol_sell)

            add_ltf_vol(n_rows, lowest_p, inv_row_h, bucket_vol_total, bucket_vol_buy, bucket_vol_sell)

            // --- SHORT-TERM PROFILE CALCULATION ---
            array<float> bucket_s_total = array.new_float(n_rows, 0.0)
            array<float> bucket_s_buy   = array.new_float(n_rows, 0.0)
            array<float> bucket_s_sell  = array.new_float(n_rows, 0.0)
            
            if show_vp_short
                int s_hist_start = math.max(0, data_size - (final_vp_lookback_s - 1))
                for i = s_hist_start to data_size - 1
                    distribute_vol(n_rows, lowest_p, inv_row_h, array.get(hist_open, i), array.get(hist_high, i), array.get(hist_low, i), array.get(hist_close, i), array.get(hist_buy_vol, i) + array.get(hist_sell_vol, i), bucket_s_total, bucket_s_buy, bucket_s_sell)
                
                // Also add current bar data to short term profile
                add_ltf_vol(n_rows, lowest_p, inv_row_h, bucket_s_total, bucket_s_buy, bucket_s_sell)

            float max_total_vol = array.max(bucket_vol_total)
            float inv_max_total_vol = max_total_vol != 0 ? 1.0 / max_total_vol : 1.0
            
            float max_split_vol = math.max(array.max(bucket_vol_buy), array.max(bucket_vol_sell))
            float inv_max_split_vol = max_split_vol != 0 ? 1.0 / max_split_vol : 1.0

            float max_s_vol = array.max(bucket_s_total)
            float inv_max_s_vol = max_s_vol != 0 ? 1.0 / max_s_vol : 1.0
            
            // --- SHORT VP METRICS CALCULATION ---
            int poc_s_idx = array.indexof(bucket_s_total, max_s_vol)
            float total_s_vol = array.sum(bucket_s_total)
            float target_va_s = total_s_vol * 0.70
            float va_vol_s = max_s_vol
            int va_top_s = poc_s_idx
            int va_bot_s = poc_s_idx
            
            if show_vp_short
                int loop_s = 0
                while va_vol_s < target_va_s and loop_s < n_rows
                    loop_s += 1
                    float v_up = (va_top_s < n_rows - 1) ? array.get(bucket_s_total, va_top_s + 1) : 0.0
                    float v_dn = (va_bot_s > 0) ? array.get(bucket_s_total, va_bot_s - 1) : 0.0
                    if v_up >= v_dn and va_top_s < n_rows - 1
                        va_vol_s += v_up
                        va_top_s += 1
                    else if va_bot_s > 0
                        va_vol_s += v_dn
                        va_bot_s -= 1
                    else if va_top_s < n_rows - 1
                        va_vol_s += v_up
                        va_top_s += 1
            
            float vah_s_price = lowest_p + (va_top_s * row_height) + row_height
            float val_s_price = lowest_p + (va_bot_s * row_height)
            
            array<int> lvn_s_indices = array.new_int(0)
            if show_vp_short and show_lvn
                float thresh_s = max_s_vol * lvn_threshold
                for i = 1 to n_rows - 2
                    float v_prev = array.get(bucket_s_total, i-1)
                    float v_curr = array.get(bucket_s_total, i)
                    float v_next = array.get(bucket_s_total, i+1)
                    if v_curr < v_prev and v_curr < v_next and v_curr < thresh_s
                        array.push(lvn_s_indices, i)

            array<int> hvn_s_indices = array.new_int(0)
            if show_vp_short and show_hvn
                float thresh_s_hvn = max_s_vol * hvn_threshold
                for i = 1 to n_rows - 2
                    float v_prev = array.get(bucket_s_total, i-1)
                    float v_curr = array.get(bucket_s_total, i)
                    float v_next = array.get(bucket_s_total, i+1)
                    if v_curr > v_prev and v_curr > v_next and v_curr >= thresh_s_hvn and i != poc_s_idx
                        array.push(hvn_s_indices, i)
                
            int poc_idx = array.indexof(bucket_vol_total, max_total_vol)
            float total_profile_vol = array.sum(bucket_vol_total)
            
            float va_vol = max_total_vol
            float target_va = total_profile_vol * 0.70
            int va_top = poc_idx
            int va_bot = poc_idx
            
            int loop_safety = 0
            while va_vol < target_va and loop_safety < n_rows
                loop_safety += 1
                float v_up = (va_top < n_rows - 1) ? array.get(bucket_vol_total, va_top + 1) : 0.0
                float v_dn = (va_bot > 0) ? array.get(bucket_vol_total, va_bot - 1) : 0.0
                if v_up >= v_dn and va_top < n_rows - 1
                    va_vol += v_up
                    va_top += 1
                else if va_bot > 0
                    va_vol += v_dn
                    va_bot -= 1
                else if va_top < n_rows - 1
                    va_vol += v_up
                    va_top += 1

            float vah_price = lowest_p + (va_top * row_height) + row_height
            float val_price = lowest_p + (va_bot * row_height)
            float poc_price = lowest_p + (poc_idx * row_height) + (row_height/2)
            
            // --- LVN IDENTIFICATION ---
            array<int> lvn_indices = array.new_int(0)
            if show_lvn
                float threshold_vol = max_total_vol * lvn_threshold
                for i = 1 to n_rows - 2
                    float v_prev = array.get(bucket_vol_total, i - 1)
                    float v_curr = array.get(bucket_vol_total, i)
                    float v_next = array.get(bucket_vol_total, i + 1)
                    if v_curr < v_prev and v_curr < v_next and v_curr < threshold_vol
                        array.push(lvn_indices, i)

            // --- HVN IDENTIFICATION ---
            array<int> hvn_indices = array.new_int(0)
            if show_hvn
                float threshold_hvn_vol = max_total_vol * hvn_threshold
                for i = 1 to n_rows - 2
                    float v_prev = array.get(bucket_vol_total, i - 1)
                    float v_curr = array.get(bucket_vol_total, i)
                    float v_next = array.get(bucket_vol_total, i + 1)
                    if v_curr > v_prev and v_curr > v_next and v_curr >= threshold_hvn_vol and i != poc_idx
                        array.push(hvn_indices, i)

            // --- HVTs IDENTIFICATION FOR PREDICTION ---
            array.clear(targets_all)
            // --- HVTs IDENTIFICATION FOR PREDICTION (Structured 4-Step Collection) ---
            if show_predict
                array<HVT> raw_targets = array.new<HVT>()
                
                // STEP 1: Trend Focus (Average Delta +/- Trends & EMA)
                if show_ema_long and not na(ema_long_val)
                    array.push(raw_targets, HVT.new(price=ema_long_val, strength=150.0, is_above=ema_long_val > close, priority=1, description="institutional ema trend"))
                if not na(hist_avg_buy_g)
                    array.push(raw_targets, HVT.new(price=hist_avg_buy_g, strength=100.0, is_above=hist_avg_buy_g > close, priority=1, description="trend average buy price"))
                if not na(hist_avg_sell_g)
                    array.push(raw_targets, HVT.new(price=hist_avg_sell_g, strength=100.0, is_above=hist_avg_sell_g > close, priority=1, description="trend average sell price"))

                // STEP 2: Total Delta Main Volume Profile (VAL, VAH, POC, HVN, LVN)
                if not na(val_price)
                    array.push(raw_targets, HVT.new(price=val_price, strength=120.0, is_above=val_price > close, priority=2, description="main profile val"))
                if not na(vah_price)
                    array.push(raw_targets, HVT.new(price=vah_price, strength=120.0, is_above=vah_price > close, priority=2, description="main profile vah"))
                if not na(poc_price)
                    array.push(raw_targets, HVT.new(price=poc_price, strength=140.0, is_above=poc_price > close, priority=2, description="main profile poc"))
                if array.size(hvn_indices) > 0
                    for hvn_idx in hvn_indices
                        float p_hvn = lowest_p + (hvn_idx * row_height) + (row_height/2)
                        array.push(raw_targets, HVT.new(price=p_hvn, strength=110.0, is_above=p_hvn > close, priority=2, description="main profile hvn"))
                if array.size(lvn_indices) > 0
                    for lvn_idx in lvn_indices
                        float p_lvn = lowest_p + (lvn_idx * row_height) + (row_height/2)
                        array.push(raw_targets, HVT.new(price=p_lvn, strength=80.0, is_above=p_lvn > close, priority=2, description="main profile lvn"))

                // STEP 3: Short Volume Profile (VAL, VAH, POC, LVN, HVN)
                if show_vp_short
                    if not na(val_s_price)
                        array.push(raw_targets, HVT.new(price=val_s_price, strength=90.0, is_above=val_s_price > close, priority=3, description="short profile val"))
                    if not na(vah_s_price)
                        array.push(raw_targets, HVT.new(price=vah_s_price, strength=90.0, is_above=vah_s_price > close, priority=3, description="short profile vah"))
                    float poc_s_p = lowest_p + (poc_s_idx * row_height) + (row_height/2)
                    if not na(poc_s_p)
                        array.push(raw_targets, HVT.new(price=poc_s_p, strength=100.0, is_above=poc_s_p > close, priority=3, description="short profile poc"))
                    if array.size(lvn_s_indices) > 0
                        for l_idx in lvn_s_indices
                            float lp = lowest_p + (l_idx * row_height) + (row_height/2)
                            array.push(raw_targets, HVT.new(price=lp, strength=70.0, is_above=lp > close, priority=3, description="short profile lvn"))
                    if array.size(hvn_s_indices) > 0
                        for h_idx in hvn_s_indices
                            float hp = lowest_p + (h_idx * row_height) + (row_height/2)
                            array.push(raw_targets, HVT.new(price=hp, strength=95.0, is_above=hp > close, priority=3, description="short profile hvn"))

                // STEP 4: Large Bubble Volume (Bubble Volume & Delta Bubble Volume)
                if vol_intensity_buy >= large_vol_threshold and not na(buy_loc)
                    array.push(raw_targets, HVT.new(price=buy_loc, strength=130.0, is_above=buy_loc > close, priority=4, description="large buy bubble volume"))
                if vol_intensity_sell >= large_vol_threshold and not na(sell_loc)
                    array.push(raw_targets, HVT.new(price=sell_loc, strength=130.0, is_above=sell_loc > close, priority=4, description="large sell bubble volume"))
                if array.size(lv_boxes) > 0
                    for lvb in lv_boxes
                        if lvb.active and not na(lvb.level)
                            array.push(raw_targets, HVT.new(price=lvb.level, strength=110.0, is_above=lvb.level > close, priority=4, description=lvb.is_buy ? "unmitigated large buy volume bubble" : "unmitigated large sell volume bubble"))

                // --- SMART CONFLUENCE MERGING ---
                float merge_threshold = row_height * 1.2
                
                for rt in raw_targets
                    bool merged = false
                    if array.size(targets_all) > 0
                        for i = 0 to array.size(targets_all) - 1
                            HVT ct = array.get(targets_all, i)
                            if math.abs(rt.price - ct.price) < merge_threshold
                                ct.strength += rt.strength
                                ct.confluence += 1
                                ct.price := (ct.price + rt.price) / 2
                                // Keep the highest priority (lowest numeric value)
                                ct.priority := math.min(ct.priority, rt.priority)
                                
                                // Concatenate Descriptions for Confluence (Prevent duplicates)
                                if ct.description != rt.description and not str.contains(ct.description, rt.description)
                                    ct.description += "\n" + rt.description
                                
                                // EMA Precision Boost (Confluence)
                                if show_ema_long and math.abs(ct.price - ema_long_val) < row_height * 2
                                    ct.strength += 50.0
                                    ct.confluence += 1
                                    if not str.contains(ct.description, "ema s/r")
                                        ct.description += "\ninstitutional ema s/r"
                                    
                                merged := true
                                break
                    if not merged
                        array.push(targets_all, rt)

                // Global Sorting by Priority, then Score (Strength, Momentum, Volatility & Proximity)
                int size_all = array.size(targets_all)
                if size_all > 1
                    // Pre-calculate sorting scores to avoid redundant calculations in nested loops
                    array<float> sort_scores = array.new_float(size_all)
                    for i = 0 to size_all - 1
                        HVT t = array.get(targets_all, i)
                        
                        // 1. Distance Normalization
                        float dist = math.abs(t.price - close)
                        float dist_norm = dist * inv_row_h
                        
                        // 2. Trend & Sentiment Bias Calculation
                        // Enhanced with EMA, POC, and Avg Buy/Sell Slopes as priority factors
                        float sentiment_bias = 0.0
                        
                        // Priority 1: Technical Slopes (Institutional & Volume Trends)
                        sentiment_bias += ema_slope_pct * (t.is_above ? 1.0 : -1.0) * 0.4
                        sentiment_bias += (na(poc_slope) ? 0 : poc_slope) * (t.is_above ? 1.0 : -1.0) * 0.3
                        sentiment_bias += (na(ab_slope) ? 0 : ab_slope) * (t.is_above ? 1.0 : -1.0) * 0.15
                        sentiment_bias += (na(as_slope) ? 0 : as_slope) * (t.is_above ? 1.0 : -1.0) * 0.15
                        
                        // Priority 2: Market Momentum
                        sentiment_bias += daily_change_pct * (t.is_above ? 1.0 : -1.0) * 0.05
                        sentiment_bias += agg_delta_pct * (t.is_above ? 1.0 : -1.0) * 0.1
                        sentiment_bias += (agg_delta_pct - p_agg_delta_pct) * (t.is_above ? 1.0 : -1.0) * 0.15 // Net Delta Momentum
                        float d_mom = (delta - p_delta) / math.max(1.0, total_volume) * (t.is_above ? 1.0 : -1.0) * 10.0 // Delta Momentum
                        sentiment_bias += d_mom
                        
                        float trend_w = 1.0 + math.max(-0.8, math.min(0.8, sentiment_bias))
                        
                        // 3. Confluence & Volatility-Adjusted Proximity
                        float conf_w = 1.0 + (t.confluence - 1) * 0.25
                        float prox_w = 1.0 / math.pow(math.max(1.0, dist_norm / math.max(0.5, mkt_volatility)), 0.6)
                        
                        // 4. Institutional EMA Slope alignment
                        float slope_w = (ema_slope > 0 and t.is_above) or (ema_slope < 0 and not t.is_above) ? 1.25 : 0.75
                        
                        // Update HVT storage for detailed table reporting
                        t.bias := trend_w
                        t.vol_w := prox_w
                        t.momentum := d_mom
                        
                        float final_score = t.strength * trend_w * conf_w * prox_w * slope_w
                        
                        // Map priority and score into a single sortable float: Higher is better
                        // Priority 1 -> 10,000,000+, Priority 2 -> 20,000,000+, etc. (reversed)
                        array.set(sort_scores, i, (10 - t.priority) * 10000000 + final_score)

                    for i = 0 to size_all - 2
                        for j = i + 1 to size_all - 1
                            if array.get(sort_scores, j) > array.get(sort_scores, i)
                                // Swap Scores
                                float temp_s = array.get(sort_scores, i)
                                array.set(sort_scores, i, array.get(sort_scores, j))
                                array.set(sort_scores, j, temp_s)
                                // Swap Targets
                                HVT temp_t = array.get(targets_all, i)
                                array.set(targets_all, i, array.get(targets_all, j))
                                array.set(targets_all, j, temp_t)

            // --- DYNAMIC OFFSET CALCULATION ---
            int predict_count = math.min(predict_targets, array.size(targets_all))
            predict_reach := show_predict ? predict_count * predict_bars : 0
            int width_scaler_vp = math.round(30 * (vp_width / 10.0))
            int width_scaler_s = math.round(width_scaler_vp * 0.6)
            int x_s_start = bar_index + math.max(vp_h_offset, predict_reach + 10)
            
            // Safe Coordinate Capping to prevent RE10020 runtime error
            int max_x_s_start = bar_index + 416 - (show_vp_short ? width_scaler_s + vp_gap + 20 : 0) - width_scaler_vp - vp_gap
            x_s_start := math.max(bar_index + 10, math.min(x_s_start, max_x_s_start))

            int x_vp_start = x_s_start + (show_vp_short ? width_scaler_s + vp_gap + 20 : 0) // Extra space for short VP labels
            float inv_fade_range = 1.0 / (40 * row_height)

            for i = 0 to n_rows - 1
                float b_vol = array.get(bucket_vol_total, i)
                float b_s_vol = array.get(bucket_s_total, i)
                float level_bottom = lowest_p + (i * row_height)
                float level_top = level_bottom + row_height

                // --- SHORT VP RENDERING ---
                if show_vp_short and b_s_vol > 0
                    float s_buy = array.get(bucket_s_buy, i)
                    float s_sell = array.get(bucket_s_sell, i)
                    float s_delta = s_buy - s_sell
                    color s_base_c = vp_type == "Normal" ? col_poc : (s_delta > 0 ? c_buy : (s_delta < 0 ? c_sell : col_poc))
                    float pct_s = b_s_vol * inv_max_s_vol
                    int t_s = get_profile_alpha(pct_s, level_bottom, close, inv_fade_range)
                    int len_s = math.round(width_scaler_s * pct_s)
                    string txt_s_delta = show_vp_labels ? ((s_delta > 0 ? "+" : "") + format_vol(s_delta)) : ""
                    string vp_s_txt = show_vp_labels ? (format_vol(b_s_vol) + (vp_type == "Delta" ? " | " + txt_s_delta : "")) : ""
                    box bs = box.new(x_s_start, level_top, x_s_start + len_s, level_bottom, border_width=1, border_color=transparent_col, bgcolor=color.new(s_base_c, t_s), text=vp_s_txt, text_formatting=text.format_bold, text_size=size.auto, text_color=dark)
                    array.push(vp_s_boxes, bs)
                    
                    if i == poc_s_idx
                        float poc_s_p = level_bottom + (row_height/2)
                        line l_poc_s = line.new(x_s_start, poc_s_p, x_s_start + width_scaler_s, poc_s_p, color=col_poc, width=1)
                        array.push(vp_s_lines, l_poc_s)
                        lbl_poc_s = label.new(x_s_start + width_scaler_s, poc_s_p, "POC[S]: " + format_vol(max_s_vol), color=color.new(col_poc, 90), textcolor=white, size=size.tiny, style=label.style_label_left)
                        array.push(vp_s_labels, lbl_poc_s)

                // --- MAIN VP RENDERING ---
                if b_vol > 0
                    float b_buy = array.get(bucket_vol_buy, i)
                    float b_sell = array.get(bucket_vol_sell, i)
                    float b_delta = b_buy - b_sell
                    
                    // --- DELTA-BASED COLORING ---
                    // 1. Total VP (Buy Color -> Sell Color based on Delta or Normal)
                    color base_c = vp_type == "Normal" ? col_poc : (b_delta > 0 ? c_buy : (b_delta < 0 ? c_sell : col_poc))
                    float pct_total = b_vol * inv_max_total_vol
                    int t_vp = get_profile_alpha(pct_total, level_bottom, close, inv_fade_range)
                    color c_bar_vp = color.new(base_c, t_vp)
                    
                    int len_total = math.round(width_scaler_vp * pct_total)
                    string txt_delta = show_vp_labels ? ((b_delta > 0 ? "+" : "") + format_vol(b_delta)) : ""
                    
                    if show_vp
                        string vp_txt = show_vp_labels ? (format_vol(b_vol) + (vp_type == "Delta" ? " | " + txt_delta : "")) : ""
                        box b = box.new(x_vp_start, level_top, x_vp_start + len_total, level_bottom, border_width=1, border_color=transparent_col, bgcolor=c_bar_vp, text=vp_txt, text_formatting = text.format_bold,text_size=size.auto, text_color=dark)
                        array.push(vp_boxes, b)
            
            if show_vp_short
                float poc_s_p = lowest_p + (poc_s_idx * row_height) + (row_height/2)
                int x_s_end = x_s_start + width_scaler_s
                
                line l_vah_s = line.new(x_s_start, vah_s_price, x_s_end, vah_s_price, color=color.new(white, 20), width=1, style=line.style_dotted)
                array.push(vp_s_lines, l_vah_s)
                float vah_s_vol = va_top_s < n_rows ? array.get(bucket_s_total, va_top_s) : 0
                lbl_vah_s = label.new(x_s_end, vah_s_price, "VAH[S]: " + str.tostring(vah_s_price, format.mintick) + " (" + format_vol(vah_s_vol) + ")", color=color.new(white, 90), textcolor=white, size=size.tiny, style=label.style_label_left)
                array.push(vp_s_labels, lbl_vah_s)

                line l_val_s = line.new(x_s_start, val_s_price, x_s_end, val_s_price, color=color.new(white, 20), width=1, style=line.style_dotted)
                array.push(vp_s_lines, l_val_s)
                float val_s_vol = va_bot_s >= 0 ? array.get(bucket_s_total, va_bot_s) : 0
                lbl_val_s = label.new(x_s_end, val_s_price, "VAL[S]: " + str.tostring(val_s_price, format.mintick) + " (" + format_vol(val_s_vol) + ")", color=color.new(white, 90), textcolor=white, size=size.tiny, style=label.style_label_left)
                array.push(vp_s_labels, lbl_val_s)
                
                if show_lvn and array.size(lvn_s_indices) > 0
                    for l_idx in lvn_s_indices
                        float lp = lowest_p + (l_idx * row_height) + (row_height/2)
                        float l_vol = array.get(bucket_s_total, l_idx)
                        float l_bottom = lowest_p + (l_idx * row_height)
                        float l_top = l_bottom + row_height
                        color lvn_border_c = color.new(color_lvn, 30)
                        color lvn_bg_c = color.new(color_lvn, 90)
                        string lvn_txt = "LVN"//"[S]: " + str.tostring(lp, format.mintick) + " (" + format_vol(l_vol) + ")"
                        box b_lvn = box.new(left=x_s_start, top=l_top, right=x_s_end, bottom=l_bottom,
                                            border_color=lvn_border_c, border_width=1, border_style=line.style_dashed,
                                            bgcolor=lvn_bg_c, text=lvn_txt, text_color=white, text_size=size.auto,
                                            text_formatting=text.format_bold, text_halign=text.align_center, text_valign=text.align_center)
                        array.push(lvn_s_boxes, b_lvn)

                if show_hvn and array.size(hvn_s_indices) > 0
                    for h_idx in hvn_s_indices
                        float hp = lowest_p + (h_idx * row_height) + (row_height/2)
                        float h_vol = array.get(bucket_s_total, h_idx)
                        float h_bottom = lowest_p + (h_idx * row_height)
                        float h_top = h_bottom + row_height
                        color hvn_border_c = color.new(color_hvn, 30)
                        color hvn_bg_c = color.new(color_hvn, 90)
                        string hvn_txt = "HVN"//"[S]: " + str.tostring(hp, format.mintick) + " (" + format_vol(h_vol) + ")"
                        box b_hvn = box.new(left=x_s_start, top=h_top, right=x_s_end, bottom=h_bottom,
                                            border_color=hvn_border_c, border_width=1, border_style=line.style_solid,
                                            bgcolor=hvn_bg_c, text=hvn_txt, text_color=white, text_size=size.auto,
                                            text_formatting=text.format_bold, text_halign=text.align_center, text_valign=text.align_center)
                        array.push(hvn_s_boxes, b_hvn)
            int end_line = x_vp_start + width_scaler_vp + vp_gap
            int final_end_line = end_line

            if show_vp
                // Profile Boundaries Backgrounds
                array.push(vp_boxes, box.new(x_vp_start, highest_p, final_end_line, vah_price, bgcolor=color.new(col_bear,80), border_color=color.new(mitigated_color ,60),border_width = 2))
                array.push(vp_boxes, box.new(x_vp_start, vah_price, final_end_line, val_price, bgcolor=color.new(brown, 80), border_color=color.new(mitigated_color,60),border_width = 2))
                array.push(vp_boxes, box.new(x_vp_start, val_price, final_end_line, lowest_p, bgcolor=color.new(col_bull,80), border_color=color.new(mitigated_color ,60),border_width = 2))

                line l_poc = line.new(x_vp_start, poc_price, final_end_line, poc_price, color=color_vp_poc, width=1)
                array.push(vp_lines, l_poc)
                lbl_poc = label.new(final_end_line, poc_price, "POC: " + str.tostring(poc_price, format.mintick) + " (" + format_vol(max_total_vol) + ")", color=color.new(color_vp_poc, 90), textcolor=white, size=size.tiny, style=label.style_label_left)
                array.push(vp_labels, lbl_poc)
                
                line l_vah = line.new(x_vp_start, vah_price, final_end_line, vah_price, color=color.new(white, 0), width=2, style=line.style_dotted)
                array.push(vp_lines, l_vah)
                float vah_vol = va_top < n_rows ? array.get(bucket_vol_total, va_top) : 0
                lbl_vah = label.new(final_end_line, vah_price, "VAH: " + str.tostring(vah_price, format.mintick) + " (" + format_vol(vah_vol) + ")", color=color.new(white, 90), textcolor=col_poc, size=size.small, style=label.style_label_left)
                array.push(vp_labels, lbl_vah)
                
                line l_val = line.new(x_vp_start, val_price, final_end_line, val_price, color=color.new(white, 0), width=2, style=line.style_dotted)
                array.push(vp_lines, l_val)
                float val_vol = va_bot >= 0 ? array.get(bucket_vol_total, va_bot) : 0
                lbl_val = label.new(final_end_line, val_price, "VAL: " + str.tostring(val_price, format.mintick) + " (" + format_vol(val_vol) + ")", color=color.new(white, 90), textcolor=col_poc, size=size.small, style=label.style_label_left)
                array.push(vp_labels, lbl_val)

                // --- RENDER LVNs ---
                if show_lvn and array.size(lvn_indices) > 0
                    for lvn_idx in lvn_indices
                        float lvn_p = lowest_p + (lvn_idx * row_height) + (row_height/2)
                        float lvn_v = array.get(bucket_vol_total, lvn_idx)
                        float lvn_bottom = lowest_p + (lvn_idx * row_height)
                        float lvn_top = lvn_bottom + row_height
                        color lvn_border_c = color.new(color_lvn, 30)
                        color lvn_bg_c = color.new(color_lvn, 90)
                        string lvn_txt = "LVN "// + str.tostring(lvn_p, format.mintick) + " (" + format_vol(lvn_v) + ")"
                        box b_lvn = box.new(left=x_vp_start, top=lvn_top, right=final_end_line, bottom=lvn_bottom,
                                            border_color=lvn_border_c, border_width=1, border_style=line.style_dashed,
                                            bgcolor=lvn_bg_c, text=lvn_txt, text_color=white, text_size=size.auto,
                                            text_formatting=text.format_bold, text_halign=text.align_center, text_valign=text.align_center)
                        array.push(lvn_boxes, b_lvn)

                // --- RENDER HVNs ---
                if show_hvn and array.size(hvn_indices) > 0
                    for hvn_idx in hvn_indices
                        float hvn_p = lowest_p + (hvn_idx * row_height) + (row_height/2)
                        float hvn_v = array.get(bucket_vol_total, hvn_idx)
                        float hvn_bottom = lowest_p + (hvn_idx * row_height)
                        float hvn_top = hvn_bottom + row_height
                        color hvn_border_c = color.new(color_hvn, 30)
                        color hvn_bg_c = color.new(color_hvn, 90)
                        string hvn_txt = "HVN "// + str.tostring(hvn_p, format.mintick) + " (" + format_vol(hvn_v) + ")"
                        box b_hvn = box.new(left=x_vp_start, top=hvn_top, right=final_end_line, bottom=hvn_bottom,
                                            border_color=hvn_border_c, border_width=1, border_style=line.style_solid,
                                            bgcolor=hvn_bg_c, text=hvn_txt, text_color=white, text_size=size.auto,
                                            text_formatting=text.format_bold, text_halign=text.align_center, text_valign=text.align_center)
                        array.push(hvn_boxes, b_hvn)

                line l_vlh = line.new(x_vp_start - 1, val_price, x_vp_start - 1, vah_price, color=color.new(white, 0), width=6, style=line.style_solid)
                array.push(vp_lines, l_vlh)
                line l_vlh1 = line.new(x_vp_start - 1, val_price, x_vp_start - 1, lowest_p, color=color.new(col_bull , 0), width=6, style=line.style_solid)
                array.push(vp_lines, l_vlh1)
                line l_vlh2 = line.new(x_vp_start - 1, vah_price, x_vp_start - 1, highest_p, color=color.new(col_bear , 0), width=6, style=line.style_solid)
                array.push(vp_lines, l_vlh2)

            // Update Logo Offset based on final technical stack width
            l_off := (final_end_line - bar_index) + 10

            // --- BUY/SELL AVERAGE LINES (SYNCED WITH HISTORICAL PLOTS) ---
            if not na(hist_avg_buy_g) and show_vp
                line l_avg_buy = line.new(x_vp_start, hist_avg_buy_g, final_end_line, hist_avg_buy_g, color=color.new(c_buy, 0), width=1, style=line.style_dotted)
                lbl_buy = label.new(final_end_line, hist_avg_buy_g, "AVG BUY", color=color.new(c_buy, 60), textcolor=white, size=size.tiny, style=label.style_label_left)
                array.push(vp_lines, l_avg_buy)
                array.push(vp_labels, lbl_buy)

            if not na(hist_avg_sell_g) and show_vp
                line l_avg_sell = line.new(x_vp_start, hist_avg_sell_g, final_end_line, hist_avg_sell_g, color=color.new(c_sell, 0), width=1, style=line.style_dotted)
                lbl_sell = label.new(final_end_line, hist_avg_sell_g, "AVG SELL", color=color.new(c_sell, 60), textcolor=white, size=size.tiny, style=label.style_label_left)
                array.push(vp_lines, l_avg_sell)
                array.push(vp_labels, lbl_sell)

            // --- TOTAL BUY/SELL PERCENTAGE BOXES ---
            float total_buy_all = array.sum(bucket_vol_buy)
            float total_sell_all = array.sum(bucket_vol_sell)
            float total_vol_all = total_buy_all + total_sell_all

            if total_vol_all > 0 and show_vp
                float buy_pct = (total_buy_all / total_vol_all) * 100
                float sell_pct = (total_sell_all / total_vol_all) * 100

                float box_y_top = lowest_p - (row_height * 2)
                float box_y_bot = lowest_p - (row_height * 5)

                int final_total_width = final_end_line - x_vp_start
                int buy_width = math.round(final_total_width * (total_buy_all / total_vol_all))

                // Gradient Background segments (using lines and fills)
                int n_grad = 20
                float seg_w = 1.0 * final_total_width / n_grad
                line prev_l = na
                for j = 0 to n_grad
                    int x_cur = x_vp_start + math.round(j * seg_w)
                    
                    // Create vertical line for this segment boundary
                    line cur_l = line.new(x_cur, box_y_top, x_cur, box_y_bot, color=na, width=1)
                    array.push(total_grad_lines, cur_l)
                    
                    if not na(prev_l)
                        // Calculate metrics for the center of this segment
                        float mid_g_pos = 1.0 * (j - 0.5) / n_grad
                        color c_seg = color.from_gradient(mid_g_pos, 0, 1, c_buy, c_sell)
                        int g_transp = math.round(30 + (1 - (math.abs(mid_g_pos - 0.5) / 0.5)) * 70)
                        array.push(total_fills, linefill.new(prev_l, cur_l, color=color.new(c_seg, g_transp)))
                    
                    prev_l := cur_l

                string txt_buy = "BUY " + format_vol(total_buy_all) + "\n" + "\n(" + str.tostring(buy_pct, "#.#") + "%)"
                string txt_sell = "SELL " + format_vol(total_sell_all) + "\n" + "\n(" + str.tostring(sell_pct, "#.#") + "%)"

                box_total_buy = box.new(x_vp_start, box_y_top, x_vp_start + buy_width, box_y_bot,
                                 bgcolor=na, border_color=transparent_col, border_width = 2,
                                 text=txt_buy, text_color=col_poc, text_size=size.auto,text_formatting= text.format_bold, text_valign=text.align_center,text_halign = text.align_center )
                box_total_sell = box.new(x_vp_start + buy_width, box_y_top, x_vp_start + final_total_width, box_y_bot,
                                 bgcolor=na, border_color=transparent_col, border_width =2,
                                 text=txt_sell, text_color=col_poc , text_size=size.auto,text_formatting = text.format_bold, text_valign=text.align_center,text_halign = text.align_center )

                array.push(total_boxes, box_total_buy)
                array.push(total_boxes, box_total_sell)

            // --- DRAW PREDICTION ZIGZAG ---
            if show_predict
                // Draw Unified Targets (Zigzag Sequential)
                int count = math.min(predict_targets, array.size(targets_all))
                int cur_x = bar_index
                float cur_y = close
                
                for i = 0 to count - 1
                    HVT t = array.get(targets_all, i)
                    int x_start = math.min(bar_index + 450, cur_x)
                    float y_start = cur_y
                    int x_end = math.min(bar_index + 450, cur_x + predict_bars)
                    float y_end = t.price
                    color h_col = t.is_above ? col_bull : col_bear
                    
                    // Intensity based on confluence
                    int path_width = math.min(2, t.confluence)
                    
                    if x_start < x_end
                        array.push(predict_lines, line.new(x_start, y_start, x_end, y_end, color=color.new(h_col, 0), width=path_width, style=line.style_dotted))
                    
                    if x_end <= bar_index + 450
                        string lbl_txt = show_predict_labels ? str.tostring(t.price, format.mintick) : ""
                        if show_priority
                            string p_marker = t.priority == 1 ? (math.abs(t.price - ema_long_val) < row_height * 2 ? "[E]" : "[B]") : (t.priority == 2 ? "[L]" : "[V]")
                            lbl_txt += " | " + p_marker + " #" + str.tostring(i + 1)
                        // Shift labels slightly to the right of the bubble
                        array.push(predict_labels, label.new(math.min(bar_index + 480, x_end + 3), y_end, lbl_txt, color=color.new(h_col, 80), textcolor=white, style=label.style_label_left, size=size.tiny, text_formatting=text.format_bold))
                        array.push(predict_labels, label.new(x_end, y_end, "●", color=color.new(h_col, 100), textcolor=white, style=label.style_label_center, size=size.small))
                        array.push(predict_labels, label.new(x_end, y_end, "○", color=color.new(h_col, 100), textcolor=white, style=label.style_label_center, size=size.large))
                        
                        if barstate.isconfirmed and i == 0
                            array.push(predict_history, PredictHist.new(start_idx=bar_index, end_idx=bar_index + predict_bars, y_start=close, target_p=y_end, is_above=t.is_above, is_hit=false, hit_idx=na, is_settled=false, ln_path=na, lbl_target=na, lbl_price=na))
                            total_predictions += 1
                            if array.size(predict_history) > predict_hist_len
                                PredictHist old_ph = array.shift(predict_history)
                                line.delete(old_ph.ln_path), label.delete(old_ph.lbl_target), label.delete(old_ph.lbl_price)
                        
                    // Update cursor for next zigzag segment
                    cur_x := x_end
                    cur_y := y_end

            // --- VOLUME LADDER TABLE RENDERING ---
            if show_volume_ladder and total_profile_vol > 0
                string l_pos = switch ladder_position_input
                    "top_left"     => position.top_left
                    "top_right"    => position.top_right
                    "bottom_left"  => position.bottom_left
                    "bottom_right" => position.bottom_right
                    => position.top_right

                // Calculate max_abs_delta for delta cell gradients
                float max_abs_delta = 0.0
                for r = 0 to n_rows - 1
                    float b_vol = array.get(bucket_vol_total, r)
                    if b_vol > 0
                        float b_buy = array.get(bucket_vol_buy, r)
                        float b_sell = array.get(bucket_vol_sell, r)
                        float b_delta = b_buy - b_sell
                        max_abs_delta := math.max(max_abs_delta, math.abs(b_delta))

                // Current price index identification
                int current_price_row_idx = -1
                if close >= lowest_p and close <= highest_p
                    current_price_row_idx := math.floor((close - lowest_p) / row_height)
                    current_price_row_idx := math.max(0, math.min(n_rows - 1, current_price_row_idx))

                // Avg Buy and Avg Sell index identification
                int avg_buy_row_idx = -1
                if not na(hist_avg_buy_g) and hist_avg_buy_g >= lowest_p and hist_avg_buy_g <= highest_p
                    avg_buy_row_idx := math.floor((hist_avg_buy_g - lowest_p) / row_height)
                    avg_buy_row_idx := math.max(0, math.min(n_rows - 1, avg_buy_row_idx))

                int avg_sell_row_idx = -1
                if not na(hist_avg_sell_g) and hist_avg_sell_g >= lowest_p and hist_avg_sell_g <= highest_p
                    avg_sell_row_idx := math.floor((hist_avg_sell_g - lowest_p) / row_height)
                    avg_sell_row_idx := math.max(0, math.min(n_rows - 1, avg_sell_row_idx))

                // Determine display rows window
                int display_rows = math.min(n_rows, ladder_max_rows)
                int center_idx = current_price_row_idx != -1 ? current_price_row_idx : poc_idx
                int start_r = center_idx - math.floor(display_rows / 2)
                int end_r = start_r + display_rows - 1
                if start_r < 0
                    start_r := 0
                    end_r := display_rows - 1
                if end_r >= n_rows
                    end_r := n_rows - 1
                    start_r := math.max(0, end_r - display_rows + 1)

                ladder_tbl := table.new(l_pos, 4, display_rows + 1, bgcolor=dark, border_width=1, border_color=Transparent_Color, frame_color=mitigated_color, frame_width=1)
                table.cell(ladder_tbl, 0, 0, "Sell | Buy", bgcolor=dark, text_color=white, text_size=size.tiny)
                table.cell(ladder_tbl, 1, 0, "Total Vol", bgcolor=dark, text_color=white, text_size=size.tiny)
                table.cell(ladder_tbl, 2, 0, "Delta", bgcolor=dark, text_color=white, text_size=size.tiny)
                table.cell(ladder_tbl, 3, 0, "Price", bgcolor=dark, text_color=white, text_size=size.tiny)

                for r = start_r to end_r
                    int tbl_row = end_r - r + 1
                    float level_price = lowest_p + r * row_height
                    float level_vol = array.get(bucket_vol_total, r)
                    float level_buy_vol = array.get(bucket_vol_buy, r)
                    float level_sell_vol = array.get(bucket_vol_sell, r)
                    float level_delta = level_buy_vol - level_sell_vol
                    color row_bgcolor = color.new(mitigated_color, 80)

                    // Check HVN/LVN status locally based on advanced bookmap settings
                    bool is_hvn = false
                    bool is_lvn = false
                    if r > 0 and r < n_rows - 1
                        float v_prev = array.get(bucket_vol_total, r - 1)
                        float v_curr = level_vol
                        float v_next = array.get(bucket_vol_total, r + 1)
                        if show_hvn and v_curr > v_prev and v_curr > v_next and v_curr >= max_total_vol * hvn_threshold and r != poc_idx
                            is_hvn := true
                        if show_lvn and v_curr < v_prev and v_curr < v_next and v_curr < max_total_vol * lvn_threshold
                            is_lvn := true

                    if r == poc_idx
                        row_bgcolor := color.new(col_poc, 40)
                    else if is_hvn
                        row_bgcolor := color.new(col_bull, 50)
                    else if is_lvn
                        row_bgcolor := color.new(col_bear, 50)
                    else if r >= va_bot and r <= va_top
                        row_bgcolor := color.new(mitigated_color, 65)

                    // Current price highlighting
                    if r == current_price_row_idx
                        row_bgcolor := color_theme == "Gear Protocol" ? color.new(white, 20) : color.new(yellow, 30)

                    string sell_buy_str = f_formatNumber(level_sell_vol, false) + " | " + f_formatNumber(level_buy_vol, false)
                    string price_str = str.tostring(level_price, format.mintick)

                    if r == current_price_row_idx
                        price_str := "▶ " + price_str + " ◀"
                    if is_hvn
                        price_str := "[HVN] " + price_str
                    else if is_lvn
                        price_str := "[LVN] " + price_str

                    if r == va_top
                        price_str := "[VAH] " + price_str
                    else if r == va_bot
                        price_str := "[VAL] " + price_str

                    if r == poc_idx
                        price_str := "[POC] " + price_str

                    if r == avg_buy_row_idx
                        price_str := "[AVG BUY] " + price_str
                    if r == avg_sell_row_idx
                        price_str := "[AVG SELL] " + price_str

                    table.cell(ladder_tbl, 0, tbl_row, sell_buy_str, bgcolor=row_bgcolor, text_color=white, text_size=size.tiny)
                    table.cell(ladder_tbl, 1, tbl_row, f_formatNumber(level_vol, false), bgcolor=row_bgcolor, text_color=white, text_size=size.tiny)
                    
                    color base_delta_color = level_delta >= 0 ? col_bull : col_bear
                    color delta_bgcolor = f_gradientColor(base_delta_color, level_delta, max_abs_delta)
                    if (level_buy_vol > level_sell_vol * vp_imbalance_threshold and level_sell_vol > 0) or (level_sell_vol > level_buy_vol * vp_imbalance_threshold and level_buy_vol > 0)
                        delta_bgcolor := color.new(base_delta_color, 0)
                        
                    table.cell(ladder_tbl, 2, tbl_row, f_formatNumber(level_delta, true), bgcolor=delta_bgcolor, text_color=white, text_size=size.tiny)
                    table.cell(ladder_tbl, 3, tbl_row, price_str, bgcolor=row_bgcolor, text_color=white, text_size=size.tiny)

// -----------------------------------------------------------------------------
// 7. PRICE PREDICTION HISTORY & HIT DETECTION
// -----------------------------------------------------------------------------
if show_predict
    if array.size(predict_history) > 0
        for i = 0 to array.size(predict_history) - 1
            PredictHist ph = array.get(predict_history, i)
            if not ph.is_settled
                bool hit = false
                if ph.is_above
                    if high >= ph.target_p
                        hit := true
                else
                    if low <= ph.target_p
                        hit := true
                
                if hit
                    ph.is_hit    := true
                    ph.is_settled := true
                    ph.hit_idx    := bar_index
                    hits_count    += 1
                else if bar_index >= ph.end_idx
                    ph.is_settled := true

    // Visual History Rendering & Cleanup
    if barstate.islast and array.size(predict_history) > 0
        for i = 0 to array.size(predict_history) - 1
            PredictHist ph = array.get(predict_history, i)
            if show_predict_hist and ph.is_hit
                color h_col = ph.is_above ? col_bull : col_bear
                int x_hit = ph.hit_idx
                if na(ph.ln_path)
                    ph.ln_path := line.new(ph.start_idx, ph.y_start, x_hit, ph.target_p, color=color.new(h_col, 60), style=line.style_dotted, width=1)
                    ph.lbl_target := label.new(x_hit, ph.target_p, "H", color=color.new(h_col, 80), textcolor=white, style=label.style_label_center, size=size.small)
                    string p_txt = str.tostring(ph.target_p, format.mintick)
                    ph.lbl_price := label.new(x_hit + 2, ph.target_p, p_txt, color=color.new(h_col, 95), textcolor=white, style=label.style_label_left, size=size.tiny)
                else
                    line.set_xy1(ph.ln_path, ph.start_idx, ph.y_start)
                    line.set_xy2(ph.ln_path, x_hit, ph.target_p)
                    label.set_xy(ph.lbl_target, x_hit, ph.target_p)
                    label.set_xy(ph.lbl_price, x_hit + 2, ph.target_p)
            else // Missed, Expired, or History Toggle OFF
                if not na(ph.ln_path)
                    line.delete(ph.ln_path), label.delete(ph.lbl_target), label.delete(ph.lbl_price)
                    ph.ln_path := na, ph.lbl_target := na, ph.lbl_price := na


// -----------------------------------------------------------------------------
// 8. INFO TABLE
// -----------------------------------------------------------------------------
var table info_table = na
if show_table and barstate.islast
    table.delete(info_table)
    string pos = switch table_position
        "top_left"     => position.top_left
        "top_right"    => position.top_right
        "bottom_left"  => position.bottom_left
        "bottom_right" => position.bottom_right
        => position.bottom_left
    
    // Trends & Colors
    string delta_trend     = delta >= p_delta ? " (+)" : " (-)"
    string agg_delta_trend = agg_delta >= p_agg_delta ? " (+)" : " (-)"
    
    // Divergence Detection
    bool bull_div = close < close[1] and delta > 0 and delta > p_delta
    bool bear_div = close > close[1] and delta < 0 and delta < p_delta
    string div_txt = bull_div ? " [BULL DIV]" : (bear_div ? " [BEAR DIV]" : "")
    color agg_delta_c      = agg_delta >= 0 ? col_bull : col_bear
    color delta_c          = delta >= 0 ? col_bull : col_bear
    color p_delta_c        = p_delta >= 0 ? col_bull : col_bear
    color p_agg_delta_c    = p_agg_delta >= 0 ? col_bull : col_bear
    
    string imb_txt_hud  = is_imbalance_buy ? "AGGR BUY [UP]" : (is_imbalance_sell ? "AGGR SELL [DN]" : "NEUTRAL [MID]")

    // --- VOLATILITY IDENTIFICATION ---
    string vol_label = "NORMAL"
    color vol_color = col_poc
    if mkt_volatility > 1.5
        vol_label := "EXTREME"
        vol_color := red
    else if mkt_volatility > 1.2
        vol_label := "HIGH"
        vol_color := orange
    else if mkt_volatility < 0.7
        vol_label := "ULTRA LOW"
        vol_color := gray
    else if mkt_volatility < 0.85
        vol_label := "LOW"
        vol_color := white

    float predict_acc = total_predictions > 0 ? (hits_count * 100.0 / total_predictions) : 0.0
    color acc_col = predict_acc >= 70 ? col_bull : (predict_acc >= 40 ? col_poc : col_bear)

    // Table Size Mapping
    string t_size = switch table_size_input
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        "Huge"   => size.huge
        => size.small
    
    string t_header_size = switch table_size_input
        "Tiny"   => size.small
        "Small"  => size.normal
        "Normal" => size.large
        "Large"  => size.huge
        "Huge"   => size.huge
        => size.normal

    string t_desc_size = switch table_size_input
        "Tiny"   => size.small
        "Small"  => size.normal
        "Normal" => size.large
        "Large"  => size.huge
        "Huge"   => size.huge
        => size.normal

    bool is_vert = table_orientation == "Vertical"
    int t_cols = is_vert ? 2 : 6
    int t_rows = is_vert ? 16 : 8
    

    int max_table_rows = is_vert ? (show_predict ? 24 : 16) : (show_predict ? 12 : 7)
    info_table := table.new(pos, is_vert ? 2 : 6, max_table_rows, bgcolor=color.new(dark, 100), border_width=1, border_color=color.new(col_poc, 90), frame_color=color.new(brown , 40), frame_width=1)

    if is_vert
        // Header
        table.merge_cells(info_table, 0, 0, 1, 0)
        table.cell(info_table, 0, 0, "BOOKMAP PRO V4.52 | " + str.tostring(syminfo.ticker), bgcolor=color.new(brown , 80), text_color=white, text_size=t_header_size, text_formatting=text.format_bold)

        table.merge_cells(info_table, 0, 1, 1, 1)
        table.cell(info_table, 0, 1, "CURRENT BAR METRICS", text_color=col_poc, text_size=t_size, text_formatting=text.format_bold, bgcolor=get_table_bg(0, 1, 2, max_table_rows))
        table.cell(info_table, 0, 2, "BUY VOLUME", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 2, 2, max_table_rows))
        table.cell(info_table, 1, 2, format_vol(buy_volume), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 2, 2, max_table_rows))
        table.cell(info_table, 0, 3, "SELL VOLUME", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 3, 2, max_table_rows))
        table.cell(info_table, 1, 3, format_vol(sell_volume), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 3, 2, max_table_rows))
        table.cell(info_table, 0, 4, "CURRENT DELTA", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 4, 2, max_table_rows))
        table.cell(info_table, 1, 4, (delta >= 0 ? "+" : "") + format_vol(delta) + delta_trend + div_txt, text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 4, 2, max_table_rows))
        table.cell(info_table, 0, 5, "PREVIOUS DELTA", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 5, 2, max_table_rows))
        table.cell(info_table, 1, 5, (p_delta >= 0 ? "+" : "") + format_vol(p_delta), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 5, 2, max_table_rows))

        table.merge_cells(info_table, 0, 6, 1, 6)
        table.cell(info_table, 0, 6, "AGGREGATE (" + str.tostring(vp_lookback) + " BARS)", text_color=col_poc, text_size=t_size, text_formatting=text.format_bold, bgcolor=get_table_bg(0, 6, 2, max_table_rows))
        table.cell(info_table, 0, 7, "TOTAL BUY", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 7, 2, max_table_rows))
        table.cell(info_table, 1, 7, format_vol(agg_buy), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 7, 2, max_table_rows))
        table.cell(info_table, 0, 8, "TOTAL SELL", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 8, 2, max_table_rows))
        table.cell(info_table, 1, 8, format_vol(agg_sell), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 8, 2, max_table_rows))
        table.cell(info_table, 0, 9, "NET DELTA", text_color=agg_delta_c, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 9, 2, max_table_rows))
        table.cell(info_table, 1, 9, (agg_delta >= 0 ? "+" : "") + format_vol(agg_delta) + agg_delta_trend, text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 9, 2, max_table_rows))
        table.cell(info_table, 0, 10, "NET DELTA %", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 10, 2, max_table_rows))
        table.cell(info_table, 1, 10, (agg_delta_pct >= 0 ? "+" : "") + str.tostring(agg_delta_pct, "#.##") + "%", text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 10, 2, max_table_rows))
        table.cell(info_table, 0, 11, "PREV NET DELTA", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 11, 2, max_table_rows))
        table.cell(info_table, 1, 11, (p_agg_delta >= 0 ? "+" : "") + format_vol(p_agg_delta), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 11, 2, max_table_rows))

        table.cell(info_table, 0, 12, "MARKET STATE", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 12, 2, max_table_rows))
        table.cell(info_table, 1, 12, imb_txt_hud, text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 12, 2, max_table_rows))
        table.cell(info_table, 0, 13, "MARKET VOLATILITY", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 13, 2, max_table_rows))
        table.cell(info_table, 1, 13, vol_label, text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 13, 2, max_table_rows))
        table.cell(info_table, 0, 14, "DAILY PERFORMANCE", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 14, 2, max_table_rows))
        table.cell(info_table, 1, 14, (daily_change_pct >= 0 ? "+" : "") + str.tostring(daily_change_pct, "#.##") + "%", text_color=col_poc, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 14, 2, max_table_rows))

        // Prediction Analysis
        if show_predict and array.size(targets_all) > 0
            table.merge_cells(info_table, 0, 15, 1, 15)
            table.cell(info_table, 0, 15, "PREDICTION ANALYSIS", text_color=col_poc, text_size=t_size, text_formatting=text.format_bold, bgcolor=get_table_bg(0, 15, 2, max_table_rows))
            
            int p_count = math.min(3, array.size(targets_all))
            for i = 0 to p_count - 1
                HVT t = array.get(targets_all, i)
                int r_idx = 16 + i * 2
                table.merge_cells(info_table, 0, r_idx, 1, r_idx)
                string p_txt = "TARGET #" + str.tostring(i+1) + " | " + str.tostring(t.price, format.mintick)
                table.cell(info_table, 0, r_idx, p_txt, text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, r_idx, 2, max_table_rows))
                
                table.merge_cells(info_table, 0, r_idx + 1, 1, r_idx + 1)
                string full_desc = "Confidence: " + str.tostring(t.confluence) + "x | Bias: " + str.tostring((t.bias - 1.0) * 100, "#.##") + "% | Vol W: " + str.tostring(t.vol_w, "#.##") + "\n" + t.description
                table.cell(info_table, 0, r_idx + 1, full_desc, text_color=white, text_size=size.tiny, text_halign=text.align_right, bgcolor=get_table_bg(0, r_idx + 1, 2, max_table_rows))

        // Footer
        int footer_row = max_table_rows - 1
        table.merge_cells(info_table, 0, footer_row, 1, footer_row)
        table.cell(info_table, 0, footer_row, "𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤 Analysis PRO 4.36", text_color=white, text_size=t_size, bgcolor=color.new(brown, 80))
    else
        // Horizontal Header
        table.merge_cells(info_table, 0, 0, 5, 0)
        table.cell(info_table, 0, 0, "BOOKMAP PRO V4.52 | " + str.tostring(syminfo.ticker), bgcolor=color.new(brown , 80), text_color=white, text_size=t_header_size, text_formatting=text.format_bold)
        
        table.merge_cells(info_table, 0, 1, 1, 1)
        table.cell(info_table, 0, 1, "CURRENT BAR", text_color=white, text_size=t_size, text_formatting=text.format_bold, bgcolor=get_table_bg(0, 1, 6, max_table_rows))
        table.merge_cells(info_table, 2, 1, 3, 1)
        table.cell(info_table, 2, 1, "AGGREGATE (" + str.tostring(vp_lookback) + "B)", text_color=white, text_size=t_size, text_formatting=text.format_bold, bgcolor=get_table_bg(2, 1, 6, max_table_rows))
        table.merge_cells(info_table, 4, 1, 5, 1)
        table.cell(info_table, 4, 1, "MARKET STATE", text_color=white, text_size=t_size, text_formatting=text.format_bold, bgcolor=get_table_bg(4, 1, 6, max_table_rows))
        
        table.cell(info_table, 0, 2, "BUY VOL", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 2, 6, max_table_rows))
        table.cell(info_table, 1, 2, format_vol(buy_volume), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 2, 6, max_table_rows))
        table.cell(info_table, 2, 2, "TOT BUY", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(2, 2, 6, max_table_rows))
        table.cell(info_table, 3, 2, format_vol(agg_buy), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(3, 2, 6, max_table_rows))
        table.merge_cells(info_table, 4, 2, 5, 2)
        table.cell(info_table, 4, 2, imb_txt_hud, text_color=white, text_size=t_size, bgcolor=get_table_bg(4, 2, 6, max_table_rows))
        
        table.cell(info_table, 0, 3, "SELL VOL", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 3, 6, max_table_rows))
        table.cell(info_table, 1, 3, format_vol(sell_volume), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 3, 6, max_table_rows))
        table.cell(info_table, 2, 3, "TOT SELL", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(2, 3, 6, max_table_rows))
        table.cell(info_table, 3, 3, format_vol(agg_sell), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(3, 3, 6, max_table_rows))
        table.merge_cells(info_table, 4, 3, 5, 5)
        table.cell(info_table, 4, 3, "𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤 PRO 4.36", text_color=dark, text_size=t_size, text_valign=text.align_center, bgcolor=col_poc)
        
        table.cell(info_table, 0, 4, "DELTA", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 4, 6, max_table_rows))
        table.cell(info_table, 1, 4, (delta >= 0 ? "+" : "") + format_vol(delta) + delta_trend + div_txt, text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 4, 6, max_table_rows))
        table.cell(info_table, 2, 4, "NET DELTA", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(2, 4, 6, max_table_rows))
        table.cell(info_table, 3, 4, (agg_delta >= 0 ? "+" : "") + format_vol(agg_delta) + agg_delta_trend + " (" + (agg_delta_pct >= 0 ? "+" : "") + str.tostring(agg_delta_pct, "#.##") + "%)", text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(3, 4, 6, max_table_rows))

        table.cell(info_table, 0, 5, "PREV DELTA", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 5, 6, max_table_rows))
        table.cell(info_table, 1, 5, (p_delta >= 0 ? "+" : "") + format_vol(p_delta), text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(1, 5, 6, max_table_rows))
        table.cell(info_table, 2, 5, "PREV N.DELT", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(2, 5, 6, max_table_rows))
        table.cell(info_table, 3, 5, (p_agg_delta >= 0 ? "+" : "") + format_vol(p_agg_delta) + " (" + (p_agg_delta_pct >= 0 ? "+" : "") + str.tostring(p_agg_delta_pct, "#.##") + "%)", text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(3, 5, 6, max_table_rows))
        
        table.merge_cells(info_table, 0, 6, 1, 6)
        table.cell(info_table, 0, 6, "MARKET VOLATILITY", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, 6, 6, max_table_rows))
        table.cell(info_table, 2, 6, vol_label, text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(2, 6, 6, max_table_rows))
        table.cell(info_table, 3, 6, "DAILY %", text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(3, 6, 6, max_table_rows))
        table.merge_cells(info_table, 4, 6, 5, 6)
        table.cell(info_table, 4, 6, (daily_change_pct >= 0 ? "+" : "") + str.tostring(daily_change_pct, "#.##") + "%", text_color=white, text_size=t_size, text_halign=text.align_right, bgcolor=get_table_bg(4, 6, 6, max_table_rows))

        // Prediction Analysis
        if show_predict and array.size(targets_all) > 0
            table.merge_cells(info_table, 0, 7, 5, 7)
            table.cell(info_table, 0, 7, "PREDICTION ANALYSIS", text_color=col_poc, text_size=t_size, text_formatting=text.format_bold, bgcolor=get_table_bg(0, 7, 6, max_table_rows))
            
            int p_count = math.min(2, array.size(targets_all))
            for i = 0 to p_count - 1
                HVT t = array.get(targets_all, i)
                int r_idx = 8 + i
                table.merge_cells(info_table, 0, r_idx, 1, r_idx)
                string p_txt = "#" + str.tostring(i+1) + " | " + str.tostring(t.price, format.mintick)
                table.cell(info_table, 0, r_idx, p_txt, text_color=white, text_size=t_size, text_halign=text.align_left, bgcolor=get_table_bg(0, r_idx, 6, max_table_rows))
                
                table.merge_cells(info_table, 2, r_idx, 5, r_idx)
                string full_desc = "C: " + str.tostring(t.confluence) + "x | B: " + str.tostring((t.bias - 1.0) * 100, "#.#") + "% | V: " + str.tostring(t.vol_w, "#.##") + " | " + str.replace(t.description, "\n", " & ")
                table.cell(info_table, 2, r_idx, full_desc, text_color=col_poc, text_size=size.tiny, text_halign=text.align_right, bgcolor=get_table_bg(2, r_idx, 6, max_table_rows))

        // Horizontal Footer
        int footer_row = max_table_rows - 1
        table.merge_cells(info_table, 0, footer_row, 5, footer_row)
        table.cell(info_table, 0, footer_row, "𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤 Analysis PRO 4.36", text_color=white, text_size=t_size, text_valign=text.align_center, bgcolor=color.new(brown, 80))



// -----------------------------------------------------------------------------
// 9. EMAs
// -----------------------------------------------------------------------------
float ema_h   = ta.ema(high, 1)
float ema_c   = ta.ema(close, 1)
float ema_l   = ta.ema(low, 1)

p_h = plot(ema_h, "EMA High", color=color_ema_h, linewidth =1, display=show_plotline?display.all : display.none)
p_l = plot(ema_l, "EMA Low", color=color_ema_l, linewidth=1, display=show_plotline?display.all : display.none)
plot(show_ema_long ? ema_long_val : na, "Long EMA", color=color_ema_long, linewidth=1)

alertcondition(is_imbalance_buy, "Aggressive Buy Imbalance", "High Buy Volume Detected")
alertcondition(is_imbalance_sell, "Aggressive Sell Imbalance", "High Sell Volume Detected")

// -----------------------------------------------------------------------------
// 10. CANDLES
// -----------------------------------------------------------------------------
bool is_bull_candle   = candle_color_mode == "Normal" ? (close >= open) : (delta >= 0)
color candle_body_col = candle_color_mode == "Bubble Map" ? color.new(brown, 80) : (is_bull_candle ? box_col_bull : box_col_bear)
color candle_wick_col = candle_color_mode == "Bubble Map" ? brown : (is_bull_candle ? col_bull : col_bear)

plotcandle(show_candles ? open : na, high, low, close, title="Bookmap Candles", color=candle_body_col, wickcolor=candle_wick_col, bordercolor=candle_wick_col)

// Historical POC Plot
plot(show_hpoc ? hpoc_val : na, "Historical POC", color=col_poc, linewidth=1, style=plot.style_linebr)

// Historical Average Buy/Sell Plots
pavgb = plot(show_avg_plots ? hist_avg_buy_g : na, "Avg Buy Hist", color=color.new(col_bull, 0), linewidth=1)
pavgs = plot(show_avg_plots ? hist_avg_sell_g : na, "Avg Sell Hist", color=color.new(col_bear, 0), linewidth=1)

//fill(pavgb,pavgs,color = color.new(col,40),display = show_avg_plots ? display.all : display.none)

//═══════════════════════════════════════════════════════════════════════════════
// LOGO GRADIENT ENHANCED - TOTAL SYNC (LINES & FILL)
//═══════════════════════════════════════════════════════════════════════════════

color bull_c1 = col_bull
color bull_c2 = col_bear
color bear_c1 = col_bull
color bear_c2 = col_bear

// --- 2. LOGIKA ANIMASI & TREND ---
bool  trend_check = ta.ema(close, 2) > ta.ema(open, 2) 
color c_start     = trend_check ? bull_c1 : bear_c1
color c_end       = trend_check ? bull_c2 : bear_c2

// Animasi "Breathing"
float time_cycle = timenow / 1000 
float breathe    = (math.sin(time_cycle * 3) + 1) / 2 

int LG_Line_Widthb = 1
int periodb        = 200

// --- 3. PERHITUNGAN TITIK STABIL (VOLATILITY & RANGE SYNC) ---
float logo_base_raw = ta.lowest(low, periodb)
float logo_range    = ta.highest(high, periodb) - logo_base_raw
var float h_unit    = na

// Calculate a stable height unit based on a mix of ATR and recent range
// This ensures the logo maintains its aspect ratio even during extreme volatility shifts
// Increased multiplier to prevent "gepeng" (flat) appearance
float target_h = math.max(ta.atr(periodb) * 1.5, logo_range * 0.22)
h_unit := na(h_unit) ? target_h : h_unit * 0.98 + target_h * 0.02

// Offset the logo slightly below the lowest low to prevent price overlap
float logo_base = logo_base_raw - h_unit * 0.2

// Normalized points to ensure the logo never "squishes" or "stretches" disproportionately
float point1b  = logo_base + h_unit * 0.71
float point2b  = logo_base + h_unit * 0.43
float point3b  = logo_base + h_unit * 0.61
float point4b  = logo_base + h_unit * 0.32
float point5b  = logo_base + h_unit * 1.00 // Peak
float point6b  = logo_base + h_unit * 0.71
float point7b  = logo_base + h_unit * 0.18 // Base Top
float point8b  = logo_base + h_unit * 0.21
float point9b  = logo_base + h_unit * 0.71
float point1b0 = logo_base + h_unit * 0.86

// Logo Visual Objects
var line Line1b  = na
var line Line2b  = na
var line Line3b  = na
var line Line4b  = na
var line Line5b  = na
var line Line6b  = na
var line Line7b  = na
var line Line8b  = na
var line Line9b  = na
var line Line1b0 = na
var line Line1b1 = na
var line Line1b2 = na
var line Line1b3 = na
var line Line1b4 = na
var line Line1b5 = na
var line Line1b6 = na
var line Line1b7 = na
var line Line1b8 = na
var label[] brand_labels = array.new_label()

// Hapus Garis Sebelumnya (Selalu dijalankan agar bersih saat dimatikan)
if not na(Line1b)
    line.delete(Line1b)
    line.delete(Line2b)
    line.delete(Line3b)
    line.delete(Line4b)
    line.delete(Line5b)
    line.delete(Line6b)
    line.delete(Line7b)
    line.delete(Line8b)
    line.delete(Line9b)
    line.delete(Line1b0)
    line.delete(Line1b1)
    line.delete(Line1b2)
    line.delete(Line1b3)
    line.delete(Line1b4)
    line.delete(Line1b5)
    line.delete(Line1b6)
    line.delete(Line1b7)
    line.delete(Line1b8)
    while array.size(brand_labels) > 0
        label.delete(array.pop(brand_labels))

// --- FUNGSI WARNA ---
get_adv_color(step) => 
    float ratio = step / 18.0
    float dynamic_ratio = ratio + (breathe * 0.15) 
    if dynamic_ratio > 1
        dynamic_ratio := 1
    color.from_gradient(dynamic_ratio, 0, 1, c_start, c_end)

get_fade_alpha(float x_rel) =>
    // Assembly Center is at x=32, total assembly spans x=0 to x=64
    float dist = math.abs(x_rel - 32)
    float ratio = dist / 32.0 // 0 at center, 1 at edges
    // Fade from 0 (edges) to 80 (center)
    math.round(80 * (1 - ratio))

// --- PEMBUATAN GARIS (HANYA JIKA SHOW_LOGO AKTIF) ---
if show_logo and barstate.islast
    // Bagian Atas & Tengah (Head Structure) - REFERENCE COLOR (Step 1)
    color c_head_sync = get_adv_color(1) // Kita simpan warna referensi ini

    Line1b := line.new(x1 = bar_index + l_off + 4, y1 = point7b, x2 = bar_index + l_off + 11, y2 = point1b, color = col_poc, width = LG_Line_Widthb)
    Line2b := line.new(x1 = bar_index + l_off + 8, y1 = point7b, x2 = bar_index + l_off + 11, y2 = point2b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b, Line2b, color = color.new(c_head_sync, get_fade_alpha(7.5)))

    Line3b := line.new(x1 = bar_index + l_off + 11, y1 = point1b, x2 = bar_index + l_off + 13, y2 = point3b, color = col_poc, width = LG_Line_Widthb)
    Line4b := line.new(x1 = bar_index + l_off + 11, y1 = point2b, x2 = bar_index + l_off + 13, y2 = point4b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line3b, Line4b, color = color.new(get_adv_color(3), get_fade_alpha(12.0)))

    Line5b := line.new(x1 = bar_index + l_off + 13, y1 = point3b, x2 = bar_index + l_off + 19, y2 = point5b, color = col_poc, width = LG_Line_Widthb)
    Line6b := line.new(x1 = bar_index + l_off + 13, y1 = point4b, x2 = bar_index + l_off + 19, y2 = point6b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line5b, Line6b, color = color.new(get_adv_color(5), get_fade_alpha(16.0)))

    Line7b := line.new(x1 = bar_index + l_off + 19, y1 = point5b, x2 = bar_index + l_off + 24, y2 = point3b, color = col_poc, width = LG_Line_Widthb)
    Line8b := line.new(x1 = bar_index + l_off + 19, y1 = point6b, x2 = bar_index + l_off + 24, y2 = point4b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line7b, Line8b, color = color.new(get_adv_color(7), get_fade_alpha(21.5)))

    Line9b := line.new(x1 = bar_index + l_off + 24, y1 = point3b, x2 = bar_index + l_off + 26, y2 = point1b, color = col_poc, width = LG_Line_Widthb)
    Line1b0 := line.new(x1 = bar_index + l_off + 24, y1 = point4b, x2 = bar_index + l_off + 26, y2 = point2b, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line9b, Line1b0, color = color.new(get_adv_color(9), get_fade_alpha(25.0)))

    Line1b1 := line.new(x1 = bar_index + l_off + 26, y1 = point1b, x2 = bar_index + l_off + 36, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b2 := line.new(x1 = bar_index + l_off + 26, y1 = point2b, x2 = bar_index + l_off + 32, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    linefill.new(Line1b1, Line1b2, color = color.new(get_adv_color(11), get_fade_alpha(31.0)))

    // --- BAGIAN BASE HORIZONTAL (TOTAL SYNC) ---
    Line1b3 := line.new(x1 = bar_index + l_off + 2, y1 = point7b, x2 = bar_index + l_off + 26, y2 = point7b, color = col_poc, width = LG_Line_Widthb)
    Line1b4 := line.new(x1 = bar_index + l_off + 0, y1 = logo_base, x2 = bar_index + l_off + 24, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)

    // Warna Fill juga menggunakan 'c_head_sync'
    linefill.new(Line1b3, Line1b4, color = color.new(c_head_sync, get_fade_alpha(13.0))) 

    // Tutup Depan & Belakang Base
    Line1b5 := line.new(x1 = bar_index + l_off + 2, y1 = point7b, x2 = bar_index + l_off + 0, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    Line1b6 := line.new(x1 = bar_index + l_off + 26, y1 = point7b, x2 = bar_index + l_off + 24, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)

    // Ekor Tambahan & Label (Extended for wider text)
    Line1b7 := line.new(x1 = bar_index + l_off + 32, y1 = logo_base, x2 = bar_index + l_off + 36, y2 = logo_base, color = col_poc, width = LG_Line_Widthb)
    
    label l = label.new(bar_index + l_off + 54, point2b, "𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤" + "\nBOOKMAP PRO V.4.36",text_formatting = text.format_bold, style=label.style_none, textcolor=col_poc, size=size.normal,textalign = text.align_left)
    array.push(brand_labels, l)

    // --- LOGO GLOW (Character-based via label.style_none) ---
    label glow1 = label.new(bar_index + l_off + 13, point1b0, "●", style=label.style_none, textcolor=color.new(get_adv_color(2), get_fade_alpha(13.0)), size=size.huge)
    label glow2 = label.new(bar_index + l_off + 13, point1b0, "〇", style=label.style_none, textcolor=col_poc, size=size.huge)
    array.push(brand_labels, glow1)
    array.push(brand_labels, glow2)

