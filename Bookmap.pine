// 0. USER DEFINED TYPES
// -----------------------------------------------------------------------------
type HVT
    float price
    float strength
    bool  is_above
    int   priority
    string description
    int   confluence = 1
    float bias = 0.0
    float vol_w = 1.0
    float momentum = 0.0

type PredictHist
    int   start_idx
    int   end_idx
    float y_start
    float target_p
    bool  is_above
    bool  is_hit
    int   hit_idx
    bool  is_settled
    line  ln_path
    label lbl_target
    label lbl_price

var line[] predict_lines = array.new_line()
var label[] predict_labels = array.new_label()
var array<PredictHist> predict_history = array.new<PredictHist>()
var int total_predictions = 0
var int hits_count = 0
var int predict_reach = 0
var int l_off = 145
var array<HVT> targets_all = array.new<HVT>()

