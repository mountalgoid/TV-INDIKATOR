//@version=6
indicator("Bookmap Footprint Profile 𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤", shorttitle="Footprint Profile", overlay=true, max_lines_count=500, max_boxes_count=500, max_labels_count=500)

// -----------------------------------------------------------------------------
// 1. INPUTS & CONFIGURATION
// -----------------------------------------------------------------------------
string GlobalGroup = "Visual Themes & Global"
string grp_footprint = "Footprint Profile Settings"
string grp_candle = "Custom Candle Settings"

// Theme System (Ported from bookmap.pine)
string color_theme = input.string(defval = 'DEX Deep', title = 'Select Color Theme', options = ['Spartan Edge Theme', 'MountAlgo Themes', 'MountAlgo Neon', 'MountAlgo Frost', 'MountAlgo Cyber', 'Standard Spartan Edge Theme', 'Dark ICT Theme', 'Garuda Gold', 'MountAlgo Super Premium Theme', 'MountAlgo Orange White Theme', 'DEX Deep', 'Deep Sea', 'Gear Protocol'], group=GlobalGroup)

// Core Colors
color dark   = #000000
color white  = #c4d3ff
color green  = #179c74
color purple = #5134ff
color gray   = #62647a
color red    = #f23645
color yellow = #f3ba2f
color orange = #ff9800
color blue   = #1848cc
color brown  = #8b4513

color col_bull = switch color_theme
    'Spartan Edge Theme' => red
    'MountAlgo Themes' => purple
    'MountAlgo Neon' => #5134ff
    'MountAlgo Frost' => #5134ff
    'MountAlgo Cyber' => #1848cc
    'Standard Spartan Edge Theme' => green
    'Dark ICT Theme' => green
    'Garuda Gold' => yellow
    'MountAlgo Super Premium Theme' => purple
    'MountAlgo Orange White Theme' => orange
    'DEX Deep' => #a1ff3b
    'Deep Sea' => blue
    'Gear Protocol' => white
    => blue
color col_bear = switch color_theme
    'Spartan Edge Theme' => gray
    'MountAlgo Themes' => green
    'MountAlgo Neon' => #ff009a
    'MountAlgo Frost' => #00e5ff
    'MountAlgo Cyber' => #ff009a
    'Standard Spartan Edge Theme' => red
    'Dark ICT Theme' => gray
    'Garuda Gold' => gray
    'MountAlgo Super Premium Theme' => yellow
    'MountAlgo Orange White Theme' => gray
    'DEX Deep' => #ff009a
    'Deep Sea' => gray
    'Gear Protocol' => gray
    => white
color col_poc = switch color_theme
    'Spartan Edge Theme' => white
    'MountAlgo Themes' => white
    'MountAlgo Neon' => white
    'MountAlgo Frost' => white
    'MountAlgo Cyber' => white
    'Standard Spartan Edge Theme' => white
    'Dark ICT Theme' => white
    'Garuda Gold' => white
    'MountAlgo Super Premium Theme' => white
    'MountAlgo Orange White Theme' => white
    'DEX Deep' => white
    'Deep Sea' => white
    => white

// Footprint Settings
int lookback_bars = input.int(15, "Lookback Bars to Display", minval=5, maxval=22, group=grp_footprint, tooltip="Number of candle profiles to keep on chart (keep low to prevent Pine drawing limits)")
bool show_values = input.bool(true, "Show Volume Values Inside Boxes", group=grp_footprint)

// Candle Settings
int candle_body_trans = input.int(50, "Candle Body Transparency", minval=0, maxval=100, group=grp_candle)
int candle_wick_trans = input.int(30, "Candle Wick Transparency", minval=0, maxval=100, group=grp_candle)

// Hide standard candles
plotcandle(open, high, low, close, color=na, wickcolor=na, bordercolor=na, editable=false)

// -----------------------------------------------------------------------------
// 2. LOWER TIMEFRAME (LTF) SECURITY REQUEST
// -----------------------------------------------------------------------------
[ltf_o_series, ltf_h_series, ltf_l_series, ltf_c_series, ltf_v_series] = request.security_lower_tf(syminfo.tickerid, "1", [open, high, low, close, volume])

// -----------------------------------------------------------------------------
// 3. PERSISTENT DRAWING VARIABLES
// -----------------------------------------------------------------------------
var box[] profile_boxes = array.new<box>()
var line[] candle_lines = array.new<line>()
var line[] level_lines = array.new<line>()

// --- HELPER FUNCTIONS FOR VOLUME FORMATTING ---
format_vol(float v) =>
    float abs_v = math.abs(v)
    string res = ""
    if abs_v >= 1000000000
        res := str.tostring(v / 1000000000, "#.##") + "B"
    else if abs_v >= 1000000
        res := str.tostring(v / 1000000, "#.##") + "M"
    else if abs_v >= 1000
        res := str.tostring(v / 1000, "#.#") + "K"
    else
        res := str.tostring(v, "0.##")
    res

// -----------------------------------------------------------------------------
// 4. MAIN VISUALIZATION LOGIC
// -----------------------------------------------------------------------------
if barstate.islast
    // Clear old drawings to prevent leaks and visual clutter
    for b in profile_boxes
        box.delete(b)
    array.clear(profile_boxes)

    for l in candle_lines
        line.delete(l)
    array.clear(candle_lines)

    for l in level_lines
        line.delete(l)
    array.clear(level_lines)

    for k = lookback_bars - 1 to 0
        int idx = bar_index - k

        float o = open[k]
        float h = high[k]
        float l = low[k]
        float c = close[k]
        float v = volume[k]

        color cand_col = c >= o ? col_bull : col_bear
        float body_h = math.max(o, c)
        float body_l = math.min(o, c)

        // --- CUSTOM CANDLE DRAWINGS ---
        // Upper Wick: Line size 5
        line up_wick = line.new(idx, h, idx, body_h, color=color.new(cand_col, candle_wick_trans), width=5)
        array.push(candle_lines, up_wick)

        // Lower Wick: Line size 5
        line dn_wick = line.new(idx, body_l, idx, l, color=color.new(cand_col, candle_wick_trans), width=5)
        array.push(candle_lines, dn_wick)

        // Candle Body: Line size 20
        line body_line = line.new(idx, o, idx, c, color=color.new(cand_col, candle_body_trans), width=20)
        array.push(candle_lines, body_line)

        // ---------------------------------------------------------------------
        // 20-LEVEL VOLUME PROFILE PER CANDLE
        // ---------------------------------------------------------------------
        float level_height = (h - l) / 20.0
        float[] buy_level = array.new<float>(20, 0.0)
        float[] sell_level = array.new<float>(20, 0.0)

        float[] o_arr = ltf_o_series[k]
        float[] h_arr = ltf_h_series[k]
        float[] l_arr = ltf_l_series[k]
        float[] c_arr = ltf_c_series[k]
        float[] v_arr = ltf_v_series[k]

        // Safe check for lower timeframe array existence
        bool has_ltf = false
        if not na(v_arr)
            if array.size(v_arr) > 0
                has_ltf := true

        if level_height > 0
            if has_ltf
                int ltf_sz = array.size(v_arr)
                for j = 0 to ltf_sz - 1
                    float l_o = array.get(o_arr, j)
                    float l_h = array.get(h_arr, j)
                    float l_l = array.get(l_arr, j)
                    float l_c = array.get(c_arr, j)
                    float l_v = array.get(v_arr, j)

                    float l_buy = l_c >= l_o ? l_v : 0.0
                    float l_sell = l_c < l_o ? l_v : 0.0

                    float l_range = l_h - l_l
                    if l_range <= 0
                        int lvl_idx = math.min(19, math.max(0, math.floor((l_c - l) / level_height)))
                        array.set(buy_level, lvl_idx, array.get(buy_level, lvl_idx) + l_buy)
                        array.set(sell_level, lvl_idx, array.get(sell_level, lvl_idx) + l_sell)
                    else
                        for i = 0 to 19
                            float lvl_low = l + i * level_height
                            float lvl_high = lvl_low + level_height
                            float overlap = math.max(0.0, math.min(l_h, lvl_high) - math.max(l_l, lvl_low))
                            if overlap > 0
                                float fraction = overlap / l_range
                                array.set(buy_level, i, array.get(buy_level, i) + l_buy * fraction)
                                array.set(sell_level, i, array.get(sell_level, i) + l_sell * fraction)
            else
                // High-fidelity fallback heuristic partitioning
                float body_high = math.max(o, c)
                float body_low = math.min(o, c)
                float body_size = body_high - body_low
                float upper_wick = h - body_high
                float lower_wick = body_low - l

                float total_weight = body_size * 1.5 + upper_wick * 1.0 + lower_wick * 1.0
                if total_weight > 0
                    for i = 0 to 19
                        float lvl_low = l + i * level_height
                        float lvl_high = lvl_low + level_height

                        float up_overlap = math.max(0.0, math.min(h, lvl_high) - math.max(body_high, lvl_low))
                        float bo_overlap = math.max(0.0, math.min(body_high, lvl_high) - math.max(body_low, lvl_low))
                        float dn_overlap = math.max(0.0, math.min(body_low, lvl_high) - math.max(l, lvl_low))

                        float up_vol = v * (up_overlap * 1.0 / total_weight)
                        float bo_vol = v * (bo_overlap * 1.5 / total_weight)
                        float dn_vol = v * (dn_overlap * 1.0 / total_weight)

                        float b_up = up_vol * 0.1
                        float s_up = up_vol * 0.9

                        float b_dn = dn_vol * 0.9
                        float s_dn = dn_vol * 0.1

                        float b_bo = 0.0
                        float s_bo = 0.0
                        if c >= o
                            b_bo := bo_vol * 0.8
                            s_bo := bo_vol * 0.2
                        else
                            b_bo := bo_vol * 0.2
                            s_bo := bo_vol * 0.8

                        array.set(buy_level, i, b_up + b_dn + b_bo)
                        array.set(sell_level, i, s_up + s_dn + s_bo)

            // Calculate Maximum and Total Volume for this profile
            float max_lvl_vol = 0.0
            float total_prof_vol = 0.0
            for i = 0 to 19
                float lvl_total = array.get(buy_level, i) + array.get(sell_level, i)
                total_prof_vol += lvl_total
                if lvl_total > max_lvl_vol
                    max_lvl_vol := lvl_total

            // --- POC, VAH, VAL CALCULATION ---
            int poc_idx = 0
            float temp_max_vol = 0.0
            for i = 0 to 19
                float lvl_total = array.get(buy_level, i) + array.get(sell_level, i)
                if lvl_total > temp_max_vol
                    temp_max_vol := lvl_total
                    poc_idx := i

            float va_vol = array.get(buy_level, poc_idx) + array.get(sell_level, poc_idx)
            float va_target = total_prof_vol * 0.70
            int va_top = poc_idx
            int va_bot = poc_idx

            int loop_safety = 0
            while va_vol < va_target and loop_safety < 20
                loop_safety += 1
                float v_up = (va_top < 19) ? (array.get(buy_level, va_top + 1) + array.get(sell_level, va_top + 1)) : 0.0
                float v_dn = (va_bot > 0) ? (array.get(buy_level, va_bot - 1) + array.get(sell_level, va_bot - 1)) : 0.0
                if v_up >= v_dn and va_top < 19
                    va_vol += v_up
                    va_top += 1
                else if va_bot > 0
                    va_vol += v_dn
                    va_bot -= 1
                else if va_top < 19
                    va_vol += v_up
                    va_top += 1

            float poc_price = l + (poc_idx + 0.5) * level_height
            float vah_price = l + (va_top + 1) * level_height
            float val_price = l + va_bot * level_height

            // --- RENDER PROFILE LEVELS ---
            for i = 0 to 19
                float lvl_low = l + i * level_height
                float lvl_high = lvl_low + level_height
                float lvl_buy = array.get(buy_level, i)
                float lvl_sell = array.get(sell_level, i)
                float lvl_total = lvl_buy + lvl_sell

                if lvl_total > 0
                    float intensity = max_lvl_vol > 0 ? lvl_total / max_lvl_vol : 0.0
                    float ratio = lvl_buy / lvl_total

                    // Smooth super gradient: interpolate between col_bear and col_bull
                    color base_col = color.from_gradient(ratio, 0.0, 1.0, col_bear, col_bull)
                    // Glass effect transparency
                    int trans = math.round(95 - intensity * 65)

                    // Text format: ▲Buy | ▼Sell
                    string txt = show_values ? ("▲" + format_vol(lvl_buy) + " | ▼" + format_vol(lvl_sell)) : ""
                    // High-contrast text legibility based on background transparency
                    color txt_color = trans > 75 ? col_poc : dark

                    box b = box.new(idx, lvl_high, idx + 1, lvl_low,
                                    bgcolor=color.new(base_col, trans),
                                    border_color=na,
                                    text=txt,
                                    text_size=size.auto,
                                    text_color=txt_color,
                                    text_formatting=text.format_bold,
                                    text_valign=text.align_center,
                                    text_halign=text.align_center)
                    array.push(profile_boxes, b)

            // --- DRAW KEY HORIZONTAL LINES (VAH, VAL, POC) ---
            // POC Line: Spanning exactly across the volume profile bar width (idx to idx + 1)
            line l_poc = line.new(idx, poc_price, idx + 1, poc_price, color=col_poc, width=2, style=line.style_solid)
            array.push(level_lines, l_poc)

            // VAH Line: Spanning exactly across the volume profile bar width (idx to idx + 1)
            line l_vah = line.new(idx, vah_price, idx + 1, vah_price, color=color.new(col_poc, 50), width=1, style=line.style_dashed)
            array.push(level_lines, l_vah)

            // VAL Line: Spanning exactly across the volume profile bar width (idx to idx + 1)
            line l_val = line.new(idx, val_price, idx + 1, val_price, color=color.new(col_poc, 50), width=1, style=line.style_dashed)
            array.push(level_lines, l_val)
