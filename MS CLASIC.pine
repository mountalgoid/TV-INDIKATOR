//𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤
//@version=6
//═══════════════════════════════════════════════════════════════════════════════
indicator(title            = "Market Structure Clasic V.9.5.0 𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤"
, shorttitle             = "MS Clasic V.9.5.0 𝙈𝙤𝙪𝙣𝙩𝘼𝙡𝙜𝙤"
, overlay                = true
, max_bars_back          = 2000
, max_lines_count        = 500
, max_boxes_count        = 500
, max_labels_count       = 500)
//════════════════════════════════════════════════════════════════════════
// COLOR TYPE
//════════════════════════════════════════════════════════════════════════
dark   = #000000
white  = #c4d3ff
green  = #179c74
purple = #5134ff
gray   = #62647a
red    = #f23645
yellow = #f3ba2f
orange = #ff9800
blue   = #1848cc
brown  = #8b4513
Transparent_Color = color.new(dark, 100)
//════════════════════════════════════════════════════════════════════════
// GROUP
//════════════════════════════════════════════════════════════════════════
GlobalGroup = 'Visual Themes & Global'
//════════════════════════════════════════════════════════════════════════
// INPUT COLOR TYPE THEME
//════════════════════════════════════════════════════════════════════════
color_theme = input.string(defval = 'DEX Deep', title = '⬤ Select Color Theme', options = ['Spartan Edge Theme', 'MountAlgo Themes', 'MountAlgo Neon', 'MountAlgo Frost', 'MountAlgo Cyber', 'Standard Spartan Edge Theme', 'Dark ICT Theme', 'Garuda Gold', 'MountAlgo Super Premium Theme', 'MountAlgo Orange White Theme', 'DEX Deep', 'Deep Sea'], group = GlobalGroup)
type_ltf_plot_candle = input.string(defval = 'Regular Candles', title = '⬤ Type LTF Plot Candle', options = ['Regular Candles', 'Custom Candles'], group = GlobalGroup)
type_ltf_color_candle = input.string('Follow HTF Trend',title = '⬤ Type LTF Color Candle', options=['Regular Color Candles', 'Based Stochastic RSI', 'Follow HTF Trend', 'Follow LTF Trend'],group = GlobalGroup)
// UPDATED: Default set to FALSE
show_ltf_plot_candle = input.bool(defval = true, title = 'Show LTF Plot Candle', group = GlobalGroup)
show_htf_plot_candle = input.bool(defval = false, title = 'Show HTF Plot Candle', group = GlobalGroup)
//════════════════════════════════════════════════════════════════════════
// COLOR BASED ON THEME
//════════════════════════════════════════════════════════════════════════
col_bull = switch color_theme
    'Spartan Edge Theme' => red
    'MountAlgo Themes' => purple
    'MountAlgo Neon' => #5134ff
    'MountAlgo Frost' => #5134ff
    'MountAlgo Cyber' => #1848cc
    'Standard Spartan Edge Theme' => green
    'Dark ICT Theme' => green
    'Garuda Gold' => yellow
    'MountAlgo Super Premium Theme' => purple
    'MountAlgo Orange White Theme' => orange
    'DEX Deep' => #a1ff3b
    'Deep Sea' => blue
    => blue
col_bear = switch color_theme
    'Spartan Edge Theme' => gray
    'MountAlgo Themes' => green
    'MountAlgo Neon' => #ff009a
    'MountAlgo Frost' => #00e5ff
    'MountAlgo Cyber' => #ff009a
    'Standard Spartan Edge Theme' => red
    'Dark ICT Theme' => gray
    'Garuda Gold' => gray
    'MountAlgo Super Premium Theme' => yellow
    'MountAlgo Orange White Theme' => gray
    'DEX Deep' => #ff009a
    'Deep Sea' => gray
    => white
col_poc = switch color_theme
    'Spartan Edge Theme' => white
    'MountAlgo Themes' => white
    'MountAlgo Neon' => white
    'MountAlgo Frost' => white
    'MountAlgo Cyber' => white
    'Standard Spartan Edge Theme' => white
    'Dark ICT Theme' => white
    'Garuda Gold' => white
    'MountAlgo Super Premium Theme' => white
    'MountAlgo Orange White Theme' => white
    'DEX Deep' => white
    'Deep Sea' => white
    => white

box_col_bull = color.new(col_bull, 80)
box_col_bear = color.new(col_bear, 80)
mitigated_color = brown
mitigated_box_color = color.new(brown, 80)
//═══════════════════════════════════════════════════════════════════════════════
// USER INPUTS GLOBAL
//═══════════════════════════════════════════════════════════════════════════════
// Global Input
auto_tooltip = "Enabling this feature will ignore the manual input below.\n\n" +
           "Auto Configuration (Chart ➔ HTF):\n" +
           "• 1s - 2m ➔ HTF 15m\n" +
           "• 3m - 4m ➔ HTF 30m\n" +
           "• 5m - 14m ➔ HTF 1 Hour (1H)\n" +
           "• 15m - 1H ➔ HTF 4 Hour (4H)\n" +
           "• > 1H (2H+) ➔ HTF Daily (1D)\n" +
           "• Daily (1D) ➔ HTF Weekly (1W)\n" +
           "• Weekly ➔ HTF Monthly (1M)\n\n" +
           "NOTE: The LTF (Lower Timeframe) will always be the same as the current chart."
// UPDATED: Default set to FALSE
auto_htf_mode = input.bool(true, '⬤ Auto Mode (HTF & LTF)', tooltip = auto_tooltip, group = GlobalGroup)
// 2. INPUT MANUAL (Hanya berfungsi jika Auto Mode = OFF)
HTFtime_opt = input.string("1H", '⬤ Manual HTF', tooltip = "Only works if Auto Mode = OFF", group = GlobalGroup, options = ["15m","30m","45m","1H","2H","4H","1D","3D","1W","2W","1M","3M","6M"])
ltf_in_input = input.timeframe('5', '⬤ Manual LTF', tooltip = "Only works if Auto Mode = OFF", group = GlobalGroup)
// ==========================
// LOGIC HELPER: CONVERT STRING TO MINUTES (INT)
// ==========================
f_str_to_minutes(tf_str) =>
    if tf_str == "D" or tf_str == "1D"
        1440
    else if tf_str == "3D"
        4320
    else if tf_str == "W" or tf_str == "1W"
        10080
    else if tf_str == "2W"
        20160
    else if tf_str == "M" or tf_str == "1M"
        43200
    else if tf_str == "3M"
        129600
    else if tf_str == "6M"
        259200
    else 
        nz(str.tonumber(tf_str), timeframe.multiplier)
// ==========================
// LOGIC 1: MANUAL HTF MAPPING
// ==========================
get_manual_tf_string(opt) =>
    switch opt
        "15m" => "15"
        "30m" => "30"
        "45m" => "45"
        "1H"  => "60"
        "2H"  => "120"
        "4H"  => "240"
        "1D"  => "D"
        "3D"  => "3D"
        "1W"  => "W"
        "2W"  => "2W"
        "1M"  => "M"
        "3M"  => "3M"
        "6M"  => "6M"
        => "60"
// ==========================
// LOGIC 2: AUTO HTF MAPPING (SMART LOGIC)
// ==========================
get_auto_htf() =>
    if timeframe.isseconds
        "15" // Detik -> 15m
    else if timeframe.isminutes
        int m = timeframe.multiplier
        if m <= 2
            "15"  // 1m-2m -> 15m
        else if m <= 4
            "30"  // 3m-4m -> 30m
        else if m <= 14
            "60"  // 5m-14m -> 1H
        else if m <= 60
            "240" // 15m s/d 60m (1H) -> 4H
        else 
            "D"   // Di atas 1H -> Daily
    else if timeframe.isdaily
        "W"       // Daily -> Weekly
    else
        "M"       // Weekly+ -> Monthly
// ==========================
// FINAL EXECUTION VARIABLES
// ==========================
ltf_in = auto_htf_mode ? timeframe.period : (ltf_in_input == "" ? timeframe.period : ltf_in_input)
htf_str = auto_htf_mode ? get_auto_htf() : get_manual_tf_string(HTFtime_opt)
minutes_val = f_str_to_minutes(htf_str)
x_show = input.int(5, '⬤ Show MS Structures', minval = 1, group = GlobalGroup)
showms = input.string('Name', '⬤ Type Events', options = ['Symbol', 'Name'], group = GlobalGroup)
gap_threshold = input.float(0.00006, '⬤ Minimum Gap Percentage', minval = 0.0, step = 0.005, tooltip = 'Minimum gap size as a percentage of current price', group = GlobalGroup)
// UPDATED: Default set to FALSE
ifvg_selected_high_prob = input.bool(true, 'High Prob IFVG Only', tooltip = "Only displays IFVG if the Gap size is large enough (2x Threshold)", group = GlobalGroup)
use_snd_mid_filter = input.bool(true, 'Filter 1/2 Body (Strong Imbalance)', tooltip = 'If active: Demand = 1/2 Body Candle > Previous High, Supply = 1/2 Body Candle < Previous Low', group = GlobalGroup)
pd_group = 'Premium & Discount'
show_pd_ltf = input.bool(false, 'Show LTF P/D Zones', group = pd_group)
// UPDATED: Default set to FALSE
show_pd_htf = input.bool(true, 'Show HTF P/D Zones', group = pd_group)
eq_group = 'EQH / EQL Settings'
// UPDATED: Default set to FALSE
show_eq = input.bool(true, 'Show EQH/EQL', group = eq_group)
eq_threshold_per = input.float(0.1, '● Tolerance (%)', step=0.01, tooltip="Maximum price difference (percentage) to be considered 'Equal'", group = eq_group)
eq_len = input.int(4, '● Pivot Length', minval=2, group = eq_group)
show_connector = true
// TRENDLINE LIQUIDITY INPUTS
tl_group = 'Trendline Liquidity'
// UPDATED: Default set to FALSE
show_tliq         = input.bool(true, 'Show TL Liquidity', group=tl_group)
tliq_len          = input.int(4, '● Pivot Length', minval=2, tooltip="Pivot sensitivity for TL liquidity pivots", group=tl_group)
tliq_width        = input.int(1, '● Line Width', minval=1, group=tl_group)
tliq_extend       = input.int(8, '● Extend Bars', minval=1, tooltip='How far active TL is extended to the right', group=tl_group)
tliq_break_mode   = input.string('Wick', '● Sweep Validation', options=['Wick', 'Close'], tooltip='Wick = faster signal, Close = stricter and cleaner confirmation', group=tl_group)
tliq_break_buffer = input.float(0.05, '● Break Buffer (ATR)', minval=0.0, step=0.01, tooltip='Extra ATR-based distance required to confirm liquidity sweep', group=tl_group)
tliq_min_move_atr = input.float(0.10, '● Min Pivot Distance (ATR)', minval=0.0, step=0.05, tooltip='Skip flat/noisy TL by requiring minimum pivot-to-pivot distance', group=tl_group)
show_tliq_tag     = input.bool(false, 'Show T-LIQ Tags', tooltip='Show/hide running T-LIQ label on active trendline', group=tl_group)
show_tliq_swp     = input.bool(true, 'Show Sweep Mark', tooltip='Show mark when TL liquidity is swept', group=tl_group)
dsp_group = 'Displacement Candle'
// UPDATED: Default set to FALSE
show_dsp_candle = input.bool(true, 'Show Displacement', group=dsp_group)
dsp_len         = input.int(20, '● ATR Length', minval=1, tooltip="The average period of the candle range", group=dsp_group)
dsp_mult        = input.float(1.2, '● Range Multiplier', step=0.1, tooltip="The minimum candle size must be X times the average.", group=dsp_group)
dsp_body_min    = input.float(0.60, '● Min Body Ratio (0-1)', step=0.05, maxval=1.0, tooltip="Minimum percentage of body compared to total range", group=dsp_group)
col_dsp_buy     = box_col_bull
col_dsp_sell    = box_col_bear
ltf_ms_filter_group = 'LTF MSS Midline Filter'
use_ltf_ms_mid_filter = input.bool(false, 'Use Midline Swing Filter', tooltip='Filter breakout MSS LTF berdasarkan garis tengah antara swing high dan swing low terakhir.', group=ltf_ms_filter_group)
ltf_ms_swing_len = input.int(5, '● Swing Size', minval=2, tooltip='Ukuran swing/pivot untuk mencari swing high dan swing low.', group=ltf_ms_filter_group)
ltf_ms_line_extend = input.int(30, '● Line Extend Bars', minval=5, tooltip='Panjang visualisasi garis midline ke kanan.', group=ltf_ms_filter_group)
show_ltf_ms_midline = input.bool(false, 'Show Midline Visual', group=ltf_ms_filter_group)
// NEW: INPUT KILL ZONES (VERTICAL LINES)
kz_group = 'Kill Zone Sessions'
// UPDATED: Default set to FALSE
show_kz      = input.bool(true, 'Show Kill Zones', group=kz_group)
kz_timezone  = input.string("Asia/Jakarta", "● Timezone", options=["Asia/Jakarta", "America/New_York", "Europe/London", "UTC"], tooltip="Select Asia/Jakarta for WIB", group=kz_group)
sess_asia    = input.session("0700-1400", "● Asia Time", group=kz_group)
sess_london  = input.session("1400-2200", "● London Time", group=kz_group)
sess_ny      = input.session("1900-0300", "● New York Time", group=kz_group)
col_kz_asia  = mitigated_color
col_kz_lon   = col_bull
col_kz_ny    = col_bear
hl_group = 'Point High/Low (Day/Week/Month) (Auto)'
show_hl_auto = input.bool(true, 'Show High/Low Auto', group=hl_group)
hl_mode_opt  = input.string("Previous", "⬤ Mode", options=["Previous", "Current"], group=hl_group, tooltip="Previous: High/Low candle then\nCurrent: High/Low candle now")
// 1. DASHBOARD INPUTS
table_group = 'Dashboard Panel'
// UPDATED: Default set to FALSE
show_table = input.bool(true, 'Show Dashboard', group=table_group)
table_pos  = input.string(position.top_right, '● Position', options=[position.top_right, position.bottom_right, position.top_left, position.bottom_left], group=table_group)
table_size = input.string(size.small, '● Size', options=[size.tiny, size.small, size.normal, size.large], group=table_group)
// --- 0. PENGATURAN TAMPILAN (MODIFIKASI) ---
show_logo = input.bool(true, "Show Logo", group = "Logo Settings", tooltip = "Enable/Disable visual logo display")
//═══════════════════════════════════════════════════════════════════════════════
// STRATEGY INPUTS
//═══════════════════════════════════════════════════════════════════════════════
strategyGroup = 'Strategy'
strategy1_Rules_Group = 'Select Rules Strategy'
// Strategy Input
//===> input_strategy rules 1-15 (UPDATED TO "NONE")
input_rule1_stg1 = input.string(defval = 'HTF MSS', title = '➤ Rules 1', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule2_stg1 = input.string(defval = 'HTF Liquidity Sweep', title = '➤ Rules 2', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule3_stg1 = input.string(defval = 'HTF SnD Created', title = '➤ Rules 3', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule4_stg1 = input.string(defval = 'HTF SnD Mitigated', title = '➤ Rules 4', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule5_stg1 = input.string(defval = 'HTF FVG Mitigated', title = '➤ Rules 5', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule6_stg1 = input.string(defval = 'HTF LTF Inversion FVG', title = '➤ Rules 6', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule7_stg1 = input.string(defval = 'HTF Breaker', title = '➤ Rules 7', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule8_stg1 = input.string(defval = 'LTF MSS', title = '➤ Rules 8', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule9_stg1 = input.string(defval = 'LTF Liquidity Sweep', title = '➤ Rules 9', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule10_stg1 = input.string(defval = 'LTF SnD Created', title = '➤ Rules 10', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule11_stg1 = input.string(defval = 'LTF SnD Mitigated', title = '➤ Rules 11', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule12_stg1 = input.string(defval = 'LTF FVG Mitigated', title = '➤ Rules 12', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule13_stg1 = input.string(defval = 'LTF Breaker', title = '➤ Rules 13', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule14_stg1 = input.string(defval = 'None', title = '➤ Rules 14', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
input_rule15_stg1 = input.string(defval = 'None', title = '➤ Rules 15', options = ['HTF Liquidity Sweep','HTF SnD Created', 'HTF SnD Mitigated', 'HTF FVG Mitigated', 'HTF MSS','HTF Breaker', 'Stochastic RSI', 'LTF Liquidity Sweep', 'LTF SnD Created', 'LTF SnD Mitigated', 'LTF FVG Mitigated', 'LTF MSS','LTF Breaker',  'HTF LTF Inversion FVG','None'], group = strategy1_Rules_Group)
check_rule(cond_str) =>
    input_rule1_stg1 == cond_str or input_rule2_stg1 == cond_str or input_rule3_stg1 == cond_str or input_rule4_stg1 == cond_str or input_rule5_stg1 == cond_str or input_rule6_stg1 == cond_str or input_rule7_stg1 == cond_str or input_rule8_stg1 == cond_str or input_rule9_stg1 == cond_str or input_rule10_stg1 == cond_str or input_rule11_stg1 == cond_str or input_rule12_stg1 == cond_str or input_rule13_stg1 == cond_str or input_rule14_stg1 == cond_str or input_rule15_stg1 == cond_str
ltf_MSS_selected           = check_rule('LTF MSS')
ltf_snd_created_selected   = check_rule('LTF SnD Created')
ltf_snd_mitigated_selected = check_rule('LTF SnD Mitigated')
ltf_fvg_mitigated_selected = check_rule('LTF FVG Mitigated')
stochastic_rsi_selected    = check_rule('Stochastic RSI')
htf_MSS_selected           = check_rule('HTF MSS')
htf_snd_created_selected   = check_rule('HTF SnD Created')
htf_snd_mitigated_selected = check_rule('HTF SnD Mitigated')
htf_fvg_mitigated_selected = check_rule('HTF FVG Mitigated')
ifvg_selected              = check_rule('HTF LTF Inversion FVG')
ltf_lqs_selected           = check_rule('LTF Liquidity Sweep')
Htf_lqs_selected           = check_rule('HTF Liquidity Sweep')
breaker_htf_selected       = check_rule('HTF Breaker')
breaker_ltf_selected       = check_rule('LTF Breaker')
//═══════════════════════════════════════════════════════════════════════════════
// COUNTERS
//═══════════════════════════════════════════════════════════════════════════════
// stores the value of a single variable of the last Htf and Ltf candles
//===> LTF Bullish
var float[] lastCandleBullishOpenLtf  = array.new_float( )
var float[] lastCandleBullishHighLtf  = array.new_float( )
var float[] lastCandleBullishLowLtf   = array.new_float( )
var float[] lastCandleBullishCloseLtf = array.new_float( )
//===> LTF Bearish
var float[] lastCandleBearishOpenLtf  = array.new_float( )
var float[] lastCandleBearishHighLtf  = array.new_float( )
var float[] lastCandleBearishLowLtf   = array.new_float( )
var float[] lastCandleBearishCloseLtf = array.new_float( )
//===> HTF Bullish
var float[] lastCandleBullishOpenHtf  = array.new_float( )
var float[] lastCandleBullishHighHtf  = array.new_float( )
var float[] lastCandleBullishLowHtf   = array.new_float( )
var float[] lastCandleBullishCloseHtf = array.new_float( )
//===> HTF Bearish
var float[] lastCandleBearishOpenHtf  = array.new_float( )
var float[] lastCandleBearishHighHtf  = array.new_float( )
var float[] lastCandleBearishLowHtf   = array.new_float( )
var float[] lastCandleBearishCloseHtf = array.new_float( )
// Advanced Arrays for SND Tracking //
//===> HTF Supply
var array<float> htf_supply_high = array.new_float(0)
var array<float> htf_supply_low = array.new_float(0)
var array<box> htf_supply_box = array.new_box(0)
var array<bool> htf_supply_mitigated = array.new_bool(0)
var array<line> htf_ms_bull_line = array.new_line(0)
var array<label> htf_ms_bull_label = array.new_label(0)
var array<bool> htf_ms_bull_breakout = array.new_bool(0)
//===> HTF Demand
